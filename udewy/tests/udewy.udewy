# udewy bootstrapped compiler
# Compiles udewy source to x86_64 GNU assembly

# ============================================================================
# Constants
# ============================================================================

# Syscall numbers
const SYS_READ:int = 0
const SYS_WRITE:int = 1
const SYS_OPEN:int = 2
const SYS_CLOSE:int = 3
const SYS_MMAP:int = 9
const SYS_FORK:int = 57
const SYS_EXECVE:int = 59
const SYS_EXIT:int = 60
const SYS_WAIT4:int = 61
const SYS_MKDIR:int = 83
const SYS_CREAT:int = 85

# Open flags
const O_WRONLY:int = 1
const O_CREAT:int = 64
const O_TRUNC:int = 512

# File descriptors
const STDIN:int = 0
const STDOUT:int = 1
const STDERR:int = 2

# mmap constants
const PROT_READ:int = 1
const PROT_WRITE:int = 2
const MAP_PRIVATE:int = 2
const MAP_ANONYMOUS:int = 32

# ASCII character codes
const CH_NUL:int = 0
const CH_TAB:int = 9
const CH_LF:int = 10
const CH_CR:int = 13
const CH_SPACE:int = 32
const CH_HASH:int = 35
const CH_DQUOTE:int = 34
const CH_PERCENT:int = 37
const CH_LPAREN:int = 40
const CH_RPAREN:int = 41
const CH_STAR:int = 42
const CH_PLUS:int = 43
const CH_MINUS:int = 45
const CH_DOT:int = 46
const CH_SLASH:int = 47
const CH_0:int = 48
const CH_1:int = 49
const CH_9:int = 57
const CH_COLON:int = 58
const CH_LT:int = 60
const CH_EQ:int = 61
const CH_GT:int = 62
const CH_A:int = 65
const CH_F:int = 70
const CH_Z:int = 90
const CH_LBRACKET:int = 91
const CH_BACKSLASH:int = 92
const CH_RBRACKET:int = 93
const CH_UNDERSCORE:int = 95
const CH_a:int = 97
const CH_b:int = 98
const CH_c:int = 99
const CH_f:int = 102
const CH_i:int = 105
const CH_m:int = 109
const CH_n:int = 110
const CH_o:int = 111
const CH_p:int = 112
const CH_r:int = 114
const CH_t:int = 116
const CH_x:int = 120
const CH_z:int = 122
const CH_LBRACE:int = 123
const CH_RBRACE:int = 125

# Memory sizes
const ARENA_SIZE:int = 0x1000000
const MAX_TOKENS:int = 65536
const MAX_FUNCTIONS:int = 1024
const MAX_GLOBALS:int = 1024
const MAX_CONSTS:int = 1024
const MAX_SCOPES:int = 64
const MAX_VARS_PER_SCOPE:int = 64
const OUTPUT_BUF_SIZE:int = 0x100000

# Token kinds (must match t0.py)
const TK_IDENT:int = 0
const TK_IDENT_CALL:int = 1
const TK_STRING:int = 2
const TK_PATH_STRING:int = 3
const TK_TYPE_PARAM:int = 4
const TK_VOID:int = 5
const TK_NUMBER:int = 6
const TK_LET:int = 7
const TK_IF:int = 8
const TK_LOOP:int = 9
const TK_ELSE:int = 10
const TK_RETURN:int = 11
const TK_BREAK:int = 12
const TK_CONTINUE:int = 13
const TK_IMPORT:int = 14
const TK_PLUS:int = 16
const TK_MINUS:int = 17
const TK_MUL:int = 18
const TK_IDIV:int = 19
const TK_MOD:int = 20
const TK_EQ:int = 21
const TK_NOT_EQ:int = 22
const TK_GT:int = 23
const TK_GT_EQ:int = 24
const TK_LT:int = 25
const TK_LT_EQ:int = 26
const TK_AND:int = 27
const TK_OR:int = 28
const TK_XOR:int = 29
const TK_NOT:int = 30
const TK_LEFT_SHIFT:int = 31
const TK_RIGHT_SHIFT:int = 32
const TK_ASSIGN:int = 34
const TK_UPDATE_ASSIGN:int = 35
const TK_EXPR_CALL:int = 36
const TK_LEFT_PAREN:int = 37
const TK_RIGHT_PAREN:int = 38
const TK_LEFT_BRACE:int = 39
const TK_RIGHT_BRACE:int = 40
const TK_LEFT_BRACKET:int = 41
const TK_RIGHT_BRACKET:int = 42
const TK_COLON:int = 43
const TK_FN_COLON:int = 44
const TK_TYPE:int = 45
const TK_FN_TYPE:int = 46
const TK_FN_ARROW:int = 47
const TK_PIPE:int = 48
const TK_TRANSMUTE:int = 49

const TRUE_VAL:int =  0xFFFF_FFFF_FFFF_FFFF
const FALSE_VAL:int = 0x0000_0000_0000_0000

# Precedence levels
const PREC_OR:int = 1
const PREC_XOR:int = 2
const PREC_AND:int = 3
const PREC_EQ:int = 4
const PREC_CMP:int = 5
const PREC_SHIFT:int = 6
const PREC_ADD:int = 7
const PREC_MUL:int = 8
const PREC_PIPE:int = 9

# ============================================================================
# Global state (pointers to mmap'd memory)
# ============================================================================

# Source code
const g_src:int = 0
const g_src_len:int = 0
const g_src_idx:int = 0

# Token array: each token is 16 bytes (value:8, location:4, kind:2, padding:2)
const g_tokens:int = 0
const g_tok_count:int = 0
const g_tok_idx:int = 0

# Function table: each entry is 40 bytes
const g_fn_table:int = 0
const g_fn_count:int = 0

# Global variable table: each entry is 24 bytes
const g_global_table:int = 0
const g_global_count:int = 0

# Const table: each entry is 24 bytes
const g_const_table:int = 0
const g_const_count:int = 0

# Scope stack: array of scope pointers
const g_scope_stack:int = 0
const g_scope_depth:int = 0

# Each scope is 8 + MAX_VARS_PER_SCOPE * 24 bytes

# Output buffer
const g_output:int = 0
const g_output_len:int = 0

# Code generation state
const g_next_label:int = 0
const g_stack_offset:int = 0
const g_loop_start:int = 0
const g_loop_end:int = 0
const g_fn_epilogue:int = 0

# ============================================================================
# Memory management
# ============================================================================

let g_arena:int = 0
let g_arena_ptr:int = 0

let arena_init = ():>void => {
    g_arena = __syscall6__(SYS_MMAP 0 ARENA_SIZE (PROT_READ or PROT_WRITE) (MAP_PRIVATE or MAP_ANONYMOUS) 0 - 1 0)
    g_arena_ptr = g_arena
    return void
}

let arena_alloc = (size:int):>int => {
    let ptr:int = g_arena_ptr
    g_arena_ptr = g_arena_ptr + size
    return ptr
}

# ============================================================================
# Output helpers
# ============================================================================

let out_ptr:int = 0
let out_len:int = 0

let out_init = ():>void => { 
    out_ptr = arena_alloc(OUTPUT_BUF_SIZE)
    out_len = 0
    return void
}

let out_char = (c:int):>void => {
    __store8__(c out_ptr + out_len)
    out_len = out_len + 1
    return void
}

let out_str = (s:int):>void => {
    let len:int = __load__(s + 0 - 8)
    let i:int = 0
    loop i <? len {
        let c:int = __load8__(s + i)
        out_char(c)
        i = i + 1
    }
    return void
}

let out_int = (n:int):>void => {
    if n <? 0 {
        out_char(45)
        n = 0 - n
    }
    if n =? 0 {
        out_char(48)
        return void
    }
    let buf:int = arena_alloc(24)
    let i:int = 0
    loop n >? 0 {
        let digit:int = n % 10
        __store8__(digit + 48 buf + i)
        n = n // 10
        i = i + 1
    }
    loop i >? 0 {
        i = i - 1
        out_char(__load8__(buf + i))
    }
    return void
}

let out_flush = ():>void => {
    __syscall3__(SYS_WRITE STDOUT out_ptr out_len)
    return void
}

let out_line = (s:int):>void => {
    out_str("    ")
    out_str(s)
    out_char(10)
    return void
}

let out_label = (prefix:int n:int):>void => {
    out_str(prefix)
    out_int(n)
    out_str(":\n")
    return void
}

# ============================================================================
# Character classification (inline for performance)
# ============================================================================

let is_alpha = (c:int):>int => {
    if (c >=? CH_A) and (c <=? CH_Z) { return TRUE_VAL }
    if (c >=? CH_a) and (c <=? CH_z) { return TRUE_VAL }
    if c =? CH_UNDERSCORE { return TRUE_VAL }
    return FALSE_VAL
}

let is_digit = (c:int):>int => {
    if (c >=? CH_0) and (c <=? CH_9) { return TRUE_VAL }
    return FALSE_VAL
}

let is_hex = (c:int):>int => {
    if (c >=? CH_0) and (c <=? CH_9) { return TRUE_VAL }
    if (c >=? CH_A) and (c <=? CH_F) { return TRUE_VAL }
    if (c >=? CH_a) and (c <=? CH_f) { return TRUE_VAL }
    return FALSE_VAL
}

let is_space = (c:int):>int => {
    if c =? CH_SPACE { return TRUE_VAL }
    if c =? CH_TAB { return TRUE_VAL }
    if c =? CH_LF { return TRUE_VAL }
    if c =? CH_CR { return TRUE_VAL }
    return FALSE_VAL
}

# ============================================================================
# String comparison
# ============================================================================

let str_eq_len = (s1:int len1:int s2:int len2:int):>int => {
    if len1 not=? len2 { return FALSE_VAL }
    let i:int = 0
    loop i <? len1 {
        if __load8__(s1 + i) not=? __load8__(s2 + i) {
            return FALSE_VAL
        }
        i = i + 1
    }
    return TRUE_VAL
}

let str_match = (s:int start:int len:int target:int):>int => {
    let tlen:int = __load__(target + 0 - 8)
    return str_eq_len(s + start len target tlen)
}

let str_prefix = (s:int pos:int target:int):>int => {
    let tlen:int = __load__(target + 0 - 8)
    let i:int = 0
    loop i <? tlen {
        if __load8__(s + pos + i) not=? __load8__(target + i) {
            return FALSE_VAL
        }
        i = i + 1
    }
    return TRUE_VAL
}

let escape_char = (c:int):>int => {
    if c =? CH_n { return CH_LF }
    if c =? CH_LF { return 0 - 1 }
    if c =? CH_t { return CH_TAB }
    if c =? CH_r { return CH_CR }
    if c =? CH_0 { return CH_NUL }
    return c
}

# ============================================================================
# Token storage
# ============================================================================

let tok_ptr:int = 0
let tok_count:int = 0

let tok_init = ():>void => {
    tok_ptr = arena_alloc(MAX_TOKENS * 16)
    tok_count = 0
    return void
}

let tok_add = (value:int loc:int kind:int):>void => {
    let off:int = tok_count * 16
    __store__(value tok_ptr + off)
    __store__(loc tok_ptr + off + 8)
    __store__(kind tok_ptr + off + 12)
    tok_count = tok_count + 1
    return void
}

let tok_kind = (idx:int):>int => {
    return __load__(tok_ptr + (idx * 16) + 12) and 0xFFFF
}

let tok_loc = (idx:int):>int => {
    return __load__(tok_ptr + (idx * 16) + 8) and 0xFFFFFFFF
}

let tok_value = (idx:int):>int => {
    return __load__(tok_ptr + (idx * 16))
}

# ============================================================================
# Tokenizer
# ============================================================================

let src_ptr:int = 0
let src_len:int = 0

let tokenize = ():>void => {
    let i:int = 0
    let n:int = src_len
    
    loop i <? n {
        let c:int = __load8__(src_ptr + i)
        
        # Skip whitespace
        if is_space(c) {
            i = i + 1
            continue
        }
        
        # Skip comments
        if c =? CH_HASH {
            i = i + 1
            loop (i <? n) and (__load8__(src_ptr + i) not=? CH_LF) {
                i = i + 1
            }
            continue
        }
        
        # Identifier or keyword
        if is_alpha(c) {
            let start:int = i
            i = i + 1
            loop (i <? n) and (is_alpha(__load8__(src_ptr + i)) or is_digit(__load8__(src_ptr + i))) {
                i = i + 1
            }
            let len:int = i - start
            
            if str_match(src_ptr start len "let") {
                tok_add(0 start TK_LET)
            } else if str_match(src_ptr start len "const") {
                tok_add(0 start TK_LET)
            } else if str_match(src_ptr start len "if") {
                tok_add(0 start TK_IF)
            } else if str_match(src_ptr start len "else") {
                tok_add(0 start TK_ELSE)
            } else if str_match(src_ptr start len "loop") {
                tok_add(0 start TK_LOOP)
            } else if str_match(src_ptr start len "return") {
                tok_add(0 start TK_RETURN)
            } else if str_match(src_ptr start len "break") {
                tok_add(0 start TK_BREAK)
            } else if str_match(src_ptr start len "continue") {
                tok_add(0 start TK_CONTINUE)
            } else if str_match(src_ptr start len "import") {
                tok_add(0 start TK_IMPORT)
            } else if str_match(src_ptr start len "and") {
                tok_add(0 start TK_AND)
            } else if str_match(src_ptr start len "or") {
                tok_add(0 start TK_OR)
            } else if str_match(src_ptr start len "xor") {
                tok_add(0 start TK_XOR)
            } else if str_match(src_ptr start len "not") {
                tok_add(0 start TK_NOT)
            } else if str_match(src_ptr start len "true") {
                tok_add(TRUE_VAL start TK_NUMBER)
            } else if str_match(src_ptr start len "false") {
                tok_add(FALSE_VAL start TK_NUMBER)
            } else if str_match(src_ptr start len "transmute") {
                tok_add(0 start TK_TRANSMUTE)
            } else if str_match(src_ptr start len "void") {
                if (tok_count >? 0) and (tok_kind(tok_count - 1) =? TK_COLON) {
                    tok_count = tok_count - 1
                    tok_add(len start TK_TYPE)
                } else if (tok_count >? 0) and (tok_kind(tok_count - 1) =? TK_FN_COLON) {
                    tok_count = tok_count - 1
                    tok_add(len start TK_FN_TYPE)
                } else {
                    tok_add(0 start TK_VOID)
                }
            } else if (i <? n) and (__load8__(src_ptr + i) =? CH_LPAREN) {
                tok_add(len start TK_IDENT_CALL)
                i = i + 1
            } else if (tok_count >? 0) and (tok_kind(tok_count - 1) =? TK_COLON) {
                tok_count = tok_count - 1
                tok_add(len start TK_TYPE)
            } else if (tok_count >? 0) and (tok_kind(tok_count - 1) =? TK_FN_COLON) {
                tok_count = tok_count - 1
                tok_add(len start TK_FN_TYPE)
            } else {
                tok_add(len start TK_IDENT)
            }
            continue
        }
        
        # Hex number
        if (c =? CH_0) and ((i + 1) <? n) and (__load8__(src_ptr + i + 1) =? CH_x) {
            let start:int = i
            i = i + 2
            let val:int = 0
            loop (i <? n) and (is_hex(__load8__(src_ptr + i)) or (__load8__(src_ptr + i) =? CH_UNDERSCORE)) {
                let d:int = __load8__(src_ptr + i)
                if d not=? CH_UNDERSCORE {
                    let dv:int = 0
                    if (d >=? CH_0) and (d <=? CH_9) {
                        dv = d - CH_0
                    } else if (d >=? CH_A) and (d <=? CH_F) {
                        dv = d - 55
                    } else {
                        dv = d - 87
                    }
                    val = (val << 4) or dv
                }
                i = i + 1
            }
            tok_add(val start TK_NUMBER)
            continue
        }
        
        # Binary number
        if (c =? CH_0) and ((i + 1) <? n) and (__load8__(src_ptr + i + 1) =? CH_b) {
            let start:int = i
            i = i + 2
            let val:int = 0
            loop (i <? n) and ((__load8__(src_ptr + i) =? CH_0) or (__load8__(src_ptr + i) =? CH_1) or (__load8__(src_ptr + i) =? CH_UNDERSCORE)) {
                let d:int = __load8__(src_ptr + i)
                if d not=? CH_UNDERSCORE {
                    val = (val << 1) or (d - CH_0)
                }
                i = i + 1
            }
            tok_add(val start TK_NUMBER)
            continue
        }
        
        # Decimal number
        if is_digit(c) {
            let start:int = i
            let val:int = 0
            loop (i <? n) and is_digit(__load8__(src_ptr + i)) {
                val = (val * 10) + (__load8__(src_ptr + i) - 48)
                i = i + 1
            }
            tok_add(val start TK_NUMBER)
            continue
        }
        
        # Path string p"..."
        if (c =? CH_p) and ((i + 1) <? n) and (__load8__(src_ptr + i + 1) =? CH_DQUOTE) {
            let start:int = i
            i = i + 2
            loop (i <? n) and (__load8__(src_ptr + i) not=? CH_DQUOTE) {
                if __load8__(src_ptr + i) =? CH_BACKSLASH {
                    i = i + 1
                }
                i = i + 1
            }
            i = i + 1
            tok_add(i - start start TK_PATH_STRING)
            continue
        }
        
        # String
        if c =? CH_DQUOTE {
            let start:int = i
            i = i + 1
            loop (i <? n) and (__load8__(src_ptr + i) not=? CH_DQUOTE) {
                if __load8__(src_ptr + i) =? CH_BACKSLASH {
                    i = i + 1
                }
                i = i + 1
            }
            i = i + 1
            tok_add(i - start start TK_STRING)
            continue
        }
        
        # Multi-char operators
        if str_prefix(src_ptr i "//") {
            tok_add(0 i TK_IDIV)
            i = i + 2
            continue
        }
        if str_prefix(src_ptr i "=?") {
            if (tok_count >? 0) and (tok_kind(tok_count - 1) =? TK_NOT) {
                tok_count = tok_count - 1
                tok_add(0 i TK_NOT_EQ)
            } else {
                tok_add(0 i TK_EQ)
            }
            i = i + 2
            continue
        }
        if str_prefix(src_ptr i ">=?") {
            tok_add(0 i TK_GT_EQ)
            i = i + 3
            continue
        }
        if str_prefix(src_ptr i "<=?") {
            tok_add(0 i TK_LT_EQ)
            i = i + 3
            continue
        }
        if str_prefix(src_ptr i ">?") {
            tok_add(0 i TK_GT)
            i = i + 2
            continue
        }
        if str_prefix(src_ptr i "<?") {
            tok_add(0 i TK_LT)
            i = i + 2
            continue
        }
        if str_prefix(src_ptr i ":>") {
            tok_add(0 i TK_FN_COLON)
            i = i + 2
            continue
        }
        if str_prefix(src_ptr i "=>") {
            tok_add(0 i TK_FN_ARROW)
            i = i + 2
            continue
        }
        if str_prefix(src_ptr i "|>") {
            tok_add(0 i TK_PIPE)
            i = i + 2
            continue
        }
        if str_prefix(src_ptr i "<<") {
            tok_add(0 i TK_LEFT_SHIFT)
            i = i + 2
            continue
        }
        if str_prefix(src_ptr i ">>") {
            tok_add(0 i TK_RIGHT_SHIFT)
            i = i + 2
            continue
        }
        if str_prefix(src_ptr i ")(") {
            tok_add(0 i TK_RIGHT_PAREN)
            tok_add(0 i TK_EXPR_CALL)
            i = i + 2
            continue
        }
        
        # Type parameter
        if c =? CH_LT {
            let start:int = i
            let depth:int = 1
            i = i + 1
            loop (i <? n) and (depth >? 0) {
                let tc:int = __load8__(src_ptr + i)
                if tc =? CH_LT { depth = depth + 1 }
                if tc =? CH_GT { depth = depth - 1 }
                i = i + 1
            }
            tok_add(i - start start TK_TYPE_PARAM)
            continue
        }
        
        # Single-char tokens
        i = i + 1
        if c =? CH_PLUS { tok_add(0 i TK_PLUS) continue }
        if c =? CH_MINUS { tok_add(0 i TK_MINUS) continue }
        if c =? CH_STAR { tok_add(0 i TK_MUL) continue }
        if c =? CH_PERCENT { tok_add(0 i TK_MOD) continue }
        if c =? CH_LPAREN { tok_add(0 i TK_LEFT_PAREN) continue }
        if c =? CH_RPAREN { tok_add(0 i TK_RIGHT_PAREN) continue }
        if c =? CH_LBRACE { tok_add(0 i TK_LEFT_BRACE) continue }
        if c =? CH_RBRACE { tok_add(0 i TK_RIGHT_BRACE) continue }
        if c =? CH_LBRACKET { tok_add(0 i TK_LEFT_BRACKET) continue }
        if c =? CH_RBRACKET { tok_add(0 i TK_RIGHT_BRACKET) continue }
        if c =? CH_COLON { tok_add(0 i TK_COLON) continue }
        if c =? CH_EQ {
            if tok_count >? 0 {
                let pk:int = tok_kind(tok_count - 1)
                if (pk >? 15) and (pk <? 33) {
                    tok_count = tok_count - 1
                    tok_add(pk i TK_UPDATE_ASSIGN)
                    continue
                }
            }
            tok_add(0 i TK_ASSIGN)
            continue
        }
    }
    return void
}

# ============================================================================
# Symbol tables
# ============================================================================

let fn_ptr:int = 0
let fn_count:int = 0

let fn_init = ():>void => {
    fn_ptr = arena_alloc(MAX_FUNCTIONS * 40)
    fn_count = 0
    return void
}

let fn_lookup = (name_start:int name_len:int):>int => {
    let i:int = 0
    loop i <? fn_count {
        let off:int = i * 40
        let s:int = __load__(fn_ptr + off)
        let l:int = __load__(fn_ptr + off + 8)
        if str_eq_len(src_ptr + name_start name_len src_ptr + s l) {
            return i
        }
        i = i + 1
    }
    return 0 - 1
}

let fn_add = (name_start:int name_len:int label_id:int num_args:int is_def:int):>int => {
    let idx:int = fn_count
    let off:int = fn_count * 40
    __store__(name_start fn_ptr + off)
    __store__(name_len fn_ptr + off + 8)
    __store__(label_id fn_ptr + off + 16)
    __store__(num_args fn_ptr + off + 24)
    __store__(is_def fn_ptr + off + 32)
    fn_count = fn_count + 1
    return idx
}

let fn_get_label = (idx:int):>int => {
    return __load__(fn_ptr + (idx * 40) + 16)
}

let fn_set_defined = (idx:int num_args:int):>void => {
    let off:int = idx * 40
    __store__(num_args fn_ptr + off + 24)
    __store__(1 fn_ptr + off + 32)
    return void
}

let fn_is_defined = (idx:int):>int => {
    return __load__(fn_ptr + (idx * 40) + 32)
}

# Global variables
let glob_ptr:int = 0
let glob_count:int = 0

let glob_init = ():>void => {
    glob_ptr = arena_alloc(MAX_GLOBALS * 24)
    glob_count = 0
    return void
}

let glob_lookup = (name_start:int name_len:int):>int => {
    let i:int = 0
    loop i <? glob_count {
        let off:int = i * 24
        let s:int = __load__(glob_ptr + off)
        let l:int = __load__(glob_ptr + off + 8)
        if str_eq_len(src_ptr + name_start name_len src_ptr + s l) {
            return i
        }
        i = i + 1
    }
    return 0 - 1
}

let glob_add = (name_start:int name_len:int label_id:int):>int => {
    let idx:int = glob_count
    let off:int = glob_count * 24
    __store__(name_start glob_ptr + off)
    __store__(name_len glob_ptr + off + 8)
    __store__(label_id glob_ptr + off + 16)
    glob_count = glob_count + 1
    return idx
}

let glob_get_label = (idx:int):>int => {
    return __load__(glob_ptr + (idx * 24) + 16)
}

# Const table
let const_ptr:int = 0
let const_count:int = 0

let const_init = ():>void => {
    const_ptr = arena_alloc(MAX_CONSTS * 24)
    const_count = 0
    return void
}

let const_lookup = (name_start:int name_len:int):>int => {
    let i:int = 0
    loop i <? const_count {
        let off:int = i * 24
        let s:int = __load__(const_ptr + off)
        let l:int = __load__(const_ptr + off + 8)
        if str_eq_len(src_ptr + name_start name_len src_ptr + s l) {
            return i
        }
        i = i + 1
    }
    return 0 - 1
}

let const_add = (name_start:int name_len:int value:int):>int => {
    let idx:int = const_count
    let off:int = const_count * 24
    __store__(name_start const_ptr + off)
    __store__(name_len const_ptr + off + 8)
    __store__(value const_ptr + off + 16)
    const_count = const_count + 1
    return idx
}

let const_get_value = (idx:int):>int => {
    return __load__(const_ptr + (idx * 24) + 16)
}

# Scope stack for local variables
let scope_ptr:int = 0
let scope_depth:int = 0

let scope_init = ():>void => {
    scope_ptr = arena_alloc(MAX_SCOPES * 8)
    scope_depth = 0
    return void
}

let scope_push = ():>void => {
    let new_scope:int = arena_alloc(8 + (MAX_VARS_PER_SCOPE * 24))
    __store__(0 new_scope)
    __store__(new_scope scope_ptr + (scope_depth * 8))
    scope_depth = scope_depth + 1
    return void
}

let scope_pop = ():>void => {
    scope_depth = scope_depth - 1
    return void
}

let var_lookup = (name_start:int name_len:int):>int => {
    let si:int = scope_depth - 1
    loop si >=? 0 {
        let scp:int = __load__(scope_ptr + (si * 8))
        let vcount:int = __load__(scp)
        let vi:int = 0
        loop vi <? vcount {
            let off:int = 8 + (vi * 24)
            let s:int = __load__(scp + off)
            let l:int = __load__(scp + off + 8)
            if str_eq_len(src_ptr + name_start name_len src_ptr + s l) {
                return __load__(scp + off + 16)
            }
            vi = vi + 1
        }
        si = si - 1
    }
    return 0x7FFFFFFFFFFFFFFF
}

let var_add = (name_start:int name_len:int stack_off:int):>void => {
    let scp:int = __load__(scope_ptr + ((scope_depth - 1) * 8))
    let vcount:int = __load__(scp)
    let off:int = 8 + (vcount * 24)
    __store__(name_start scp + off)
    __store__(name_len scp + off + 8)
    __store__(stack_off scp + off + 16)
    __store__(vcount + 1 scp)
    return void
}

# ============================================================================
# Code generation state
# ============================================================================

let next_label:int = 0
let stack_offset:int = 0
let loop_start_label:int = 0
let loop_end_label:int = 0
let fn_epilogue_label:int = 0

# ============================================================================
# Parser helpers
# ============================================================================

let cur_tok:int = 0

let expect = (kind:int):>void => {
    if tok_kind(cur_tok) not=? kind {
        out_str("Parse error: unexpected token\n")
        out_flush()
        __syscall1__(SYS_EXIT 1)
    }
    cur_tok = cur_tok + 1
    return void
}

let get_prec = (kind:int):>int => {
    if kind =? TK_OR { return PREC_OR }
    if kind =? TK_XOR { return PREC_XOR }
    if kind =? TK_AND { return PREC_AND }
    if (kind =? TK_EQ) or (kind =? TK_NOT_EQ) { return PREC_EQ }
    if (kind =? TK_GT) or (kind =? TK_LT) or (kind =? TK_GT_EQ) or (kind =? TK_LT_EQ) { return PREC_CMP }
    if (kind =? TK_LEFT_SHIFT) or (kind =? TK_RIGHT_SHIFT) { return PREC_SHIFT }
    if (kind =? TK_PLUS) or (kind =? TK_MINUS) { return PREC_ADD }
    if (kind =? TK_MUL) or (kind =? TK_IDIV) or (kind =? TK_MOD) { return PREC_MUL }
    if kind =? TK_PIPE { return PREC_PIPE }
    return 0
}

let is_binop = (kind:int):>int => {
    if get_prec(kind) >? 0 { return TRUE_VAL }
    return FALSE_VAL
}

let name_eq_intrinsic = (start:int len:int target:int):>int => {
    let tlen:int = __load__(target + 0 - 8)
    return str_eq_len(src_ptr + start len target tlen)
}

let is_intrinsic = (start:int len:int):>int => {
    if name_eq_intrinsic(start len "__syscall0__") { return TRUE_VAL }
    if name_eq_intrinsic(start len "__syscall1__") { return TRUE_VAL }
    if name_eq_intrinsic(start len "__syscall2__") { return TRUE_VAL }
    if name_eq_intrinsic(start len "__syscall3__") { return TRUE_VAL }
    if name_eq_intrinsic(start len "__syscall4__") { return TRUE_VAL }
    if name_eq_intrinsic(start len "__syscall5__") { return TRUE_VAL }
    if name_eq_intrinsic(start len "__syscall6__") { return TRUE_VAL }
    if name_eq_intrinsic(start len "__load__") { return TRUE_VAL }
    if name_eq_intrinsic(start len "__store__") { return TRUE_VAL }
    if name_eq_intrinsic(start len "__load8__") { return TRUE_VAL }
    if name_eq_intrinsic(start len "__store8__") { return TRUE_VAL }
    if name_eq_intrinsic(start len "__load16__") { return TRUE_VAL }
    if name_eq_intrinsic(start len "__store16__") { return TRUE_VAL }
    if name_eq_intrinsic(start len "__load32__") { return TRUE_VAL }
    if name_eq_intrinsic(start len "__store32__") { return TRUE_VAL }
    return FALSE_VAL
}

# ============================================================================
# Data section accumulator
# ============================================================================

let data_ptr:int = 0
let data_len:int = 0

let data_init = ():>void => {
    data_ptr = arena_alloc(OUTPUT_BUF_SIZE)
    data_len = 0
    return void
}

let data_char = (c:int):>void => {
    __store8__(c data_ptr + data_len)
    data_len = data_len + 1
    return void
}

let data_str = (s:int):>void => {
    let len:int = __load__(s + 0 - 8)
    let i:int = 0
    loop i <? len {
        data_char(__load8__(s + i))
        i = i + 1
    }
    return void
}

let data_int = (n:int):>void => {
    if n <? 0 {
        data_char(45)
        n = 0 - n
    }
    if n =? 0 {
        data_char(48)
        return void
    }
    let buf:int = arena_alloc(24)
    let i:int = 0
    loop n >? 0 {
        let digit:int = n % 10
        __store8__(digit + 48 buf + i)
        n = n // 10
        i = i + 1
    }
    loop i >? 0 {
        i = i - 1
        data_char(__load8__(buf + i))
    }
    return void
}

let data_line = (s:int):>void => {
    data_str("    ")
    data_str(s)
    data_char(10)
    return void
}

let data_label = (prefix:int n:int):>void => {
    data_str(prefix)
    data_int(n)
    data_str(":\n")
    return void
}

# ============================================================================
# Intrinsic code generation
# ============================================================================

let emit_intrinsic = (start:int len:int nargs:int):>void => {
    if name_eq_intrinsic(start len "__load__") {
        out_line("movq (%rax), %rax")
    } else if name_eq_intrinsic(start len "__store__") {
        out_line("popq %rbx")
        out_line("movq %rbx, (%rax)")
        out_line("xorq %rax, %rax")
    } else if name_eq_intrinsic(start len "__load8__") {
        out_line("movzbq (%rax), %rax")
    } else if name_eq_intrinsic(start len "__store8__") {
        out_line("popq %rbx")
        out_line("movb %bl, (%rax)")
        out_line("xorq %rax, %rax")
    } else if name_eq_intrinsic(start len "__load16__") {
        out_line("movzwq (%rax), %rax")
    } else if name_eq_intrinsic(start len "__store16__") {
        out_line("popq %rbx")
        out_line("movw %bx, (%rax)")
        out_line("xorq %rax, %rax")
    } else if name_eq_intrinsic(start len "__load32__") {
        out_line("movl (%rax), %eax")
    } else if name_eq_intrinsic(start len "__store32__") {
        out_line("popq %rbx")
        out_line("movl %ebx, (%rax)")
        out_line("xorq %rax, %rax")
    } else if name_eq_intrinsic(start len "__syscall0__") {
        out_line("syscall")
    } else if name_eq_intrinsic(start len "__syscall1__") {
        out_line("movq %rax, %rdi")
        out_line("popq %rax")
        out_line("syscall")
    } else if name_eq_intrinsic(start len "__syscall2__") {
        out_line("movq %rax, %rsi")
        out_line("popq %rdi")
        out_line("popq %rax")
        out_line("syscall")
    } else if name_eq_intrinsic(start len "__syscall3__") {
        out_line("movq %rax, %rdx")
        out_line("popq %rsi")
        out_line("popq %rdi")
        out_line("popq %rax")
        out_line("syscall")
    } else if name_eq_intrinsic(start len "__syscall4__") {
        out_line("movq %rax, %r10")
        out_line("popq %rdx")
        out_line("popq %rsi")
        out_line("popq %rdi")
        out_line("popq %rax")
        out_line("syscall")
    } else if name_eq_intrinsic(start len "__syscall5__") {
        out_line("movq %rax, %r8")
        out_line("popq %r10")
        out_line("popq %rdx")
        out_line("popq %rsi")
        out_line("popq %rdi")
        out_line("popq %rax")
        out_line("syscall")
    } else if name_eq_intrinsic(start len "__syscall6__") {
        out_line("movq %rax, %r9")
        out_line("popq %r8")
        out_line("popq %r10")
        out_line("popq %rdx")
        out_line("popq %rsi")
        out_line("popq %rdi")
        out_line("popq %rax")
        out_line("syscall")
    }
    return void
}

# ============================================================================
# Expression parsing
# ============================================================================

let parse_atom = ():>void => {
    let kind:int = tok_kind(cur_tok)
    
    if kind =? TK_NUMBER {
        let val:int = tok_value(cur_tok)
        out_str("    movq $")
        out_int(val)
        out_str(", %rax\n")
        cur_tok = cur_tok + 1
        return void
    }
    
    if kind =? TK_VOID {
        out_line("xorq %rax, %rax")
        cur_tok = cur_tok + 1
        return void
    }
    
    if kind =? TK_STRING {
        let start:int = tok_loc(cur_tok)
        let len:int = tok_value(cur_tok)
        cur_tok = cur_tok + 1
        
        let label_id:int = next_label
        next_label = next_label + 1
        
        data_label(".Lstr" label_id)
        
        let slen:int = 0
        let si:int = start + 1
        let send:int = start + len - 1
        loop si <? send {
            let c:int = __load8__(src_ptr + si)
            if c =? CH_BACKSLASH {
                si = si + 1
                c = __load8__(src_ptr + si)
                if c =? CH_LF {
                    si = si + 1
                    continue
                }
            }
            slen = slen + 1
            si = si + 1
        }
        
        data_str("    .quad ")
        data_int(slen)
        data_char(CH_LF)
        
        data_str("    .byte ")
        si = start + 1
        let first:int = 1
        loop si <? send {
            let c:int = __load8__(src_ptr + si)
            if c =? CH_BACKSLASH {
                si = si + 1
                c = escape_char(__load8__(src_ptr + si))
                if c =? (0 - 1) {
                    si = si + 1
                    continue
                }
            }
            if first =? 0 {
                data_str(", ")
            }
            first = 0
            data_int(c)
            si = si + 1
        }
        data_char(10)
        
        out_str("    leaq .Lstr")
        out_int(label_id)
        out_str("+8(%rip), %rax\n")
        return void
    }
    
    if kind =? TK_IDENT {
        let start:int = tok_loc(cur_tok)
        let len:int = tok_value(cur_tok)
        cur_tok = cur_tok + 1
        
        let off:int = var_lookup(start len)
        if off not=? 0x7FFFFFFFFFFFFFFF {
            out_str("    movq ")
            out_int(off)
            out_str("(%rbp), %rax\n")
            return void
        }
        
        let gi:int = glob_lookup(start len)
        if gi >=? 0 {
            out_str("    movq .Lglobal")
            out_int(glob_get_label(gi))
            out_str("(%rip), %rax\n")
            return void
        }
        
        let fi:int = fn_lookup(start len)
        if fi >=? 0 {
            out_str("    leaq .Lfn")
            out_int(fn_get_label(fi))
            out_str("(%rip), %rax\n")
            return void
        }
        
        let label_id:int = next_label
        next_label = next_label + 1
        fn_add(start len label_id 0 0)
        out_str("    leaq .Lfn")
        out_int(label_id)
        out_str("(%rip), %rax\n")
        return void
    }
    
    if kind =? TK_IDENT_CALL {
        let start:int = tok_loc(cur_tok)
        let len:int = tok_value(cur_tok)
        cur_tok = cur_tok + 1
        
        let nargs:int = 0
        loop tok_kind(cur_tok) not=? TK_RIGHT_PAREN {
            parse_expr(0)
            out_line("pushq %rax")
            nargs = nargs + 1
        }
        expect(TK_RIGHT_PAREN)
        
        if is_intrinsic(start len) {
            if nargs >? 0 {
                out_line("popq %rax")
            }
            emit_intrinsic(start len nargs)
        } else {
            let ai:int = nargs - 1
            loop ai >=? 0 {
                if ai =? 0 { out_line("popq %rdi") }
                else if ai =? 1 { out_line("popq %rsi") }
                else if ai =? 2 { out_line("popq %rdx") }
                else if ai =? 3 { out_line("popq %rcx") }
                else if ai =? 4 { out_line("popq %r8") }
                else if ai =? 5 { out_line("popq %r9") }
                ai = ai - 1
            }
            
            let fi:int = fn_lookup(start len)
            if fi <? 0 {
                let label_id:int = next_label
                next_label = next_label + 1
                fi = fn_add(start len label_id nargs 0)
            }
            out_str("    call .Lfn")
            out_int(fn_get_label(fi))
            out_char(10)
        }
        return void
    }
    
    if kind =? TK_LEFT_PAREN {
        cur_tok = cur_tok + 1
        parse_expr(0)
        expect(TK_RIGHT_PAREN)
        return void
    }
    
    if kind =? TK_LEFT_BRACKET {
        cur_tok = cur_tok + 1
        
        # Each element: 16 bytes (kind:8, value:8)
        # kind: 0=number, 1=fnref, 2=strref, 3=arrref
        let elems:int = arena_alloc(1024 * 16)
        let nelem:int = 0
        
        loop tok_kind(cur_tok) not=? TK_RIGHT_BRACKET {
            let ek:int = tok_kind(cur_tok)
            let eoff:int = nelem * 16
            
            if ek =? TK_NUMBER {
                __store__(0 elems + eoff)
                __store__(tok_value(cur_tok) elems + eoff + 8)
                cur_tok = cur_tok + 1
                nelem = nelem + 1
            } else if ek =? TK_IDENT {
                let es:int = tok_loc(cur_tok)
                let el:int = tok_value(cur_tok)
                cur_tok = cur_tok + 1
                
                let ci:int = const_lookup(es el)
                if ci >=? 0 {
                    __store__(0 elems + eoff)
                    __store__(const_get_value(ci) elems + eoff + 8)
                } else {
                    let fi:int = fn_lookup(es el)
                    if fi >=? 0 {
                        __store__(1 elems + eoff)
                        __store__(fn_get_label(fi) elems + eoff + 8)
                    } else {
                        # Forward function reference
                        let fwd_id:int = next_label
                        next_label = next_label + 1
                        fn_add(es el fwd_id 0 0)
                        __store__(1 elems + eoff)
                        __store__(fwd_id elems + eoff + 8)
                    }
                }
                nelem = nelem + 1
            } else if ek =? TK_STRING {
                let start:int = tok_loc(cur_tok)
                let len:int = tok_value(cur_tok)
                cur_tok = cur_tok + 1
                
                let label_id:int = next_label
                next_label = next_label + 1
                
                data_label(".Lstr" label_id)
                
                let slen:int = 0
                let si:int = start + 1
                let send:int = start + len - 1
                loop si <? send {
                    let c:int = __load8__(src_ptr + si)
                    if c =? CH_BACKSLASH {
                        si = si + 1
                        c = __load8__(src_ptr + si)
                        if c =? CH_LF {
                            si = si + 1
                            continue
                        }
                    }
                    slen = slen + 1
                    si = si + 1
                }
                
                data_str("    .quad ")
                data_int(slen)
                data_char(CH_LF)
                
                data_str("    .byte ")
                si = start + 1
                let first:int = 1
                loop si <? send {
                    let c:int = __load8__(src_ptr + si)
                    if c =? CH_BACKSLASH {
                        si = si + 1
                        c = escape_char(__load8__(src_ptr + si))
                        if c =? (0 - 1) {
                            si = si + 1
                            continue
                        }
                    }
                    if first =? 0 {
                        data_str(", ")
                    }
                    first = 0
                    data_int(c)
                    si = si + 1
                }
                data_char(10)
                
                __store__(2 elems + eoff)
                __store__(label_id elems + eoff + 8)
                nelem = nelem + 1
            } else {
                out_str("Error: array elements must be compile-time constants\n")
                out_flush()
                __syscall1__(SYS_EXIT 1)
            }
        }
        expect(TK_RIGHT_BRACKET)
        
        let arr_id:int = next_label
        next_label = next_label + 1
        
        data_label(".Larr" arr_id)
        data_str("    .quad ")
        data_int(nelem)
        data_char(10)
        
        let ei:int = 0
        loop ei <? nelem {
            let ekind:int = __load__(elems + (ei * 16))
            let eval:int = __load__(elems + (ei * 16) + 8)
            if ekind =? 0 {
                data_str("    .quad ")
                data_int(eval)
                data_char(10)
            } else if ekind =? 1 {
                data_str("    .quad .Lfn")
                data_int(eval)
                data_char(10)
            } else if ekind =? 2 {
                data_str("    .quad .Lstr")
                data_int(eval)
                data_str("+8\n")
            }
            ei = ei + 1
        }
        
        out_str("    leaq .Larr")
        out_int(arr_id)
        out_str("+8(%rip), %rax\n")
        return void
    }
    
    out_str("Parse error: unexpected token in expr\n")
    out_flush()
    __syscall1__(SYS_EXIT 1)
    return void
}

let parse_prefix = ():>void => {
    let kind:int = tok_kind(cur_tok)
    
    if kind =? TK_NOT {
        cur_tok = cur_tok + 1
        parse_prefix()
        out_line("notq %rax")
        return void
    }
    
    if kind =? TK_MINUS {
        cur_tok = cur_tok + 1
        if tok_kind(cur_tok) =? TK_NUMBER {
            let val:int = tok_value(cur_tok)
            out_str("    movq $")
            out_int(0 - val)
            out_str(", %rax\n")
            cur_tok = cur_tok + 1
        } else {
            parse_prefix()
            out_line("negq %rax")
        }
        return void
    }
    
    parse_atom()
    return void
}

let parse_expr_impl = (min_prec:int):>void => {
    parse_prefix()
    skip_cast_annot()
    
    loop cur_tok <? tok_count {
        let kind:int = tok_kind(cur_tok)
        
        if kind =? TK_EXPR_CALL {
            out_line("pushq %rax")
            cur_tok = cur_tok + 1
            
            let nargs:int = 0
            loop tok_kind(cur_tok) not=? TK_RIGHT_PAREN {
                parse_expr(0)
                out_line("pushq %rax")
                nargs = nargs + 1
            }
            expect(TK_RIGHT_PAREN)
            
            let ai:int = nargs - 1
            loop ai >=? 0 {
                if ai =? 0 { out_line("popq %rdi") }
                else if ai =? 1 { out_line("popq %rsi") }
                else if ai =? 2 { out_line("popq %rdx") }
                else if ai =? 3 { out_line("popq %rcx") }
                else if ai =? 4 { out_line("popq %r8") }
                else if ai =? 5 { out_line("popq %r9") }
                ai = ai - 1
            }
            out_line("popq %rax")
            out_line("call *%rax")
            continue
        }
        
        if not is_binop(kind) {
            break
        }
        
        let prec:int = get_prec(kind)
        if (prec >? min_prec) and (min_prec >? 0) {
            out_str("Precedence error: use parentheses\n")
            out_flush()
            __syscall1__(SYS_EXIT 1)
        }
        
        cur_tok = cur_tok + 1
        out_line("pushq %rax")
        
        if kind =? TK_PIPE {
            parse_prefix()
            skip_cast_annot()
            out_line("movq %rax, %r11")
            out_line("popq %rdi")
            out_line("call *%r11")
        } else {
            parse_prefix()
            skip_cast_annot()
            out_line("movq %rax, %rcx")
            out_line("popq %rax")
            
            if kind =? TK_PLUS { out_line("addq %rcx, %rax") }
            else if kind =? TK_MINUS { out_line("subq %rcx, %rax") }
            else if kind =? TK_MUL { out_line("imulq %rcx, %rax") }
            else if kind =? TK_IDIV {
                out_line("cqto")
                out_line("idivq %rcx")
            }
            else if kind =? TK_MOD {
                out_line("cqto")
                out_line("idivq %rcx")
                out_line("movq %rdx, %rax")
            }
            else if kind =? TK_LEFT_SHIFT { out_line("shlq %cl, %rax") }
            else if kind =? TK_RIGHT_SHIFT { out_line("sarq %cl, %rax") }
            else if kind =? TK_AND { out_line("andq %rcx, %rax") }
            else if kind =? TK_OR { out_line("orq %rcx, %rax") }
            else if kind =? TK_XOR { out_line("xorq %rcx, %rax") }
            else if kind =? TK_EQ {
                out_line("cmpq %rcx, %rax")
                out_line("sete %al")
                out_line("movzbq %al, %rax")
                out_line("negq %rax")
            }
            else if kind =? TK_NOT_EQ {
                out_line("cmpq %rcx, %rax")
                out_line("setne %al")
                out_line("movzbq %al, %rax")
                out_line("negq %rax")
            }
            else if kind =? TK_GT {
                out_line("cmpq %rcx, %rax")
                out_line("setg %al")
                out_line("movzbq %al, %rax")
                out_line("negq %rax")
            }
            else if kind =? TK_LT {
                out_line("cmpq %rcx, %rax")
                out_line("setl %al")
                out_line("movzbq %al, %rax")
                out_line("negq %rax")
            }
            else if kind =? TK_GT_EQ {
                out_line("cmpq %rcx, %rax")
                out_line("setge %al")
                out_line("movzbq %al, %rax")
                out_line("negq %rax")
            }
            else if kind =? TK_LT_EQ {
                out_line("cmpq %rcx, %rax")
                out_line("setle %al")
                out_line("movzbq %al, %rax")
                out_line("negq %rax")
            }
        }
        
        min_prec = prec
    }
    return void
}

let parse_expr = (min_prec:int):>void => {
    parse_expr_impl(min_prec)
    return void
}

# ============================================================================
# Statement parsing
# ============================================================================

let skip_type_annot = ():>void => {
    if tok_kind(cur_tok) =? TK_TYPE {
        cur_tok = cur_tok + 1
        if tok_kind(cur_tok) =? TK_TYPE_PARAM {
            cur_tok = cur_tok + 1
        }
    } else if tok_kind(cur_tok) =? TK_TYPE_PARAM {
        cur_tok = cur_tok + 1
    }
    return void
}

let skip_fn_type = ():>void => {
    if tok_kind(cur_tok) =? TK_FN_TYPE {
        cur_tok = cur_tok + 1
        if tok_kind(cur_tok) =? TK_TYPE_PARAM {
            cur_tok = cur_tok + 1
        }
    }
    return void
}

let skip_cast_annot = ():>void => {
    if tok_kind(cur_tok) =? TK_TRANSMUTE {
        cur_tok = cur_tok + 1
        if tok_kind(cur_tok) =? TK_IDENT {
            cur_tok = cur_tok + 1
            if tok_kind(cur_tok) =? TK_TYPE_PARAM {
                cur_tok = cur_tok + 1
            }
        } else if tok_kind(cur_tok) =? TK_TYPE_PARAM {
            cur_tok = cur_tok + 1
        }
    }
    return void
}

let parse_var_decl = ():>void => {
    cur_tok = cur_tok + 1
    
    let start:int = tok_loc(cur_tok)
    let len:int = tok_value(cur_tok)
    cur_tok = cur_tok + 1
    
    skip_type_annot()
    expect(TK_ASSIGN)
    parse_expr(0)
    
    let off:int = stack_offset
    stack_offset = stack_offset - 8
    
    # Check for stack overflow (1024 bytes allocated)
    if off <? (0 - 1024) {
        out_str("Error: too many local variables (stack overflow)\n")
        out_flush()
        __syscall1__(SYS_EXIT 1)
    }
    
    var_add(start len off)
    
    out_str("    movq %rax, ")
    out_int(off)
    out_str("(%rbp)\n")
    return void
}

let parse_fn_decl = ():>void => {
    cur_tok = cur_tok + 1
    
    let name_start:int = tok_loc(cur_tok)
    let name_len:int = tok_value(cur_tok)
    cur_tok = cur_tok + 1
    
    expect(TK_ASSIGN)
    expect(TK_LEFT_PAREN)
    
    let params_ptr:int = arena_alloc(64 * 16)
    let nparam:int = 0
    
    loop tok_kind(cur_tok) not=? TK_RIGHT_PAREN {
        let ps:int = tok_loc(cur_tok)
        let pl:int = tok_value(cur_tok)
        __store__(ps params_ptr + (nparam * 16))
        __store__(pl params_ptr + (nparam * 16) + 8)
        nparam = nparam + 1
        cur_tok = cur_tok + 1
        skip_type_annot()
    }
    expect(TK_RIGHT_PAREN)
    skip_fn_type()
    expect(TK_FN_ARROW)
    expect(TK_LEFT_BRACE)
    
    let fi:int = fn_lookup(name_start name_len)
    let label_id:int = 0
    if fi >=? 0 {
        fn_set_defined(fi nparam)
        label_id = fn_get_label(fi)
    } else {
        label_id = next_label
        next_label = next_label + 1
        fn_add(name_start name_len label_id nparam 1)
    }
    
    if str_eq_len(src_ptr + name_start name_len "main" 4) {
        out_str("__main__:\n")
    }
    out_label(".Lfn" label_id)
    
    out_line("pushq %rbp")
    out_line("movq %rsp, %rbp")
    out_line("subq $1024, %rsp")
    out_line("movq %rbx, -8(%rbp)")
    out_line("movq %r12, -16(%rbp)")
    out_line("movq %r13, -24(%rbp)")
    out_line("movq %r14, -32(%rbp)")
    out_line("movq %r15, -40(%rbp)")
    
    scope_push()
    
    let saved_offset:int = stack_offset
    stack_offset = 0 - 48
    
    let saved_loop_start:int = loop_start_label
    let saved_loop_end:int = loop_end_label
    loop_start_label = 0
    loop_end_label = 0
    
    let saved_epilogue:int = fn_epilogue_label
    fn_epilogue_label = label_id
    
    let pi:int = 0
    loop pi <? nparam {
        let ps:int = __load__(params_ptr + (pi * 16))
        let pl:int = __load__(params_ptr + (pi * 16) + 8)
        
        if pi =? 0 {
            out_str("    movq %rdi, ")
            out_int(stack_offset)
            out_str("(%rbp)\n")
        } else if pi =? 1 {
            out_str("    movq %rsi, ")
            out_int(stack_offset)
            out_str("(%rbp)\n")
        } else if pi =? 2 {
            out_str("    movq %rdx, ")
            out_int(stack_offset)
            out_str("(%rbp)\n")
        } else if pi =? 3 {
            out_str("    movq %rcx, ")
            out_int(stack_offset)
            out_str("(%rbp)\n")
        } else if pi =? 4 {
            out_str("    movq %r8, ")
            out_int(stack_offset)
            out_str("(%rbp)\n")
        } else if pi =? 5 {
            out_str("    movq %r9, ")
            out_int(stack_offset)
            out_str("(%rbp)\n")
        }
        
        var_add(ps pl stack_offset)
        stack_offset = stack_offset - 8
        
        # Check for stack overflow
        if stack_offset <? (0 - 1024) {
            out_str("Error: too many parameters (stack overflow)\n")
            out_flush()
            __syscall1__(SYS_EXIT 1)
        }
        
        pi = pi + 1
    }
    
    loop tok_kind(cur_tok) not=? TK_RIGHT_BRACE {
        parse_statement()
    }
    expect(TK_RIGHT_BRACE)
    
    out_str(".Lfn")
    out_int(label_id)
    out_str("_epilogue:\n")
    out_line("movq -8(%rbp), %rbx")
    out_line("movq -16(%rbp), %r12")
    out_line("movq -24(%rbp), %r13")
    out_line("movq -32(%rbp), %r14")
    out_line("movq -40(%rbp), %r15")
    out_line("movq %rbp, %rsp")
    out_line("popq %rbp")
    out_line("ret")
    
    scope_pop()
    stack_offset = saved_offset
    loop_start_label = saved_loop_start
    loop_end_label = saved_loop_end
    fn_epilogue_label = saved_epilogue
    return void
}

let parse_if = ():>void => {
    let end_id:int = next_label
    next_label = next_label + 1
    
    let else_id:int = next_label
    next_label = next_label + 1
    
    cur_tok = cur_tok + 1
    parse_expr(0)
    
    out_line("testq %rax, %rax")
    out_str("    jz .Lelse")
    out_int(else_id)
    out_char(10)
    
    expect(TK_LEFT_BRACE)
    scope_push()
    loop tok_kind(cur_tok) not=? TK_RIGHT_BRACE {
        parse_statement()
    }
    expect(TK_RIGHT_BRACE)
    scope_pop()
    
    out_str("    jmp .Lif_end")
    out_int(end_id)
    out_char(10)
    out_label(".Lelse" else_id)
    
    loop tok_kind(cur_tok) =? TK_ELSE {
        cur_tok = cur_tok + 1
        
        if tok_kind(cur_tok) =? TK_IF {
            cur_tok = cur_tok + 1
            
            else_id = next_label
            next_label = next_label + 1
            
            parse_expr(0)
            out_line("testq %rax, %rax")
            out_str("    jz .Lelse")
            out_int(else_id)
            out_char(10)
            
            expect(TK_LEFT_BRACE)
            scope_push()
            loop tok_kind(cur_tok) not=? TK_RIGHT_BRACE {
                parse_statement()
            }
            expect(TK_RIGHT_BRACE)
            scope_pop()
            
            out_str("    jmp .Lif_end")
            out_int(end_id)
            out_char(10)
            out_label(".Lelse" else_id)
        } else {
            expect(TK_LEFT_BRACE)
            scope_push()
            loop tok_kind(cur_tok) not=? TK_RIGHT_BRACE {
                parse_statement()
            }
            expect(TK_RIGHT_BRACE)
            scope_pop()
            break
        }
    }
    
    out_label(".Lif_end" end_id)
    return void
}

let parse_loop = ():>void => {
    let start_id:int = next_label
    next_label = next_label + 1
    
    let end_id:int = next_label
    next_label = next_label + 1
    
    let saved_start:int = loop_start_label
    let saved_end:int = loop_end_label
    loop_start_label = start_id
    loop_end_label = end_id
    
    cur_tok = cur_tok + 1
    
    out_label(".Lloop_start" start_id)
    parse_expr(0)
    out_line("testq %rax, %rax")
    out_str("    jz .Lloop_end")
    out_int(end_id)
    out_char(10)
    
    expect(TK_LEFT_BRACE)
    scope_push()
    loop tok_kind(cur_tok) not=? TK_RIGHT_BRACE {
        parse_statement()
    }
    expect(TK_RIGHT_BRACE)
    scope_pop()
    
    out_str("    jmp .Lloop_start")
    out_int(start_id)
    out_char(10)
    out_label(".Lloop_end" end_id)
    
    loop_start_label = saved_start
    loop_end_label = saved_end
    return void
}

let parse_return = ():>void => {
    cur_tok = cur_tok + 1
    parse_expr(0)
    out_str("    jmp .Lfn")
    out_int(fn_epilogue_label)
    out_str("_epilogue\n")
    return void
}

let parse_break = ():>void => {
    cur_tok = cur_tok + 1
    out_str("    jmp .Lloop_end")
    out_int(loop_end_label)
    out_char(10)
    return void
}

let parse_continue = ():>void => {
    cur_tok = cur_tok + 1
    out_str("    jmp .Lloop_start")
    out_int(loop_start_label)
    out_char(10)
    return void
}

let parse_assign_or_expr = ():>void => {
    if tok_kind(cur_tok) =? TK_IDENT {
        let nk:int = tok_kind(cur_tok + 1)
        
        if nk =? TK_ASSIGN {
            let start:int = tok_loc(cur_tok)
            let len:int = tok_value(cur_tok)
            cur_tok = cur_tok + 2
            
            parse_expr(0)
            
            let off:int = var_lookup(start len)
            if off not=? 0x7FFFFFFFFFFFFFFF {
                out_str("    movq %rax, ")
                out_int(off)
                out_str("(%rbp)\n")
            } else {
                let gi:int = glob_lookup(start len)
                if gi >=? 0 {
                    out_str("    movq %rax, .Lglobal")
                    out_int(glob_get_label(gi))
                    out_str("(%rip)\n")
                }
            }
            return void
        }
        
        if nk =? TK_UPDATE_ASSIGN {
            let start:int = tok_loc(cur_tok)
            let len:int = tok_value(cur_tok)
            let op_kind:int = tok_value(cur_tok + 1)
            cur_tok = cur_tok + 2
            
            let off:int = var_lookup(start len)
            let is_local:int = 1
            let gi:int = 0
            if off =? 0x7FFFFFFFFFFFFFFF {
                is_local = 0
                gi = glob_lookup(start len)
            }
            
            if is_local {
                out_str("    movq ")
                out_int(off)
                out_str("(%rbp), %rbx\n")
            } else {
                out_str("    movq .Lglobal")
                out_int(glob_get_label(gi))
                out_str("(%rip), %rbx\n")
            }
            out_line("pushq %rbx")
            
            parse_expr(0)
            
            out_line("movq %rax, %rcx")
            out_line("popq %rax")
            
            if op_kind =? TK_PLUS { out_line("addq %rcx, %rax") }
            else if op_kind =? TK_MINUS { out_line("subq %rcx, %rax") }
            else if op_kind =? TK_MUL { out_line("imulq %rcx, %rax") }
            else if op_kind =? TK_IDIV {
                out_line("cqto")
                out_line("idivq %rcx")
            }
            else if op_kind =? TK_MOD {
                out_line("cqto")
                out_line("idivq %rcx")
                out_line("movq %rdx, %rax")
            }
            else if op_kind =? TK_LEFT_SHIFT { out_line("shlq %cl, %rax") }
            else if op_kind =? TK_RIGHT_SHIFT { out_line("sarq %cl, %rax") }
            else if op_kind =? TK_AND { out_line("andq %rcx, %rax") }
            else if op_kind =? TK_OR { out_line("orq %rcx, %rax") }
            else if op_kind =? TK_XOR { out_line("xorq %rcx, %rax") }
            
            if is_local {
                out_str("    movq %rax, ")
                out_int(off)
                out_str("(%rbp)\n")
            } else {
                out_str("    movq %rax, .Lglobal")
                out_int(glob_get_label(gi))
                out_str("(%rip)\n")
            }
            return void
        }
    }
    
    parse_expr(0)
    return void
}

let parse_statement_impl = ():>void => {
    let kind:int = tok_kind(cur_tok)
    
    if kind =? TK_LET {
        if tok_kind(cur_tok + 2) =? TK_ASSIGN {
            if tok_kind(cur_tok + 3) =? TK_LEFT_PAREN {
                parse_fn_decl()
                return void
            }
        }
        parse_var_decl()
        return void
    }
    
    if kind =? TK_IF {
        parse_if()
        return void
    }
    
    if kind =? TK_LOOP {
        parse_loop()
        return void
    }
    
    if kind =? TK_RETURN {
        parse_return()
        return void
    }
    
    if kind =? TK_BREAK {
        parse_break()
        return void
    }
    
    if kind =? TK_CONTINUE {
        parse_continue()
        return void
    }
    
    parse_assign_or_expr()
    return void
}

let parse_statement = ():>void => {
    parse_statement_impl()
    return void
}

# ============================================================================
# Top-level parsing
# ============================================================================

let parse_global_var = ():>void => {
    cur_tok = cur_tok + 1
    
    let name_start:int = tok_loc(cur_tok)
    let name_len:int = tok_value(cur_tok)
    cur_tok = cur_tok + 1
    
    skip_type_annot()
    expect(TK_ASSIGN)
    
    let kind:int = tok_kind(cur_tok)
    
    if kind =? TK_NUMBER {
        let val:int = tok_value(cur_tok)
        cur_tok = cur_tok + 1
        
        const_add(name_start name_len val)
        
        let label_id:int = next_label
        next_label = next_label + 1
        glob_add(name_start name_len label_id)
        
        data_label(".Lglobal" label_id)
        data_str("    .quad ")
        data_int(val)
        data_char(10)
        return void
    }
    
    if kind =? TK_STRING {
        let start:int = tok_loc(cur_tok)
        let len:int = tok_value(cur_tok)
        cur_tok = cur_tok + 1
        
        let str_id:int = next_label
        next_label = next_label + 1
        
        data_label(".Lstr" str_id)
        
        let slen:int = 0
        let si:int = start + 1
        let send:int = start + len - 1
        loop si <? send {
            let c:int = __load8__(src_ptr + si)
            if c =? CH_BACKSLASH {
                si = si + 1
                c = __load8__(src_ptr + si)
                if c =? CH_LF {
                    si = si + 1
                    continue
                }
            }
            slen = slen + 1
            si = si + 1
        }
        
        data_str("    .quad ")
        data_int(slen)
        data_char(CH_LF)
        
        data_str("    .byte ")
        si = start + 1
        let first:int = 1
        loop si <? send {
            let c:int = __load8__(src_ptr + si)
            if c =? CH_BACKSLASH {
                si = si + 1
                c = escape_char(__load8__(src_ptr + si))
                if c =? (0 - 1) {
                    si = si + 1
                    continue
                }
            }
            if first =? 0 { data_str(", ") }
            first = 0
            data_int(c)
            si = si + 1
        }
        data_char(CH_LF)
        
        let label_id:int = next_label
        next_label = next_label + 1
        glob_add(name_start name_len label_id)
        
        data_label(".Lglobal" label_id)
        data_str("    .quad .Lstr")
        data_int(str_id)
        data_str("+8\n")
        return void
    }
    
    if kind =? TK_LEFT_BRACKET {
        cur_tok = cur_tok + 1
        
        # Each element: 16 bytes (kind:8, value:8)
        # kind: 0=number, 1=fnref, 2=strref, 3=arrref
        let elems:int = arena_alloc(1024 * 16)
        let nelem:int = 0
        
        loop tok_kind(cur_tok) not=? TK_RIGHT_BRACKET {
            let ek:int = tok_kind(cur_tok)
            let eoff:int = nelem * 16
            
            if ek =? TK_NUMBER {
                __store__(0 elems + eoff)
                __store__(tok_value(cur_tok) elems + eoff + 8)
                cur_tok = cur_tok + 1
                nelem = nelem + 1
            } else if ek =? TK_IDENT {
                let es:int = tok_loc(cur_tok)
                let el:int = tok_value(cur_tok)
                cur_tok = cur_tok + 1
                
                let ci:int = const_lookup(es el)
                if ci >=? 0 {
                    __store__(0 elems + eoff)
                    __store__(const_get_value(ci) elems + eoff + 8)
                } else {
                    let fi:int = fn_lookup(es el)
                    if fi >=? 0 {
                        __store__(1 elems + eoff)
                        __store__(fn_get_label(fi) elems + eoff + 8)
                    } else {
                        # Forward function reference
                        let fwd_id:int = next_label
                        next_label = next_label + 1
                        fn_add(es el fwd_id 0 0)
                        __store__(1 elems + eoff)
                        __store__(fwd_id elems + eoff + 8)
                    }
                }
                nelem = nelem + 1
            } else if ek =? TK_STRING {
                let start:int = tok_loc(cur_tok)
                let len:int = tok_value(cur_tok)
                cur_tok = cur_tok + 1
                
                let label_id:int = next_label
                next_label = next_label + 1
                
                data_label(".Lstr" label_id)
                
                let slen:int = 0
                let si:int = start + 1
                let send:int = start + len - 1
                loop si <? send {
                    let c:int = __load8__(src_ptr + si)
                    if c =? CH_BACKSLASH {
                        si = si + 1
                        c = __load8__(src_ptr + si)
                        if c =? CH_LF {
                            si = si + 1
                            continue
                        }
                    }
                    slen = slen + 1
                    si = si + 1
                }
                
                data_str("    .quad ")
                data_int(slen)
                data_char(CH_LF)
                
                data_str("    .byte ")
                si = start + 1
                let first:int = 1
                loop si <? send {
                    let c:int = __load8__(src_ptr + si)
                    if c =? CH_BACKSLASH {
                        si = si + 1
                        c = escape_char(__load8__(src_ptr + si))
                        if c =? (0 - 1) {
                            si = si + 1
                            continue
                        }
                    }
                    if first =? 0 {
                        data_str(", ")
                    }
                    first = 0
                    data_int(c)
                    si = si + 1
                }
                data_char(10)
                
                __store__(2 elems + eoff)
                __store__(label_id elems + eoff + 8)
                nelem = nelem + 1
            } else {
                out_str("Error: array elements must be compile-time constants\n")
                out_flush()
                __syscall1__(SYS_EXIT 1)
            }
        }
        expect(TK_RIGHT_BRACKET)
        
        let arr_id:int = next_label
        next_label = next_label + 1
        
        data_label(".Larr" arr_id)
        data_str("    .quad ")
        data_int(nelem)
        data_char(10)
        
        let ei:int = 0
        loop ei <? nelem {
            let ekind:int = __load__(elems + (ei * 16))
            let eval:int = __load__(elems + (ei * 16) + 8)
            if ekind =? 0 {
                data_str("    .quad ")
                data_int(eval)
                data_char(10)
            } else if ekind =? 1 {
                data_str("    .quad .Lfn")
                data_int(eval)
                data_char(10)
            } else if ekind =? 2 {
                data_str("    .quad .Lstr")
                data_int(eval)
                data_str("+8\n")
            }
            ei = ei + 1
        }
        
        let label_id:int = next_label
        next_label = next_label + 1
        glob_add(name_start name_len label_id)
        
        data_label(".Lglobal" label_id)
        data_str("    .quad .Larr")
        data_int(arr_id)
        data_str("+8\n")
        return void
    }
    
    out_str("Error: global must have const init\n")
    out_flush()
    __syscall1__(SYS_EXIT 1)
    return void
}

let parse_program = ():>void => {
    loop cur_tok <? tok_count {
        let kind:int = tok_kind(cur_tok)
        
        if kind =? TK_LET {
            if tok_kind(cur_tok + 2) =? TK_ASSIGN {
                if tok_kind(cur_tok + 3) =? TK_LEFT_PAREN {
                    parse_fn_decl()
                    continue
                }
            }
            parse_global_var()
            continue
        }
        
        out_str("Error: only let/const at top level\n")
        out_flush()
        __syscall1__(SYS_EXIT 1)
    }
    return void
}

# ============================================================================
# Import processing
# ============================================================================

const MAX_IMPORTS:int = 256

let imported_paths:int = 0
let imported_count:int = 0

let imports_init = ():>void => {
    imported_paths = arena_alloc(MAX_IMPORTS * 256)
    imported_count = 0
    return void
}

let cstr_eq = (a:int b:int):>int => {
    let i:int = 0
    loop true {
        let ca:int = __load8__(a + i)
        let cb:int = __load8__(b + i)
        if ca not=? cb { return FALSE_VAL }
        if ca =? CH_NUL { return TRUE_VAL }
        i = i + 1
    }
    return FALSE_VAL
}

let is_already_imported = (path:int):>int => {
    let i:int = 0
    loop i <? imported_count {
        if cstr_eq(imported_paths + (i * 256) path) {
            return TRUE_VAL
        }
        i = i + 1
    }
    return FALSE_VAL
}

let mark_imported = (path:int):>void => {
    let dst:int = imported_paths + (imported_count * 256)
    let i:int = 0
    loop __load8__(path + i) not=? CH_NUL {
        __store8__(__load8__(path + i) dst + i)
        i = i + 1
    }
    __store8__(CH_NUL dst + i)
    imported_count = imported_count + 1
    return void
}

let get_dir_from_path = (path:int):>int => {
    let buf:int = arena_alloc(256)
    let plen:int = 0
    loop __load8__(path + plen) not=? CH_NUL {
        plen = plen + 1
    }
    
    let last_slash:int = 0 - 1
    let i:int = 0
    loop i <? plen {
        if __load8__(path + i) =? CH_SLASH {
            last_slash = i
        }
        i = i + 1
    }
    
    if last_slash <? 0 {
        __store8__(CH_DOT buf)
        __store8__(CH_SLASH buf + 1)
        __store8__(CH_NUL buf + 2)
        return buf
    }
    
    i = 0
    loop i <=? last_slash {
        __store8__(__load8__(path + i) buf + i)
        i = i + 1
    }
    __store8__(CH_NUL buf + i)
    return buf
}

let join_path = (dir:int file:int):>int => {
    let buf:int = arena_alloc(512)
    let pos:int = 0
    
    loop __load8__(dir + pos) not=? CH_NUL {
        __store8__(__load8__(dir + pos) buf + pos)
        pos = pos + 1
    }
    
    if (pos >? 0) and (__load8__(buf + pos - 1) not=? CH_SLASH) {
        __store8__(CH_SLASH buf + pos)
        pos = pos + 1
    }
    
    let i:int = 0
    loop __load8__(file + i) not=? CH_NUL {
        __store8__(__load8__(file + i) buf + pos)
        pos = pos + 1
        i = i + 1
    }
    __store8__(CH_NUL buf + pos)
    return buf
}

let read_file_content = (path:int):>int => {
    let fd:int = __syscall2__(SYS_OPEN path 0)
    if fd <? 0 { return 0 }
    
    let content:int = arena_alloc(0x100000)
    let len:int = __syscall3__(SYS_READ fd content 0x100000)
    __syscall1__(SYS_CLOSE fd)
    
    if len <? 0 { return 0 }
    
    let result:int = arena_alloc(16)
    __store__(content result)
    __store__(len result + 8)
    return result
}

let combined_src:int = 0
let combined_len:int = 0
let combined_cap:int = 0

let combined_init = ():>void => {
    combined_cap = 0x400000
    combined_src = arena_alloc(combined_cap)
    combined_len = 0
    return void
}

let combined_append = (data:int len:int):>void => {
    let i:int = 0
    loop i <? len {
        __store8__(__load8__(data + i) combined_src + combined_len)
        combined_len = combined_len + 1
        i = i + 1
    }
    return void
}

let combined_append_char = (c:int):>void => {
    __store8__(c combined_src + combined_len)
    combined_len = combined_len + 1
    return void
}

let process_imports = (content:int clen:int dir:int):>void => {
    let i:int = 0
    
    loop i <? clen {
        let c:int = __load8__(content + i)
        
        if is_space(c) {
            combined_append_char(c)
            i = i + 1
            continue
        }
        
        if c =? CH_HASH {
            loop (i <? clen) and (__load8__(content + i) not=? CH_LF) {
                combined_append_char(__load8__(content + i))
                i = i + 1
            }
            continue
        }
        
        if str_prefix(content i "import") {
            let start:int = i
            i = i + 6
            
            loop (i <? clen) and ((__load8__(content + i) =? CH_SPACE) or (__load8__(content + i) =? CH_TAB)) {
                i = i + 1
            }
            
            if (i <? clen) and (__load8__(content + i) =? CH_p) and ((i + 1) <? clen) and (__load8__(content + i + 1) =? CH_DQUOTE) {
                i = i + 2
                let path_start:int = i
                
                loop (i <? clen) and (__load8__(content + i) not=? CH_DQUOTE) {
                    if __load8__(content + i) =? CH_BACKSLASH {
                        i = i + 1
                    }
                    i = i + 1
                }
                
                let path_len:int = i - path_start
                i = i + 1
                
                let import_rel:int = arena_alloc(path_len + 1)
                let j:int = 0
                loop j <? path_len {
                    __store8__(__load8__(content + path_start + j) import_rel + j)
                    j = j + 1
                }
                __store8__(CH_NUL import_rel + path_len)
                
                let import_path:int = join_path(dir import_rel)
                
                if not is_already_imported(import_path) {
                    mark_imported(import_path)
                    
                    let file_info:int = read_file_content(import_path)
                    if file_info not=? 0 {
                        let file_content:int = __load__(file_info)
                        let file_len:int = __load__(file_info + 8)
                        let import_dir:int = get_dir_from_path(import_path)
                        
                        process_imports(file_content file_len import_dir)
                        combined_append_char(CH_LF)
                    }
                }
                continue
            } else {
                i = start
            }
        }
        
        loop (i <? clen) and (not is_space(__load8__(content + i))) {
            let cc:int = __load8__(content + i)
            combined_append_char(cc)
            
            if cc =? CH_DQUOTE {
                i = i + 1
                loop (i <? clen) and (__load8__(content + i) not=? CH_DQUOTE) {
                    if __load8__(content + i) =? CH_BACKSLASH {
                        combined_append_char(__load8__(content + i))
                        i = i + 1
                    }
                    combined_append_char(__load8__(content + i))
                    i = i + 1
                }
                if i <? clen {
                    combined_append_char(__load8__(content + i))
                    i = i + 1
                }
                continue
            }
            
            if cc =? CH_HASH {
                loop (i <? clen) and (__load8__(content + i) not=? CH_LF) {
                    combined_append_char(__load8__(content + i))
                    i = i + 1
                }
                continue
            }
            
            i = i + 1
        }
    }
    return void
}

# ============================================================================
# Process execution helpers
# ============================================================================

let run_cmd = (prog:int arg1:int arg2:int arg3:int arg4:int):>int => {
    let argv_buf:int = arena_alloc(48)
    __store__(prog argv_buf)
    __store__(arg1 argv_buf + 8)
    __store__(arg2 argv_buf + 16)
    __store__(arg3 argv_buf + 24)
    __store__(arg4 argv_buf + 32)
    __store__(0 argv_buf + 40)
    
    let pid:int = __syscall0__(SYS_FORK)
    if pid =? 0 {
        __syscall3__(SYS_EXECVE prog argv_buf 0)
        __syscall1__(SYS_EXIT 127)
    }
    
    let status_buf:int = arena_alloc(8)
    __syscall4__(SYS_WAIT4 pid status_buf 0 0)
    return __load__(status_buf)
}

let write_file = (path:int content:int len:int):>int => {
    let fd:int = __syscall3__(SYS_OPEN path (O_WRONLY or O_CREAT or O_TRUNC) 0x1B4)
    if fd <? 0 { return fd }
    __syscall3__(SYS_WRITE fd content len)
    __syscall1__(SYS_CLOSE fd)
    return 0
}

let str_copy = (dst:int s:int):>int => {
    let slen:int = __load__(s + 0 - 8)
    let i:int = 0
    loop i <? slen {
        __store8__(__load8__(s + i) dst + i)
        i = i + 1
    }
    return slen
}

let str_copy_cstr = (dst:int s:int):>int => {
    let i:int = 0
    loop __load8__(s + i) not=? CH_NUL {
        __store8__(__load8__(s + i) dst + i)
        i = i + 1
    }
    return i
}

let make_path = (dir:int name:int ext:int):>int => {
    let buf:int = arena_alloc(256)
    let pos:int = 0
    pos = pos + str_copy(buf + pos dir)
    pos = pos + str_copy(buf + pos name)
    pos = pos + str_copy(buf + pos ext)
    __store8__(0 buf + pos)
    return buf
}

let get_basename = (path:int):>int => {
    let plen:int = 0
    loop __load8__(path + plen) not=? CH_NUL {
        plen = plen + 1
    }
    
    let last_slash:int = 0 - 1
    let i:int = 0
    loop i <? plen {
        if __load8__(path + i) =? CH_SLASH {
            last_slash = i
        }
        i = i + 1
    }
    
    let start:int = last_slash + 1
    
    let last_dot:int = plen
    i = plen - 1
    loop i >? start {
        if __load8__(path + i) =? CH_DOT {
            last_dot = i
            break
        }
        i = i - 1
    }
    
    let name_len:int = last_dot - start
    let buf:int = arena_alloc(8 + name_len + 1)
    __store__(name_len buf)
    i = 0
    loop i <? name_len {
        __store8__(__load8__(path + start + i) buf + 8 + i)
        i = i + 1
    }
    __store8__(0 buf + 8 + name_len)
    return buf + 8
}

# ============================================================================
# Main entry point
# ============================================================================

let main = (argc:int argv:int):>int => {
    arena_init()
    out_init()
    data_init()
    tok_init()
    fn_init()
    glob_init()
    const_init()
    scope_init()
    imports_init()
    combined_init()
    
    if argc <? 2 {
        __syscall3__(SYS_WRITE STDERR "Usage: udewy [-c] <file.udewy> [args...]\n" 41)
        __syscall3__(SYS_WRITE STDERR "  -c    Compile only, don't run\n" 32)
        return 1
    }
    
    let compile_only:int = 0
    let arg_idx:int = 1
    
    let first_arg:int = __load__(argv + 8)
    if (__load8__(first_arg) =? CH_MINUS) and (__load8__(first_arg + 1) =? CH_c) and (__load8__(first_arg + 2) =? CH_NUL) {
        compile_only = 1
        arg_idx = 2
    }
    
    if arg_idx >=? argc {
        __syscall3__(SYS_WRITE STDERR "Error: No input file specified\n" 31)
        return 1
    }
    
    let filename:int = __load__(argv + (arg_idx * 8))
    let script_args_start:int = arg_idx + 1
    let script_argc:int = argc - script_args_start
    
    let file_info:int = read_file_content(filename)
    if file_info =? 0 {
        __syscall3__(SYS_WRITE STDERR "Error: cannot open file\n" 24)
        return 1
    }
    
    let raw_src:int = __load__(file_info)
    let raw_len:int = __load__(file_info + 8)
    let src_dir:int = get_dir_from_path(filename)
    
    mark_imported(filename)
    process_imports(raw_src raw_len src_dir)
    
    src_ptr = combined_src
    src_len = combined_len
    
    tokenize()
    
    cur_tok = 0
    next_label = 0
    stack_offset = 0 - 8
    loop_start_label = 0
    loop_end_label = 0
    fn_epilogue_label = 0
    
    out_str(".text\n")
    out_str(".globl __main__\n\n")
    
    parse_program()
    
    out_str("\n.data\n")
    
    let di:int = 0
    loop di <? data_len {
        out_char(__load8__(data_ptr + di))
        di = di + 1
    }
    
    out_str("\n.section .note.GNU-stack,\"\",@progbits\n")
    
    __syscall2__(SYS_MKDIR "__dewycache__\0" 0x1FF)
    
    let compiler_path:int = __load__(argv)
    let compiler_dir:int = get_dir_from_path(compiler_path)
    let basename:int = get_basename(filename)
    let asm_path:int = make_path("__dewycache__/" basename ".s\0")
    let obj_path:int = make_path("__dewycache__/" basename ".o\0")
    let exe_path:int = make_path("__dewycache__/" basename "\0")
    let runtime_obj:int = "__dewycache__/runtime.o\0"
    let runtime_src:int = join_path(compiler_dir "../udewy/runtime.s\0")
    
    write_file(asm_path out_ptr out_len)
    
    run_cmd("/usr/bin/as\0" asm_path "-o\0" obj_path 0)
    run_cmd("/usr/bin/as\0" runtime_src "-o\0" runtime_obj 0)
    run_cmd("/usr/bin/ld\0" obj_path runtime_obj "-o\0" exe_path)
    
    if compile_only {
        __syscall3__(SYS_WRITE STDOUT "Compiled: " 10)
        let olen:int = 0
        loop __load8__(exe_path + olen) not=? CH_NUL {
            olen = olen + 1
        }
        __syscall3__(SYS_WRITE STDOUT exe_path olen)
        __syscall3__(SYS_WRITE STDOUT "\n" 1)
        return 0
    }
    
    let new_argv:int = arena_alloc((script_argc + 2) * 8)
    __store__(exe_path new_argv)
    let ai:int = 0
    loop ai <? script_argc {
        __store__(__load__(argv + ((script_args_start + ai) * 8)) new_argv + ((ai + 1) * 8))
        ai = ai + 1
    }
    __store__(0 new_argv + ((script_argc + 1) * 8))
    
    __syscall3__(SYS_EXECVE exe_path new_argv 0)
    
    __syscall3__(SYS_WRITE STDERR "Error: failed to execute\n" 25)
    return 1
}
