import p"../bootstrap/t1.udewy"

let main = (argc:int argv:int):>int => {
    arena_init()
    if argc <? 2 {
        eprintl("usage: test_bootstrap_t1 <file>")
        return 1
    }
    let path_cstr:int = __load__(argv + 8)
    let path:int = path_from_cstr(path_cstr)

    let bb:int = bb_new(8)
    bb_push_str(bb "x86_64")
    let target:int = bb_finalize_as_string(bb)

    let loaded:int = t0_load_program(path target)
    let src:int = loaded_source(loaded)
    let ts:int = t1_tokenize(src)
    let dump:int = t1_dump_normalized(ts)
    host_write(STDOUT dump str_len(dump))
    return 0
}
