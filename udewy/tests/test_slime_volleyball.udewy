let sin256 = (angle:int):>int => {
    let a:int = angle % 1024
    if a <? 0 {
        a = a + 1024
    }

    let quad:int = a // 256
    let x:int = a % 256
    let y:int = 0
    let term:int = 0
    if quad =? 0 {
        term = 512 - x
        y = (x * term) // 256
    }
    if quad =? 1 {
        x = 256 - x
        term = 512 - x
        y = (x * term) // 256
    }
    if quad =? 2 {
        term = 512 - x
        y = 0 - ((x * term) // 256)
    }
    if quad =? 3 {
        x = 256 - x
        term = 512 - x
        y = 0 - ((x * term) // 256)
    }
    return y
}

let str_len = (s:int):>int => {
    return __load__(s - 8)
}

let abs_int = (v:int):>int => {
    if v <? 0 {
        return 0 - v
    }
    return v
}

let isqrt = (n:int):>int => {
    let bit:int = 1
    loop (bit * bit) <=? n {
        bit = bit + 1
    }
    return bit - 1
}

let to_fp = (value:int):>int => {
    return value * PHYS_SCALE
}

let from_fp = (value:int):>int => {
    return value // PHYS_SCALE
}

let sync_positions = ():>int => {
    left_y = from_fp(left_y_fp)
    right_y = from_fp(right_y_fp)
    ball_y = from_fp(ball_y_fp)
    ball_prev_y = from_fp(ball_prev_y_fp)
    return 0
}

let stage_name = (stage:int):>int => {
    if stage =? STAGE_EARTH {
        return text_stage_earth
    }
    if stage =? STAGE_MOON {
        return text_stage_moon
    }
    if stage =? STAGE_MARS {
        return text_stage_mars
    }
    if stage =? STAGE_JUPITER {
        return text_stage_jupiter
    }
    return text_stage_station
}

let apply_stage_settings = (stage:int):>int => {
    current_stage = stage
    player_gravity_fp = EARTH_PLAYER_GRAVITY_FP
    ball_gravity_fp = EARTH_BALL_GRAVITY_FP
    if current_stage =? STAGE_MOON {
        player_gravity_fp = MOON_PLAYER_GRAVITY_FP
        ball_gravity_fp = MOON_BALL_GRAVITY_FP
    } else if current_stage =? STAGE_MARS {
        player_gravity_fp = MARS_PLAYER_GRAVITY_FP
        ball_gravity_fp = MARS_BALL_GRAVITY_FP
    } else if current_stage =? STAGE_JUPITER {
        player_gravity_fp = JUPITER_PLAYER_GRAVITY_FP
        ball_gravity_fp = JUPITER_BALL_GRAVITY_FP
    } else if current_stage =? STAGE_STATION {
        player_gravity_fp = STATION_PLAYER_GRAVITY_FP
        ball_gravity_fp = STATION_BALL_GRAVITY_FP
    }
    jump_velocity_fp = isqrt((player_gravity_fp * JUMP_HEIGHT_FP * 2))
    return 0
}

let apply_pace_settings = (pace:int):>int => {
    current_pace = pace
    sim_rate_num = 3
    sim_rate_den = 4
    if current_pace =? PACE_CALM {
        sim_rate_num = 1
        sim_rate_den = 2
    } else if current_pace =? PACE_SLOW {
        sim_rate_num = 1
        sim_rate_den = 3
    }
    sim_rate_accum = 0
    return 0
}

let arr_get = (arr:int idx:int):>int => {
    return __load__(arr + (idx * 8))
}

let key_down = (code:int):>int => {
    return __key_down__(code str_len(code))
}

let key_pressed = (code:int):>int => {
    return __key_pressed__(code str_len(code))
}

let set_pixel = (x:int y:int r:int g:int b:int):>int => {
    if x <? 0 { return 0 }
    if y <? 0 { return 0 }
    if x >=? WIDTH { return 0 }
    if y >=? HEIGHT { return 0 }
    let offset:int = ((y * WIDTH) + x) * 4
    let addr:int = canvas_buf + offset
    __store_u8__(r addr)
    __store_u8__(g addr + 1)
    __store_u8__(b addr + 2)
    __store_u8__(255 addr + 3)
    return 0
}

let fill_rect = (x:int y:int w:int h:int r:int g:int b:int):>int => {
    let yy:int = y
    loop yy <? (y + h) {
        let xx:int = x
        loop xx <? (x + w) {
            set_pixel(xx yy r g b)
            xx = xx + 1
        }
        yy = yy + 1
    }
    return 0
}

let fill_circle = (cx:int cy:int radius:int r:int g:int b:int):>int => {
    let yy:int = cy - radius
    let rr:int = radius * radius
    loop yy <=? (cy + radius) {
        let xx:int = cx - radius
        loop xx <=? (cx + radius) {
            let dx:int = xx - cx
            let dy:int = yy - cy
            if ((dx * dx) + (dy * dy)) <=? rr {
                set_pixel(xx yy r g b)
            }
            xx = xx + 1
        }
        yy = yy + 1
    }
    return 0
}

let fill_slime = (cx:int cy:int radius:int body_r:int body_g:int body_b:int eye_dir:int):>int => {
    let yy:int = cy - radius
    let rr:int = radius * radius
    loop yy <=? cy {
        let xx:int = cx - radius
        loop xx <=? (cx + radius) {
            let dx:int = xx - cx
            let dy:int = yy - cy
            if ((dx * dx) + (dy * dy)) <=? rr {
                set_pixel(xx yy body_r body_g body_b)
            }
            xx = xx + 1
        }
        yy = yy + 1
    }

    let eye_y:int = cy - (radius // 2)
    let eye_shift:int = eye_dir * 2
    fill_rect((cx - 7 + eye_shift) eye_y 4 4 255 255 255)
    fill_rect((cx + 3 + eye_shift) eye_y 4 4 255 255 255)
    fill_rect((cx - 5 + eye_shift) (eye_y + 1) 2 2 20 20 20)
    fill_rect((cx + 5 + eye_shift) (eye_y + 1) 2 2 20 20 20)
    return 0
}

let font_index = (code:int):>int => {
    if code =? 32 {
        return 0
    }
    if code >=? 48 {
        if code <=? 57 {
            return (code - 47)
        }
    }
    if code >=? 65 {
        if code <=? 90 {
            return (11 + code - 65)
        }
    }
    return 0
}

let draw_char = (code:int x:int y:int scale:int r:int g:int b:int):>int => {
    let idx:int = font_index(code)
    let row:int = 0
    loop row <? 5 {
        let pattern:int = arr_get(font_rows ((idx * 5) + row))
        let col:int = 0
        loop col <? 3 {
            let mask:int = 1 << (2 - col)
            if pattern and mask {
                fill_rect((x + (col * scale)) (y + (row * scale)) scale scale r g b)
            }
            col = col + 1
        }
        row = row + 1
    }
    return 0
}

let draw_text = (text:int x:int y:int scale:int r:int g:int b:int):>int => {
    let i:int = 0
    let advance:int = 4 * scale
    let len:int = str_len(text)
    loop i <? len {
        let code:int = __load_u8__(text + i)
        draw_char(code (x + (i * advance)) y scale r g b)
        i = i + 1
    }
    return 0
}

let draw_text_center = (text:int y:int scale:int r:int g:int b:int):>int => {
    let len:int = str_len(text)
    let text_w:int = (((len * 4) - 1) * scale)
    let x:int = (WIDTH - text_w) // 2
    draw_text(text x y scale r g b)
    return 0
}

let draw_text_right = (text:int right_x:int y:int scale:int r:int g:int b:int):>int => {
    let len:int = str_len(text)
    let text_w:int = (((len * 4) - 1) * scale)
    let x:int = right_x - text_w
    draw_text(text x y scale r g b)
    return 0
}

let draw_digit = (value:int x:int y:int scale:int r:int g:int b:int):>int => {
    draw_char((48 + value) x y scale r g b)
    return 0
}

let play_sound = (kind:int):>int => {
    if audio_buf =? 0 {
        return 0
    }

    let sample_rate:int = 22050
    let num_samples:int = 1024
    let freq:int = 460
    let slide:int = 0
    let volume:int = 120
    if kind =? 1 {
        freq = 620
        slide = 2
        volume = 96
    }
    if kind =? 2 {
        freq = 860
        slide = 0 - 3
        volume = 112
    }
    if kind =? 3 {
        freq = 420
        slide = 3
        volume = 120
    }
    if kind =? 4 {
        freq = 300
        slide = 5
        volume = 128
    }

    let phase:int = 0
    let i:int = 0
    loop i <? num_samples {
        let env:int = ((num_samples - i) * volume) // num_samples
        let cur_freq:int = freq + ((slide * i) // 32)
        if cur_freq <? 80 {
            cur_freq = 80
        }
        phase = (phase + ((cur_freq * 1024) // sample_rate)) % 1024
        let sample:int = (sin256(phase) * env) // 2
        __store_u16__(sample (audio_buf + (i * 2)))
        i = i + 1
    }
    __audio_play__()
    return 0
}

let set_round_positions = ():>int => {
    let ground_fp:int = to_fp(GROUND_Y)
    left_x = 80
    left_y = GROUND_Y
    left_y_fp = ground_fp
    left_vy_fp = 0
    left_move_dir = 0

    right_x = 240
    right_y = GROUND_Y
    right_y_fp = ground_fp
    right_vy_fp = 0
    right_move_dir = 0

    if serve_side =? 0 {
        ball_x = left_x
    } else {
        ball_x = right_x
    }
    ball_y = GROUND_Y - SLIME_R - BALL_R - 4
    ball_vx = 0
    ball_y_fp = to_fp(ball_y)
    ball_prev_y_fp = ball_y_fp
    ball_vy_fp = 0
    serve_timer = SERVE_DELAY
    impact_timer = 0
    point_flash_timer = 12
    left_jump_buffer = 0
    right_jump_buffer = 0
    sync_positions()
    return 0
}

let start_match = (mode:int):>int => {
    player_mode = mode
    apply_stage_settings(selected_stage)
    apply_pace_settings(selected_pace)
    left_score = 0
    right_score = 0
    winner_side = 0
    serve_side = 0
    game_state = STATE_SERVE
    set_round_positions()
    play_sound(3)
    return 0
}

let sample_input_buffers = ():>int => {
    if key_pressed(key_w) {
        left_jump_buffer = JUMP_BUFFER_FRAMES
    }
    if key_pressed(key_up) {
        right_jump_buffer = JUMP_BUFFER_FRAMES
    }
    return 0
}

let decay_input_buffers = ():>int => {
    if left_jump_buffer >? 0 {
        left_jump_buffer = left_jump_buffer - 1
    }
    if right_jump_buffer >? 0 {
        right_jump_buffer = right_jump_buffer - 1
    }
    return 0
}

let award_point = (side:int):>int => {
    if side =? 0 {
        left_score = left_score + 1
    } else {
        right_score = right_score + 1
    }
    serve_side = side
    play_sound(3)
    if side =? 0 {
        if left_score >=? SCORE_TO_WIN {
            winner_side = 0
            game_state = STATE_GAME_OVER
            play_sound(4)
            return 0
        }
    } else if right_score >=? SCORE_TO_WIN {
        winner_side = 1
        game_state = STATE_GAME_OVER
        play_sound(4)
        return 0
    }
    game_state = STATE_SERVE
    set_round_positions()
    return 0
}

let update_left_player = ():>int => {
    let ground_fp:int = to_fp(GROUND_Y)
    left_move_dir = 0
    if key_down(key_a) {
        left_move_dir = 0 - 1
    }
    if key_down(key_d) {
        left_move_dir = 1
    }
    if left_y =? GROUND_Y {
        if left_jump_buffer >? 0 {
            left_vy_fp = 0 - jump_velocity_fp
            left_jump_buffer = 0
            play_sound(1)
        }
    }

    left_x = left_x + (left_move_dir * SLIME_SPEED)
    if left_x <? SLIME_R {
        left_x = SLIME_R
    }
    if left_x >? (NET_X - NET_HALF_W - SLIME_R) {
        left_x = NET_X - NET_HALF_W - SLIME_R
    }

    left_y_fp = left_y_fp + left_vy_fp
    left_vy_fp = left_vy_fp + player_gravity_fp
    if left_y_fp >? ground_fp {
        left_y_fp = ground_fp
        left_y = GROUND_Y
        left_vy_fp = 0
    }
    left_y = from_fp(left_y_fp)
    return 0
}

let update_right_ai = ():>int => {
    let ground_fp:int = to_fp(GROUND_Y)
    right_move_dir = 0
    let target_x:int = 240
    if ball_x >? NET_X {
        target_x = ball_x
    }
    if target_x <? (NET_X + NET_HALF_W + SLIME_R) {
        target_x = NET_X + NET_HALF_W + SLIME_R
    }
    if target_x >? (WIDTH - SLIME_R) {
        target_x = WIDTH - SLIME_R
    }
    if right_x <? (target_x - 2) {
        right_move_dir = 1
    }
    if right_x >? (target_x + 2) {
        right_move_dir = 0 - 1
    }

    if right_y =? GROUND_Y {
        if ball_x >? (NET_X + 10) {
            if abs_int(ball_x - right_x) <? 26 {
                if ball_y <? (right_y - 8) {
                    if ball_vy_fp >? 0 {
                        right_vy_fp = 0 - jump_velocity_fp
                        play_sound(1)
                    }
                }
            }
        }
    }

    right_x = right_x + (right_move_dir * SLIME_SPEED)
    if right_x <? (NET_X + NET_HALF_W + SLIME_R) {
        right_x = NET_X + NET_HALF_W + SLIME_R
    }
    if right_x >? (WIDTH - SLIME_R) {
        right_x = WIDTH - SLIME_R
    }

    right_y_fp = right_y_fp + right_vy_fp
    right_vy_fp = right_vy_fp + player_gravity_fp
    if right_y_fp >? ground_fp {
        right_y_fp = ground_fp
        right_y = GROUND_Y
        right_vy_fp = 0
    }
    right_y = from_fp(right_y_fp)
    return 0
}

let update_right_player = ():>int => {
    let ground_fp:int = to_fp(GROUND_Y)
    right_move_dir = 0
    if key_down(key_left) {
        right_move_dir = 0 - 1
    }
    if key_down(key_right) {
        right_move_dir = 1
    }
    if right_y =? GROUND_Y {
        if right_jump_buffer >? 0 {
            right_vy_fp = 0 - jump_velocity_fp
            right_jump_buffer = 0
            play_sound(1)
        }
    }

    right_x = right_x + (right_move_dir * SLIME_SPEED)
    if right_x <? (NET_X + NET_HALF_W + SLIME_R) {
        right_x = NET_X + NET_HALF_W + SLIME_R
    }
    if right_x >? (WIDTH - SLIME_R) {
        right_x = WIDTH - SLIME_R
    }

    right_y_fp = right_y_fp + right_vy_fp
    right_vy_fp = right_vy_fp + player_gravity_fp
    if right_y_fp >? ground_fp {
        right_y_fp = ground_fp
        right_y = GROUND_Y
        right_vy_fp = 0
    }
    right_y = from_fp(right_y_fp)
    return 0
}

let collide_ball_with_slime = (slime_x:int slime_y:int slime_push:int):>int => {
    let dx:int = ball_x - slime_x
    let dy:int = ball_y - slime_y
    let total_r:int = SLIME_R + BALL_R
    if ball_y <=? slime_y {
        if ((dx * dx) + (dy * dy)) <=? (total_r * total_r) {
            ball_y = slime_y - total_r
            ball_y_fp = to_fp(ball_y)
            ball_vx = (dx // 3) + slime_push
            if ball_vx =? 0 {
                if dx <? 0 {
                    ball_vx = 0 - 1
                } else {
                    ball_vx = 1
                }
            }
            ball_vy_fp = 0 - ((7 + (abs_int(dx) // 4)) * PHYS_SCALE)
            impact_timer = 4
            play_sound(2)
            return 1
        }
    }
    return 0
}

let update_ball = ():>int => {
    ball_prev_x = ball_x
    ball_prev_y_fp = ball_y_fp
    ball_prev_y = ball_y

    ball_x = ball_x + ball_vx
    ball_y_fp = ball_y_fp + ball_vy_fp
    ball_vy_fp = ball_vy_fp + ball_gravity_fp
    ball_y = from_fp(ball_y_fp)

    if ball_x <? BALL_R {
        ball_x = BALL_R
        if ball_vx <? 0 {
            ball_vx = 0 - ball_vx
            play_sound(2)
        }
    }
    if ball_x >? (WIDTH - BALL_R) {
        ball_x = WIDTH - BALL_R
        if ball_vx >? 0 {
            ball_vx = 0 - ball_vx
            play_sound(2)
        }
    }
    if ball_y <? BALL_R {
        ball_y_fp = to_fp(BALL_R)
        ball_y = BALL_R
        if ball_vy_fp <? 0 {
            ball_vy_fp = 0 - ball_vy_fp
            play_sound(2)
        }
    }

    let net_left:int = NET_X - NET_HALF_W
    let net_right:int = NET_X + NET_HALF_W
    let net_top:int = GROUND_Y - NET_H
    if (ball_x + BALL_R) >=? net_left {
        if (ball_x - BALL_R) <=? net_right {
            if (ball_y + BALL_R) >=? net_top {
                if (ball_y - BALL_R) <=? GROUND_Y {
                    if (ball_prev_y + BALL_R) <=? net_top {
                        ball_y_fp = to_fp(net_top - BALL_R)
                        ball_y = net_top - BALL_R
                        if ball_vy_fp >? 0 {
                            ball_vy_fp = 0 - ball_vy_fp
                        }
                    } else {
                        if ball_x <? NET_X {
                            ball_x = net_left - BALL_R
                            if ball_vx >? 0 {
                                ball_vx = 0 - ball_vx
                            }
                        } else {
                            ball_x = net_right + BALL_R
                            if ball_vx <? 0 {
                                ball_vx = 0 - ball_vx
                            }
                        }
                    }
                    impact_timer = 3
                    play_sound(2)
                }
            }
        }
    }

    if collide_ball_with_slime(left_x left_y (left_move_dir * 2)) {
        return 0
    }
    if collide_ball_with_slime(right_x right_y (right_move_dir * 2)) {
        return 0
    }

    if (ball_y + BALL_R) >=? GROUND_Y {
        if ball_x <? NET_X {
            award_point(1)
        } else {
            award_point(0)
        }
        return 0
    }
    return 0
}

let update_title = ():>int => {
    if key_pressed(key_w) or key_pressed(key_up) {
        menu_row = menu_row - 1
        if menu_row <? MENU_MODE {
            menu_row = MENU_PACE
        }
    }
    if key_pressed(key_s) or key_pressed(key_down_code) {
        menu_row = menu_row + 1
        if menu_row >? MENU_PACE {
            menu_row = MENU_MODE
        }
    }
    if menu_row =? MENU_MODE {
        if key_pressed(key_a) or key_pressed(key_left) {
            selected_mode = MODE_CPU
        }
        if key_pressed(key_d) or key_pressed(key_right) {
            selected_mode = MODE_TWO_PLAYER
        }
    }
    if menu_row =? MENU_STAGE {
        if key_pressed(key_a) or key_pressed(key_left) {
            selected_stage = selected_stage - 1
            if selected_stage <? STAGE_EARTH {
                selected_stage = STAGE_STATION
            }
        }
        if key_pressed(key_d) or key_pressed(key_right) {
            selected_stage = selected_stage + 1
            if selected_stage >? STAGE_STATION {
                selected_stage = STAGE_EARTH
            }
        }
    }
    if menu_row =? MENU_PACE {
        if key_pressed(key_a) or key_pressed(key_left) {
            selected_pace = selected_pace - 1
            if selected_pace <? PACE_FULL {
                selected_pace = PACE_SLOW
            }
        }
        if key_pressed(key_d) or key_pressed(key_right) {
            selected_pace = selected_pace + 1
            if selected_pace >? PACE_SLOW {
                selected_pace = PACE_FULL
            }
        }
    }
    if key_pressed(key_space) or key_pressed(key_enter) {
        start_match(selected_mode)
    }
    return 0
}

let update_serve = ():>int => {
    if serve_side =? 0 {
        ball_x = left_x
    } else {
        ball_x = right_x
    }
    ball_y = GROUND_Y - SLIME_R - BALL_R - 4
    ball_y_fp = to_fp(ball_y)

    serve_timer = serve_timer - 1
    if serve_timer <=? 0 {
        game_state = STATE_PLAY
        ball_vy_fp = 0 - SERVE_BALL_VY_FP
        if serve_side =? 0 {
            ball_vx = 3
        } else {
            ball_vx = 0 - 3
        }
        play_sound(1)
    }
    return 0
}

let update_match = ():>int => {
    update_left_player()
    if player_mode =? MODE_CPU {
        update_right_ai()
    } else {
        update_right_player()
    }
    update_ball()
    return 0
}

let run_match_steps = ():>int => {
    sim_rate_accum = sim_rate_accum + sim_rate_num
    loop sim_rate_accum >=? sim_rate_den {
        sim_rate_accum = sim_rate_accum - sim_rate_den
        if game_state =? STATE_SERVE {
            update_serve()
        }
        if game_state =? STATE_PLAY {
            update_match()
        }
    }
    return 0
}

let draw_background = (stage:int):>int => {
    if stage =? STAGE_MOON {
        fill_rect(0 0 WIDTH GROUND_Y 20 22 42)
        fill_rect(0 GROUND_Y WIDTH (HEIGHT - GROUND_Y) 148 148 160)
        fill_rect(0 (GROUND_Y - 4) WIDTH 4 188 188 196)
        fill_rect(26 22 2 2 255 255 255)
        fill_rect(82 44 2 2 255 255 255)
        fill_rect(140 26 2 2 255 255 255)
        fill_rect(210 38 2 2 255 255 255)
        fill_rect(284 18 2 2 255 255 255)
        fill_circle(258 42 14 226 226 214)
    } else if stage =? STAGE_MARS {
        fill_rect(0 0 WIDTH GROUND_Y 196 116 88)
        fill_rect(0 GROUND_Y WIDTH (HEIGHT - GROUND_Y) 176 92 70)
        fill_rect(0 (GROUND_Y - 4) WIDTH 4 226 156 124)
        fill_circle(46 34 16 255 228 162)
        fill_rect(208 30 20 2 255 194 164)
        fill_rect(220 42 28 2 255 194 164)
    } else if stage =? STAGE_JUPITER {
        fill_rect(0 0 WIDTH GROUND_Y 214 176 124)
        fill_rect(0 30 WIDTH 16 196 132 82)
        fill_rect(0 62 WIDTH 14 228 206 154)
        fill_rect(0 94 WIDTH 16 182 118 72)
        fill_rect(0 GROUND_Y WIDTH (HEIGHT - GROUND_Y) 196 144 104)
        fill_rect(0 (GROUND_Y - 4) WIDTH 4 236 214 172)
        fill_rect(234 82 24 10 210 126 90)
    } else if stage =? STAGE_STATION {
        fill_rect(0 0 WIDTH GROUND_Y 10 12 18)
        fill_rect(0 GROUND_Y WIDTH (HEIGHT - GROUND_Y) 120 128 140)
        fill_rect(0 (GROUND_Y - 4) WIDTH 4 176 184 196)
        fill_rect(18 16 2 2 255 255 255)
        fill_rect(64 40 2 2 255 255 255)
        fill_rect(118 22 2 2 255 255 255)
        fill_rect(192 34 2 2 255 255 255)
        fill_rect(274 20 2 2 255 255 255)
        fill_rect(236 48 34 8 176 184 196)
        fill_rect(248 40 10 24 176 184 196)
    } else {
        fill_rect(0 0 WIDTH GROUND_Y 92 198 255)
        fill_rect(0 GROUND_Y WIDTH (HEIGHT - GROUND_Y) 212 196 126)
        fill_rect(0 (GROUND_Y - 4) WIDTH 4 230 220 160)
        fill_circle(258 34 14 255 238 120)
    }
    fill_rect((NET_X - NET_HALF_W) (GROUND_Y - NET_H) (NET_HALF_W * 2) NET_H 236 236 236)
    fill_rect((NET_X - NET_HALF_W - 1) (GROUND_Y - NET_H) 1 NET_H 20 30 40)
    fill_rect((NET_X + NET_HALF_W) (GROUND_Y - NET_H) 1 NET_H 20 30 40)
    return 0
}

let draw_ball_shadow = ():>int => {
    let shadow_w:int = 8 + ((GROUND_Y - ball_y) // 12)
    if shadow_w <? 6 {
        shadow_w = 6
    }
    fill_rect((ball_x - (shadow_w // 2)) (GROUND_Y - 3) shadow_w 2 120 106 72)
    return 0
}

let draw_match_scene = ():>int => {
    draw_background(current_stage)

    if point_flash_timer >? 0 {
        fill_rect(0 0 WIDTH 10 255 255 255)
        point_flash_timer = point_flash_timer - 1
    }

    draw_ball_shadow()
    fill_circle(ball_x ball_y BALL_R 250 250 250)
    if impact_timer >? 0 {
        fill_circle(ball_x ball_y (BALL_R + impact_timer + 1) 255 228 96)
        impact_timer = impact_timer - 1
    }

    let left_eye_dir:int = 0
    let right_eye_dir:int = 0
    if ball_x <? left_x {
        left_eye_dir = 0 - 1
    }
    if ball_x >? left_x {
        left_eye_dir = 1
    }
    if ball_x <? right_x {
        right_eye_dir = 0 - 1
    }
    if ball_x >? right_x {
        right_eye_dir = 1
    }
    fill_slime(left_x left_y SLIME_R 78 188 106 left_eye_dir)
    fill_slime(right_x right_y SLIME_R 252 112 106 right_eye_dir)

    draw_digit(left_score 118 14 4 255 255 255)
    draw_digit(right_score 190 14 4 255 255 255)
    return 0
}

let draw_title = ():>int => {
    draw_background(selected_stage)
    let t:int = __frame_time__() // 6
    let preview_x:int = (WIDTH // 2) + (sin256(t) // 12)
    let preview_y:int = 84 + (sin256((t * 2)) // 28)
    fill_slime(88 GROUND_Y SLIME_R 78 188 106 1)
    fill_slime(232 GROUND_Y SLIME_R 252 112 106 (0 - 1))
    fill_circle(preview_x preview_y BALL_R 250 250 250)

    draw_text_center(text_title_1 18 6 255 255 255)
    draw_text_center(text_title_2 52 5 24 56 92)

    draw_text(text_mode 28 104 2 255 255 255)
    if menu_row =? MENU_MODE {
        fill_rect(20 100 130 22 255 255 255)
        draw_text(text_mode 28 104 2 24 56 92)
    }
    if selected_mode =? MODE_CPU {
        fill_rect(162 100 86 20 255 255 255)
        draw_text(text_menu_1 172 105 3 24 56 92)
        draw_text(text_menu_2 268 105 3 255 255 255)
    } else {
        draw_text(text_menu_1 172 105 3 255 255 255)
        fill_rect(260 100 28 20 255 255 255)
        draw_text(text_menu_2 268 105 3 24 56 92)
    }

    draw_text(text_stage 24 130 2 255 255 255)
    if menu_row =? MENU_STAGE {
        fill_rect(20 126 130 22 255 255 255)
        draw_text(text_stage 24 130 2 24 56 92)
    }
    fill_rect(156 126 150 20 255 255 255)
    draw_text_right(stage_name(selected_stage) 300 131 3 24 56 92)

    draw_text(text_pace 32 156 2 255 255 255)
    if menu_row =? MENU_PACE {
        fill_rect(20 152 130 22 255 255 255)
        draw_text(text_pace 32 156 2 24 56 92)
    }
    if selected_pace =? PACE_FULL {
        fill_rect(160 152 58 20 255 255 255)
        draw_text(text_pace_full 166 157 2 24 56 92)
        draw_text(text_pace_calm 226 157 2 255 255 255)
        draw_text(text_pace_slow 278 157 2 255 255 255)
    } else if selected_pace =? PACE_CALM {
        draw_text(text_pace_full 166 157 2 255 255 255)
        fill_rect(220 152 50 20 255 255 255)
        draw_text(text_pace_calm 226 157 2 24 56 92)
        draw_text(text_pace_slow 278 157 2 255 255 255)
    } else {
        draw_text(text_pace_full 166 157 2 255 255 255)
        draw_text(text_pace_calm 226 157 2 255 255 255)
        fill_rect(272 152 48 20 255 255 255)
        draw_text(text_pace_slow 278 157 2 24 56 92)
    }

    if ((__frame_count__() // 24) % 2) =? 0 {
        draw_text_center(text_start 172 1 255 255 255)
    }
    return 0
}

let draw_game_over = ():>int => {
    draw_match_scene()
    fill_rect(44 40 232 68 24 56 92)
    fill_rect(48 44 224 60 255 255 255)
    if winner_side =? 0 {
        draw_text_center(text_left_wins 54 4 24 56 92)
    } else if player_mode =? MODE_CPU {
        draw_text_center(text_cpu_wins 54 4 24 56 92)
    } else {
        draw_text_center(text_right_wins 54 4 24 56 92)
    }
    draw_text_center(text_play_again 84 3 24 56 92)
    return 0
}

let return_to_menu = ():>int => {
    game_state = STATE_TITLE
    selected_mode = player_mode
    selected_stage = current_stage
    selected_pace = current_pace
    menu_row = MENU_MODE
    left_jump_buffer = 0
    right_jump_buffer = 0
    return 0
}

let update_game_over = ():>int => {
    if key_pressed(key_space) or key_pressed(key_enter) {
        return_to_menu()
    }
    return 0
}

let main = ():>int => {
    if initialized =? 0 {
        canvas_buf = __canvas_init__(WIDTH HEIGHT)
        audio_buf = __audio_init__(22050 1024 1)
        set_round_positions()
        initialized = 1
    }

    sample_input_buffers()

    if game_state not=? STATE_TITLE {
        if key_pressed(key_escape) {
            return_to_menu()
        }
    }

    if game_state =? STATE_TITLE {
        update_title()
        draw_title()
    }
    if game_state =? STATE_SERVE {
        run_match_steps()
        draw_match_scene()
    }
    if game_state =? STATE_PLAY {
        run_match_steps()
        draw_match_scene()
    }
    if game_state =? STATE_GAME_OVER {
        update_game_over()
        draw_game_over()
    }

    decay_input_buffers()
    __canvas_present__()
    return 0
}
