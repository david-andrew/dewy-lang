import p"../../third_party/sdl/sdl.udewy"

# ============================================================================
# uZero shared core: stable primitives used by every stage.
#   - Float bit constants for the GL boundary
# - Q16 fixed-point arithmetic
# - 1024-units-per-turn sin / cos
# - vec3 helpers
# - Q16 -> f32 / f64 bit-pattern conversion
# - world_v3: emit a GL vertex from Q16 world coordinates
# 1 Q16 unit = 1 m, FP_ONE = 65536. 1 angle-unit = 360/1024 deg.
# ============================================================================

# ---------- Float bit constants ----------------------------------------------

const F32_ZERO:int = 0
const F32_ONE:int = 0x3f800000
const F32_NEG_ONE:int = 0xbf800000
const F32_HALF:int = 0x3f000000

const F64_ZERO:int = 0
const F64_NEAR:int = __i64_to_f64_bits__(2)
const F64_FAR:int = __i64_to_f64_bits__(4000)

# ---------- Fixed-point ------------------------------------------------------

const FP_SHIFT:int = 16
const FP_ONE:int = 65536
const FP_HALF:int = 32768
const FP_QUARTER:int = 16384

const ANG_TURN:int = 1024
const ANG_HALF_TURN:int = 512
const ANG_QTR:int = 256
const ANG_OCTANT:int = 128
const ANG_MASK:int = 1023

# ---------- Math primitives --------------------------------------------------

let abs_i = (v:int):>int => {
    if v <? 0 {
        return 0 - v
    }
    return v
}

let clamp_i = (v:int lo:int hi:int):>int => {
    if v <? lo {
        return lo
    }
    if v >? hi {
        return hi
    }
    return v
}

let fp_mul = (a:int b:int):>int => {
    return __signed_shr__(a * b 16)
}

let fp_div = (a:int b:int):>int => {
    if b =? 0 {
        return 0
    }
    return (a << 16) // b
}

let fp_sqrt = (n:int):>int => {
    if n <=? 0 {
        return 0
    }
    let bit:int = 1
    let value:int = n
    loop value >=? 4 {
        value = value >> 2
        bit = bit << 1
    }
    let x:int = bit << 1
    let i:int = 0
    loop i <? 12 {
        if x =? 0 {
            return 0
        }
        let y:int = (x + (n // x)) >> 1
        if y >=? x {
            return x
        }
        x = y
        i += 1
    }
    return x
}

# Sin in 1024-units-per-turn, returning Q16 in [-65536, 65536].
# Bhaskara I: sin(t) ~= 16 t (pi - t) / (5 pi^2 - 4 t (pi - t)) for t in [0, pi].
# Max error ~0.16% over the full circle (vs ~6% for the parabola); produces
# unit-length basis vectors at any angle without needing renormalization.
let sin_fp = (angle:int):>int => {
    let a:int = angle % ANG_TURN
    if a <? 0 {
        a += ANG_TURN
    }
    let sign:int = 1
    if a >=? ANG_HALF_TURN {
        a -= ANG_HALF_TURN
        sign = 0 - 1
    }
    let u:int = a * (ANG_HALF_TURN - a)
    let num:int = (16 * u) * FP_ONE
    let denom:int = (5 * 262144) - (4 * u)
    return sign * (num // denom)
}

let cos_fp = (angle:int):>int => {
    return sin_fp(angle + ANG_QTR)
}

# atan2 in 1024-units-per-turn. Returns angle a in [0, ANG_TURN) such that
# cos(a) ~= x / r and sin(a) ~= y / r, where r = sqrt(x^2 + y^2). Implemented
# as a quadrant pre-classification followed by a 10-step binary search on
# sin within the quadrant (where sin is monotonic).
let atan2_fp = (y:int x:int):>int => {
    if (x =? 0) and (y =? 0) {
        return 0
    }
    let r:int = fp_sqrt((x * x) + (y * y))
    if r =? 0 {
        return 0
    }
    let cy_target:int = fp_div(y r)
    let lo:int = 0
    let hi:int = ANG_QTR
    let increasing:int = 1
    if x >=? 0 {
        if y >=? 0 {
            lo = 0
            hi = ANG_QTR
            increasing = 1
        } else {
            lo = 3 * ANG_QTR
            hi = ANG_TURN
            increasing = 1
        }
    } else {
        if y >=? 0 {
            lo = ANG_QTR
            hi = ANG_HALF_TURN
            increasing = 0
        } else {
            lo = ANG_HALF_TURN
            hi = 3 * ANG_QTR
            increasing = 0
        }
    }
    let i:int = 0
    loop i <? 10 {
        let mid:int = (lo + hi) // 2
        let s:int = sin_fp(mid)
        let go_right:int = 0
        if increasing not=? 0 {
            if cy_target >? s {
                go_right = 1
            }
        } else {
            if cy_target <? s {
                go_right = 1
            }
        }
        if go_right not=? 0 {
            lo = mid
        } else {
            hi = mid
        }
        i += 1
    }
    return (lo + hi) // 2
}

# ---------- vec3 helpers (Q16 components) ------------------------------------

let vec3_mag = (x:int y:int z:int):>int => {
    return fp_sqrt((x * x) + (y * y) + (z * z))
}

let vec3_dot = (ax:int ay:int az:int bx:int by:int bz:int):>int => {
    return fp_mul(ax bx) + fp_mul(ay by) + fp_mul(az bz)
}

# ---------- GL boundary ------------------------------------------------------

# Convert Q16 value to f32 bit pattern by adjusting the exponent.
# Equivalent to (float)val / 65536.0 but exact for all representable values.
let q16_to_f32 = (val:int):>int => {
    if val =? 0 {
        return 0
    }
    let raw:int = __i64_to_f32_bits__(val)
    return raw - (16 << 23)
}

let q16_to_f64 = (val:int):>int => {
    if val =? 0 {
        return 0
    }
    let raw:int = __i64_to_f64_bits__(val)
    return raw - (16 << 52)
}

# Emit a GL vertex from Q16 world coordinates.
let world_v3 = (x:int y:int z:int):>void => {
    GL_Vertex3f(q16_to_f32(x) q16_to_f32(y) q16_to_f32(z))
    return 0
}
