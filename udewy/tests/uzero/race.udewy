import p"./uzero_core.udewy"

# ============================================================================
# uZero Race: a complete one-race game.
#
# Title screen -> single race on a closed circuit -> results / game over.
# Player + 30 AI competitors. Boost is finite (refilled only on recharge
# strips); wall hits dock the shared meter; running into a wall at zero
# meter explodes the player and triggers game over.
#
# Controls: WASD/arrows + Q/E strafe, Space = boost (in race) or start
# (in title/results), R = restart (game over) / respawn-mid-race,
# F = toggle fps counter, Esc = quit.
# ============================================================================

const SDL_SCANCODE_E:int = 8
