# ---------- Results --------------------------------------------------------
# Sort the cars by progress (descending) and display the top 8 finishers.

const RESULTS_HEADER:int = "FINAL\0"
const RESULTS_PROMPT:int = "PRESS SPACE\0"

const RESULTS_SORTED_BYTES:int = 248
const results_sorted_idx:int = __static_alloca__(RESULTS_SORTED_BYTES)

let sort_cars_by_progress = ():>void => {
    let i:int = 0
    loop i <? MAX_CARS {
        __store__(i (results_sorted_idx + (i * 8)))
        i += 1
    }
    # Insertion sort by descending progress.
    let j:int = 1
    loop j <? MAX_CARS {
        let key:int = __load__(results_sorted_idx + (j * 8))
        let key_p:int = car_get_progress(key)
        let k:int = j - 1
        loop k >=? 0 {
            let other:int = __load__(results_sorted_idx + (k * 8))
            if car_get_progress(other) <? key_p {
                __store__(other (results_sorted_idx + ((k + 1) * 8)))
                k -= 1
            } else {
                k = -1
            }
        }
        __store__(key (results_sorted_idx + ((k + 1) * 8)))
        j += 1
    }
    return 0
}

let update_results = ():>void => {
    results_camera_frames += 1
    position_title_camera()
    if in_start not=? 0 {
        game_state = STATE_TITLE
    }
    return 0
}

let render_results = (sw:int sh:int):>void => {
    glViewport(0 0 sw sh)
    GL_ClearColor(q16_to_f32(COL_SKY_R) q16_to_f32(COL_SKY_G) q16_to_f32(COL_SKY_B) F32_ONE)
    glClear(GL_COLOR_BUFFER_BIT + GL_DEPTH_BUFFER_BIT)
    glEnable(GL_DEPTH_TEST)
    set_perspective(sw sh)
    apply_camera()
    draw_ground()
    draw_track()
    draw_walls()

    setup_2d(sw sh)
    GL_Color4f(F32_ZERO F32_ZERO F32_ZERO q16_to_f32(45875))
    glBegin(GL_QUADS)
    hud_quad(sw // 4 80 (3 * sw) // 4 sh - 80)
    glEnd()

    GL_Color4f(F32_ONE q16_to_f32(58982) q16_to_f32(13107) F32_ONE)
    glBegin(GL_QUADS)
    draw_text_centered(sw // 2 110 RESULTS_HEADER 50 80 8 12)
    glEnd()

    # Top 8 finishers: row of "RANK IDX" rendered as digits.
    let row_w:int = 22
    let row_h:int = 36
    let row_t:int = 5
    let row_gap:int = 5
    GL_Color4f(F32_ONE F32_ONE F32_ONE F32_ONE)
    glBegin(GL_QUADS)
    let rank:int = 0
    loop rank <? 8 {
        let car_idx:int = __load__(results_sorted_idx + (rank * 8))
        let row_y:int = 220 + (rank * (row_h + 14))
        # Rank digit
        draw_number_right(sw // 2 - 200 row_y rank + 1 2 row_w row_h row_t row_gap)
        # Car id
        draw_number_right(sw // 2 row_y car_idx + 1 3 row_w row_h row_t row_gap)
        # Lap count completed
        draw_number_right(sw // 2 + 200 row_y car_get_lap(car_idx) + 1 2 row_w row_h row_t row_gap)
        rank += 1
    }
    glEnd()

    if (results_camera_frames % 120) <? 80 {
        GL_Color4f(F32_ONE F32_ONE F32_ONE q16_to_f32(60293))
        glBegin(GL_QUADS)
        draw_text_centered(sw // 2 (sh - 110) RESULTS_PROMPT 18 30 4 4)
        glEnd()
    }
    teardown_2d()
    return 0
}

# ---------- Game Over ------------------------------------------------------

const GAMEOVER_TEXT:int = "GAME OVER\0"
const GAMEOVER_PROMPT:int = "PRESS R\0"

let update_gameover = ():>void => {
    game_over_frames += 1
    # Keep stepping cars so the wreck physics tumble continues.
    let i:int = 0
    loop i <? MAX_CARS {
        car_load(i)
        if i =? 0 {
            in_thrust = 0
            in_brake = 0
            in_steer_l = 0
            in_steer_r = 0
            in_strafe_l = 0
            in_strafe_r = 0
            in_boost = 0
        } else {
            ai_compute_input(i)
        }
        physics_step()
        car_store(i)
        i += 1
    }
    car_load(0)
    update_chase()
    if in_restart not=? 0 {
        reset_game()
        game_state = STATE_RACE
    }
    return 0
}

let render_gameover = (sw:int sh:int):>void => {
    glViewport(0 0 sw sh)
    GL_ClearColor(q16_to_f32(COL_SKY_R // 4) q16_to_f32(COL_SKY_G // 4) q16_to_f32(COL_SKY_B // 4) F32_ONE)
    glClear(GL_COLOR_BUFFER_BIT + GL_DEPTH_BUFFER_BIT)
    glEnable(GL_DEPTH_TEST)
    set_perspective(sw sh)
    apply_camera()
    draw_ground()
    draw_track()
    draw_walls()
    draw_all_cars()
    draw_sparks()

    setup_2d(sw sh)
    GL_Color4f(F32_ZERO F32_ZERO F32_ZERO q16_to_f32(45875))
    glBegin(GL_QUADS)
    hud_quad(0 0 sw sh)
    glEnd()
    GL_Color4f(F32_ONE q16_to_f32(13107) q16_to_f32(13107) F32_ONE)
    glBegin(GL_QUADS)
    draw_text_centered(sw // 2 (sh // 2 - 80) GAMEOVER_TEXT 50 80 8 10)
    glEnd()
    if (game_over_frames % 120) <? 80 {
        GL_Color4f(F32_ONE F32_ONE F32_ONE q16_to_f32(60293))
        glBegin(GL_QUADS)
        draw_text_centered(sw // 2 (sh // 2 + 60) GAMEOVER_PROMPT 26 42 5 6)
        glEnd()
    }
    teardown_2d()
    return 0
}

# ---------- Main loop -------------------------------------------------------

let main = ():>int => {
    SDL_SetMainReady()
    if SDL_Init(SDL_INIT_VIDEO + SDL_INIT_AUDIO) =? 0 {
        return 1
    }
    if SDL_GL_SetAttribute(SDL_GL_DOUBLEBUFFER 1) =? 0 {
        SDL_Quit()
        return 2
    }
    if SDL_GL_SetAttribute(SDL_GL_DEPTH_SIZE 24) =? 0 {
        SDL_Quit()
        return 3
    }
    if SDL_GL_SetAttribute(SDL_GL_CONTEXT_MAJOR_VERSION 2) =? 0 {
        SDL_Quit()
        return 4
    }
    if SDL_GL_SetAttribute(SDL_GL_CONTEXT_MINOR_VERSION 1) =? 0 {
        SDL_Quit()
        return 5
    }
    if SDL_GL_SetAttribute(SDL_GL_CONTEXT_PROFILE_MASK SDL_GL_CONTEXT_PROFILE_COMPATIBILITY) =? 0 {
        SDL_Quit()
        return 6
    }

    let title:int = "uZero Race\0"
    let window:int = SDL_CreateWindow(title 1280 720 SDL_WINDOW_OPENGL + SDL_WINDOW_RESIZABLE)
    if window =? 0 {
        SDL_Quit()
        return 7
    }
    SDL_SetWindowIconFromUdewyData(window SDL_DEFAULT_WINDOW_ICON_DATA)

    let gl_context:int = SDL_GL_CreateContext(window)
    if gl_context =? 0 {
        SDL_DestroyWindow(window)
        SDL_Quit()
        return 8
    }
    if SDL_GL_MakeCurrent(window gl_context) =? 0 {
        SDL_GL_DestroyContext(gl_context)
        SDL_DestroyWindow(window)
        SDL_Quit()
        return 9
    }
    SDL_GL_SetSwapInterval(1)

    let event:int = __static_alloca__(SDL_EVENT_SIZE)
    let size:int = __static_alloca__(8)

    glEnable(GL_DEPTH_TEST)
    glDepthFunc(GL_LEQUAL)
    glDisable(GL_CULL_FACE)
    init_checker_textures()
    build_track()
    init_cars()
    speed_lines_init()
    audio_init()
    fps_last_ticks = SDL_GetTicks()

    loop running not=? 0 {
        let has_event:int = SDL_PollEvent(event)
        loop has_event not=? 0 {
            if SDL_EventType(event) =? SDL_EVENT_QUIT {
                running = 0
            }
            has_event = SDL_PollEvent(event)
        }

        let keyboard:int = SDL_GetKeyboardState(0)
        # Edge inputs (toggles + start + restart). Per-car physics will
        # reuse the keyboard for car 0.
        update_input(keyboard)
        if in_quit not=? 0 {
            running = 0
        }
        if in_fps_toggle not=? 0 {
            show_fps = 1 - show_fps
        }

        SDL_GetWindowSizeInPixels(window size size + 4)
        let sw:int = __load_u32__(size)
        let sh:int = __load_u32__(size + 4)

        if game_state =? STATE_TITLE {
            update_title()
            audio_step(FP_ONE 0)
            render_title(sw sh)
        } else {
            if game_state =? STATE_RACE {
                step_all_cars(keyboard)
                spark_step()
                recompute_player_position()
                # Race-end check: 3 laps wins, explosion ends.
                if pending_explode_player not=? 0 {
                    game_state = STATE_GAMEOVER
                    sfx_play(SFX_KIND_EXPLODE FP_ONE)
                }
                if car_get_lap(0) >=? TOTAL_LAPS {
                    sort_cars_by_progress()
                    game_state = STATE_RESULTS
                }
                audio_step(32768 49152)        # 0.5 music, 0.75 engine
                render_race(sw sh)
            } else {
                if game_state =? STATE_RESULTS {
                    update_results()
                    audio_step(FP_ONE 0)
                    render_results(sw sh)
                } else {
                    update_gameover()
                    audio_step(26214 13107)
                    render_gameover(sw sh)
                }
            }
        }

        SDL_GL_SwapWindow(window)
        SDL_Delay(16)
        frame_count += 1

        fps_sample_count += 1
        if fps_sample_count >=? HUD_FPS_SAMPLE_FRAMES {
            let now_ticks:int = SDL_GetTicks()
            let elapsed_ms:int = now_ticks - fps_last_ticks
            if elapsed_ms >? 0 {
                fps_value = (fps_sample_count * 1000) // elapsed_ms
            }
            fps_last_ticks = now_ticks
            fps_sample_count = 0
        }
    }

    SDL_GL_DestroyContext(gl_context)
    SDL_DestroyWindow(window)
    SDL_Quit()
    return 0
}
