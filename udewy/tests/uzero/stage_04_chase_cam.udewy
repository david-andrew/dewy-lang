import p"./uzero_core.udewy"

# ============================================================================
# uZero Stage 04: smoothed chase camera with FOV punch and bank follow.
#
# Same flat-plane physics as stage 03. The only thing being judged here is
# camera + visual feel:
#   - camera position lerps toward the rigid follow point
#   - camera yaw lerps toward craft yaw (high-precision Q16 angle store)
#   - craft banks visually into the turn (roll about its forward axis)
#   - FOV widens with forward speed (fish-eye sense of acceleration)
#
# Controls: WASD/arrows + Q/E strafe, Space = boost, R = respawn, Esc = quit.
#
# Sign-off goal: yanking turns at top speed makes the craft drift across the
# screen, banking into the corner, while the world widens out around it. When
# you stop steering, everything settles back to centred.
# ============================================================================

# ---------- SDL scancodes ----------------------------------------------------

const SDL_SCANCODE_E:int = 8
const SDL_SCANCODE_Q:int = 20
const SDL_SCANCODE_R:int = 21

# ---------- Physics (identical to stage 03) ---------------------------------

const HOVER_HEIGHT_FLAT:int = 98304
const TOP_SPEED:int = 163840
const BOOST_BONUS:int = 65536
const THRUST_ACCEL:int = 1638
const BRAKE_DECEL:int = 3277
const BOOST_THRUST_MULT:int = 196608
const STRAFE_RATE:int = 32768

const STEER_BASE:int = 12
const STEER_MIN:int = 8

const LATERAL_GRIP:int = 9830
const DRAG_COAST:int = 100
const DRAG_THRUST:int = 327

const HEADING_CAP_SPEED:int = 6553

# ---------- Camera tunables --------------------------------------------------

const CAM_BACK:int = 983040              # 15 m behind (along smoothed fwd)
const CAM_LIFT:int = 262144              # 4 m up
const CAM_LOOK_LIFT:int = 65536          # 1 m above craft for look point
const CAM_PITCH_UNITS:int = -28          # ~-9.8 deg

# Position smoothing: cam_pos += (target - cam_pos) * POS_ALPHA each frame.
# 0.18 -> ~6-frame effective lag.
const POS_ALPHA:int = 11796              # 0.18

# Yaw smoothing: similar but on the angle. 0.12 -> ~9-frame lag, so the
# craft visibly drifts sideways before the camera catches up.
const YAW_ALPHA:int = 7864               # 0.12

# Bank: bank_target = clamp(yaw_rate * BANK_GAIN * speed_norm, +- BANK_MAX).
# Yaw_rate is in raw angle units / frame (typically 0..12). Output is also
# raw angle units (1024 = 360 deg). BANK_MAX = 50 -> ~17.6 deg max lean.
const BANK_GAIN:int = 6
const BANK_MAX:int = 50
const BANK_ALPHA:int = 13107             # 0.20 -> ~5-frame catch-up

# FOV punch: top_q16 = near * (1 + speed_norm * FOV_PUNCH). 0.4 widens half-
# angle from 45 deg (tan = 1) to ~54 deg (tan = 1.4) at top boosted speed.
const FOV_PUNCH:int = 26214              # 0.40

# ---------- Ground -----------------------------------------------------------

const TILE_SIZE:int = 655360
const HALF_TILES:int = 80
const GROUND_Y:int = 0

const COL_TILE_A_R:int = 8519
const COL_TILE_A_G:int = 11796
const COL_TILE_A_B:int = 16384
const COL_TILE_B_R:int = 13107
const COL_TILE_B_G:int = 19660
const COL_TILE_B_B:int = 26214

const COL_SKY_R:int = 2621
const COL_SKY_G:int = 3932
const COL_SKY_B:int = 8192

# ---------- Globals ----------------------------------------------------------

let running:int = 1
let frame_count:int = 0

let cx:int = 0
let cy:int = 98304
let cz:int = 0
let cvx:int = 0
let cvz:int = 0
let cyaw:int = 0
let prev_cyaw:int = 0                    # previous-frame yaw, for yaw_rate

# Physics basis (yaw only, no roll). Used by physics + as input to visual.
let fx:int = 0
let fy:int = 0
let fz:int = -65536

# Visual basis (includes bank roll). Used by craft_emit only.
let vrx:int = 65536
let vry:int = 0
let vrz:int = 0
let vux:int = 0
let vuy:int = 65536
let vuz:int = 0

# Camera state. chase_yaw_q is yaw in Q16-scaled angle units (i.e. units *
# FP_ONE) so per-frame fractional updates don't get truncated.
let chase_yaw_q:int = 0
let cam_x:int = 0
let cam_y:int = 262144
let cam_z:int = 983040
let bank:int = 0                         # current visual roll, raw angle units
let cur_fov_top_q16:int = 131072         # 2.0 m, base half-frustum top

# ---------- Input ------------------------------------------------------------

let in_thrust:int = 0
let in_brake:int = 0
let in_steer_l:int = 0
let in_steer_r:int = 0
let in_strafe_l:int = 0
let in_strafe_r:int = 0
let in_boost:int = 0
let in_respawn:int = 0
let in_respawn_prev:int = 0
let in_quit:int = 0

let update_input = (keyboard:int):>void => {
    in_thrust = SDL_ScancodeDown(keyboard SDL_SCANCODE_W) or SDL_ScancodeDown(keyboard SDL_SCANCODE_UP)
    in_brake = SDL_ScancodeDown(keyboard SDL_SCANCODE_S) or SDL_ScancodeDown(keyboard SDL_SCANCODE_DOWN)
    in_steer_l = SDL_ScancodeDown(keyboard SDL_SCANCODE_A) or SDL_ScancodeDown(keyboard SDL_SCANCODE_LEFT)
    in_steer_r = SDL_ScancodeDown(keyboard SDL_SCANCODE_D) or SDL_ScancodeDown(keyboard SDL_SCANCODE_RIGHT)
    in_strafe_l = SDL_ScancodeDown(keyboard SDL_SCANCODE_Q)
    in_strafe_r = SDL_ScancodeDown(keyboard SDL_SCANCODE_E)
    in_boost = SDL_ScancodeDown(keyboard SDL_SCANCODE_SPACE)
    let r_now:int = SDL_ScancodeDown(keyboard SDL_SCANCODE_R)
    in_respawn = (r_now not=? 0) and (in_respawn_prev =? 0)
    in_respawn_prev = r_now
    in_quit = SDL_ScancodeDown(keyboard SDL_SCANCODE_ESCAPE)
    return 0
}

# ---------- Physics step (copy of stage 03) ---------------------------------

let reset_craft = ():>void => {
    cx = 0
    cy = HOVER_HEIGHT_FLAT
    cz = 0
    cvx = 0
    cvz = 0
    cyaw = 0
    prev_cyaw = 0
    chase_yaw_q = 0
    cam_x = 0
    cam_y = HOVER_HEIGHT_FLAT + CAM_LIFT
    cam_z = CAM_BACK
    bank = 0
    return 0
}

let physics_step = ():>void => {
    prev_cyaw = cyaw

    let speed:int = fp_sqrt((cvx * cvx) + (cvz * cvz))
    let speed_norm:int = 0
    if TOP_SPEED >? 0 {
        speed_norm = (speed << 16) // (TOP_SPEED + 1)
    }
    if speed_norm >? FP_ONE {
        speed_norm = FP_ONE
    }
    if speed_norm <? 0 {
        speed_norm = 0
    }

    let steer_in:int = 0
    if in_steer_l not=? 0 {
        steer_in -= 1
    }
    if in_steer_r not=? 0 {
        steer_in += 1
    }
    let steer_rate:int = STEER_BASE - fp_mul((STEER_BASE - STEER_MIN) speed_norm)
    let proposed_yaw:int = cyaw + (steer_in * steer_rate)
    proposed_yaw = proposed_yaw % ANG_TURN
    if proposed_yaw <? 0 {
        proposed_yaw += ANG_TURN
    }

    let prop_fx:int = sin_fp(proposed_yaw)
    let prop_fz:int = 0 - cos_fp(proposed_yaw)

    let accept:int = 1
    if speed >? HEADING_CAP_SPEED {
        let prop_dot:int = fp_mul(prop_fx cvx) + fp_mul(prop_fz cvz)
        if prop_dot <? 0 {
            accept = 0
        }
    }
    if accept not=? 0 {
        cyaw = proposed_yaw
        fx = prop_fx
        fz = prop_fz
    }
    fy = 0

    let thrust:int = 0
    let thrust_active:int = 0
    if in_thrust not=? 0 {
        thrust = THRUST_ACCEL
        thrust_active = 1
        if in_boost not=? 0 {
            thrust = fp_mul(THRUST_ACCEL BOOST_THRUST_MULT)
        }
    }
    if thrust not=? 0 {
        cvx += fp_mul(fx thrust)
        cvz += fp_mul(fz thrust)
    }

    if in_brake not=? 0 {
        let fwd_speed:int = fp_mul(cvx fx) + fp_mul(cvz fz)
        if fwd_speed >? 0 {
            let brake:int = BRAKE_DECEL
            if brake >? fwd_speed {
                brake = fwd_speed
            }
            cvx -= fp_mul(fx brake)
            cvz -= fp_mul(fz brake)
        }
    }

    let strafe:int = 0
    if in_strafe_l not=? 0 {
        strafe -= STRAFE_RATE
    }
    if in_strafe_r not=? 0 {
        strafe += STRAFE_RATE
    }
    if strafe not=? 0 {
        # right (no roll) = (-fz, 0, fx)
        cx += fp_mul(0 - fz strafe)
        cz += fp_mul(fx strafe)
    }

    # Lateral grip
    let rx0:int = 0 - fz
    let rz0:int = fx
    let side_dot:int = fp_mul(cvx rx0) + fp_mul(cvz rz0)
    let side_kill:int = fp_mul(side_dot LATERAL_GRIP)
    cvx -= fp_mul(rx0 side_kill)
    cvz -= fp_mul(rz0 side_kill)

    let drag:int = DRAG_COAST
    if thrust_active not=? 0 {
        drag = DRAG_THRUST
    }
    let fwd_dot:int = fp_mul(cvx fx) + fp_mul(cvz fz)
    let drag_force:int = fp_mul(fwd_dot drag)
    cvx -= fp_mul(fx drag_force)
    cvz -= fp_mul(fz drag_force)

    let max_speed:int = TOP_SPEED
    if in_boost not=? 0 {
        max_speed = TOP_SPEED + BOOST_BONUS
    }
    let cur_speed:int = fp_sqrt((cvx * cvx) + (cvz * cvz))
    if cur_speed >? max_speed {
        cvx = fp_div(fp_mul(cvx max_speed) cur_speed)
        cvz = fp_div(fp_mul(cvz max_speed) cur_speed)
    }

    cx += cvx
    cz += cvz

    if in_respawn not=? 0 {
        reset_craft()
    }
    return 0
}

# ---------- Smoothed camera + visual basis -----------------------------------

let update_chase = ():>void => {
    # Speed used for FOV / bank scaling. Allow >1 with boost.
    let speed:int = fp_sqrt((cvx * cvx) + (cvz * cvz))
    let sn_full:int = 0
    if TOP_SPEED >? 0 {
        sn_full = (speed << 16) // TOP_SPEED
    }
    let sn_clamp:int = sn_full
    if sn_clamp >? FP_ONE {
        sn_clamp = FP_ONE
    }

    # Wrap-aware yaw lerp at Q16 precision.
    let cyaw_q:int = cyaw << FP_SHIFT
    let half_q:int = ANG_HALF_TURN << FP_SHIFT
    let turn_q:int = ANG_TURN << FP_SHIFT
    let dy_q:int = cyaw_q - chase_yaw_q
    if dy_q >? half_q {
        dy_q -= turn_q
    }
    if dy_q <? (0 - half_q) {
        dy_q += turn_q
    }
    chase_yaw_q += fp_mul(dy_q YAW_ALPHA)
    chase_yaw_q = chase_yaw_q % turn_q
    if chase_yaw_q <? 0 {
        chase_yaw_q += turn_q
    }
    let chase_yaw:int = __signed_shr__(chase_yaw_q FP_SHIFT)
    let chase_fx:int = sin_fp(chase_yaw)
    let chase_fz:int = 0 - cos_fp(chase_yaw)

    # Position lerp.
    let target_x:int = cx - fp_mul(chase_fx CAM_BACK)
    let target_y:int = cy + CAM_LIFT
    let target_z:int = cz - fp_mul(chase_fz CAM_BACK)
    cam_x += fp_mul(target_x - cam_x POS_ALPHA)
    cam_y += fp_mul(target_y - cam_y POS_ALPHA)
    cam_z += fp_mul(target_z - cam_z POS_ALPHA)

    # FOV punch.
    let scale:int = FP_ONE + fp_mul(sn_clamp FOV_PUNCH)
    cur_fov_top_q16 = fp_mul(131072 scale)

    # Bank: yaw_rate this frame in raw angle units, wrap-aware.
    let dyaw:int = cyaw - prev_cyaw
    if dyaw >? ANG_HALF_TURN {
        dyaw -= ANG_TURN
    }
    if dyaw <? (0 - ANG_HALF_TURN) {
        dyaw += ANG_TURN
    }
    let bank_target:int = fp_mul((dyaw * BANK_GAIN) sn_clamp)
    if bank_target >? BANK_MAX {
        bank_target = BANK_MAX
    }
    if bank_target <? (0 - BANK_MAX) {
        bank_target = 0 - BANK_MAX
    }
    bank += fp_mul(bank_target - bank BANK_ALPHA)

    # Build visual basis with roll.
    let cos_r:int = cos_fp(bank)
    let sin_r:int = sin_fp(bank)
    let R0x:int = 0 - fz
    let R0z:int = fx
    # new_R = R*cos_r - U*sin_r ; new_U = U*cos_r + R*sin_r ; F unchanged
    vrx = fp_mul(R0x cos_r)
    vry = 0 - sin_r
    vrz = fp_mul(R0z cos_r)
    vux = fp_mul(R0x sin_r)
    vuy = cos_r
    vuz = fp_mul(R0z sin_r)
    return 0
}

# ---------- Rendering -------------------------------------------------------

let set_perspective = (screen_w:int screen_h:int):>void => {
    glMatrixMode(GL_PROJECTION)
    glLoadIdentity()
    let aspect_q16:int = (screen_w << 16) // screen_h
    let near_q16:int = 2 * FP_ONE
    let top_q16:int = cur_fov_top_q16
    let right_q16:int = fp_mul(top_q16 aspect_q16)
    GL_Frustum(q16_to_f64(0 - right_q16) q16_to_f64(right_q16) q16_to_f64(0 - top_q16) q16_to_f64(top_q16) F64_NEAR F64_FAR)
    glMatrixMode(GL_MODELVIEW)
    glLoadIdentity()
    return 0
}

let apply_camera = ():>void => {
    let chase_yaw:int = __signed_shr__(chase_yaw_q FP_SHIFT)
    let yaw_deg:int = (chase_yaw * 360) // ANG_TURN
    let pitch_deg:int = (CAM_PITCH_UNITS * 360) // ANG_TURN
    GL_Rotatef(__i64_to_f32_bits__(0 - pitch_deg) F32_ONE F32_ZERO F32_ZERO)
    GL_Rotatef(__i64_to_f32_bits__(yaw_deg) F32_ZERO F32_ONE F32_ZERO)
    GL_Translatef(q16_to_f32(0 - cam_x) q16_to_f32(0 - cam_y) q16_to_f32(0 - cam_z))
    return 0
}

let draw_ground = ():>void => {
    let i:int = 0 - HALF_TILES
    loop i <? HALF_TILES {
        let j:int = 0 - HALF_TILES
        loop j <? HALF_TILES {
            let x0:int = i * TILE_SIZE
            let x1:int = (i + 1) * TILE_SIZE
            let z0:int = j * TILE_SIZE
            let z1:int = (j + 1) * TILE_SIZE
            let dark:int = (i + j) and 1
            let r:int = COL_TILE_A_R
            let g:int = COL_TILE_A_G
            let b:int = COL_TILE_A_B
            if dark =? 0 {
                r = COL_TILE_B_R
                g = COL_TILE_B_G
                b = COL_TILE_B_B
            }
            glBegin(GL_QUADS)
            GL_Color3f(q16_to_f32(r) q16_to_f32(g) q16_to_f32(b))
            world_v3(x0 GROUND_Y z0)
            world_v3(x1 GROUND_Y z0)
            world_v3(x1 GROUND_Y z1)
            world_v3(x0 GROUND_Y z1)
            glEnd()
            j += 1
        }
        i += 1
    }
    return 0
}

let craft_emit = (lx:int ly:int lz:int):>void => {
    let wx:int = cx + fp_mul(vrx lx) + fp_mul(vux ly) + fp_mul(fx lz)
    let wy:int = cy + fp_mul(vry lx) + fp_mul(vuy ly) + fp_mul(fy lz)
    let wz:int = cz + fp_mul(vrz lx) + fp_mul(vuz ly) + fp_mul(fz lz)
    world_v3(wx wy wz)
    return 0
}

let draw_craft = ():>void => {
    let nose_z:int = 229376
    let tail_z:int = 0 - 131072
    let wing_x:int = 163840
    let body_y_top:int = 39321
    let body_y_bot:int = 0 - 13107
    let canopy_z:int = 65536
    let canopy_y:int = 78643

    let body_r:int = q16_to_f32(13107)
    let body_g:int = q16_to_f32(45875)
    let body_b:int = q16_to_f32(58982)
    let belly_r:int = q16_to_f32(6553)
    let belly_g:int = q16_to_f32(13107)
    let belly_b:int = q16_to_f32(32768)
    let side_r:int = q16_to_f32(6553)
    let side_g:int = q16_to_f32(26214)
    let side_b:int = q16_to_f32(45875)
    let canopy_r:int = q16_to_f32(58982)
    let canopy_g:int = q16_to_f32(58982)
    let canopy_b:int = F32_ONE
    let glow_r:int = F32_ONE
    let glow_g:int = q16_to_f32(45875)
    let glow_b:int = q16_to_f32(6553)

    glBegin(GL_TRIANGLES)
    GL_Color3f(body_r body_g body_b)
    craft_emit(0 body_y_top nose_z)
    craft_emit(0 - wing_x body_y_top tail_z)
    craft_emit(wing_x body_y_top tail_z)
    glEnd()
    glBegin(GL_TRIANGLES)
    GL_Color3f(belly_r belly_g belly_b)
    craft_emit(0 body_y_bot nose_z)
    craft_emit(wing_x body_y_bot tail_z)
    craft_emit(0 - wing_x body_y_bot tail_z)
    glEnd()
    glBegin(GL_TRIANGLES)
    GL_Color3f(side_r side_g side_b)
    craft_emit(0 body_y_top nose_z)
    craft_emit(0 - wing_x body_y_bot tail_z)
    craft_emit(0 - wing_x body_y_top tail_z)
    craft_emit(0 body_y_top nose_z)
    craft_emit(0 body_y_bot nose_z)
    craft_emit(0 - wing_x body_y_bot tail_z)
    glEnd()
    glBegin(GL_TRIANGLES)
    GL_Color3f(side_r side_g side_b)
    craft_emit(0 body_y_top nose_z)
    craft_emit(wing_x body_y_top tail_z)
    craft_emit(wing_x body_y_bot tail_z)
    craft_emit(0 body_y_top nose_z)
    craft_emit(wing_x body_y_bot tail_z)
    craft_emit(0 body_y_bot nose_z)
    glEnd()
    glBegin(GL_TRIANGLES)
    GL_Color3f(canopy_r canopy_g canopy_b)
    craft_emit(0 canopy_y canopy_z)
    craft_emit(0 - 26214 body_y_top 0)
    craft_emit(26214 body_y_top 0)
    glEnd()
    let glow_x:int = 65536
    let glow_y_bot:int = 0
    let glow_y_top:int = 26214
    glBegin(GL_QUADS)
    GL_Color3f(glow_r glow_g glow_b)
    craft_emit(0 - glow_x glow_y_bot tail_z)
    craft_emit(glow_x glow_y_bot tail_z)
    craft_emit(glow_x glow_y_top tail_z)
    craft_emit(0 - glow_x glow_y_top tail_z)
    glEnd()
    return 0
}

let render_scene = (sw:int sh:int):>void => {
    glViewport(0 0 sw sh)
    GL_ClearColor(q16_to_f32(COL_SKY_R) q16_to_f32(COL_SKY_G) q16_to_f32(COL_SKY_B) F32_ONE)
    glClear(GL_COLOR_BUFFER_BIT + GL_DEPTH_BUFFER_BIT)
    glEnable(GL_DEPTH_TEST)
    glDepthFunc(GL_LEQUAL)
    glDisable(GL_CULL_FACE)
    set_perspective(sw sh)
    apply_camera()
    draw_ground()
    draw_craft()
    return 0
}

# ---------- Main loop --------------------------------------------------------

let main = ():>int => {
    SDL_SetMainReady()
    if SDL_Init(SDL_INIT_VIDEO) =? 0 {
        return 1
    }
    if SDL_GL_SetAttribute(SDL_GL_DOUBLEBUFFER 1) =? 0 {
        SDL_Quit()
        return 2
    }
    if SDL_GL_SetAttribute(SDL_GL_DEPTH_SIZE 24) =? 0 {
        SDL_Quit()
        return 3
    }
    if SDL_GL_SetAttribute(SDL_GL_CONTEXT_MAJOR_VERSION 2) =? 0 {
        SDL_Quit()
        return 4
    }
    if SDL_GL_SetAttribute(SDL_GL_CONTEXT_MINOR_VERSION 1) =? 0 {
        SDL_Quit()
        return 5
    }
    if SDL_GL_SetAttribute(SDL_GL_CONTEXT_PROFILE_MASK SDL_GL_CONTEXT_PROFILE_COMPATIBILITY) =? 0 {
        SDL_Quit()
        return 6
    }

    let title:int = "uZero Stage 04: Chase Cam\0"
    let window:int = SDL_CreateWindow(title 1280 720 SDL_WINDOW_OPENGL + SDL_WINDOW_RESIZABLE)
    if window =? 0 {
        SDL_Quit()
        return 7
    }
    SDL_SetWindowIconFromUdewyData(window SDL_DEFAULT_WINDOW_ICON_DATA)

    let gl_context:int = SDL_GL_CreateContext(window)
    if gl_context =? 0 {
        SDL_DestroyWindow(window)
        SDL_Quit()
        return 8
    }
    if SDL_GL_MakeCurrent(window gl_context) =? 0 {
        SDL_GL_DestroyContext(gl_context)
        SDL_DestroyWindow(window)
        SDL_Quit()
        return 9
    }
    SDL_GL_SetSwapInterval(1)

    let event:int = __static_alloca__(SDL_EVENT_SIZE)
    let size:int = __static_alloca__(8)

    glEnable(GL_DEPTH_TEST)
    glDepthFunc(GL_LEQUAL)
    glDisable(GL_CULL_FACE)

    reset_craft()

    loop running not=? 0 {
        let has_event:int = SDL_PollEvent(event)
        loop has_event not=? 0 {
            if SDL_EventType(event) =? SDL_EVENT_QUIT {
                running = 0
            }
            has_event = SDL_PollEvent(event)
        }

        let keyboard:int = SDL_GetKeyboardState(0)
        update_input(keyboard)
        if in_quit not=? 0 {
            running = 0
        }

        physics_step()
        update_chase()

        SDL_GetWindowSizeInPixels(window size size + 4)
        render_scene(__load_u32__(size) __load_u32__(size + 4))
        SDL_GL_SwapWindow(window)
        SDL_Delay(16)
        frame_count += 1
    }

    SDL_GL_DestroyContext(gl_context)
    SDL_DestroyWindow(window)
    SDL_Quit()
    return 0
}
