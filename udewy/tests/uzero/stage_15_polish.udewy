const RAMP_HALF_W:int = 983040           # 15 m
const RAMP_TAN:int = 32768               # 0.5  (15/30)
const RAMP_SIN:int = 29314               # sin(atan(0.5)) = 0.4472
const RAMP_COS:int = 58622               # cos(atan(0.5)) = 0.8944
const RAMP_Z_SEGMENTS:int = 6            # 30 m / 5 m
const RAMP_W_SEGMENTS:int = 6            # 30 m / 5 m

