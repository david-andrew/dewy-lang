let fz:int = -65536
let rx:int = 65536
let ry:int = 0
let rz:int = 0
let ux:int = 0
let uy:int = 65536
let uz:int = 0

# Visual basis (physics basis with turn lean rolled in around fwd).
let vfx:int = 0
let vfy:int = 0
let vfz:int = -65536
let vrx:int = 65536
let vry:int = 0
let vrz:int = 0
let vux:int = 0
let vuy:int = 65536
let vuz:int = 0

# Previous-frame physics fwd, for yaw-rate measurement.
let prev_fx:int = 0
let prev_fy:int = 0
let prev_fz:int = -65536

# Current visual roll angle (raw angle units, lerped toward bank_target).
let bank:int = 0

# Speed published by update_chase for the visual layer (HUD, speed lines).
# vis_speed is the raw |cv| in Q16 m/frame; vis_speed_norm is that divided
# by TOP_SPEED, clamped to FP_ONE; vis_boost_norm is the same but allowed
# to exceed FP_ONE while boosting (capped by BOOST_BONUS overhead).
let vis_speed:int = 0
let vis_speed_norm:int = 0
let vis_boost_norm:int = 0

# Per-streak state for the speed-line animation. Each entry holds an
# independent (phase_q, angle_idx, start_r_q) triple. Initialized once at
# startup from the xorshift+ stream so every streak has its own random
# angle, origin, and lifetime offset -- no shared phase, no pinwheel.
const SPEED_LINE_STATE:int = __static_alloca__(SPEED_LINE_STATE_BYTES)

# Spark pool. Wrapping head pointer = next slot to overwrite.
const SPARK_BUF:int = __static_alloca__(SPARK_BUF_BYTES)
let spark_head:int = 0
# Tracks airborne state across frames so physics_step can detect the
# airborne -> grounded transition (i.e. landing) and trigger a spark burst.
let was_airborne:int = 1

# Engine trail ring buffer state. trail_buf is a static block of TRAIL_LEN
# samples; trail_head is the next write slot; trail_count saturates at
# TRAIL_LEN. (Functions below.)
const TRAIL_BUF:int = __static_alloca__(TRAIL_BUF_BYTES)
let trail_head:int = 0
let trail_count:int = 0

# Ground checker texture. Static 2x2 RGBA pixel block + 8-byte slot for
# the GL texture id (written by glGenTextures, only the low 32 bits used).
const GROUND_TEX_PIXELS:int = __static_alloca__(GROUND_TEX_BYTES)
const GROUND_TEX_ID_SLOT:int = __static_alloca__(8)

# Camera basis (further smoothed, used to build the view matrix).
let cam_x:int = 0
let cam_y:int = 360448                   # cy + CAM_LIFT
let cam_z:int = 983040                   # CAM_BACK
let cam_fx:int = 0
let cam_fy:int = 0
let cam_fz:int = -65536
let cam_ux:int = 0
let cam_uy:int = 65536
let cam_uz:int = 0
let cur_fov_top_q16:int = 131072

# Surface query result: 3D surface point + outward normal.
let surf_x:int = 0
let surf_y:int = 65536
let surf_z:int = 0
let surf_nx:int = 0
let surf_ny:int = 65536
let surf_nz:int = 0

# ---------- Input ------------------------------------------------------------

let in_thrust:int = 0
let in_brake:int = 0
let in_steer_l:int = 0
let in_steer_r:int = 0
let in_strafe_l:int = 0
let in_strafe_r:int = 0
let in_boost:int = 0
let in_boost_prev:int = 0
let in_respawn:int = 0
let in_respawn_prev:int = 0
let in_quit:int = 0

# Boost / shared energy bar state. energy is Q16 in [0, ENERGY_FULL];
# boost_active_frames counts down while the speed cap is lifted post-press.
let energy:int = 65536                   # start full
let boost_active_frames:int = 0

let update_input = (keyboard:int):>void => {
    in_thrust = SDL_ScancodeDown(keyboard SDL_SCANCODE_W) or SDL_ScancodeDown(keyboard SDL_SCANCODE_UP)
    in_brake = SDL_ScancodeDown(keyboard SDL_SCANCODE_S) or SDL_ScancodeDown(keyboard SDL_SCANCODE_DOWN)
    in_steer_l = SDL_ScancodeDown(keyboard SDL_SCANCODE_A) or SDL_ScancodeDown(keyboard SDL_SCANCODE_LEFT)
    in_steer_r = SDL_ScancodeDown(keyboard SDL_SCANCODE_D) or SDL_ScancodeDown(keyboard SDL_SCANCODE_RIGHT)
    in_strafe_l = SDL_ScancodeDown(keyboard SDL_SCANCODE_Q)
    in_strafe_r = SDL_ScancodeDown(keyboard SDL_SCANCODE_E)
    in_boost = SDL_ScancodeDown(keyboard SDL_SCANCODE_SPACE)
    let r_now:int = SDL_ScancodeDown(keyboard SDL_SCANCODE_R)
    in_respawn = (r_now not=? 0) and (in_respawn_prev =? 0)
    in_respawn_prev = r_now
    in_quit = SDL_ScancodeDown(keyboard SDL_SCANCODE_ESCAPE)
    return 0
}

# ---------- Surface query ---------------------------------------------------

let surface_flat = (x:int z:int):>void => {
    surf_x = x
    surf_y = GROUND_Y
    surf_z = z
    surf_nx = 0
    surf_ny = FP_ONE
    surf_nz = 0
    return 0
}

# Each surface_* helper returns 1 if the (x, y, z) probe is on its
# obstacle (and writes surf_*), else 0 (and leaves surf_* untouched, the
# dispatcher falls through to the next or to flat ground).

let surface_ramp = (x:int y:int z:int):>int => {
    if (z <=? Z_RAMP_NEAR) and (z >=? Z_RAMP_FAR) {
        if (x >=? (0 - RAMP_HALF_W)) and (x <=? RAMP_HALF_W) {
            surf_x = x
            surf_y = fp_mul(Z_RAMP_NEAR - z RAMP_TAN)
            surf_z = z
            surf_nx = 0
            surf_ny = RAMP_COS
            surf_nz = RAMP_SIN
            return 1
        }
    }
    return 0
}

let surface_loop = (x:int y:int z:int):>int => {
    let rel_y:int = y - LOOP_YC
    let rel_z:int = z - LOOP_ZC
    let dist_to_axis:int = fp_sqrt((rel_y * rel_y) + (rel_z * rel_z))
    if (dist_to_axis <? (LOOP_R + LOOP_MARGIN)) and (dist_to_axis >? 0) {
        let phi:int = atan2_fp(0 - rel_z 0 - rel_y)
        let x_center:int = (phi * LOOP_W) // ANG_TURN
        let w:int = x - x_center
        if (w >=? (0 - LOOP_HALF_W)) and (w <=? LOOP_HALF_W) {
            let cphi:int = cos_fp(phi)
            let sphi:int = sin_fp(phi)
            surf_x = x
            surf_y = LOOP_YC - fp_mul(LOOP_R cphi)
            surf_z = LOOP_ZC - fp_mul(LOOP_R sphi)
            surf_nx = 0
            surf_ny = cphi
            surf_nz = sphi
            return 1
        }
    }
    return 0
}

let surface_hills = (x:int z:int):>int => {
    if (z <=? Z_HILL_START) and (z >=? Z_HILL_END) {
        if (x >=? (0 - HILL_HALF_W)) and (x <=? HILL_HALF_W) {
            let phase:int = ((Z_HILL_START - z) * ANG_TURN) // HILL_WAVELENGTH
            let s:int = sin_fp(phase)
            let c:int = cos_fp(phase)
            let nz_unn:int = fp_mul(HILL_SLOPE_FACTOR s)
            let m:int = fp_sqrt((FP_ONE * FP_ONE) + (nz_unn * nz_unn))
            surf_x = x
            surf_y = fp_mul(HILL_AMP_HALF FP_ONE - c)
            surf_z = z
            surf_nx = 0
            surf_ny = fp_div(FP_ONE m)
            surf_nz = fp_div(nz_unn m)
            return 1
        }
    }
    return 0
}

let surface_halfpipe = (x:int y:int z:int):>int => {
    if (z <=? Z_PIPE_START) and (z >=? Z_PIPE_END) {
        let rel_y:int = y - PIPE_R
        if rel_y <=? 0 {
            let d:int = fp_sqrt((x * x) + (rel_y * rel_y))
            if (d <=? (PIPE_R + PIPE_MARGIN)) and (d >? 1024) {
                let sth:int = fp_div(x d)
                let cth:int = fp_div(0 - rel_y d)
                surf_x = fp_mul(PIPE_R sth)
                surf_y = PIPE_R - fp_mul(PIPE_R cth)
                surf_z = z
                surf_nx = 0 - sth
                surf_ny = cth
                surf_nz = 0
                return 1
            }
        }
    }
    return 0
}

let surface_corkscrew = (x:int y:int z:int):>int => {
    if (z <=? CORK_Z_START) and (z >=? CORK_Z_END) {
        let theta:int = ((CORK_Z_START - z) * ANG_TURN) // CORK_LEN
        let cth:int = cos_fp(theta)
        let sth:int = sin_fp(theta)
        let y_centerline:int = (CORK_Y_PEAK - fp_mul(CORK_Y_PEAK cth)) // 2
        let rel_x:int = x - CORK_X_CENTER
        let rel_y:int = y - y_centerline
        # Decompose rel into the strip basis: w along the strip tangent
        # (cth, sth), perp along the strip normal (-sth, cth). The (z, w)
        # gate alone would claim any height since the strip rotates -- a
        # craft 50 m above (or beside) the strip can still project to a
        # valid w. The perp gate ensures the craft is actually near the
        # strip's surface plane before we let the magnet snap to it.
        let w:int = fp_mul(rel_x cth) + fp_mul(rel_y sth)
        let perp:int = fp_mul(rel_y cth) - fp_mul(rel_x sth)
        if (w >=? (0 - CORK_HALF_W)) and (w <=? CORK_HALF_W) and (perp >=? (0 - CORK_REACH)) and (perp <=? (HOVER_HEIGHT + CORK_REACH)) {
            surf_x = CORK_X_CENTER + fp_mul(w cth)
            surf_y = y_centerline + fp_mul(w sth)
            surf_z = z
            surf_nx = 0 - sth
            surf_ny = cth
            surf_nz = 0
            return 1
        }
    }
    return 0
}

let surface_inner_ramp = (x:int z:int):>int => {
    if (z <=? Z_INNER_NEAR) and (z >=? Z_INNER_FAR) {
        if (x >=? (0 - INNER_RAMP_HALF_W)) and (x <=? INNER_RAMP_HALF_W) {
            surf_x = x
            surf_y = fp_mul(Z_INNER_NEAR - z INNER_RAMP_TAN)
            surf_z = z
            surf_nx = 0
            surf_ny = INNER_RAMP_COS
            surf_nz = INNER_RAMP_SIN
            return 1
        }
    }
    return 0
}

let surface_outer_ramp = (x:int z:int):>int => {
    if (z <=? Z_OUTER_NEAR) and (z >=? Z_OUTER_FAR) {
        let dx:int = x - OUTER_RAMP_X_CENTER
        if (dx >=? (0 - OUTER_RAMP_HALF_W)) and (dx <=? OUTER_RAMP_HALF_W) {
            surf_x = x
            surf_y = fp_mul(Z_OUTER_NEAR - z OUTER_RAMP_TAN)
            surf_z = z
            surf_nx = 0
            surf_ny = OUTER_RAMP_COS
            surf_nz = OUTER_RAMP_SIN
            return 1
        }
    }
    return 0
}

# Sphere with a polar-cap hole on the +Z face. Closest-point-on-sphere
# (radial projection from the center) gives both inner and outer surface
# at the same direction; we pick which side based on whether the probe is
# inside or outside the shell. Inside-driving uses an inward-pointing
# normal so the hover target is at distance R - HOVER_HEIGHT from the
# center (i.e. above the inner wall); outside-driving uses outward
# normal as usual. The hole region (direction-z above SPHERE_HOLE_COS)
# returns 0 so the magnet doesn't grab inside the entry tunnel.
let surface_sphere = (x:int y:int z:int):>int => {
    let rel_x:int = x - SPHERE_CX
    let rel_y:int = y - SPHERE_CY
    let rel_z:int = z - SPHERE_CZ
    let dist_sq:int = (rel_x * rel_x) + (rel_y * rel_y) + (rel_z * rel_z)
    let dist:int = fp_sqrt(dist_sq)
    if dist <=? 0 {
        return 0
    }
    if dist >? (SPHERE_R + SPHERE_REACH) {
        return 0
    }
    if dist <? (SPHERE_R - SPHERE_REACH) {
        return 0
    }
    # Direct fp_div rather than (1/dist)*rel_x: with R=300 m, inv_d truncates
    # to only ~218 Q16 ULPs and the projected surface point jitters by several
    # metres between frames. fp_div(rel_x, dist) keeps full Q16 precision.
    let dx:int = fp_div(rel_x dist)
    let dy:int = fp_div(rel_y dist)
    let dz:int = fp_div(rel_z dist)
    if dz >? SPHERE_HOLE_COS {
        return 0
    }
    surf_x = SPHERE_CX + fp_mul(SPHERE_R dx)
    surf_y = SPHERE_CY + fp_mul(SPHERE_R dy)
    surf_z = SPHERE_CZ + fp_mul(SPHERE_R dz)
    if dist <? SPHERE_R {
        surf_nx = 0 - dx
        surf_ny = 0 - dy
        surf_nz = 0 - dz
    } else {
        surf_nx = dx
        surf_ny = dy
        surf_nz = dz
    }
    return 1
}

# Top-level dispatcher: each helper gates itself on its own (axis-aligned
# or 3D) bounds and returns 0 when the probe is outside, so the dispatcher
# just walks the list and falls through to flat ground. Order matters only
# if obstacle Z windows overlap -- they don't, by design.
let query_surface = (x:int y:int z:int):>void => {
    if surface_ramp(x y z) =? 1 { return 0 }
    if surface_loop(x y z) =? 1 { return 0 }
    if surface_hills(x z) =? 1 { return 0 }
    if surface_halfpipe(x y z) =? 1 { return 0 }
    if surface_corkscrew(x y z) =? 1 { return 0 }
    if surface_inner_ramp(x z) =? 1 { return 0 }
    if surface_outer_ramp(x z) =? 1 { return 0 }
    if surface_sphere(x y z) =? 1 { return 0 }
    surface_flat(x z)
    return 0
}

# Hard wall clamp. Active only inside the corridor Z range and below the
# wall top. Effective inner edge = CORRIDOR_HALF_W - CRAFT_HALF_W so the
# visible wings stop at the inner face. The component of cv pushing into
# the wall is zeroed; the tangent (Z) component is multiplicatively
# damped by WALL_FRICTION so a sustained scrape sheds speed instead of
# acting as a frictionless rail.
# Two-sided slab collision. Each wall is a slab with an inner face (toward
# the corridor) and an outer face (toward the rest of the world). The
# craft's center is forbidden in [inner_face - CRAFT_HALF_W,
# outer_face + CRAFT_HALF_W]. If the center has crossed into the forbidden
# zone we push it to the nearer face and zero only the inward velocity
# component. Players outside the slab + craft margin are completely
# untouched -- so driving around the corridor at any distance is fine.
let wall_collide = ():>void => {
    if (cz <=? Z_WALL_START) and (cz >=? Z_WALL_END) and (cy <? WALL_HEIGHT) {
        let touching:int = 0

        # Right wall slab: inner face at +CORRIDOR_HALF_W, outer at +CORRIDOR_HALF_W + WALL_THICKNESS.
        let r_in:int = CORRIDOR_HALF_W - CRAFT_HALF_W
        let r_out:int = CORRIDOR_HALF_W + WALL_THICKNESS + CRAFT_HALF_W
        let r_mid:int = CORRIDOR_HALF_W + (WALL_THICKNESS // 2)
        if (cx >? r_in) and (cx <? r_out) {
            if cx <? r_mid {
                cx = r_in
                if cvx >? 0 {
                    cvx = 0
                }
            } else {
                cx = r_out
                if cvx <? 0 {
                    cvx = 0
                }
            }
            touching = 1
        }

        # Left wall slab: inner face at -CORRIDOR_HALF_W, outer at -CORRIDOR_HALF_W - WALL_THICKNESS.
        let l_in:int = (0 - CORRIDOR_HALF_W) + CRAFT_HALF_W
        let l_out:int = (0 - CORRIDOR_HALF_W) - WALL_THICKNESS - CRAFT_HALF_W
        let l_mid:int = (0 - CORRIDOR_HALF_W) - (WALL_THICKNESS // 2)
        if (cx <? l_in) and (cx >? l_out) {
            if cx >? l_mid {
                cx = l_in
                if cvx <? 0 {
                    cvx = 0
                }
            } else {
                cx = l_out
                if cvx >? 0 {
                    cvx = 0
                }
            }
            touching = 1
        }

        if touching not=? 0 {
            cvz -= fp_mul(cvz WALL_FRICTION)
        }
    }
    return 0
}

# Ramp solid-wall collision. A linear-slope ramp is treated as a solid
# wedge with three blocking faces:
#   - left  side at x = xc - hw       (vertical triangle)
#   - right side at x = xc + hw       (vertical triangle)
#   - back  wall at z = z_far         (vertical rectangle, full ramp height)
# The sloped top is left to the magnet snap; the bottom rests on the ground.
# Any craft whose center sits inside the wedge's expanded forbidden zone
# (footprint widened by CRAFT_HALF_W on each face) gets pushed out the
# nearer of those three faces and the inward velocity component is zeroed.
# Used for the stage-11 ramp and both sphere-access ramps so the magnet
# can't snap a craft up onto the ramp top from the side or from behind.
let ramp_side_collide = (xc:int hw:int z_near:int z_far:int tan_q:int):>void => {
    let height:int = fp_mul(z_near - z_far tan_q)
    let r_face:int = xc + hw + CRAFT_HALF_W
    let l_face:int = xc - hw - CRAFT_HALF_W
    let z_back_face:int = z_far - CRAFT_HALF_W

    # Side walls: inside the ramp's plan footprint AND below the local
    # sloped top -> escape via the closest of {left side, right side, toe}.
    # The toe-escape case lifts cy up to surface_y (let craft ride up the
    # ramp); the side-escape cases push laterally and zero the inward x-
    # velocity. This way a craft entering from the front at low cy (the
    # normal approach) gets snapped onto the ramp top, while a craft sneaking
    # in laterally (deep in z, close to a side face) still gets punted out.
    if (cz <=? z_near) and (cz >=? z_far) {
        let surface_y:int = fp_mul(z_near - cz tan_q)
        if cy <? surface_y {
            if (cx <? r_face) and (cx >? l_face) {
                let to_right:int = r_face - cx
                let to_left:int = cx - l_face
                let to_toe:int = z_near - cz
                if (to_toe <=? to_left) and (to_toe <=? to_right) {
                    cy = surface_y
                    if cvy <? 0 { cvy = 0 }
                } else {
                    if to_right <? to_left {
                        cx = r_face
                        if cvx <? 0 { cvx = 0 }
                    } else {
                        cx = l_face
                        if cvx >? 0 { cvx = 0 }
                    }
                }
            }
        }
    }

    # Back wall: vertical face at z=z_far rising from y=0 to y=height (the
    # ramp's max height at the lip), bounded in x by the ramp footprint.
    # Block craft trying to drive into the back of the ramp from past the
    # lip (cz on the -Z side of z_far): push them back to z_back_face and
    # zero any +Z velocity component pulling them into the wall.
    if (cz <? z_far) and (cz >? z_back_face) {
        if (cy <? height) and (cx <? r_face) and (cx >? l_face) {
            cz = z_back_face
            if cvz >? 0 { cvz = 0 }
        }
    }
    return 0
}

# Signed distance along the surface normal from craft to its hover target.
# Positive: craft is above hover target (further from surface than H).
# Negative: craft is embedded (closer to surface than H).
let normal_gap = (px:int py:int pz:int):>int => {
    let target_x:int = surf_x + fp_mul(HOVER_HEIGHT surf_nx)
    let target_y:int = surf_y + fp_mul(HOVER_HEIGHT surf_ny)
    let target_z:int = surf_z + fp_mul(HOVER_HEIGHT surf_nz)
    return fp_mul(px - target_x surf_nx) + fp_mul(py - target_y surf_ny) + fp_mul(pz - target_z surf_nz)
}

# ---------- Orientation helpers ---------------------------------------------

# Re-project forward to be perpendicular to up; renormalize.
let reortho_forward = ():>void => {
    let f_dot_u:int = fp_mul(fx ux) + fp_mul(fy uy) + fp_mul(fz uz)
    fx -= fp_mul(ux f_dot_u)
    fy -= fp_mul(uy f_dot_u)
    fz -= fp_mul(uz f_dot_u)
    let m:int = fp_sqrt((fx * fx) + (fy * fy) + (fz * fz))
    if m >? 1024 {
        fx = fp_div(fx m)
        fy = fp_div(fy m)
        fz = fp_div(fz m)
    }
    return 0
}

# right = forward x up.
let update_right = ():>void => {
    rx = fp_mul(fy uz) - fp_mul(fz uy)
    ry = fp_mul(fz ux) - fp_mul(fx uz)
    rz = fp_mul(fx uy) - fp_mul(fy ux)
    return 0
}

# Rotate forward around up by `angle` units (1024 per turn, positive = right).
# Rodrigues with k = up: f' = f*cos + (k x f)*sin; with k = up and f orthogonal
# to k that's just f' = f*cos + right*sin.
let rotate_forward = (angle:int):>void => {
    let c:int = cos_fp(angle)
    let s:int = sin_fp(angle)
    let nfx:int = fp_mul(fx c) + fp_mul(rx s)
    let nfy:int = fp_mul(fy c) + fp_mul(ry s)
    let nfz:int = fp_mul(fz c) + fp_mul(rz s)
    fx = nfx
    fy = nfy
    fz = nfz
    update_right()
    return 0
}

# ---------- Physics step -----------------------------------------------------

let reset_craft = ():>void => {
    cx = 0
    cy = HOVER_HEIGHT
    cz = 0
    cvx = 0
    cvy = 0
    cvz = 0
    fx = 0
    fy = 0
    fz = 0 - FP_ONE
    ux = 0
    uy = FP_ONE
    uz = 0
    rx = FP_ONE
    ry = 0
    rz = 0
    vfx = fx
    vfy = fy
    vfz = fz
    vux = ux
    vuy = uy
    vuz = uz
    vrx = rx
    vry = ry
    vrz = rz
    prev_fx = fx
    prev_fy = fy
    prev_fz = fz
    bank = 0
    cam_fx = fx
    cam_fy = fy
    cam_fz = fz
    cam_ux = ux
    cam_uy = uy
    cam_uz = uz
    cam_x = cx - fp_mul(CAM_BACK fx) + fp_mul(CAM_LIFT ux)
    cam_y = cy - fp_mul(CAM_BACK fy) + fp_mul(CAM_LIFT uy)
    cam_z = cz - fp_mul(CAM_BACK fz) + fp_mul(CAM_LIFT uz)
    trail_head = 0
    trail_count = 0
    energy = ENERGY_FULL
    boost_active_frames = 0
    return 0
}

let physics_step = ():>void => {
    # Surface at current pos.
    query_surface(cx cy cz)
    let gap_now:int = normal_gap(cx cy cz)
    let airborne:int = 0
    if gap_now >? AIR_GAP {
        airborne = 1
    }

    # Landing detection: previous frame ended airborne, this frame starts
    # grounded -> the magnet snap happened last frame, fire a spark burst.
    # Direction is the surface normal so sparks fan up off the contact;
    # burst size scales with horizontal speed (higher = bigger skid spray).
    if (was_airborne not=? 0) and (airborne =? 0) {
        let speed_xy:int = fp_sqrt((cvx * cvx) + (cvz * cvz))
        let burst:int = 6 + (speed_xy // 32768)
        if burst >? SPARK_MAX_BURST {
            burst = SPARK_MAX_BURST
        }
        spark_emit(cx cy cz surf_nx surf_ny surf_nz burst)
    }
    was_airborne = airborne

    # Grounded: physics up = surface normal exactly. Airborne: hold the
    # current up *unless* the player is inputting -- in which case ease back
    # toward world up so they regain control. (Touching the ground re-snaps.)
    # Anti-antipodal kick: lerp + renormalize is degenerate at exactly 180
    # degrees, so nudge ux off the Y axis when nearly inverted.
    if airborne =? 0 {
        ux = surf_nx
        uy = surf_ny
        uz = surf_nz
    } else {
        let any_input:int = in_thrust or in_brake or in_steer_l or in_steer_r or in_strafe_l or in_strafe_r or in_boost
        if any_input not=? 0 {
            if uy <? -58982 {
                if (ux >? -6553) and (ux <? 6553) {
                    ux += 6553
                }
            }
            ux += fp_mul((0 - ux) UP_ALPHA_AIR)
            uy += fp_mul(FP_ONE - uy UP_ALPHA_AIR)
            uz += fp_mul((0 - uz) UP_ALPHA_AIR)
            let um:int = fp_sqrt((ux * ux) + (uy * uy) + (uz * uz))
            if um >? 1024 {
                ux = fp_div(ux um)
                uy = fp_div(uy um)
                uz = fp_div(uz um)
            }
        }
    }
    reortho_forward()
    update_right()

    # Steering: rotate forward around up.
    let speed_xyz:int = fp_sqrt((cvx * cvx) + (cvy * cvy) + (cvz * cvz))
    let speed_norm:int = 0
    if TOP_SPEED >? 0 {
        speed_norm = (speed_xyz << 16) // (TOP_SPEED + 1)
    }
    if speed_norm >? FP_ONE {
        speed_norm = FP_ONE
    }
    if speed_norm <? 0 {
        speed_norm = 0
    }
    let steer_in:int = 0
    if in_steer_l not=? 0 {
        steer_in -= 1
    }
    if in_steer_r not=? 0 {
        steer_in += 1
    }
    let steer_rate:int = STEER_BASE - fp_mul((STEER_BASE - STEER_MIN) speed_norm)
    if steer_in not=? 0 {
        rotate_forward(steer_in * steer_rate)
    }

    # Thrust along forward (continuous, no boost bonus -- boost is discrete).
    let thrust:int = 0
    let thrust_active:int = 0
    if in_thrust not=? 0 {
        thrust = THRUST_ACCEL
        thrust_active = 1
    }
    if thrust not=? 0 {
        cvx += fp_mul(fx thrust)
        cvy += fp_mul(fy thrust)
        cvz += fp_mul(fz thrust)
    }

    # Edge-triggered boost: fire only on the press transition, only if
    # there's enough energy. Adds an instant forward impulse and lifts the
    # speed cap for BOOST_DURATION frames so the kick can settle before
    # drag/grip eat it.
    let boost_pressed:int = (in_boost not=? 0) and (in_boost_prev =? 0)
    in_boost_prev = in_boost
    if (boost_pressed not=? 0) and (energy >=? BOOST_COST_Q) {
        cvx += fp_mul(fx BOOST_IMPULSE)
        cvy += fp_mul(fy BOOST_IMPULSE)
        cvz += fp_mul(fz BOOST_IMPULSE)
        boost_active_frames = BOOST_DURATION
        energy -= BOOST_COST_Q
    }
    if boost_active_frames >? 0 {
        boost_active_frames -= 1
    }
    energy += ENERGY_REGEN_Q
    if energy >? ENERGY_FULL {
        energy = ENERGY_FULL
    }

    # Brake: kill forward component of velocity.
    if in_brake not=? 0 {
        let fwd_speed:int = fp_mul(cvx fx) + fp_mul(cvy fy) + fp_mul(cvz fz)
        if fwd_speed >? 0 {
            let brake:int = BRAKE_DECEL
            if brake >? fwd_speed {
                brake = fwd_speed
            }
            cvx -= fp_mul(fx brake)
            cvy -= fp_mul(fy brake)
            cvz -= fp_mul(fz brake)
        }
    }

    # Strafe: direct position translation along right.
    let strafe:int = 0
    if in_strafe_l not=? 0 {
        strafe -= STRAFE_RATE
    }
    if in_strafe_r not=? 0 {
        strafe += STRAFE_RATE
    }
    if strafe not=? 0 {
        cx += fp_mul(rx strafe)
        cy += fp_mul(ry strafe)
        cz += fp_mul(rz strafe)
    }

    # Grip + drag (only when grounded).
    if airborne =? 0 {
        let side_dot:int = fp_mul(cvx rx) + fp_mul(cvy ry) + fp_mul(cvz rz)
        let side_kill:int = fp_mul(side_dot LATERAL_GRIP)
        cvx -= fp_mul(rx side_kill)
        cvy -= fp_mul(ry side_kill)
        cvz -= fp_mul(rz side_kill)

        let drag:int = DRAG_COAST
        if thrust_active not=? 0 {
            drag = DRAG_THRUST
        }
        let fwd_dot:int = fp_mul(cvx fx) + fp_mul(cvy fy) + fp_mul(cvz fz)
        let drag_force:int = fp_mul(fwd_dot drag)
        cvx -= fp_mul(fx drag_force)
        cvy -= fp_mul(fy drag_force)
        cvz -= fp_mul(fz drag_force)
    }

    # Top speed clamp. The boost cap stays elevated for the full
    # boost_active_frames window after the press, then snaps back so drag
    # gradually pulls speed down to the normal ceiling.
    let max_speed:int = TOP_SPEED
    if boost_active_frames >? 0 {
        max_speed = TOP_SPEED + BOOST_BONUS
    }
    let cur_speed:int = fp_sqrt((cvx * cvx) + (cvy * cvy) + (cvz * cvz))
    if cur_speed >? max_speed {
        cvx = fp_div(fp_mul(cvx max_speed) cur_speed)
        cvy = fp_div(fp_mul(cvy max_speed) cur_speed)
        cvz = fp_div(fp_mul(cvz max_speed) cur_speed)
    }

    # Gravity (world -Y) when airborne; otherwise project velocity onto the
    # tangent plane so gravity & inertia don't drag the craft into the surface.
    if airborne not=? 0 {
        cvy -= GRAVITY
    } else {
        let cv_dot_n:int = fp_mul(cvx surf_nx) + fp_mul(cvy surf_ny) + fp_mul(cvz surf_nz)
        cvx -= fp_mul(surf_nx cv_dot_n)
        cvy -= fp_mul(surf_ny cv_dot_n)
        cvz -= fp_mul(surf_nz cv_dot_n)

        # Tangential slope gravity: g_tan = g - (g . n) n with g = (0, -SG, 0).
        let proj:int = fp_mul(SLOPE_GRAVITY surf_ny)
        cvx += fp_mul(surf_nx proj)
        cvy += fp_mul(surf_ny proj) - SLOPE_GRAVITY
        cvz += fp_mul(surf_nz proj)
    }

    cx += cvx
    cy += cvy
    cz += cvz

    # Wall clamp before the magnet snap so the snap operates on the
    # corrected position (avoids a one-frame visual penetration). Same
    # idea for ramp side-walls: don't let the craft phase through a ramp
    # side and then get yanked up to the top by the magnet.
    # Snapshot velocity so we can read off the impulse the collision
    # functions applied (delta v = sparks).
    let pre_cvx:int = cvx
    let pre_cvy:int = cvy
    let pre_cvz:int = cvz
    wall_collide()
    ramp_side_collide(0 RAMP_HALF_W Z_RAMP_NEAR Z_RAMP_FAR RAMP_TAN)
    ramp_side_collide(0 INNER_RAMP_HALF_W Z_INNER_NEAR Z_INNER_FAR INNER_RAMP_TAN)
    ramp_side_collide(OUTER_RAMP_X_CENTER OUTER_RAMP_HALF_W Z_OUTER_NEAR Z_OUTER_FAR OUTER_RAMP_TAN)

    # Spark spawn: any collision that zeroed an inward velocity component
    # shows up as a non-trivial dv in the opposite (outward) direction.
    let dvx:int = cvx - pre_cvx
    let dvy:int = cvy - pre_cvy
    let dvz:int = cvz - pre_cvz
    let imp_mag:int = fp_sqrt((dvx * dvx) + (dvy * dvy) + (dvz * dvz))
    if imp_mag >? SPARK_IMPULSE_THRESHOLD {
        let burst:int = (imp_mag - SPARK_IMPULSE_THRESHOLD) // SPARK_IMPULSE_PER_PARTICLE + 1
        if burst >? SPARK_MAX_BURST {
            burst = SPARK_MAX_BURST
        }
        let nx:int = fp_div(dvx imp_mag)
        let ny:int = fp_div(dvy imp_mag)
        let nz:int = fp_div(dvz imp_mag)
        spark_emit(cx cy cz nx ny nz burst)
    }

    # Magnet snap: pull craft toward hover target along the new surface normal.
    query_surface(cx cy cz)
    let post_gap:int = normal_gap(cx cy cz)
    if post_gap <=? AIR_GAP {
        let snap_amt:int = fp_mul(0 - post_gap SNAP_ALPHA)
        cx += fp_mul(snap_amt surf_nx)
        cy += fp_mul(snap_amt surf_ny)
        cz += fp_mul(snap_amt surf_nz)
    }

    if in_respawn not=? 0 {
        reset_craft()
    }
    return 0
}

# ---------- Visual + camera basis -------------------------------------------

# Visual basis = physics basis rolled about fwd by `bank`, where bank lerps
# toward yaw_rate * speed_norm. Camera basis lerps toward the (unrolled)
# physics basis so the chase trails without itself rolling.
let update_chase = ():>void => {
    # Yaw rate this frame = signed component of delta_fwd along right axis.
    # Works for any orientation (yaw on flat ground, banking around a loop,
    # spinning around the sphere) because `right` is always the local
    # surface-tangent right.
    let dfx:int = fx - prev_fx
    let dfy:int = fy - prev_fy
    let dfz:int = fz - prev_fz
    let yaw_rate_q:int = fp_mul(dfx rx) + fp_mul(dfy ry) + fp_mul(dfz rz)

    # speed_norm clamped to 0..FP_ONE for bank scaling (no boost-overdrive).
    # Also publish raw speed and an unclamped boost-norm for the HUD and
    # speed lines (which want to see the boost overhead).
    let speed:int = fp_sqrt((cvx * cvx) + (cvy * cvy) + (cvz * cvz))
    vis_speed = speed
    vis_boost_norm = (speed << 16) // (TOP_SPEED + BOOST_BONUS)
    let sn:int = 0
    if TOP_SPEED >? 0 {
        sn = (speed << 16) // TOP_SPEED
    }
    if sn >? FP_ONE {
        sn = FP_ONE
    }
    vis_speed_norm = sn

    # yaw_rate_q is Q16 radians (sin(theta) for small angles). Convert to
    # raw angle units (1024 = 360 deg) by *RAW_PER_RAD then >> FP_SHIFT.
    # Sign: a right turn rotates fwd toward +right, so dot(delta_fwd, right)
    # is positive. The roll formula below (new_U = U*cos + R*sin) tilts the
    # up vector toward +right when bank > 0, which visually leans the craft
    # right. So bank_target = +yaw_rate * gain (no negation).
    let yaw_rate:int = __signed_shr__(yaw_rate_q * RAW_PER_RAD FP_SHIFT)
    let bank_target:int = fp_mul(yaw_rate * BANK_GAIN sn)
    if bank_target >? BANK_MAX {
        bank_target = BANK_MAX
    }
    if bank_target <? (0 - BANK_MAX) {
        bank_target = 0 - BANK_MAX
    }
    bank += fp_mul(bank_target - bank BANK_ALPHA)

    # Roll physics basis about fwd by `bank`. F unchanged; R, U rotate.
    #   new_R = R*cos - U*sin
    #   new_U = U*cos + R*sin
    let cos_b:int = cos_fp(bank)
    let sin_b:int = sin_fp(bank)
    vfx = fx
    vfy = fy
    vfz = fz
    vrx = fp_mul(rx cos_b) - fp_mul(ux sin_b)
    vry = fp_mul(ry cos_b) - fp_mul(uy sin_b)
    vrz = fp_mul(rz cos_b) - fp_mul(uz sin_b)
    vux = fp_mul(ux cos_b) + fp_mul(rx sin_b)
    vuy = fp_mul(uy cos_b) + fp_mul(ry sin_b)
    vuz = fp_mul(uz cos_b) + fp_mul(rz sin_b)

    prev_fx = fx
    prev_fy = fy
    prev_fz = fz

    # Camera follows the unrolled physics basis (no visual roll on camera).
    cam_fx += fp_mul(fx - cam_fx ORIENT_ALPHA)
    cam_fy += fp_mul(fy - cam_fy ORIENT_ALPHA)
    cam_fz += fp_mul(fz - cam_fz ORIENT_ALPHA)
    cam_ux += fp_mul(ux - cam_ux ORIENT_ALPHA)
    cam_uy += fp_mul(uy - cam_uy ORIENT_ALPHA)
    cam_uz += fp_mul(uz - cam_uz ORIENT_ALPHA)
    let cum:int = fp_sqrt((cam_ux * cam_ux) + (cam_uy * cam_uy) + (cam_uz * cam_uz))
    if cum >? 1024 {
        cam_ux = fp_div(cam_ux cum)
        cam_uy = fp_div(cam_uy cum)
        cam_uz = fp_div(cam_uz cum)
    }
    let cf_dot_cu:int = fp_mul(cam_fx cam_ux) + fp_mul(cam_fy cam_uy) + fp_mul(cam_fz cam_uz)
    cam_fx -= fp_mul(cam_ux cf_dot_cu)
    cam_fy -= fp_mul(cam_uy cf_dot_cu)
    cam_fz -= fp_mul(cam_uz cf_dot_cu)
    let cfm:int = fp_sqrt((cam_fx * cam_fx) + (cam_fy * cam_fy) + (cam_fz * cam_fz))
    if cfm >? 1024 {
        cam_fx = fp_div(cam_fx cfm)
        cam_fy = fp_div(cam_fy cfm)
        cam_fz = fp_div(cam_fz cfm)
    }

    let target_cam_x:int = cx - fp_mul(CAM_BACK cam_fx) + fp_mul(CAM_LIFT cam_ux)
    let target_cam_y:int = cy - fp_mul(CAM_BACK cam_fy) + fp_mul(CAM_LIFT cam_uy)
    let target_cam_z:int = cz - fp_mul(CAM_BACK cam_fz) + fp_mul(CAM_LIFT cam_uz)
    cam_x += fp_mul(target_cam_x - cam_x POS_ALPHA)
    cam_y += fp_mul(target_cam_y - cam_y POS_ALPHA)
    cam_z += fp_mul(target_cam_z - cam_z POS_ALPHA)

    # Keep the camera at least MIN_CAM_CLEAR above the floor (walls are
    # not part of the surface query, but the floor still is). Mutates
    # surf_* but the next physics_step re-queries before using them.
    query_surface(cam_x cam_y cam_z)
    let cam_clear:int = fp_mul(cam_x - surf_x surf_nx) + fp_mul(cam_y - surf_y surf_ny) + fp_mul(cam_z - surf_z surf_nz)
    if cam_clear <? MIN_CAM_CLEAR {
        let push:int = MIN_CAM_CLEAR - cam_clear
        cam_x += fp_mul(push surf_nx)
        cam_y += fp_mul(push surf_ny)
        cam_z += fp_mul(push surf_nz)
    }

    let scale:int = FP_ONE + fp_mul(sn FOV_PUNCH)
    cur_fov_top_q16 = fp_mul(131072 scale)
    return 0
}

# ---------- Rendering -------------------------------------------------------

let set_perspective = (screen_w:int screen_h:int):>void => {
    glMatrixMode(GL_PROJECTION)
    glLoadIdentity()
    let aspect_q16:int = (screen_w << 16) // screen_h
    let top_q16:int = cur_fov_top_q16
    let right_q16:int = fp_mul(top_q16 aspect_q16)
    GL_Frustum(q16_to_f64(0 - right_q16) q16_to_f64(right_q16) q16_to_f64(0 - top_q16) q16_to_f64(top_q16) F64_NEAR F64_FAR)
    glMatrixMode(GL_MODELVIEW)
    glLoadIdentity()
    return 0
}

# Build the world->camera view matrix from the camera basis (cam_fx/fy/fz,
# cam_ux/uy/uz, derived right) and cam position. OpenGL is column-major.
#
#   right = cam_fwd x cam_up
#   V = | rx   ux  -fx   -dot(R, cam) |
#       | ry   uy  -fy   -dot(U, cam) |
#       | rz   uz  -fz    dot(F, cam) |
#       |  0    0    0       1        |
let apply_camera = ():>void => {
    let crx:int = fp_mul(cam_fy cam_uz) - fp_mul(cam_fz cam_uy)
    let cry:int = fp_mul(cam_fz cam_ux) - fp_mul(cam_fx cam_uz)
    let crz:int = fp_mul(cam_fx cam_uy) - fp_mul(cam_fy cam_ux)

    let neg_dot_r:int = 0 - (fp_mul(crx cam_x) + fp_mul(cry cam_y) + fp_mul(crz cam_z))
    let neg_dot_u:int = 0 - (fp_mul(cam_ux cam_x) + fp_mul(cam_uy cam_y) + fp_mul(cam_uz cam_z))
    let dot_f:int = fp_mul(cam_fx cam_x) + fp_mul(cam_fy cam_y) + fp_mul(cam_fz cam_z)

    let mat:int = __static_alloca__(64)
    __store_u32__(q16_to_f32(crx) mat + 0)
    __store_u32__(q16_to_f32(cam_ux) mat + 4)
    __store_u32__(q16_to_f32(0 - cam_fx) mat + 8)
    __store_u32__(0 mat + 12)

    __store_u32__(q16_to_f32(cry) mat + 16)
    __store_u32__(q16_to_f32(cam_uy) mat + 20)
    __store_u32__(q16_to_f32(0 - cam_fy) mat + 24)
    __store_u32__(0 mat + 28)

    __store_u32__(q16_to_f32(crz) mat + 32)
    __store_u32__(q16_to_f32(cam_uz) mat + 36)
    __store_u32__(q16_to_f32(0 - cam_fz) mat + 40)
    __store_u32__(0 mat + 44)

    __store_u32__(q16_to_f32(neg_dot_r) mat + 48)
    __store_u32__(q16_to_f32(neg_dot_u) mat + 52)
    __store_u32__(q16_to_f32(dot_f) mat + 56)
    __store_u32__(F32_ONE mat + 60)

    glLoadMatrixf(mat)
    return 0
}

# Convert a Q16 color channel in [0, FP_ONE] to an 8-bit byte in [0, 255]
# for the texture upload. Saturates outside the unit range.
let q16_to_u8 = (q:int):>int => {
    let b:int = (q * 255) >> FP_SHIFT
    if b <? 0 { b = 0 }
    if b >? 255 { b = 255 }
    return b
}

let ground_tex_write_pixel = (offset:int r:int g:int b:int):>void => {
    __store_u8__(q16_to_u8(r) GROUND_TEX_PIXELS + offset)
    __store_u8__(q16_to_u8(g) GROUND_TEX_PIXELS + offset + 1)
    __store_u8__(q16_to_u8(b) GROUND_TEX_PIXELS + offset + 2)
    __store_u8__(255 GROUND_TEX_PIXELS + offset + 3)
    return 0
}

# One-time GL setup for the ground texture. Builds the 2x2 RGBA checker
# from the existing COL_TILE_A/B constants, uploads it with NEAREST/REPEAT
# so it tiles infinitely with no filtering blur, and stashes the texture
# id in GROUND_TEX_ID_SLOT for draw_ground to bind every frame.
# Pixel layout (row-major): (B, A) / (A, B) so that world-tile (i, j) with
# (i + j) even shows COL_TILE_B (matches the prior per-quad pattern).
let ground_texture_init = ():>void => {
    ground_tex_write_pixel(0  COL_TILE_B_R COL_TILE_B_G COL_TILE_B_B)
    ground_tex_write_pixel(4  COL_TILE_A_R COL_TILE_A_G COL_TILE_A_B)
    ground_tex_write_pixel(8  COL_TILE_A_R COL_TILE_A_G COL_TILE_A_B)
    ground_tex_write_pixel(12 COL_TILE_B_R COL_TILE_B_G COL_TILE_B_B)
    glPixelStorei(0x0CF5 1)  # GL_UNPACK_ALIGNMENT = 1 (defensive; RGBA rows are 8 bytes anyway)
    glGenTextures(1 GROUND_TEX_ID_SLOT)
    let tex_id:int = __load_u32__(GROUND_TEX_ID_SLOT)
    glBindTexture(GL_TEXTURE_2D tex_id)
    glTexParameteri(GL_TEXTURE_2D GL_TEXTURE_MIN_FILTER GL_NEAREST)
    glTexParameteri(GL_TEXTURE_2D GL_TEXTURE_MAG_FILTER GL_NEAREST)
    glTexParameteri(GL_TEXTURE_2D GL_TEXTURE_WRAP_S GL_REPEAT)
    glTexParameteri(GL_TEXTURE_2D GL_TEXTURE_WRAP_T GL_REPEAT)
    glTexImage2D(GL_TEXTURE_2D 0 GL_RGBA 2 2 0 GL_RGBA GL_UNSIGNED_BYTE GROUND_TEX_PIXELS)
    return 0
}

# One textured quad covering the full +/-5 km ground plane. Tex coords
# scale with world position so each 5 m of world maps to half a tex_uv
# unit (one texel under GL_NEAREST), giving 5 m checker cells regardless
# of the quad size.
let draw_ground = ():>void => {
    let half_q16:int = GROUND_HALF_EXTENT
    let tex_q16:int = half_q16 // GROUND_TEX_UV_DIVISOR
    let pos_xyz:int = q16_to_f32(half_q16)
    let neg_xyz:int = q16_to_f32(0 - half_q16)
    let pos_uv:int = q16_to_f32(tex_q16)
    let neg_uv:int = q16_to_f32(0 - tex_q16)
    let y:int = q16_to_f32(GROUND_Y)
    let tex_id:int = __load_u32__(GROUND_TEX_ID_SLOT)

    glEnable(GL_TEXTURE_2D)
    glBindTexture(GL_TEXTURE_2D tex_id)
    glBegin(GL_QUADS)
    GL_Color3f(F32_ONE F32_ONE F32_ONE)
    GL_TexCoord2f(neg_uv neg_uv)
    GL_Vertex3f(neg_xyz y neg_xyz)
    GL_TexCoord2f(pos_uv neg_uv)
    GL_Vertex3f(pos_xyz y neg_xyz)
    GL_TexCoord2f(pos_uv pos_uv)
    GL_Vertex3f(pos_xyz y pos_xyz)
    GL_TexCoord2f(neg_uv pos_uv)
    GL_Vertex3f(neg_xyz y pos_xyz)
    glEnd()
    glDisable(GL_TEXTURE_2D)
    return 0
}

# ---- Ramp ----
let draw_ramp = ():>void => {
    let r_a:int = q16_to_f32(COL_RAMP_A_R)
    let g_a:int = q16_to_f32(COL_RAMP_A_G)
    let b_a:int = q16_to_f32(COL_RAMP_A_B)
    let r_b:int = q16_to_f32(COL_RAMP_B_R)
    let g_b:int = q16_to_f32(COL_RAMP_B_G)
    let b_b:int = q16_to_f32(COL_RAMP_B_B)
    let r_s:int = q16_to_f32(COL_RAMP_SIDE_R)
    let g_s:int = q16_to_f32(COL_RAMP_SIDE_G)
    let b_s:int = q16_to_f32(COL_RAMP_SIDE_B)
    let zi:int = 0
    loop zi <? RAMP_Z_SEGMENTS {
        let z0:int = Z_RAMP_NEAR - ((zi * RAMP_LENGTH) // RAMP_Z_SEGMENTS)
        let z1:int = Z_RAMP_NEAR - (((zi + 1) * RAMP_LENGTH) // RAMP_Z_SEGMENTS)
        let y0:int = fp_mul(Z_RAMP_NEAR - z0 RAMP_TAN)
        let y1:int = fp_mul(Z_RAMP_NEAR - z1 RAMP_TAN)
        let wi:int = 0
        loop wi <? RAMP_W_SEGMENTS {
            let x0:int = (0 - RAMP_HALF_W) + ((wi * (2 * RAMP_HALF_W)) // RAMP_W_SEGMENTS)
            let x1:int = (0 - RAMP_HALF_W) + (((wi + 1) * (2 * RAMP_HALF_W)) // RAMP_W_SEGMENTS)
            let cell:int = (zi + wi) and 1
            let rr:int = r_a
            let gg:int = g_a
            let bb:int = b_a
            if cell =? 0 {
                rr = r_b
                gg = g_b
                bb = b_b
            }
            glBegin(GL_QUADS)
            GL_Color3f(rr gg bb)
            world_v3(x0 y0 z0)
            world_v3(x1 y0 z0)
            world_v3(x1 y1 z1)
            world_v3(x0 y1 z1)
            glEnd()
            wi += 1
        }
        zi += 1
    }
    glBegin(GL_TRIANGLES)
    GL_Color3f(r_s g_s b_s)
    world_v3(0 - RAMP_HALF_W 0 Z_RAMP_NEAR)
    world_v3(0 - RAMP_HALF_W 0 Z_RAMP_FAR)
    world_v3(0 - RAMP_HALF_W RAMP_HEIGHT Z_RAMP_FAR)
    world_v3(RAMP_HALF_W 0 Z_RAMP_NEAR)
    world_v3(RAMP_HALF_W RAMP_HEIGHT Z_RAMP_FAR)
    world_v3(RAMP_HALF_W 0 Z_RAMP_FAR)
    glEnd()
    glBegin(GL_QUADS)
    GL_Color3f(r_s g_s b_s)
    world_v3(0 - RAMP_HALF_W 0 Z_RAMP_FAR)
    world_v3(RAMP_HALF_W 0 Z_RAMP_FAR)
    world_v3(RAMP_HALF_W RAMP_HEIGHT Z_RAMP_FAR)
    world_v3(0 - RAMP_HALF_W RAMP_HEIGHT Z_RAMP_FAR)
    glEnd()
    return 0
}

# ---- Loop ----
let draw_loop = ():>void => {
    let r_a:int = q16_to_f32(COL_LOOP_A_R)
    let g_a:int = q16_to_f32(COL_LOOP_A_G)
    let b_a:int = q16_to_f32(COL_LOOP_A_B)
    let r_b:int = q16_to_f32(COL_LOOP_B_R)
    let g_b:int = q16_to_f32(COL_LOOP_B_G)
    let b_b:int = q16_to_f32(COL_LOOP_B_B)
    let pi:int = 0
    loop pi <? LOOP_PHI_SEGMENTS {
        let phi0:int = (pi * ANG_TURN) // LOOP_PHI_SEGMENTS
        let phi1:int = ((pi + 1) * ANG_TURN) // LOOP_PHI_SEGMENTS
        let xc0:int = (phi0 * LOOP_W) // ANG_TURN
        let xc1:int = (phi1 * LOOP_W) // ANG_TURN
        let cphi0:int = cos_fp(phi0)
        let sphi0:int = sin_fp(phi0)
        let cphi1:int = cos_fp(phi1)
        let sphi1:int = sin_fp(phi1)
        let y0:int = LOOP_YC - fp_mul(LOOP_R cphi0)
        let z0:int = LOOP_ZC - fp_mul(LOOP_R sphi0)
        let y1:int = LOOP_YC - fp_mul(LOOP_R cphi1)
        let z1:int = LOOP_ZC - fp_mul(LOOP_R sphi1)
        let wi:int = 0
        loop wi <? LOOP_W_SEGMENTS {
            let w0:int = (0 - LOOP_HALF_W) + ((wi * LOOP_W) // LOOP_W_SEGMENTS)
            let w1:int = (0 - LOOP_HALF_W) + (((wi + 1) * LOOP_W) // LOOP_W_SEGMENTS)
            let x00:int = xc0 + w0
            let x01:int = xc0 + w1
            let x10:int = xc1 + w0
            let x11:int = xc1 + w1
            let cell:int = (pi + wi) and 1
            let rr:int = r_a
            let gg:int = g_a
            let bb:int = b_a
            if cell =? 0 {
                rr = r_b
                gg = g_b
                bb = b_b
            }
            glBegin(GL_QUADS)
            GL_Color3f(rr gg bb)
            world_v3(x00 y0 z0)
            world_v3(x01 y0 z0)
            world_v3(x11 y1 z1)
            world_v3(x10 y1 z1)
            glEnd()
            wi += 1
        }
        pi += 1
    }
    return 0
}

# ---- Hills ----
let draw_hills = ():>void => {
    let r_a:int = q16_to_f32(COL_HILL_A_R)
    let g_a:int = q16_to_f32(COL_HILL_A_G)
    let b_a:int = q16_to_f32(COL_HILL_A_B)
    let r_b:int = q16_to_f32(COL_HILL_B_R)
    let g_b:int = q16_to_f32(COL_HILL_B_G)
    let b_b:int = q16_to_f32(COL_HILL_B_B)
    let w_span:int = 2 * HILL_HALF_W
    let zi:int = 0
    loop zi <? HILL_Z_SEGMENTS {
        let z0:int = Z_HILL_START - ((zi * HILL_LENGTH) // HILL_Z_SEGMENTS)
        let z1:int = Z_HILL_START - (((zi + 1) * HILL_LENGTH) // HILL_Z_SEGMENTS)
        let phase0:int = ((Z_HILL_START - z0) * ANG_TURN) // HILL_WAVELENGTH
        let phase1:int = ((Z_HILL_START - z1) * ANG_TURN) // HILL_WAVELENGTH
        let y0:int = fp_mul(HILL_AMP_HALF FP_ONE - cos_fp(phase0))
        let y1:int = fp_mul(HILL_AMP_HALF FP_ONE - cos_fp(phase1))
        let wi:int = 0
        loop wi <? HILL_W_SEGMENTS {
            let x0:int = (0 - HILL_HALF_W) + ((wi * w_span) // HILL_W_SEGMENTS)
            let x1:int = (0 - HILL_HALF_W) + (((wi + 1) * w_span) // HILL_W_SEGMENTS)
            let cell:int = (zi + wi) and 1
            let rr:int = r_a
            let gg:int = g_a
            let bb:int = b_a
            if cell =? 0 {
                rr = r_b
                gg = g_b
                bb = b_b
            }
            glBegin(GL_QUADS)
            GL_Color3f(rr gg bb)
            world_v3(x0 y0 z0)
            world_v3(x1 y0 z0)
            world_v3(x1 y1 z1)
            world_v3(x0 y1 z1)
            glEnd()
            wi += 1
        }
        zi += 1
    }
    return 0
}

# ---- Halfpipe ----
let draw_halfpipe = ():>void => {
    let r_a:int = q16_to_f32(COL_PIPE_A_R)
    let g_a:int = q16_to_f32(COL_PIPE_A_G)
    let b_a:int = q16_to_f32(COL_PIPE_A_B)
    let r_b:int = q16_to_f32(COL_PIPE_B_R)
    let g_b:int = q16_to_f32(COL_PIPE_B_G)
    let b_b:int = q16_to_f32(COL_PIPE_B_B)
    let theta_span:int = 2 * ANG_QTR
    let zi:int = 0
    loop zi <? PIPE_Z_SEGMENTS {
        let z0:int = Z_PIPE_START - ((zi * PIPE_LEN) // PIPE_Z_SEGMENTS)
        let z1:int = Z_PIPE_START - (((zi + 1) * PIPE_LEN) // PIPE_Z_SEGMENTS)
        let ti:int = 0
        loop ti <? PIPE_THETA_SEGMENTS {
            let theta0:int = (0 - ANG_QTR) + ((ti * theta_span) // PIPE_THETA_SEGMENTS)
            let theta1:int = (0 - ANG_QTR) + (((ti + 1) * theta_span) // PIPE_THETA_SEGMENTS)
            let cth0:int = cos_fp(theta0)
            let sth0:int = sin_fp(theta0)
            let cth1:int = cos_fp(theta1)
            let sth1:int = sin_fp(theta1)
            let x0:int = fp_mul(PIPE_R sth0)
            let y0:int = PIPE_R - fp_mul(PIPE_R cth0)
            let x1:int = fp_mul(PIPE_R sth1)
            let y1:int = PIPE_R - fp_mul(PIPE_R cth1)
            let cell:int = (zi + ti) and 1
            let rr:int = r_a
            let gg:int = g_a
            let bb:int = b_a
            if cell =? 0 {
                rr = r_b
                gg = g_b
                bb = b_b
            }
            glBegin(GL_QUADS)
            GL_Color3f(rr gg bb)
            world_v3(x0 y0 z0)
            world_v3(x1 y1 z0)
            world_v3(x1 y1 z1)
            world_v3(x0 y0 z1)
            glEnd()
            ti += 1
        }
        zi += 1
    }
    return 0
}

# ---- Corkscrew ----
let draw_corkscrew = ():>void => {
    let r_a:int = q16_to_f32(COL_CORK_A_R)
    let g_a:int = q16_to_f32(COL_CORK_A_G)
    let b_a:int = q16_to_f32(COL_CORK_A_B)
    let r_b:int = q16_to_f32(COL_CORK_B_R)
    let g_b:int = q16_to_f32(COL_CORK_B_G)
    let b_b:int = q16_to_f32(COL_CORK_B_B)
    let zi:int = 0
    loop zi <? CORK_Z_SEGMENTS {
        let z0:int = CORK_Z_START - ((zi * CORK_LEN) // CORK_Z_SEGMENTS)
        let z1:int = CORK_Z_START - (((zi + 1) * CORK_LEN) // CORK_Z_SEGMENTS)
        let theta0:int = ((CORK_Z_START - z0) * ANG_TURN) // CORK_LEN
        let theta1:int = ((CORK_Z_START - z1) * ANG_TURN) // CORK_LEN
        let cth0:int = cos_fp(theta0)
        let sth0:int = sin_fp(theta0)
        let cth1:int = cos_fp(theta1)
        let sth1:int = sin_fp(theta1)
        let yc0:int = (CORK_Y_PEAK - fp_mul(CORK_Y_PEAK cth0)) // 2
        let yc1:int = (CORK_Y_PEAK - fp_mul(CORK_Y_PEAK cth1)) // 2
        let wi:int = 0
        loop wi <? CORK_W_SEGMENTS {
            let w0:int = (0 - CORK_HALF_W) + ((wi * CORK_W) // CORK_W_SEGMENTS)
            let w1:int = (0 - CORK_HALF_W) + (((wi + 1) * CORK_W) // CORK_W_SEGMENTS)
            let x00:int = CORK_X_CENTER + fp_mul(w0 cth0)
            let y00:int = yc0 + fp_mul(w0 sth0)
            let x01:int = CORK_X_CENTER + fp_mul(w1 cth0)
            let y01:int = yc0 + fp_mul(w1 sth0)
            let x10:int = CORK_X_CENTER + fp_mul(w0 cth1)
            let y10:int = yc1 + fp_mul(w0 sth1)
            let x11:int = CORK_X_CENTER + fp_mul(w1 cth1)
            let y11:int = yc1 + fp_mul(w1 sth1)
            let cell:int = (zi + wi) and 1
            let rr:int = r_a
            let gg:int = g_a
            let bb:int = b_a
            if cell =? 0 {
                rr = r_b
                gg = g_b
                bb = b_b
            }
            glBegin(GL_QUADS)
            GL_Color3f(rr gg bb)
            world_v3(x00 y00 z0)
            world_v3(x01 y01 z0)
            world_v3(x11 y11 z1)
            world_v3(x10 y10 z1)
            glEnd()
            wi += 1
        }
        zi += 1
    }
    return 0
}

# ---- Sphere inner-access ramp (centered x=0) ----
let draw_inner_ramp = ():>void => {
    let r_a:int = q16_to_f32(COL_INNER_RAMP_A_R)
    let g_a:int = q16_to_f32(COL_INNER_RAMP_A_G)
    let b_a:int = q16_to_f32(COL_INNER_RAMP_A_B)
    let r_b:int = q16_to_f32(COL_INNER_RAMP_B_R)
    let g_b:int = q16_to_f32(COL_INNER_RAMP_B_G)
    let b_b:int = q16_to_f32(COL_INNER_RAMP_B_B)
    let r_s:int = q16_to_f32(COL_INNER_RAMP_SIDE_R)
    let g_s:int = q16_to_f32(COL_INNER_RAMP_SIDE_G)
    let b_s:int = q16_to_f32(COL_INNER_RAMP_SIDE_B)
    let zi:int = 0
    loop zi <? INNER_RAMP_Z_SEGMENTS {
        let z0:int = Z_INNER_NEAR - ((zi * INNER_RAMP_LENGTH) // INNER_RAMP_Z_SEGMENTS)
        let z1:int = Z_INNER_NEAR - (((zi + 1) * INNER_RAMP_LENGTH) // INNER_RAMP_Z_SEGMENTS)
        let y0:int = fp_mul(Z_INNER_NEAR - z0 INNER_RAMP_TAN)
        let y1:int = fp_mul(Z_INNER_NEAR - z1 INNER_RAMP_TAN)
        let wi:int = 0
        loop wi <? INNER_RAMP_W_SEGMENTS {
            let x0:int = (0 - INNER_RAMP_HALF_W) + ((wi * (2 * INNER_RAMP_HALF_W)) // INNER_RAMP_W_SEGMENTS)
            let x1:int = (0 - INNER_RAMP_HALF_W) + (((wi + 1) * (2 * INNER_RAMP_HALF_W)) // INNER_RAMP_W_SEGMENTS)
            let cell:int = (zi + wi) and 1
            let rr:int = r_a
            let gg:int = g_a
            let bb:int = b_a
            if cell =? 0 {
                rr = r_b
                gg = g_b
                bb = b_b
            }
            glBegin(GL_QUADS)
            GL_Color3f(rr gg bb)
            world_v3(x0 y0 z0)
            world_v3(x1 y0 z0)
            world_v3(x1 y1 z1)
            world_v3(x0 y1 z1)
            glEnd()
            wi += 1
        }
        zi += 1
    }
    glBegin(GL_TRIANGLES)
    GL_Color3f(r_s g_s b_s)
    world_v3(0 - INNER_RAMP_HALF_W 0 Z_INNER_NEAR)
    world_v3(0 - INNER_RAMP_HALF_W 0 Z_INNER_FAR)
    world_v3(0 - INNER_RAMP_HALF_W INNER_RAMP_HEIGHT Z_INNER_FAR)
    world_v3(INNER_RAMP_HALF_W 0 Z_INNER_NEAR)
    world_v3(INNER_RAMP_HALF_W INNER_RAMP_HEIGHT Z_INNER_FAR)
    world_v3(INNER_RAMP_HALF_W 0 Z_INNER_FAR)
    glEnd()
    return 0
}

# ---- Sphere outer-access ramp (centered x=+30, slope ~42 deg) ----
let draw_outer_ramp = ():>void => {
    let r_a:int = q16_to_f32(COL_OUTER_RAMP_A_R)
    let g_a:int = q16_to_f32(COL_OUTER_RAMP_A_G)
    let b_a:int = q16_to_f32(COL_OUTER_RAMP_A_B)
    let r_b:int = q16_to_f32(COL_OUTER_RAMP_B_R)
    let g_b:int = q16_to_f32(COL_OUTER_RAMP_B_G)
    let b_b:int = q16_to_f32(COL_OUTER_RAMP_B_B)
    let r_s:int = q16_to_f32(COL_OUTER_RAMP_SIDE_R)
    let g_s:int = q16_to_f32(COL_OUTER_RAMP_SIDE_G)
    let b_s:int = q16_to_f32(COL_OUTER_RAMP_SIDE_B)
    let xc:int = OUTER_RAMP_X_CENTER
    let zi:int = 0
    loop zi <? OUTER_RAMP_Z_SEGMENTS {
        let z0:int = Z_OUTER_NEAR - ((zi * OUTER_RAMP_LENGTH) // OUTER_RAMP_Z_SEGMENTS)
        let z1:int = Z_OUTER_NEAR - (((zi + 1) * OUTER_RAMP_LENGTH) // OUTER_RAMP_Z_SEGMENTS)
        let y0:int = fp_mul(Z_OUTER_NEAR - z0 OUTER_RAMP_TAN)
        let y1:int = fp_mul(Z_OUTER_NEAR - z1 OUTER_RAMP_TAN)
        let wi:int = 0
        loop wi <? OUTER_RAMP_W_SEGMENTS {
            let x0:int = xc + (0 - OUTER_RAMP_HALF_W) + ((wi * (2 * OUTER_RAMP_HALF_W)) // OUTER_RAMP_W_SEGMENTS)
            let x1:int = xc + (0 - OUTER_RAMP_HALF_W) + (((wi + 1) * (2 * OUTER_RAMP_HALF_W)) // OUTER_RAMP_W_SEGMENTS)
            let cell:int = (zi + wi) and 1
            let rr:int = r_a
            let gg:int = g_a
            let bb:int = b_a
            if cell =? 0 {
                rr = r_b
                gg = g_b
                bb = b_b
            }
            glBegin(GL_QUADS)
            GL_Color3f(rr gg bb)
            world_v3(x0 y0 z0)
            world_v3(x1 y0 z0)
            world_v3(x1 y1 z1)
            world_v3(x0 y1 z1)
            glEnd()
            wi += 1
        }
        zi += 1
    }
    glBegin(GL_TRIANGLES)
    GL_Color3f(r_s g_s b_s)
    world_v3(xc - OUTER_RAMP_HALF_W 0 Z_OUTER_NEAR)
    world_v3(xc - OUTER_RAMP_HALF_W 0 Z_OUTER_FAR)
    world_v3(xc - OUTER_RAMP_HALF_W OUTER_RAMP_HEIGHT Z_OUTER_FAR)
    world_v3(xc + OUTER_RAMP_HALF_W 0 Z_OUTER_NEAR)
    world_v3(xc + OUTER_RAMP_HALF_W OUTER_RAMP_HEIGHT Z_OUTER_FAR)
    world_v3(xc + OUTER_RAMP_HALF_W 0 Z_OUTER_FAR)
    glEnd()
    return 0
}

# ---- Sphere with polar-cap hole on +Z face ----
# Latitude is measured from the +Z polar axis (so lat=0 is the +Z pole and
# the hole sits in a polar cap). Bands whose far edge is still inside the
# hole's half-angle are skipped entirely; partially-covered bands are
# drawn unmodified (a fringe of the hole rim shows but reads OK because
# the hole is a bowl, not a clean disc). With back-face culling off (the
# udewy default) each quad is visible from both inside and outside, so
# the inner cavity is naturally lit.
let draw_sphere = ():>void => {
    let r_oa:int = q16_to_f32(COL_SPHERE_OUT_A_R)
    let g_oa:int = q16_to_f32(COL_SPHERE_OUT_A_G)
    let b_oa:int = q16_to_f32(COL_SPHERE_OUT_A_B)
    let r_ob:int = q16_to_f32(COL_SPHERE_OUT_B_R)
    let g_ob:int = q16_to_f32(COL_SPHERE_OUT_B_G)
    let b_ob:int = q16_to_f32(COL_SPHERE_OUT_B_B)
    let r_rim:int = q16_to_f32(COL_SPHERE_RIM_R)
    let g_rim:int = q16_to_f32(COL_SPHERE_RIM_G)
    let b_rim:int = q16_to_f32(COL_SPHERE_RIM_B)

    # Hole cap: polar angle from +Z axis < 45 deg (half-turn-units).
    let hole_lat:int = ANG_HALF_TURN // 4    # 45 deg in (0..ANG_HALF_TURN) lat space

    let lat:int = 0
    loop lat <? SPHERE_LAT_BANDS {
        let phi0:int = (lat * ANG_HALF_TURN) // SPHERE_LAT_BANDS
        let phi1:int = ((lat + 1) * ANG_HALF_TURN) // SPHERE_LAT_BANDS
        if phi1 >? hole_lat {
            let cphi0:int = cos_fp(phi0)
            let sphi0:int = sin_fp(phi0)
            let cphi1:int = cos_fp(phi1)
            let sphi1:int = sin_fp(phi1)

            # Rim band (the one whose near edge straddles the hole): paint
            # gold so the hole reads visually.
            let is_rim:int = 0
            if (phi0 <=? hole_lat) and (phi1 >? hole_lat) {
                is_rim = 1
            }

            let lon:int = 0
            loop lon <? SPHERE_LON_BANDS {
                let theta0:int = (lon * ANG_TURN) // SPHERE_LON_BANDS
                let theta1:int = ((lon + 1) * ANG_TURN) // SPHERE_LON_BANDS
                let cth0:int = cos_fp(theta0)
                let sth0:int = sin_fp(theta0)
                let cth1:int = cos_fp(theta1)
                let sth1:int = sin_fp(theta1)

                let cell:int = (lat + lon) and 1
                let rr:int = r_oa
                let gg:int = g_oa
                let bb:int = b_oa
                if cell =? 0 {
                    rr = r_ob
                    gg = g_ob
                    bb = b_ob
                }
                if is_rim not=? 0 {
                    rr = r_rim
                    gg = g_rim
                    bb = b_rim
                }

                # Vertex (sphere-local, +Z polar axis):
                #   x = R * sin(phi) * cos(theta)
                #   y = R * sin(phi) * sin(theta)
                #   z = R * cos(phi)
                let x00:int = SPHERE_CX + fp_mul(SPHERE_R fp_mul(sphi0 cth0))
                let y00:int = SPHERE_CY + fp_mul(SPHERE_R fp_mul(sphi0 sth0))
                let z00:int = SPHERE_CZ + fp_mul(SPHERE_R cphi0)
                let x01:int = SPHERE_CX + fp_mul(SPHERE_R fp_mul(sphi0 cth1))
                let y01:int = SPHERE_CY + fp_mul(SPHERE_R fp_mul(sphi0 sth1))
                let z01:int = SPHERE_CZ + fp_mul(SPHERE_R cphi0)
                let x11:int = SPHERE_CX + fp_mul(SPHERE_R fp_mul(sphi1 cth1))
                let y11:int = SPHERE_CY + fp_mul(SPHERE_R fp_mul(sphi1 sth1))
                let z11:int = SPHERE_CZ + fp_mul(SPHERE_R cphi1)
                let x10:int = SPHERE_CX + fp_mul(SPHERE_R fp_mul(sphi1 cth0))
                let y10:int = SPHERE_CY + fp_mul(SPHERE_R fp_mul(sphi1 sth0))
                let z10:int = SPHERE_CZ + fp_mul(SPHERE_R cphi1)

                glBegin(GL_QUADS)
                GL_Color3f(rr gg bb)
                world_v3(x00 y00 z00)
                world_v3(x01 y01 z01)
                world_v3(x11 y11 z11)
                world_v3(x10 y10 z10)
                glEnd()
                lon += 1
            }
        }
        lat += 1
    }
    return 0
}

# Two parallel walls bounding the corridor. Inner faces tessellated and
# checkered along z for motion cues; tops and outer faces flat-shaded.
# End caps closed at both Z seams so the slabs read as solid blocks.
let draw_walls = ():>void => {
    let r_a:int = q16_to_f32(COL_WALL_A_R)
    let g_a:int = q16_to_f32(COL_WALL_A_G)
    let b_a:int = q16_to_f32(COL_WALL_A_B)
    let r_b:int = q16_to_f32(COL_WALL_B_R)
    let g_b:int = q16_to_f32(COL_WALL_B_G)
    let b_b:int = q16_to_f32(COL_WALL_B_B)
    let r_top:int = q16_to_f32(COL_WALL_TOP_R)
    let g_top:int = q16_to_f32(COL_WALL_TOP_G)
    let b_top:int = q16_to_f32(COL_WALL_TOP_B)
    let r_out:int = q16_to_f32(COL_WALL_OUT_R)
    let g_out:int = q16_to_f32(COL_WALL_OUT_G)
    let b_out:int = q16_to_f32(COL_WALL_OUT_B)

    let xR_in:int = CORRIDOR_HALF_W
    let xR_out:int = CORRIDOR_HALF_W + WALL_THICKNESS
    let xL_in:int = 0 - CORRIDOR_HALF_W
    let xL_out:int = (0 - CORRIDOR_HALF_W) - WALL_THICKNESS

    let zi:int = 0
    loop zi <? WALL_Z_SEGMENTS {
        let z0:int = Z_WALL_START - ((zi * WALL_LENGTH) // WALL_Z_SEGMENTS)
        let z1:int = Z_WALL_START - (((zi + 1) * WALL_LENGTH) // WALL_Z_SEGMENTS)

        let cell:int = zi and 1
        let rr:int = r_a
        let gg:int = g_a
        let bb:int = b_a
        if cell =? 0 {
            rr = r_b
            gg = g_b
            bb = b_b
        }

        # Right wall inner face (faces -x).
        glBegin(GL_QUADS)
        GL_Color3f(rr gg bb)
        world_v3(xR_in 0 z0)
        world_v3(xR_in WALL_HEIGHT z0)
        world_v3(xR_in WALL_HEIGHT z1)
        world_v3(xR_in 0 z1)
        glEnd()

        # Right wall top.
        glBegin(GL_QUADS)
        GL_Color3f(r_top g_top b_top)
        world_v3(xR_in WALL_HEIGHT z0)
        world_v3(xR_out WALL_HEIGHT z0)
        world_v3(xR_out WALL_HEIGHT z1)
        world_v3(xR_in WALL_HEIGHT z1)
        glEnd()

        # Right wall outer face (faces +x).
        glBegin(GL_QUADS)
        GL_Color3f(r_out g_out b_out)
        world_v3(xR_out WALL_HEIGHT z0)
        world_v3(xR_out 0 z0)
        world_v3(xR_out 0 z1)
        world_v3(xR_out WALL_HEIGHT z1)
        glEnd()

        # Left wall inner face (faces +x).
        glBegin(GL_QUADS)
        GL_Color3f(rr gg bb)
        world_v3(xL_in 0 z0)
        world_v3(xL_in 0 z1)
        world_v3(xL_in WALL_HEIGHT z1)
        world_v3(xL_in WALL_HEIGHT z0)
        glEnd()

        # Left wall top.
        glBegin(GL_QUADS)
        GL_Color3f(r_top g_top b_top)
        world_v3(xL_in WALL_HEIGHT z0)
        world_v3(xL_in WALL_HEIGHT z1)
        world_v3(xL_out WALL_HEIGHT z1)
        world_v3(xL_out WALL_HEIGHT z0)
        glEnd()

        # Left wall outer face (faces -x).
        glBegin(GL_QUADS)
        GL_Color3f(r_out g_out b_out)
        world_v3(xL_out 0 z0)
        world_v3(xL_out 0 z1)
        world_v3(xL_out WALL_HEIGHT z1)
        world_v3(xL_out WALL_HEIGHT z0)
        glEnd()

        zi += 1
    }

    # End caps at both Z seams so the slabs read as solid blocks rather
    # than open shells when viewed from off-axis.
    glBegin(GL_QUADS)
    GL_Color3f(r_out g_out b_out)
    # Right wall, near end (z = Z_WALL_START), face normal +z.
    world_v3(xR_in 0 Z_WALL_START)
    world_v3(xR_in WALL_HEIGHT Z_WALL_START)
    world_v3(xR_out WALL_HEIGHT Z_WALL_START)
    world_v3(xR_out 0 Z_WALL_START)
    # Right wall, far end (z = Z_WALL_END), face normal -z.
    world_v3(xR_out 0 Z_WALL_END)
    world_v3(xR_out WALL_HEIGHT Z_WALL_END)
    world_v3(xR_in WALL_HEIGHT Z_WALL_END)
    world_v3(xR_in 0 Z_WALL_END)
    # Left wall, near end.
    world_v3(xL_out 0 Z_WALL_START)
    world_v3(xL_out WALL_HEIGHT Z_WALL_START)
    world_v3(xL_in WALL_HEIGHT Z_WALL_START)
    world_v3(xL_in 0 Z_WALL_START)
    # Left wall, far end.
    world_v3(xL_in 0 Z_WALL_END)
    world_v3(xL_in WALL_HEIGHT Z_WALL_END)
    world_v3(xL_out WALL_HEIGHT Z_WALL_END)
    world_v3(xL_out 0 Z_WALL_END)
    glEnd()
    return 0
}

# Engine trail ring buffer. (Storage and head/count declared above with the
# other physics globals so reset_craft can clear them.) Walking the ring
# "oldest to newest" is (trail_head + i) % TRAIL_LEN once full, else (i).
let trail_push = ():>void => {
    let ex:int = cx + fp_mul(ux TRAIL_OFFSET_UP) - fp_mul(fx TRAIL_OFFSET_BACK)
    let ey:int = cy + fp_mul(uy TRAIL_OFFSET_UP) - fp_mul(fy TRAIL_OFFSET_BACK)
    let ez:int = cz + fp_mul(uz TRAIL_OFFSET_UP) - fp_mul(fz TRAIL_OFFSET_BACK)
    # Boost intensity at emission time, Q16 in [0, FP_ONE]. Stored per-sample
    # so the afterburner flare persists in the ribbon even after boost ends.
    let boost_q:int = 0
    if boost_active_frames >? 0 {
        boost_q = (boost_active_frames * FP_ONE) // BOOST_DURATION
    }
    let o:int = TRAIL_BUF + (trail_head * TRAIL_STRIDE)
    __store__(ex o)
    __store__(ey (o + 8))
    __store__(ez (o + 16))
    __store__(rx (o + 24))
    __store__(ry (o + 32))
    __store__(rz (o + 40))
    __store__(boost_q (o + 48))
    trail_head = (trail_head + 1) % TRAIL_LEN
    if trail_count <? TRAIL_LEN {
        trail_count += 1
    }
    return 0
}

let draw_trail = ():>void => {
    if trail_count <? 2 {
        return 0
    }
    glEnable(GL_BLEND)
    glBlendFunc(GL_SRC_ALPHA GL_ONE_MINUS_SRC_ALPHA)
    glDepthMask(0)

    let oldest:int = 0
    if trail_count =? TRAIL_LEN {
        oldest = trail_head
    }

    glBegin(GL_QUAD_STRIP)
    let i:int = 0
    let denom:int = trail_count - 1
    loop i <? trail_count {
        let idx:int = (oldest + i) % TRAIL_LEN
        let o:int = TRAIL_BUF + (idx * TRAIL_STRIDE)
        let px:int = __load__(o)
        let py:int = __load__((o + 8))
        let pz:int = __load__((o + 16))
        let drx:int = __load__((o + 24))
        let dry:int = __load__((o + 32))
        let drz:int = __load__((o + 40))
        let boost_q:int = __load__(o + 48)

        # Age fraction: 0 at oldest sample, FP_ONE at newest.
        let age_q:int = (i * FP_ONE) // denom
        # Width tapers from 25% (oldest) to 100% (newest) of TRAIL_HALF_W,
        # then up to 2.5x while a boost is active at this sample.
        let w_scale:int = FP_QUARTER + ((age_q * 3) // 4)
        let w_boost:int = FP_ONE + fp_mul(boost_q 98304)    # 1.0 .. 2.5
        let w:int = fp_mul(TRAIL_HALF_W fp_mul(w_scale w_boost))
        let wx:int = fp_mul(drx w)
        let wy:int = fp_mul(dry w)
        let wz:int = fp_mul(drz w)

        # Alpha cubes for a stronger fade near the tail; cap newest at 0.85.
        # Boost lifts the floor so old hot segments stay punchy.
        let a_q:int = fp_mul(fp_mul(age_q age_q) age_q)
        a_q = fp_mul(a_q 55705)
        let a_boost_floor:int = fp_mul(boost_q 45875)       # up to ~0.7
        if a_q <? a_boost_floor {
            a_q = a_boost_floor
        }
        let af:int = q16_to_f32(a_q)

        # Base color: deep red (oldest) -> bright orange (newest).
        # Afterburner color: deep cyan (oldest) -> white-cyan (newest).
        # Lerp base toward afterburner by boost_q.
        let r_base:int = 39321 + ((age_q * 26214) // FP_ONE)    # 0.6 -> 1.0
        let g_base:int = 6553 + ((age_q * 39322) // FP_ONE)     # 0.1 -> 0.7
        let b_base:int = (age_q * 13107) // FP_ONE              # 0.0 -> 0.2

        let r_aft:int = 26214 + ((age_q * 39322) // FP_ONE)     # 0.4 -> 1.0
        let g_aft:int = 45875 + ((age_q * 19661) // FP_ONE)     # 0.7 -> 1.0
        let b_aft:int = FP_ONE                                  # 1.0

        let r_q:int = r_base + fp_mul(boost_q (r_aft - r_base))
        let g_q:int = g_base + fp_mul(boost_q (g_aft - g_base))
        let b_q:int = b_base + fp_mul(boost_q (b_aft - b_base))
        GL_Color4f(q16_to_f32(r_q) q16_to_f32(g_q) q16_to_f32(b_q) af)

        world_v3(px - wx py - wy pz - wz)
        world_v3(px + wx py + wy pz + wz)
        i += 1
    }
    glEnd()

    glDepthMask(1)
    glDisable(GL_BLEND)
    return 0
}

# Spawn `count` particles at (px, py, pz) with outward unit direction
# (nx, ny, nz). Each spark gets a random speed around SPARK_BASE_SPEED,
# tangential jitter, and a small upward bias so the burst arcs up before
# falling. Slots are overwritten in ring-buffer order so we never search
# for free space.
let spark_emit = (px:int py:int pz:int nx:int ny:int nz:int count:int):>void => {
    let i:int = 0
    loop i <? count {
        let slot:int = SPARK_BUF + (spark_head * SPARK_STRIDE)
        spark_head = (spark_head + 1) % SPARK_MAX

        let speed:int = SPARK_BASE_SPEED + xs_range(SPARK_SPEED_VAR) - (SPARK_SPEED_VAR // 2)
        let jx:int = xs_range(SPARK_JITTER * 2) - SPARK_JITTER
        let jy:int = xs_range(SPARK_JITTER * 2) - SPARK_JITTER
        let jz:int = xs_range(SPARK_JITTER * 2) - SPARK_JITTER

        let vx:int = fp_mul(nx speed) + jx
        let vy:int = fp_mul(ny speed) + jy + SPARK_UP_BIAS
        let vz:int = fp_mul(nz speed) + jz

        __store__(px slot)
        __store__(py (slot + 8))
        __store__(pz (slot + 16))
        __store__(vx (slot + 24))
        __store__(vy (slot + 32))
        __store__(vz (slot + 40))
        __store__(FP_ONE (slot + 48))
        i += 1
    }
    return 0
}

# Step every live particle: position += velocity, vy -= gravity, life decays.
# Done unconditionally on dead slots too -- the only state that matters is
# the life field, which the draw loop checks.
let spark_step = ():>void => {
    let i:int = 0
    loop i <? SPARK_MAX {
        let slot:int = SPARK_BUF + (i * SPARK_STRIDE)
        let life:int = __load__(slot + 48)
        if life >? 0 {
            let x:int = __load__(slot)
            let y:int = __load__(slot + 8)
            let z:int = __load__(slot + 16)
            let vx:int = __load__(slot + 24)
            let vy:int = __load__(slot + 32)
            let vz:int = __load__(slot + 40)

            x += vx
            y += vy
            z += vz
            vy -= SPARK_GRAVITY
            life -= SPARK_LIFE_DECAY
            if life <? 0 {
                life = 0
            }

            __store__(x slot)
            __store__(y (slot + 8))
            __store__(z (slot + 16))
            __store__(vy (slot + 32))
            __store__(life (slot + 48))
        }
        i += 1
    }
    return 0
}

# Render live sparks as additive 3D streaks. Color shifts hot-yellow ->
# orange -> red as life decays; the "tail" end fades to transparent so
# every spark reads as a moving point trailed by motion blur.
let draw_sparks = ():>void => {
    glEnable(GL_BLEND)
    glBlendFunc(GL_SRC_ALPHA GL_ONE)
    glDepthMask(0)
    GL_LineWidth(GL_F32_FromInt(2))

    glBegin(GL_LINES)
    let i:int = 0
    loop i <? SPARK_MAX {
        let slot:int = SPARK_BUF + (i * SPARK_STRIDE)
        let life:int = __load__(slot + 48)
        if life >? 0 {
            let x:int = __load__(slot)
            let y:int = __load__(slot + 8)
            let z:int = __load__(slot + 16)
            let vx:int = __load__(slot + 24)
            let vy:int = __load__(slot + 32)
            let vz:int = __load__(slot + 40)

            let tx:int = x - fp_mul(vx SPARK_TAIL_Q)
            let ty:int = y - fp_mul(vy SPARK_TAIL_Q)
            let tz:int = z - fp_mul(vz SPARK_TAIL_Q)

            let g_q:int = fp_mul(life FP_ONE)
            let b_q:int = fp_mul(life 19660)
            let a_q:int = life

            GL_Color4f(F32_ONE q16_to_f32(g_q) q16_to_f32(b_q) q16_to_f32(a_q))
            world_v3(x y z)
            GL_Color4f(F32_ONE q16_to_f32(g_q) q16_to_f32(b_q) F32_ZERO)
            world_v3(tx ty tz)
        }
        i += 1
    }
    glEnd()

    glDepthMask(1)
    glDisable(GL_BLEND)
    return 0
}

# Seed the xorshift+ stream and populate every speed-line slot with an
# independent random phase / angle / origin. Called once at startup so
# streaks are already scattered the first frame they're visible.
let speed_lines_init = ():>void => {
    xs_seed(0xC0FFEE)
    let i:int = 0
    loop i <? SPEED_LINES_N {
        let slot:int = SPEED_LINE_STATE + (i * SPEED_LINE_STRIDE)
        __store__(xs_range(FP_ONE) slot)
        __store__(xs_range(ANG_TURN) (slot + 8))
        __store__(xs_range(FP_ONE) (slot + 16))
        i += 1
    }
    return 0
}

# Screen-space radial speed lines drawn over the 3D scene as a 2D ortho
# overlay. Each streak owns its phase, angle, and start radius (see
# speed_lines_init). At lifetime wrap we draw fresh values from the
# xorshift+ stream so successive lifetimes are uncorrelated -- no spokes,
# no pinwheel, just continuous random streaks.
let draw_speed_lines = (sw:int sh:int):>void => {
    if vis_boost_norm <=? SPEED_LINE_THRESHOLD {
        return 0
    }
    let above:int = vis_boost_norm - SPEED_LINE_THRESHOLD
    let intensity:int = (above << 16) // (FP_ONE - SPEED_LINE_THRESHOLD)
    if intensity >? FP_ONE {
        intensity = FP_ONE
    }

    glMatrixMode(GL_PROJECTION)
    glPushMatrix()
    glLoadIdentity()
    GL_Ortho(q16_to_f64(0) q16_to_f64(sw * FP_ONE) q16_to_f64(sh * FP_ONE) q16_to_f64(0) q16_to_f64(0 - FP_ONE) q16_to_f64(FP_ONE))
    glMatrixMode(GL_MODELVIEW)
    glPushMatrix()
    glLoadIdentity()

    glDisable(GL_DEPTH_TEST)
    glEnable(GL_BLEND)
    glBlendFunc(GL_SRC_ALPHA GL_ONE_MINUS_SRC_ALPHA)
    GL_LineWidth(GL_F32_FromInt(2))

    let cx_px:int = sw // 2
    let cy_px:int = sh // 2
    # fp_sqrt is just an integer sqrt; pass plain pixel^2 (no Q16 shift)
    # so the result is also in pixels. Without this, max_r_px collapsed
    # to ~2 px and every streak clustered at the screen center.
    let max_r_px:int = fp_sqrt((cx_px * cx_px) + (cy_px * cy_px))

    # Speed and per-streak brightness are constant -- we don't slow streaks
    # down at lower intensity, we just have fewer of them alive. Density
    # follows a squared curve so it ramps up slowly at first then fills in
    # quickly toward top boost (closer to "exponential" feel than linear).
    let rate:int = SPEED_LINE_RATE_Q
    let peak_a:int = SPEED_LINE_PEAK_ALPHA_Q
    let density:int = fp_mul(intensity intensity)
    let active_count:int = (SPEED_LINES_N * density) // FP_ONE

    # Per-frame jitter amplitude in raw pixels, still scaled by intensity
    # so the shake reads as "going faster" rather than constant noise.
    let shake_px:int = (SPEED_LINE_SHAKE_PX * intensity) // FP_ONE

    glBegin(GL_LINES)
    let i:int = 0
    loop i <? SPEED_LINES_N {
        let slot:int = SPEED_LINE_STATE + (i * SPEED_LINE_STRIDE)
        let phase:int = __load__(slot) + rate
        let angle_idx:int = __load__(slot + 8)
        let r_seed:int = __load__(slot + 16)
        # Lifetime wrap: respawn at a fresh random angle and origin. Roll
        # over phase via subtraction so the spawn moment isn't quantized.
        if phase >=? FP_ONE {
            phase -= FP_ONE
            angle_idx = xs_range(ANG_TURN)
            r_seed = xs_range(FP_ONE)
        }
        __store__(phase slot)
        __store__(angle_idx (slot + 8))
        __store__(r_seed (slot + 16))

        # Inactive slots still tick their state so when density grows they
        # don't pop in mid-pulse -- they're already cycling through respawns.
        if i >=? active_count {
            i += 1
            continue
        }

        let cos_a:int = cos_fp(angle_idx)
        let sin_a:int = sin_fp(angle_idx)

        # Distance in pixels from screen center to where this ray exits the
        # screen rectangle: min(cx/|cos|, cy/|sin|).
        let abs_cos:int = cos_a
        if abs_cos <? 0 {
            abs_cos = 0 - abs_cos
        }
        let abs_sin:int = sin_a
        if abs_sin <? 0 {
            abs_sin = 0 - abs_sin
        }
        let edge_r:int = max_r_px
        if abs_cos >? 1024 {
            let d:int = (cx_px * FP_ONE) // abs_cos
            if d <? edge_r {
                edge_r = d
            }
        }
        if abs_sin >? 1024 {
            let d:int = (cy_px * FP_ONE) // abs_sin
            if d <? edge_r {
                edge_r = d
            }
        }

        # Origin sits anywhere along the ray (random per lifetime); end
        # sits a little past the edge so the line truly exits the screen.
        let start_r:int = (r_seed * edge_r) // FP_ONE
        let end_r:int = edge_r + SPEED_LINE_OVERSHOOT_PX

        let dx0:int = __signed_shr__(start_r * cos_a FP_SHIFT)
        let dy0:int = __signed_shr__(start_r * sin_a FP_SHIFT)
        let dx1:int = __signed_shr__(end_r * cos_a FP_SHIFT)
        let dy1:int = __signed_shr__(end_r * sin_a FP_SHIFT)

        # Per-streak per-frame translational jitter. Two independent sin
        # phases give an apparently chaotic 2D wobble; both endpoints share
        # the offset so the line translates without changing length.
        let jx_phase:int = ((frame_count * 71) + (i * 197)) % ANG_TURN
        let jy_phase:int = ((frame_count * 53) + (i * 311)) % ANG_TURN
        let jx_q:int = sin_fp(jx_phase)
        let jy_q:int = sin_fp(jy_phase)
        let jx_px:int = __signed_shr__(jx_q * shake_px FP_SHIFT)
        let jy_px:int = __signed_shr__(jy_q * shake_px FP_SHIFT)

        # sin(pi * phase) -> alpha rises from 0, peaks mid-cycle, fades to 0.
        let fade_q:int = sin_fp((phase * ANG_HALF_TURN) // FP_ONE)
        let alpha_q:int = fp_mul(peak_a fade_q)
        let alpha_f32:int = q16_to_f32(alpha_q)

        # Trailing end (origin side) is transparent, leading end (screen
        # edge side) carries the full alpha -- gives each streak a comet
        # tail that reads as outward motion.
        GL_Color4f(F32_ONE F32_ONE F32_ONE F32_ZERO)
        GL_Vertex3f(GL_F32_FromInt(cx_px + dx0 + jx_px) GL_F32_FromInt(cy_px + dy0 + jy_px) F32_ZERO)
        GL_Color4f(F32_ONE F32_ONE F32_ONE alpha_f32)
        GL_Vertex3f(GL_F32_FromInt(cx_px + dx1 + jx_px) GL_F32_FromInt(cy_px + dy1 + jy_px) F32_ZERO)
        i += 1
    }
    glEnd()

    glDisable(GL_BLEND)
    glEnable(GL_DEPTH_TEST)
    glMatrixMode(GL_PROJECTION)
    glPopMatrix()
    glMatrixMode(GL_MODELVIEW)
    glPopMatrix()
    return 0
}

# Hover bob offset along the surface up vector (visual only; physics and
# camera ignore it). Recomputed once per draw_craft via update_bob() and
# baked into bob_off_x/y/z so every craft_emit call shares the same offset.
let bob_off_x:int = 0
let bob_off_y:int = 0
let bob_off_z:int = 0

let update_bob = ():>void => {
    let phase:int = (frame_count * BOB_FREQ_NUM) // BOB_FREQ_DEN
    phase = phase % ANG_TURN
    if phase <? 0 {
        phase += ANG_TURN
    }
    let s:int = sin_fp(phase)
    let amp:int = fp_mul(BOB_AMP s)
    bob_off_x = fp_mul(ux amp)
    bob_off_y = fp_mul(uy amp)
    bob_off_z = fp_mul(uz amp)
    return 0
}

let craft_emit = (lx:int ly:int lz:int):>void => {
    let wx:int = cx + bob_off_x + fp_mul(vrx lx) + fp_mul(vux ly) + fp_mul(vfx lz)
    let wy:int = cy + bob_off_y + fp_mul(vry lx) + fp_mul(vuy ly) + fp_mul(vfy lz)
    let wz:int = cz + bob_off_z + fp_mul(vrz lx) + fp_mul(vuz ly) + fp_mul(vfz lz)
    world_v3(wx wy wz)
    return 0
}

let draw_craft = ():>void => {
    update_bob()
    let nose_z:int = 229376
    let tail_z:int = 0 - 131072
    let wing_x:int = 163840
    let body_y_top:int = 39321
    let body_y_bot:int = 0 - 13107
    let canopy_z:int = 65536
    let canopy_y:int = 78643

    let body_r:int = q16_to_f32(13107)
    let body_g:int = q16_to_f32(45875)
    let body_b:int = q16_to_f32(58982)
    let belly_r:int = q16_to_f32(6553)
    let belly_g:int = q16_to_f32(13107)
    let belly_b:int = q16_to_f32(32768)
    let side_r:int = q16_to_f32(6553)
    let side_g:int = q16_to_f32(26214)
    let side_b:int = q16_to_f32(45875)
    let canopy_r:int = q16_to_f32(58982)
    let canopy_g:int = q16_to_f32(58982)
    let canopy_b:int = F32_ONE
    # Engine glow color/size shifts toward bright cyan-white afterburner
    # while a boost window is active.
    let boost_q:int = 0
    if boost_active_frames >? 0 {
        boost_q = (boost_active_frames * FP_ONE) // BOOST_DURATION
    }
    let base_r:int = FP_ONE
    let base_g:int = 45875
    let base_b:int = 6553
    let aft_r:int = 58982          # 0.9
    let aft_g:int = FP_ONE
    let aft_b:int = FP_ONE
    let glow_r_q:int = base_r + fp_mul(boost_q (aft_r - base_r))
    let glow_g_q:int = base_g + fp_mul(boost_q (aft_g - base_g))
    let glow_b_q:int = base_b + fp_mul(boost_q (aft_b - base_b))
    let glow_r:int = q16_to_f32(glow_r_q)
    let glow_g:int = q16_to_f32(glow_g_q)
    let glow_b:int = q16_to_f32(glow_b_q)

    glBegin(GL_TRIANGLES)
    GL_Color3f(body_r body_g body_b)
    craft_emit(0 body_y_top nose_z)
    craft_emit(0 - wing_x body_y_top tail_z)
    craft_emit(wing_x body_y_top tail_z)
    glEnd()
    glBegin(GL_TRIANGLES)
    GL_Color3f(belly_r belly_g belly_b)
    craft_emit(0 body_y_bot nose_z)
    craft_emit(wing_x body_y_bot tail_z)
    craft_emit(0 - wing_x body_y_bot tail_z)
    glEnd()
    glBegin(GL_TRIANGLES)
    GL_Color3f(side_r side_g side_b)
    craft_emit(0 body_y_top nose_z)
    craft_emit(0 - wing_x body_y_bot tail_z)
    craft_emit(0 - wing_x body_y_top tail_z)
    craft_emit(0 body_y_top nose_z)
    craft_emit(0 body_y_bot nose_z)
    craft_emit(0 - wing_x body_y_bot tail_z)
    glEnd()
    glBegin(GL_TRIANGLES)
    GL_Color3f(side_r side_g side_b)
    craft_emit(0 body_y_top nose_z)
    craft_emit(wing_x body_y_top tail_z)
    craft_emit(wing_x body_y_bot tail_z)
    craft_emit(0 body_y_top nose_z)
    craft_emit(wing_x body_y_bot tail_z)
    craft_emit(0 body_y_bot nose_z)
    glEnd()
    glBegin(GL_TRIANGLES)
    GL_Color3f(canopy_r canopy_g canopy_b)
    craft_emit(0 canopy_y canopy_z)
    craft_emit(0 - 26214 body_y_top 0)
    craft_emit(26214 body_y_top 0)
    glEnd()
    # Base nozzle quad, scaled up to ~1.7x while boosting.
    let glow_scale:int = FP_ONE + fp_mul(boost_q 45875)         # 1.0 .. 1.7
    let glow_x:int = fp_mul(65536 glow_scale)
    let glow_y_bot:int = 0
    let glow_y_top:int = fp_mul(26214 glow_scale)
    glBegin(GL_QUADS)
    GL_Color3f(glow_r glow_g glow_b)
    craft_emit(0 - glow_x glow_y_bot tail_z)
    craft_emit(glow_x glow_y_bot tail_z)
    craft_emit(glow_x glow_y_top tail_z)
    craft_emit(0 - glow_x glow_y_top tail_z)
    glEnd()

    # Afterburner flare: an additively blended halo that streaks behind
    # the nozzle while boost is active. Larger than the base nozzle and
    # positioned slightly further back so it reads as exhaust plume.
    if boost_q >? 0 {
        glEnable(GL_BLEND)
        glBlendFunc(GL_SRC_ALPHA GL_ONE)
        glDepthMask(0)

        let halo_x:int = fp_mul(glow_x 26214)                   # ~+60% wider
        halo_x = (halo_x // FP_ONE) + glow_x
        let halo_y_top:int = fp_mul(glow_y_top 26214)
        halo_y_top = (halo_y_top // FP_ONE) + glow_y_top
        let halo_y_bot:int = 0 - (halo_y_top // 3)
        let halo_z:int = tail_z - fp_mul(boost_q 65536)         # up to 1 m back
        let halo_a:int = q16_to_f32(fp_mul(boost_q 52428))      # peaks ~0.8

        glBegin(GL_QUADS)
        GL_Color4f(glow_r glow_g glow_b halo_a)
        craft_emit(0 - halo_x halo_y_bot halo_z)
        craft_emit(halo_x halo_y_bot halo_z)
        craft_emit(halo_x halo_y_top halo_z)
        craft_emit(0 - halo_x halo_y_top halo_z)
        glEnd()

        glDepthMask(1)
        glDisable(GL_BLEND)
    }
    return 0
}

# ---------- HUD --------------------------------------------------------------
# F-Zero GX inspired overlay: gradient energy bar (top-right) plus large
# 7-segment km/h speedometer (bottom-right). All drawn in a 2D ortho pass
# after the 3D scene with depth test off.

# Emit one screen-space rectangle as a GL_QUADS quad. Caller is responsible
# for calling glBegin(GL_QUADS) / glEnd() and setting color before/between.
let hud_quad = (x0:int y0:int x1:int y1:int):>void => {
    GL_Vertex3f(GL_F32_FromInt(x0) GL_F32_FromInt(y0) F32_ZERO)
    GL_Vertex3f(GL_F32_FromInt(x0) GL_F32_FromInt(y1) F32_ZERO)
    GL_Vertex3f(GL_F32_FromInt(x1) GL_F32_FromInt(y1) F32_ZERO)
    GL_Vertex3f(GL_F32_FromInt(x1) GL_F32_FromInt(y0) F32_ZERO)
    return 0
}

# 7-segment bitmap masks. Bits: T=1 TL=2 TR=4 M=8 BL=16 BR=32 B=64.
let digit_mask = (d:int):>int => {
    if d =? 0 { return 119 }
    if d =? 1 { return 36 }
    if d =? 2 { return 93 }
    if d =? 3 { return 109 }
    if d =? 4 { return 46 }
    if d =? 5 { return 107 }
    if d =? 6 { return 123 }
    if d =? 7 { return 37 }
    if d =? 8 { return 127 }
    if d =? 9 { return 111 }
    return 0
}

# Emit one digit's lit segments as quads at (x, y) with cell dims (w, h)
# and segment thickness t. Must be inside an active glBegin(GL_QUADS).
let draw_digit = (x:int y:int d:int w:int h:int t:int):>void => {
    let mask:int = digit_mask(d)
    let half_t:int = t // 2
    let mid:int = y + (h // 2)
    if (mask and 1) not=? 0 {
        hud_quad(x + t y x + w - t y + t)
    }
    if (mask and 2) not=? 0 {
        hud_quad(x y + t x + t mid - half_t)
    }
    if (mask and 4) not=? 0 {
        hud_quad(x + w - t y + t x + w mid - half_t)
    }
    if (mask and 8) not=? 0 {
        hud_quad(x + t mid - half_t x + w - t mid + half_t)
    }
    if (mask and 16) not=? 0 {
        hud_quad(x mid + half_t x + t y + h - t)
    }
    if (mask and 32) not=? 0 {
        hud_quad(x + w - t mid + half_t x + w y + h - t)
    }
    if (mask and 64) not=? 0 {
        hud_quad(x + t y + h - t x + w - t y + h)
    }
    return 0
}

# Right-aligned integer renderer. Emits up to max_digits cells anchored at
# right_x (digits grow leftwards). Stops as soon as the value runs out.
let draw_number_right = (right_x:int y:int value:int max_digits:int w:int h:int t:int gap:int):>void => {
    if value <? 0 { value = 0 }
    let v:int = value
    let i:int = 0
    loop i <? max_digits {
        let d:int = v % 10
        v = v // 10
        let dx:int = right_x - w - (i * (w + gap))
        draw_digit(dx y d w h t)
        i += 1
        if v =? 0 {
            return 0
        }
    }
    return 0
}

# Energy bar with bordered backdrop and a left=red -> right=gradient fill.
# Right-edge color follows the current energy level (red at 0, yellow at
# 50%, green at full); a sin pulse modulates alpha while a boost is active.
let draw_energy_bar = (sw:int sh:int):>void => {
    let bar_x:int = sw - HUD_MARGIN_PX - HUD_BAR_W_PX
    let bar_y:int = HUD_MARGIN_PX
    let bw:int = HUD_BAR_W_PX
    let bh:int = HUD_BAR_H_PX
    let bdr:int = HUD_BAR_BORDER_PX

    # Backdrop: dim translucent panel framing the bar.
    GL_Color4f(F32_ZERO F32_ZERO F32_ZERO q16_to_f32(45875))
    glBegin(GL_QUADS)
    hud_quad(bar_x - bdr bar_y - bdr bar_x + bw + bdr bar_y + bh + bdr)
    glEnd()

    let fill_w:int = (bw * energy) // ENERGY_FULL
    if fill_w >? 0 {
        let r_right:int = FP_ONE
        let g_right:int = 0
        if energy >=? FP_HALF {
            r_right = FP_ONE - ((energy - FP_HALF) << 1)
            if r_right <? 0 { r_right = 0 }
            g_right = FP_ONE
        } else {
            r_right = FP_ONE
            g_right = energy << 1
            if g_right >? FP_ONE { g_right = FP_ONE }
        }

        let alpha_q:int = 60293        # 0.92
        if boost_active_frames >? 0 {
            let phase:int = (boost_active_frames * 64) % ANG_TURN
            let s:int = sin_fp(phase)
            alpha_q = 52428 + (s // 8)  # ~0.6 .. 1.0 pulse
            if alpha_q >? FP_ONE { alpha_q = FP_ONE }
            if alpha_q <? 0 { alpha_q = 0 }
        }

        glBegin(GL_QUADS)
        GL_Color4f(F32_ONE F32_ZERO F32_ZERO q16_to_f32(alpha_q))
        GL_Vertex3f(GL_F32_FromInt(bar_x) GL_F32_FromInt(bar_y) F32_ZERO)
        GL_Vertex3f(GL_F32_FromInt(bar_x) GL_F32_FromInt(bar_y + bh) F32_ZERO)
        GL_Color4f(q16_to_f32(r_right) q16_to_f32(g_right) F32_ZERO q16_to_f32(alpha_q))
        GL_Vertex3f(GL_F32_FromInt(bar_x + fill_w) GL_F32_FromInt(bar_y + bh) F32_ZERO)
        GL_Vertex3f(GL_F32_FromInt(bar_x + fill_w) GL_F32_FromInt(bar_y) F32_ZERO)
        glEnd()
    }

    # Bright outline over the panel edge so the bar reads cleanly even on
    # a busy background.
    GL_Color4f(F32_ONE F32_ONE F32_ONE q16_to_f32(45875))
    glBegin(GL_QUADS)
    hud_quad(bar_x - bdr bar_y - bdr bar_x + bw + bdr bar_y)             # top
    hud_quad(bar_x - bdr bar_y + bh bar_x + bw + bdr bar_y + bh + bdr)   # bot
    hud_quad(bar_x - bdr bar_y bar_x bar_y + bh)                         # left
    hud_quad(bar_x + bw bar_y bar_x + bw + bdr bar_y + bh)               # right
    glEnd()
    return 0
}

let draw_speedometer = (sw:int sh:int):>void => {
    let kmh:int = (vis_speed * HUD_KMH_PER_FRAME) // FP_ONE
    let right_x:int = sw - HUD_MARGIN_PX
    let y:int = sh - HUD_MARGIN_PX - HUD_DIGIT_H_PX

    let r:int = F32_ONE
    let g:int = F32_ONE
    let b:int = F32_ONE
    if boost_active_frames >? 0 {
        # Hot orange wash while boost is active.
        g = q16_to_f32(45875)   # 0.7
        b = q16_to_f32(13107)   # 0.2
    }
    GL_Color4f(r g b q16_to_f32(60293))

    glBegin(GL_QUADS)
    draw_number_right(right_x y kmh 4 HUD_DIGIT_W_PX HUD_DIGIT_H_PX HUD_SEG_THICK_PX HUD_DIGIT_GAP_PX)
    glEnd()
    return 0
}

let draw_hud = (sw:int sh:int):>void => {
    glMatrixMode(GL_PROJECTION)
    glPushMatrix()
    glLoadIdentity()
    GL_Ortho(q16_to_f64(0) q16_to_f64(sw * FP_ONE) q16_to_f64(sh * FP_ONE) q16_to_f64(0) q16_to_f64(0 - FP_ONE) q16_to_f64(FP_ONE))
    glMatrixMode(GL_MODELVIEW)
    glPushMatrix()
    glLoadIdentity()

    glDisable(GL_DEPTH_TEST)
    glEnable(GL_BLEND)
    glBlendFunc(GL_SRC_ALPHA GL_ONE_MINUS_SRC_ALPHA)

    draw_energy_bar(sw sh)
    draw_speedometer(sw sh)

    glDisable(GL_BLEND)
    glEnable(GL_DEPTH_TEST)
    glMatrixMode(GL_PROJECTION)
    glPopMatrix()
    glMatrixMode(GL_MODELVIEW)
    glPopMatrix()
    return 0
}

let render_scene = (sw:int sh:int):>void => {
    glViewport(0 0 sw sh)
    GL_ClearColor(q16_to_f32(COL_SKY_R) q16_to_f32(COL_SKY_G) q16_to_f32(COL_SKY_B) F32_ONE)
    glClear(GL_COLOR_BUFFER_BIT + GL_DEPTH_BUFFER_BIT)
    glEnable(GL_DEPTH_TEST)
    glDepthFunc(GL_LEQUAL)
    glDisable(GL_CULL_FACE)
    set_perspective(sw sh)
    apply_camera()
    draw_ground()
    draw_ramp()
    draw_loop()
    draw_hills()
    draw_halfpipe()
    draw_corkscrew()
    draw_walls()
    draw_inner_ramp()
    draw_outer_ramp()
    draw_sphere()
    draw_craft()
    draw_trail()
    draw_sparks()
    draw_speed_lines(sw sh)
    draw_hud(sw sh)
    return 0
}

# ---------- Main loop --------------------------------------------------------

let main = ():>int => {
    SDL_SetMainReady()
    if SDL_Init(SDL_INIT_VIDEO) =? 0 {
        return 1
    }
    if SDL_GL_SetAttribute(SDL_GL_DOUBLEBUFFER 1) =? 0 {
        SDL_Quit()
        return 2
    }
    if SDL_GL_SetAttribute(SDL_GL_DEPTH_SIZE 24) =? 0 {
        SDL_Quit()
        return 3
    }
    if SDL_GL_SetAttribute(SDL_GL_CONTEXT_MAJOR_VERSION 2) =? 0 {
        SDL_Quit()
        return 4
    }
    if SDL_GL_SetAttribute(SDL_GL_CONTEXT_MINOR_VERSION 1) =? 0 {
        SDL_Quit()
        return 5
    }
    if SDL_GL_SetAttribute(SDL_GL_CONTEXT_PROFILE_MASK SDL_GL_CONTEXT_PROFILE_COMPATIBILITY) =? 0 {
        SDL_Quit()
        return 6
    }

    let title:int = "uZero Stage 15: Polish\0"
    let window:int = SDL_CreateWindow(title 1280 720 SDL_WINDOW_OPENGL + SDL_WINDOW_RESIZABLE)
    if window =? 0 {
        SDL_Quit()
        return 7
    }
    SDL_SetWindowIconFromUdewyData(window SDL_DEFAULT_WINDOW_ICON_DATA)

    let gl_context:int = SDL_GL_CreateContext(window)
    if gl_context =? 0 {
        SDL_DestroyWindow(window)
        SDL_Quit()
        return 8
    }
    if SDL_GL_MakeCurrent(window gl_context) =? 0 {
        SDL_GL_DestroyContext(gl_context)
        SDL_DestroyWindow(window)
        SDL_Quit()
        return 9
    }
    SDL_GL_SetSwapInterval(1)

    let event:int = __static_alloca__(SDL_EVENT_SIZE)
    let size:int = __static_alloca__(8)

    glEnable(GL_DEPTH_TEST)
    glDepthFunc(GL_LEQUAL)
    glDisable(GL_CULL_FACE)
    ground_texture_init()

    reset_craft()
    speed_lines_init()

    loop running not=? 0 {
        let has_event:int = SDL_PollEvent(event)
        loop has_event not=? 0 {
            if SDL_EventType(event) =? SDL_EVENT_QUIT {
                running = 0
            }
            has_event = SDL_PollEvent(event)
        }

        let keyboard:int = SDL_GetKeyboardState(0)
        update_input(keyboard)
        if in_quit not=? 0 {
            running = 0
        }

        physics_step()
        update_chase()
        trail_push()
        spark_step()

        SDL_GetWindowSizeInPixels(window size size + 4)
        render_scene(__load_u32__(size) __load_u32__(size + 4))
        SDL_GL_SwapWindow(window)
        SDL_Delay(16)
        frame_count += 1
    }

    SDL_GL_DestroyContext(gl_context)
    SDL_DestroyWindow(window)
    SDL_Quit()
    return 0
}
