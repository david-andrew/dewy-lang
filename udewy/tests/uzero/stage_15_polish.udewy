const WALL_LENGTH:int = 19660800         # 300 m
const WALL_Z_SEGMENTS:int = 60           # 300 m / 5 m

# Tangent friction while in contact: cvz *= (1 - WALL_FRICTION) per frame.
const WALL_FRICTION:int = 2621           # 0.04 (Q16)

# ---------- Sphere (center z=-3600, R=300, hole on +Z face) -----------------
# 3x v1 sphere per user request. Bottom of shell sits at y = 10 (10 m above
# ground) so the inner cavity clears the floor.

const SPHERE_CX:int = 0
const SPHERE_CY:int = 20316160           # 310 m
const SPHERE_CZ:int = -235929600         # -3600 m
const SPHERE_R:int = 19660800            # 300 m
const SPHERE_REACH:int = 1966080         # 30 m  shell-proximity gate for surface query (scaled)
const SPHERE_HOLE_COS:int = 46341        # cos(45 deg) -- direction-z above this is in the hole
const SPHERE_LAT_BANDS:int = 48          # pi*300 m arc / 20 m -- 4 * CHECKER_TILE
const SPHERE_LON_BANDS:int = 96          # 2*pi*300 m equator arc / 20 m

# ---------- Sphere inner-access ramp (centered x=0, leads INTO the hole) ----
# Lip lands exactly at the sphere's +Z polar point (0, 310, -3300), which is
# the hole center. Slope = atan(310 / 600) ~ 27.3 deg.

const Z_INNER_NEAR:int = -176947200      # -2700 m  ramp toe (right after wall corridor end)
const Z_INNER_FAR:int = -216268800       # -3300 m  ramp lip = sphere +Z polar point
const INNER_RAMP_LENGTH:int = 39321600   # 600 m
const INNER_RAMP_HEIGHT:int = 20316160   # 310 m   = SPHERE_CY (lip lands at hole center)
const INNER_RAMP_HALF_W:int = 983040     # 15 m
const INNER_RAMP_TAN:int = 33861         # 310/600 = 0.5167
const INNER_RAMP_SIN:int = 30084         # sin(atan(0.5167)) ~ 0.459
const INNER_RAMP_COS:int = 58238         # cos(atan(0.5167)) ~ 0.889
const INNER_RAMP_Z_SEGMENTS:int = 120    # 600 m / 5 m
const INNER_RAMP_W_SEGMENTS:int = 6      # 30 m / 5 m

# ---------- Sphere outer-access ramp (centered x=+40, lands on upper +Z face)
# Lip at (40, 531, -3401) sits on the sphere upper hemisphere; the sphere's
# outward normal there is roughly (0.133, 0.737, 0.663). The ramp slope (42
# deg) is chosen so the ramp's plane normal (0, 0.743, 0.669) is within ~8
# deg of the sphere normal -- close to tangent at the contact point. The
# ramp axis stays straight along -Z (no banking) so it remains drivable like
# the others. Base at z=-2811 keeps it well past the wall corridor
# (z >= -2700). xc=+40 (rather than +30) leaves a 5 m gap between the inner
# and outer ramps' side-wall collision footprints so they don't fight each
# other when the craft drives down the alley between them.

const OUTER_RAMP_X_CENTER:int = 2621440  # +40 m
const Z_OUTER_NEAR:int = -184221696      # -2811 m
const Z_OUTER_FAR:int = -222887936       # -3401 m
const OUTER_RAMP_LENGTH:int = 38666240   # 590 m
const OUTER_RAMP_HEIGHT:int = 34799616   # 531 m   (= 590 * tan(42 deg))
const OUTER_RAMP_HALF_W:int = 983040     # 15 m
const OUTER_RAMP_TAN:int = 58982         # 0.900   (= tan(42 deg) approx 0.9004)
const OUTER_RAMP_SIN:int = 43837         # sin(atan(0.9)) = 0.6687
const OUTER_RAMP_COS:int = 48706         # cos(atan(0.9)) = 0.7431
const OUTER_RAMP_Z_SEGMENTS:int = 120    # 600 m / 5 m
const OUTER_RAMP_W_SEGMENTS:int = 6      # 30 m / 5 m

