import p"./uzero_core.udewy"

# ============================================================================
# uZero Stage 15: full gym + polish (turn lean, hover bob, looser chase cam).
#
# Same circuit and physics as stage 14. Three "feel" passes layered on top:
#
#   1. Turn lean. The visual basis (vrx/vry/vrz, vux/vuy/vuz used by the
#      craft mesh) rolls about the physics fwd by an angle proportional to
#      yaw rate * speed_norm (BANK_GAIN, BANK_MAX, BANK_ALPHA). The physics
#      basis is left exact -- only the rendered craft leans into corners.
#      Ported from stage_04_chase_cam but generalized: yaw_rate is computed
#      as dot(delta_fwd, right) so it works on loops/sphere/halfpipe too,
#      not just flat ground.
#
#   2. Hover bob. craft_emit translates the rendered craft along the
#      surface up vector by BOB_AMP * sin(frame * BOB_FREQ_NUM/BOB_FREQ_DEN)
#      so the hover idle isn't perfectly rigid. Camera ignores the bob
#      (otherwise the whole world would shake).
#
#   3. Looser chase cam. ORIENT_ALPHA 0.20 -> 0.10 and POS_ALPHA 0.18 ->
#      0.12 give the camera a ~10-frame elastic lag, restoring the stage_04
#      "barely keeping up" feel that the stiffer stage 14 cam had lost.
#
#   4. Engine trail. A 36-sample ring buffer of recent exhaust positions +
#      right vectors, rendered as an alpha-blended quad strip behind the
#      craft. Width and color taper from a hot orange head to a deep red
#      tail; the trail tracks the physics path (no bob/lean) for stability.
#
#   5. Speed lines. A 96-streak radial overlay drawn in 2D ortho after the
#      3D scene. Streaks animate outward at a rate proportional to
#      (vis_boost_norm - SPEED_LINE_THRESHOLD), so they're invisible at
#      cruise, fade in past 50% top speed, and stream aggressively at
#      boost. Per-streak alpha follows a sin(pi*r) curve so they peak in
#      the mid-radius band and don't pop at the screen edge.
#
# All other geometry / physics / surface dispatch is verbatim from stage 14.
# See the stage 14 file for the full obstacle layout (~3.9 km circuit:
# ramp, loop, hills, halfpipe, corkscrew, walls, sphere finale).
#
# Controls: WASD/arrows + Q/E strafe, Space = boost, R = respawn, Esc = quit.
# ============================================================================

const SDL_SCANCODE_E:int = 8
const SDL_SCANCODE_Q:int = 20
const SDL_SCANCODE_R:int = 21

# ---------- Physics ---------------------------------------------------------

const HOVER_HEIGHT:int = 98304           # 1.5 m above the surface
const TOP_SPEED:int = 500000 #229376             # 3.5 m/frame (= old boost ceiling)
const BOOST_BONUS:int = 400000 #98304            # +1.5 m/frame -> 5.0 m/frame boost ceiling
const THRUST_ACCEL:int = 4000
const BRAKE_DECEL:int = 3277
const STRAFE_RATE:int = 32768

# Boost is a discrete, edge-triggered action (F-Zero GX style): one press
# spends a chunk of the shared energy bar, gives an instant forward impulse
# of BOOST_IMPULSE m/frame, and lifts the top-speed cap for BOOST_DURATION
# frames so drag/grip don't immediately scrub the kick. Holding does
# nothing; you have to release and re-press to fire again.
const BOOST_IMPULSE:int = 65536          # 1.0 m/frame instant velocity bump
const BOOST_DURATION:int = 30            # frames the elevated speed cap holds
const ENERGY_FULL:int = 65536            # FP_ONE -- full bar
const BOOST_COST_Q:int = 19660           # 0.30 of bar per boost (-> 3 boosts when full)
const ENERGY_REGEN_Q:int = 328           # ~0.005 / frame -> ~3.3 s to refill from empty

const STEER_BASE:int = 12
const STEER_MIN:int = 8

const LATERAL_GRIP:int = 9830
const DRAG_COAST:int = 100
const DRAG_THRUST:int = 327

const SNAP_ALPHA:int = 39322             # 0.60  -- corkscrew-class strength so inversion holds
const AIR_GAP:int = 262144               # 4 m clearance -> airborne (matches stage 09)
const GRAVITY:int = 6000

# Tangential slope gravity. While grounded, world gravity is split into a
# normal component (cancelled by the magnet) and a tangent component (added
# to velocity, makes the craft drift downhill). Kept small so thrust easily
# overpowers it but a craft left idle on a slope (or partway up the pipe
# wall) will slide back down.
const SLOPE_GRAVITY:int = 300

# When grounded the physics up snaps directly to the surface normal -- no
# smoothing -- so the craft conforms to the track instantly. Visual basis
# also tracks physics directly. Only the camera basis is smoothed (below)
# so the chase still trails. UP_ALPHA is the airborne settle rate (decays
# the craft's last "tilted" up back toward world up while in the air).
const UP_ALPHA_AIR:int = 6553            # 0.10  -- mild airborne settle

# ---------- Camera ----------------------------------------------------------

const CAM_BACK:int = 983040              # 15 m behind craft
const CAM_LIFT:int = 262144              #  4 m above craft
const POS_ALPHA:int = 7864               # 0.12 camera position lerp (was 0.18)
const ORIENT_ALPHA:int = 6553            # 0.10 camera orientation lerp (was 0.20)
const FOV_PUNCH:int = 26214

# ---------- Visual polish ---------------------------------------------------

# Turn lean. Visual basis rolls about the physics fwd by an angle proportional
# to yaw_rate * speed_norm. Yaw rate is measured as dot(delta_fwd, right)
# (signed component of this frame's fwd change projected onto the right
# axis), so it works in 3D (loops, sphere, etc.), not just yaw on flat
# ground. Result is in Q16 radians; multiply by RAW_PER_RAD to get raw
# angle units (where 1024 = 360 deg). BANK_MAX = 60 -> ~21 deg max lean.
const RAW_PER_RAD:int = 163              # 1024/(2*pi), raw angle units per radian
const BANK_GAIN:int = 10
const BANK_MAX:int = 60
const BANK_ALPHA:int = 11796             # 0.18 -> ~6-frame catch-up

# Hover bob. Idle vertical wobble of the rendered craft along its surface
# up vector. BOB_AMP is a Q16 distance; BOB_FREQ_NUM/DEN advances the angle
# by ~24 angle units per frame -> a full cycle every ~43 frames (~0.7 s at
# 60 Hz). Camera intentionally does NOT follow the bob.
const BOB_AMP:int = 19660                # 0.30 m peak
const BOB_FREQ_NUM:int = 24              # angle units per frame numerator
const BOB_FREQ_DEN:int = 1               # denominator

# Engine trail. A ring buffer of past exhaust positions + right vectors;
# rendered as a width-tapered, alpha-fading quad strip behind the craft.
# Each sample is 6 ints (x, y, z, rx, ry, rz) = 48 bytes; total
# TRAIL_LEN * 48 bytes of static storage. The trail emits from the
# physics state (not visual) so bob/lean don't wobble the trail itself.
const TRAIL_LEN:int = 36                 # ~0.6 s of history at 60 Hz
const TRAIL_STRIDE:int = 56              # bytes per sample (pos3 + right3 + boost_q)
const TRAIL_BUF_BYTES:int = 2016         # TRAIL_LEN * TRAIL_STRIDE
const TRAIL_HALF_W:int = 49152           # 0.75 m peak ribbon half-width
const TRAIL_OFFSET_BACK:int = 131072     # 2 m behind craft (matches mesh tail)
const TRAIL_OFFSET_UP:int = 13107        # 0.2 m up (matches glow plate)

# Speed lines. A fixed set of N radial streaks rendered as a 2D ortho
# overlay after the 3D scene. Each streak's angle and phase seed are
# derived from its index (golden-angle distribution); the radial position
# animates outward at SPEED_LINE_RATE * (boost_norm - threshold), looping
# back to the inner radius. They only show above SPEED_LINE_THRESHOLD
# (so cruising stays clean and the lines kick in as you push for boost).
const SPEED_LINES_N:int = 80
const SPEED_LINE_RATE_Q:int = 4915        # 0.075 / frame at full intensity (1 / lifetime)
const SPEED_LINE_THRESHOLD:int = 32768    # 0.50  speed_norm where lines begin
const SPEED_LINE_PEAK_ALPHA_Q:int = 52428 # 0.80 alpha at full boost intensity
const SPEED_LINE_SHAKE_PX:int = 4         # peak per-frame line jitter in pixels
const SPEED_LINE_OVERSHOOT_PX:int = 24    # extend lines past the edge so they truly exit
# Per-streak state: { phase_q, angle_idx, start_r_q } as three int64 fields.
const SPEED_LINE_STRIDE:int = 24
const SPEED_LINE_STATE_BYTES:int = 1920   # SPEED_LINES_N * SPEED_LINE_STRIDE

# Sparks. A fixed-size pool of short-lived 3D particles emitted whenever
# wall_collide / ramp_side_collide produce a non-trivial impulse. New sparks
# overwrite the oldest slot via a wrapping head pointer (no free-slot search).
# Each particle: { x, y, z, vx, vy, vz, life } -- 7 int64 fields, 56-byte stride.
const SPARK_MAX:int = 192
const SPARK_STRIDE:int = 56
const SPARK_BUF_BYTES:int = 10752         # SPARK_MAX * SPARK_STRIDE
const SPARK_LIFE_DECAY:int = 2185         # ~30-frame lifetime (FP_ONE / 30)
const SPARK_BASE_SPEED:int = 65536        # 1.0 m/frame outward kick
const SPARK_SPEED_VAR:int = 65536         # +/- 1.0 m/frame variation
const SPARK_JITTER:int = 19660            # 0.3 m/frame tangential scatter
const SPARK_UP_BIAS:int = 9830            # 0.15 m/frame upward kick (sparky arc)
const SPARK_GRAVITY:int = 1310            # 0.02 m/frame^2 (lighter than craft gravity)
const SPARK_TAIL_Q:int = 49152            # 0.75 -- tail length = vel * this
# Impulse threshold and per-particle cost in Q16 m/frame. Below the threshold
# we stay silent (no sparks on gentle contact); above it the burst size grows
# with how hard the collision pushed back.
const SPARK_IMPULSE_THRESHOLD:int = 6553  # 0.10 m/frame (light scrape)
const SPARK_IMPULSE_PER_PARTICLE:int = 16384 # 0.25 m/frame per spark
const SPARK_MAX_BURST:int = 24            # cap per-collision burst

# HUD layout (F-Zero GX inspired). Energy bar in the top-right; large
# 7-segment km/h speedometer in the bottom-right.
const HUD_MARGIN_PX:int = 20
const HUD_BAR_W_PX:int = 220
const HUD_BAR_H_PX:int = 18
const HUD_BAR_BORDER_PX:int = 2
const HUD_DIGIT_W_PX:int = 30
const HUD_DIGIT_H_PX:int = 54
const HUD_DIGIT_GAP_PX:int = 6
const HUD_SEG_THICK_PX:int = 6
const HUD_KMH_PER_FRAME:int = 216        # 60 fps * 3.6 -> Q16 m/frame * this // FP_ONE = km/h

const MIN_CAM_CLEAR:int = 131072         # 2 m  minimum cam clearance over surface

# Half-extent of the craft's wings -- used by wall collision so the
# visible mesh stops cleanly at the inner wall face instead of clipping.
const CRAFT_HALF_W:int = 163840          # 2.5 m (matches draw_craft wing_x)

# ---------- Checker tiling --------------------------------------------------
# Every track surface is tessellated so that one checker cell measures
# roughly CHECKER_TILE_M metres along the surface, so the apparent rate of
# tiles streaming past the camera is independent of which obstacle you're
# on. The per-surface *_Z_SEGMENTS / *_W_SEGMENTS / *_THETA_SEGMENTS
# below are all chosen as length / CHECKER_TILE rounded to an integer
# (arc length for the curved ones). The flat ground uses the same 5 m
# tile size but renders as a single huge GL_REPEAT-textured quad rather
# than per-tile quads (see GROUND_TEX_PIXELS / draw_ground).
const CHECKER_TILE:int = 327680          # 5 m -- target tile edge for course surfaces
# Sphere is a special case: at R=300 m one full longitude is 1.9 km, so
# a 5 m tile would mean ~377 lon bands. Use a 4x coarser tile (~20 m) so
# the existing 48 lat / 96 lon bands stay both performant and visually
# consistent with each other.

