const Z_PIPE_END:int = -85196800         # -1300 m far seam
const PIPE_LEN:int = 19660800            # 300 m
const PIPE_MARGIN:int = 196608           # 3 m
const PIPE_Z_SEGMENTS:int = 60           # 300 m / 5 m
const PIPE_THETA_SEGMENTS:int = 19       # pi*30 m arc / 5 m ~= 19

# ---------- Corkscrew (z in [-1450, -2250]) ---------------------------------

const CORK_W:int = 6553600               # 100 m  track width
const CORK_HALF_W:int = 3276800          #  50 m
const CORK_X_CENTER:int = 0
const CORK_Z_START:int = -95027200       # -1450 m
const CORK_Z_END:int = -147456000        # -2250 m
const CORK_LEN:int = 52428800            # 800 m
const CORK_Y_PEAK:int = 6553600          # 100 m centerline rise at theta = pi
const CORK_Z_SEGMENTS:int = 160          # 800 m / 5 m
const CORK_W_SEGMENTS:int = 20           # 100 m / 5 m

# Perpendicular reach for surface_corkscrew. The strip is a rotating ribbon,
# so a craft sitting "next to" or "above" the strip can fall inside the
# strip's (z, w) projection without being anywhere near its surface plane.
# Without a perp gate the magnet snap will yank the craft tens of metres
# back to the strip. Claim the position only when its signed distance
# along the surface normal lies in [-CORK_REACH, HOVER_HEIGHT + CORK_REACH]:
# slightly behind the strip is OK (snap recovery, slight bounce), and we
# extend a bit past the airborne threshold so the airborne -> grounded
# transition can re-grab smoothly. Beyond that the corkscrew releases the
# craft and surface_flat (or whatever else is in range) takes over.
const CORK_REACH:int = 393216            # 6 m

# ---------- Walls (z in [-2400, -2700]) -------------------------------------

const CORRIDOR_HALF_W:int = 983040       # 15 m  inner half-width (30 m wide corridor)
const WALL_HEIGHT:int = 327680           #  5 m  wall top
