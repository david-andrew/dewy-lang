# ---------- Ground -----------------------------------------------------------

# Ground is a single huge textured quad rather than a per-tile mesh: a 2x2
# RGBA texture in GL_NEAREST + GL_REPEAT mode renders the whole +/-5 km
# checker plane as 4 vertices. tex_coord units of 1 = 2 texels = 2 tiles
# = 2 * CHECKER_TILE; so tex_uv_per_metre = 1 / (2 * 5 m) = 0.1 / m.
const GROUND_HALF_EXTENT:int = 327680000 # +/- 5000 m
const GROUND_TEX_UV_DIVISOR:int = 10     # world metres per tex_uv unit (1 uv = 2 tiles)
const GROUND_TEX_BYTES:int = 16          # 2x2 RGBA8
const GROUND_Y:int = 0

