import p"./uzero_core.udewy"

# ============================================================================
# uZero Stage 14: full gym (every obstacle in one chained circuit).
#
# All approved obstacles from prior stages composed into a single ~3.3 km
# course running along -Z from spawn, with a sphere-and-hole capstone at
# the far end. Each obstacle keeps its standalone geometry; query_surface
# dispatches to the right helper based on which Z window (or 3D shell)
# the craft is in, defaulting to flat ground in the gaps.
#
# Layout (mostly centered on x = 0; sphere outer ramp is offset):
#
#   z range            length   obstacle
#   ----------------   ------   ---------------------------------------
#   [    0,   -50]      50 m    open spawn straight
#   [  -50,   -80]      30 m    ramp (15 m tall jump pad) -- stage 11
#   [  -80,  -200]     120 m    open landing zone
#   [ -200,  -260]      60 m    vertical loop (R = 60 m)  -- stage 08
#   [ -260,  -400]     140 m    open straight
#   [ -400,  -880]     480 m    sinusoidal hills          -- stage 12
#   [ -880, -1000]     120 m    open straight
#   [-1000, -1300]     300 m    halfpipe (R = 30 m)       -- stage 10
#   [-1300, -1450]     150 m    open straight
#   [-1450, -2250]     800 m    corkscrew (1 full twist)  -- stage 09
#   [-2250, -2400]     150 m    open straight
#   [-2400, -2700]     300 m    wall corridor             -- stage 13
#   [-2700, -2900]     200 m    open straight (sphere approach)
#   [-2900, -3300]     400 m    SPHERE FINALE             -- stage 14 v2
#                                 - inner ramp x=0 lifts to (0, 110, -3100),
#                                   the +Z polar point of a R=100 sphere
#                                   centered at (0, 110, -3200). Player
#                                   launches into the polar-cap hole and
#                                   coasts through ~1 s of cavity flight
#                                   before the magnet grabs the inner wall.
#                                 - outer ramp x=+50 lifts to (50, 39.3,
#                                   -3150), which sits exactly on the
#                                   sphere's outer +Z+X surface. Player
#                                   transitions cleanly onto the outside.
#                                 - hole half-angle 45 deg (~141 m wide
#                                   opening). Direction-z above cos(45)
#                                   returns no surface so the magnet does
#                                   not grab while the craft is in the
#                                   entry tunnel.
#
# Physics tunables are stage-09-class (SNAP_ALPHA = 0.60, AIR_GAP = 4 m)
# so the corkscrew inversion holds; this stronger magnet also keeps the
# craft glued to the loop, the halfpipe, and the sphere's inverted inner
# wall reliably. The hills no longer launch the craft (per prior decision
# -- launches are reserved for the explicit ramp), but everything else
# feels identical to its standalone stage. Wall friction (0.04) carries
# over from stage 13.
#
# Sign-off goal: complete one continuous run from spawn through every
# obstacle in order without ever clipping, falling through, or losing
# magnet adhesion. Backtrack and re-attempt any obstacle freely.
#
# Controls: WASD/arrows + Q/E strafe, Space = boost, R = respawn, Esc = quit.
# ============================================================================

const SDL_SCANCODE_E:int = 8
const SDL_SCANCODE_Q:int = 20
const SDL_SCANCODE_R:int = 21

# ---------- Physics ---------------------------------------------------------

const HOVER_HEIGHT:int = 98304           # 1.5 m above the surface
const TOP_SPEED:int = 163840
