$supported_targets = ["wasm32"]

import p"../../third_party/web/dom.udewy"
import p"../../third_party/web/highlight.udewy"
import p"../../third_party/web/artifacts/web_compiler.wasm"
import p"../../third_party/web/artifacts/wabt.js"
import p"../../third_party/web/playground_host.js"

# The Run button click handler reads the editor text and asks JS to compile
# + run via `host_playground_run`. JS owns the wabt + iframe pipeline because
# both pieces are entirely JS-side.
let host_playground_run = (src:int src_len:int):>void => extern

const EX_FIZZBUZZ:int =
"let printed:bool = false
let print = (s:string):>void => \{
    printed = true  # Mark that print was called
    __host_log__(s __load__(s - 8))
    return void
\}

let main = ():>int => \{
    let i:int = 1
    loop i <=? 20 \{
        printed = false
        if i % 3 =? 0 \{ print(\"Fizz\") \}
        if i % 5 =? 0 \{ print(\"Buzz\") \}
        if not printed \{ __log_int__(i) \}
        print(\"\\n\")
        i = i + 1
    \}
    return 0
\}
"

const EX_FIB:int =
"let puts = (s:string):>void => \{
    __host_log__(s __load__(s - 8))
    return void
\}
let puti = (i:int):>void => \{
    __log_int__(i)
    return void
\}

let main = ():>int => \{
    let i:int = 0
    let i0:int = 0
    let i1:int = 1
    loop i <? 100 \{
        puts(\"fib(\")
        puti(i)
        puts(\") = \")
        puti(i0)
        puts(\"\\n\")
        i = i + 1
        i1 = i0 + i1
        i0 = i1 - i0
    \}
    return 0
\}
"

const EX_SIEVE:int =
"# Sieve of Eratosthenes up to 100.
let print = (s:string):>void => \{
    __host_log__(s __load__(s - 8))
    return void
\}

let main = ():>int => \{
    let n:int = 100
    let buf:int = __static_alloca__(101)
    let i:int = 0
    loop i <=? n \{
        __store_u8__(1 buf + i)
        i = i + 1
    \}
    __store_u8__(0 buf + 0)
    __store_u8__(0 buf + 1)

    let p:int = 2
    loop p * p <=? n \{
        if __load_u8__(buf + p) \{
            let q:int = p * p
            loop q <=? n \{
                __store_u8__(0 buf + q)
                q = q + p
            \}
        \}
        p = p + 1
    \}

    print(\"primes up to 100:\\n\")
    let j:int = 2
    loop j <=? n \{
        if __load_u8__(buf + j) \{
            __log_int__(j)
            print(\" \")
        \}
        j = j + 1
    \}
    print(\"\\n\")
    return 0
\}
"

const EX_TRIANGLE:int =
"# Print an ASCII triangle by writing bytes into a buffer.
let main = ():>int => \{
    let buf:int = __static_alloca__(16)
    let row:int = 1
    loop row <=? 8 \{
        let i:int = 0
        loop i <? row \{
            __store_u8__(42 buf + i)
            i = i + 1
        \}
        __store_u8__(10 buf + row)
        __host_log__(buf row + 1)
        row = row + 1
    \}
    return 0
\}
"

const EX_COLLATZ:int =
"let print = (s:string):>void => \{
    __host_log__(s __load__(s - 8))
    return void
\}

# Print the Collatz sequence starting at `n`, plus its step count.
let collatz = (n:int):>int => \{
    let steps:int = 0
    __log_int__(n)
    loop n not=? 1 \{
        if (n % 2) =? 0 \{ n = n // 2 \}
        else \{ n = 3 * n + 1 \}
        print(\" -> \")
        __log_int__(n)
        steps = steps + 1
    \}
    print(\"\\n(\")
    __log_int__(steps)
    print(\" steps)\\n\")
    return steps
\}

let main = ():>int => \{
    collatz(27)
    return 0
\}
"

const STARTER_SOURCE:int =
"# Hello from the udewy playground.
# Edit this code and press Run.

let print = (s:string):>void => \{
    let len:int = __load__(s - 8)
    __host_log__(s len)
    return void
\}

let main = ():>int => \{
    print(\"hello from udewy in wasm!\")
    return 0
\}"

# Globals so the input / click callbacks can find the live DOM nodes without
# re-walking the document.
let g_editor:int = 0
let g_status:int = 0
let g_gutter:int = 0
let g_toggle_btn:int = 0
let g_line_numbers_shown:int = false
let g_example_select:int = 0

# Count source lines in `src`. Always reports at least 1.
let count_lines = (src:int):>int => {
    let n:int = str_len(src)
    let lines:int = 1
    let i:int = 0
    loop i <? n {
        if __load_u8__(src + i) =? CH_LF { lines = lines + 1 }
        i = i + 1
    }
    return lines
}

# Build "1\n2\n...\nN" as a fresh udewy string.
let build_line_numbers = (count:int):>int => {
    let bb:int = bb_new(count * 4)
    let i:int = 1
    loop i <=? count {
        bb_push_int(bb i)
        if i <? count { bb_push_byte(bb CH_LF) }
        i = i + 1
    }
    return bb_finalize_as_string(bb)
}

let update_line_numbers = ():>void => {
    if g_gutter =? 0 { return void }
    if not g_line_numbers_shown { return void }
    let src:int = Web_GetText(g_editor)
    Web_SetText(g_gutter build_line_numbers(count_lines(src)))
    return void
}

let on_toggle_line_numbers = ():>void => {
    if g_gutter =? 0 { return void }
    if g_line_numbers_shown {
        Web_SetStyle(g_gutter "display" "none")
        Web_SetText(g_toggle_btn "Show line numbers")
        g_line_numbers_shown = false
    } else {
        Web_SetStyle(g_gutter "display" "block")
        g_line_numbers_shown = true
        update_line_numbers()
        Web_SetText(g_toggle_btn "Hide line numbers")
    }
    return void
}

let playground_on_input = ():>void => {
    if g_editor =? 0 { return void }
    let caret:int = Web_GetCaret(g_editor)
    let src:int = Web_GetText(g_editor)
    Web_RenderHighlightedSource(g_editor src)
    Web_SetCaret(g_editor caret)
    update_line_numbers()
    return void
}

let playground_on_run = ():>void => {
    if g_editor =? 0 { return void }
    let src:int = Web_GetText(g_editor)
    host_playground_run(src str_len(src))
    return void
}

# Replace the editor with `src`, re-highlight, and refresh the gutter.
let load_example = (src:int):>void => {
    if g_editor =? 0 { return void }
    Web_RenderHighlightedSource(g_editor src)
    Web_SetCaret(g_editor 0)
    update_line_numbers()
    return void
}

# The dropdown's `value` attribute drives this lookup. The first option is
# the starter source -- selecting it resets the editor to the welcome text.
let on_example_change = ():>void => {
    if g_example_select =? 0 { return void }
    let name:int = Web_GetText(g_example_select)
    if str_eq(name "hello") { load_example(STARTER_SOURCE) }
    else if str_eq(name "fizzbuzz") { load_example(EX_FIZZBUZZ) }
    else if str_eq(name "fib") { load_example(EX_FIB) }
    else if str_eq(name "sieve") { load_example(EX_SIEVE) }
    else if str_eq(name "triangle") { load_example(EX_TRIANGLE) }
    else if str_eq(name "collatz") { load_example(EX_COLLATZ) }
    return void
}

# Apply the editor's monospace / dark code-block styling. Used both for the
# initial render and after every rehighlight.
let style_editor = (node:int):>void => {
    Web_SetStyle(node "white-space" "pre")
    Web_SetStyle(node "overflow-x" "auto")
    Web_SetStyle(node "min-height" "16rem")
    Web_SetStyle(node "padding" "1rem")
    Web_SetStyle(node "margin" "0")
    Web_SetStyle(node "border-radius" "14px")
    Web_SetStyle(node "background" "#1e1e1e")
    Web_SetStyle(node "color" "#d4d4d4")
    Web_SetStyle(node "font-family" "ui-monospace, SFMono-Regular, Menlo, monospace")
    Web_SetStyle(node "font-size" "0.95rem")
    Web_SetStyle(node "line-height" "1.15")
    Web_SetStyle(node "outline" "none")
    Web_SetStyle(node "tab-size" "4")
    return void
}

let style_status = (node:int):>void => {
    Web_SetStyle(node "white-space" "pre-wrap")
    Web_SetStyle(node "min-height" "4rem")
    Web_SetStyle(node "padding" "0.75rem 1rem")
    Web_SetStyle(node "margin" "0")
    Web_SetStyle(node "border-radius" "10px")
    Web_SetStyle(node "background" "#fff7f0")
    Web_SetStyle(node "color" "#8a3700")
    Web_SetStyle(node "font-family" "ui-monospace, SFMono-Regular, Menlo, monospace")
    Web_SetStyle(node "font-size" "0.85rem")
    return void
}

let style_run_button = (node:int):>void => {
    Web_SetStyle(node "padding" "0.6rem 1.4rem")
    Web_SetStyle(node "border" "none")
    Web_SetStyle(node "border-radius" "999px")
    Web_SetStyle(node "background" "#4c8f6a")
    Web_SetStyle(node "color" "#ffffff")
    Web_SetStyle(node "font-weight" "700")
    Web_SetStyle(node "font-size" "0.95rem")
    Web_SetStyle(node "cursor" "pointer")
    Web_SetStyle(node "letter-spacing" "0.04em")
    return void
}

let style_subtle_button = (node:int):>void => {
    Web_SetStyle(node "padding" "0.3rem 0.75rem")
    Web_SetStyle(node "border" "1px solid #d4cabb")
    Web_SetStyle(node "border-radius" "999px")
    Web_SetStyle(node "background" "#fbf7f0")
    Web_SetStyle(node "color" "#596171")
    Web_SetStyle(node "font-family" "Inter, ui-sans-serif, system-ui, sans-serif")
    Web_SetStyle(node "font-size" "0.78rem")
    Web_SetStyle(node "font-weight" "600")
    Web_SetStyle(node "cursor" "pointer")
    return void
}

# Add one `<option value=value>label</option>` to a `<select>`.
let add_example_option = (sel:int value:int label:int):>void => {
    let opt:int = Web_AppendTextElement(sel "option" label)
    Web_SetAttr(opt "value" value)
    return void
}

# Inject a page-wide stylesheet. Used for things browser selectors handle
# more naturally than inline styles -- in particular `::selection` so we can
# render an IDE-style translucent highlight that keeps the original syntax
# colors visible.
let inject_global_styles = ():>void => {
    let s:int = Web_AppendElement(Web_Body() "style")
    Web_SetText(s "::selection \{ background-color: rgb(38, 79, 120); color: inherit; \}")
    return void
}

# Line-number gutter that sits to the left of the editor. Must keep
# font-family / font-size / line-height / vertical padding identical to
# style_editor so each gutter row aligns with the matching editor row.
# Width is intrinsic to its content so it stays as tight as possible.
let style_gutter = (node:int):>void => {
    Web_SetStyle(node "white-space" "pre")
    Web_SetStyle(node "padding" "1rem 0.4rem 1rem 0.6rem")
    Web_SetStyle(node "margin" "0")
    Web_SetStyle(node "background" "#1a1a1a")
    Web_SetStyle(node "color" "#6e6e6e")
    Web_SetStyle(node "font-family" "ui-monospace, SFMono-Regular, Menlo, monospace")
    Web_SetStyle(node "font-size" "0.95rem")
    Web_SetStyle(node "line-height" "1.15")
    Web_SetStyle(node "text-align" "right")
    Web_SetStyle(node "user-select" "none")
    Web_SetStyle(node "flex" "0 0 auto")
    return void
}

let main = ():>int => {
    Web_SetTitle("udewy playground")
    Web_SetFaviconSvg("<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><rect width='64' height='64' rx='14' fill='#1e1e1e'/><text x='32' y='44' text-anchor='middle' font-family='ui-monospace, Menlo' font-size='34' font-weight='800' fill='#d9822b'>&#x03BC;</text></svg>")
    inject_global_styles()

    let root:int = Web_Root()
    Web_Clear(root)
    Web_SetStyle(root "background" "#f6f2eb")
    Web_SetStyle(root "color" "#232734")
    Web_SetStyle(root "font-family" "Inter, ui-sans-serif, system-ui, sans-serif")
    Web_SetStyle(root "padding" "2rem 1.25rem")
    Web_SetStyle(root "min-height" "100vh")

    let article:int = Web_AppendElement(root "article")
    Web_FlexColumn(article 18)
    Web_SetStyle(article "max-width" "1100px")
    Web_SetStyle(article "margin" "0 auto")

    let header:int = Web_AppendElement(article "header")
    Web_FlexRow(header 16)
    Web_SetStyle(header "align-items" "center")
    Web_SetStyle(header "justify-content" "space-between")

    let title_block:int = Web_AppendElement(header "div")
    Web_FlexColumn(title_block 4)
    let kicker:int = Web_AppendTextElement(title_block "p" "udewy")
    Web_SetStyle(kicker "margin" "0")
    Web_SetStyle(kicker "color" "#8f5f2f")
    Web_SetStyle(kicker "font-weight" "700")
    Web_SetStyle(kicker "letter-spacing" "0.10em")
    Web_SetStyle(kicker "text-transform" "uppercase")
    let title:int = Web_AppendTextElement(title_block "h1" "playground")
    Web_SetStyle(title "margin" "0")
    Web_SetStyle(title "font-size" "clamp(1.8rem, 5vw, 2.6rem)")
    Web_SetStyle(title "letter-spacing" "-0.04em")

    let run_btn:int = Web_AppendTextElement(header "button" "Run")
    style_run_button(run_btn)
    Web_SetAttr(run_btn "id" "udewy-run")

    let panes:int = Web_AppendElement(article "section")
    Web_FlexRow(panes 18)
    Web_SetStyle(panes "align-items" "stretch")

    let left:int = Web_AppendElement(panes "div")
    Web_FlexColumn(left 10)
    Web_SetStyle(left "flex" "1 1 0")
    Web_SetStyle(left "min-width" "0")

    let left_header:int = Web_AppendElement(left "div")
    Web_FlexRow(left_header 8)
    Web_SetStyle(left_header "align-items" "center")
    Web_SetStyle(left_header "justify-content" "space-between")

    let left_label:int = Web_AppendTextElement(left_header "p" "Source")
    Web_SetStyle(left_label "margin" "0")
    Web_SetStyle(left_label "font-weight" "600")
    Web_SetStyle(left_label "color" "#596171")
    Web_SetStyle(left_label "flex" "1 1 auto")

    let example_select:int = Web_AppendElement(left_header "select")
    style_subtle_button(example_select)
    add_example_option(example_select "hello" "Hello, world")
    add_example_option(example_select "fizzbuzz" "FizzBuzz")
    add_example_option(example_select "fib" "Fibonacci")
    add_example_option(example_select "sieve" "Prime sieve")
    add_example_option(example_select "triangle" "ASCII triangle")
    add_example_option(example_select "collatz" "Collatz sequence")
    g_example_select = example_select

    let toggle_ln:int = Web_AppendTextElement(left_header "button" "Show line numbers")
    style_subtle_button(toggle_ln)
    g_toggle_btn = toggle_ln

    let editor_wrap:int = Web_AppendElement(left "div")
    Web_SetStyle(editor_wrap "display" "flex")
    Web_SetStyle(editor_wrap "flex-direction" "row")
    Web_SetStyle(editor_wrap "border-radius" "14px")
    Web_SetStyle(editor_wrap "overflow" "hidden")
    Web_SetStyle(editor_wrap "background" "#1e1e1e")

    let gutter:int = Web_AppendElement(editor_wrap "pre")
    style_gutter(gutter)
    Web_SetStyle(gutter "display" "none")
    g_gutter = gutter

    let editor:int = Web_AppendElement(editor_wrap "pre")
    Web_SetAttr(editor "id" "udewy-editor")
    Web_SetAttr(editor "spellcheck" "false")
    style_editor(editor)
    Web_SetContentEditable(editor true)
    Web_SetStyle(editor "flex" "1 1 auto")
    Web_SetStyle(editor "min-width" "0")
    g_editor = editor

    Web_AddClickListener(toggle_ln on_toggle_line_numbers)
    Web_AddEventListener(example_select "change" on_example_change)

    let right:int = Web_AppendElement(panes "div")
    Web_FlexColumn(right 10)
    Web_SetStyle(right "flex" "1 1 0")
    Web_SetStyle(right "min-width" "0")

    let right_label:int = Web_AppendTextElement(right "p" "Output")
    Web_SetStyle(right_label "margin" "0")
    Web_SetStyle(right_label "font-weight" "600")
    Web_SetStyle(right_label "color" "#596171")

    let iframe_host:int = Web_AppendElement(right "div")
    Web_SetAttr(iframe_host "id" "udewy-iframe-host")
    Web_SetStyle(iframe_host "flex" "1 1 0")
    Web_SetStyle(iframe_host "min-height" "16rem")
    Web_SetStyle(iframe_host "border-radius" "14px")
    Web_SetStyle(iframe_host "background" "#ffffff")
    Web_SetStyle(iframe_host "border" "1px solid rgba(35, 39, 52, 0.18)")
    Web_SetStyle(iframe_host "overflow" "hidden")
    Web_SetStyle(iframe_host "position" "relative")

    let placeholder:int = Web_AppendTextElement(iframe_host "p" "Press Run to compile and execute your program.")
    Web_SetStyle(placeholder "margin" "0")
    Web_SetStyle(placeholder "padding" "1rem")
    Web_SetStyle(placeholder "color" "#8a8a8a")
    Web_SetStyle(placeholder "font-family" "ui-monospace, SFMono-Regular, Menlo, monospace")
    Web_SetStyle(placeholder "font-size" "0.85rem")

    let status:int = Web_AppendElement(article "pre")
    Web_SetAttr(status "id" "udewy-status")
    style_status(status)
    g_status = status

    # Seed the editor with the starter source then highlight it.
    Web_RenderHighlightedSource(g_editor STARTER_SOURCE)

    Web_AddInputListener(g_editor playground_on_input)
    Web_AddClickListener(run_btn playground_on_run)

    return 0
}
