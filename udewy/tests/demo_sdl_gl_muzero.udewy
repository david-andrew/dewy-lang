let fx_phase:int = 0
let fx_freq:int = 0
let fx_timer:int = 0

let track_cx:int = 0
let track_cy:int = 0
let track_cz:int = 0
let track_rx:int = 0
let track_ry:int = 0
let track_rz:int = 0
let track_ux:int = 0
let track_uy:int = 0
let track_uz:int = 0
let track_roll:int = 0

let scratch_a:int = 0
let scratch_b:int = 0
let scratch_c:int = 0
let scratch_d:int = 0
let scratch_e:int = 0
let scratch_f:int = 0

let camera_ready:int = 0
let camera_x:int = 0
let camera_y:int = 0
let camera_z:int = 0

let abs_i = (value:int):>int => {
    if value <? 0 {
        return 0 - value
    }
    return value
}

let clamp_i = (value:int low:int high:int):>int => {
    if value <? low {
        return low
    }
    if value >? high {
        return high
    }
    return value
}

let wrap_progress = (value:int):>int => {
    let wrapped:int = value % TRACK_TOTAL_FP
    if wrapped <? 0 {
        wrapped += TRACK_TOTAL_FP
    }
    return wrapped
}

let wrap_roll = (angle:int):>int => {
    let wrapped:int = angle % 1024
    if wrapped <? 0 {
        wrapped += 1024
    }
    if wrapped >? 512 {
        wrapped -= 1024
    }
    return wrapped
}

let sin256 = (angle:int):>int => {
    let a:int = angle % 1024
    if a <? 0 {
        a += 1024
    }
    let quad:int = a // 256
    let x:int = a % 256
    if quad =? 0 {
        return (x * (512 - x)) // 256
    }
    if quad =? 1 {
        return ((256 - x) * (256 + x)) // 256
    }
    if quad =? 2 {
        return 0 - ((x * (512 - x)) // 256)
    }
    return 0 - (((256 - x) * (256 + x)) // 256)
}

let cos256 = (angle:int):>int => {
    return sin256(angle + 256)
}

let isqrt = (n:int):>int => {
    let bit:int = 1
    loop (bit * bit) <=? n {
        bit += 1
    }
    return bit - 1
}

let dir_yaw_units = (dx:int dz:int):>int => {
    let best_angle:int = 0
    let best_score:int = 0 - 9_999_999
    let angle:int = 0
    loop angle <? 1024 {
        let vx:int = 0 - sin256(angle)
        let vz:int = 0 - cos256(angle)
        let score:int = (dx * vx) + (dz * vz)
        if score >? best_score {
            best_score = score
            best_angle = angle
        }
        angle += 16
    }
    return best_angle
}

let dir_pitch_units = (horizontal:int dy:int):>int => {
    let best_angle:int = 0
    let best_score:int = 0 - 9_999_999
    let angle:int = 0 - 128
    loop angle <=? 128 {
        let score:int = (horizontal * cos256(angle)) + (dy * sin256(angle))
        if score >? best_score {
            best_score = score
            best_angle = angle
        }
        angle += 8
    }
    return best_angle
}

let load_arr = (arr:int idx:int):>int => {
    return __load__(arr + (idx * 8))
}

let store_arr = (arr:int idx:int value:int):>void => {
    __store__(value arr + (idx * 8))
    return 0
}

let interp_track = (arr:int progress:int):>int => {
    let wrapped:int = wrap_progress(progress)
    let idx:int = wrapped >> FP_SHIFT
    let frac:int = wrapped and FP_MASK
    let next:int = idx + 1
    if next >=? TRACK_SAMPLES {
        next = 0
    }
    let a:int = load_arr(arr idx)
    let b:int = load_arr(arr next)
    return a + (((b - a) * frac) // FP_ONE)
}

let normalize3 = (x:int y:int z:int out:int):>void => {
    let mag:int = isqrt((x * x) + (y * y) + (z * z))
    __store__((x * 256) // mag out + 0)
    __store__((y * 256) // mag out + 8)
    __store__((z * 256) // mag out + 16)
    return 0
}

let sample_track_point = (progress:int lane:int lift:int out:int):>void => {
    let cx:int = interp_track(track_cx progress)
    let cy:int = interp_track(track_cy progress)
    let cz:int = interp_track(track_cz progress)
    let rx:int = interp_track(track_rx progress)
    let ry:int = interp_track(track_ry progress)
    let rz:int = interp_track(track_rz progress)
    let ux:int = interp_track(track_ux progress)
    let uy:int = interp_track(track_uy progress)
    let uz:int = interp_track(track_uz progress)
    __store__(cx + ((rx * lane) // 256) + ((ux * lift) // 256) out + 0)
    __store__(cy + ((ry * lane) // 256) + ((uy * lift) // 256) out + 8)
    __store__(cz + ((rz * lane) // 256) + ((uz * lift) // 256) out + 16)
    return 0
}

let sample_forward = (progress:int out:int):>void => {
    sample_track_point(progress + (FP_ONE * 2) 0 0 scratch_e)
    sample_track_point(progress - (FP_ONE * 2) 0 0 scratch_f)
    let dx:int = __load__(scratch_e + 0) - __load__(scratch_f + 0)
    let dy:int = __load__(scratch_e + 8) - __load__(scratch_f + 8)
    let dz:int = __load__(scratch_e + 16) - __load__(scratch_f + 16)
    normalize3(dx dy dz out)
    return 0
}

let world_vertex = (x:int y:int z:int):>void => {
    GL_Vertex3f(GL_F32_FromInt(x) GL_F32_FromInt(y) GL_F32_FromInt(z))
    return 0
}

let tri3 = (x0:int y0:int z0:int x1:int y1:int z1:int x2:int y2:int z2:int r:int g:int b:int):>void => {
    glBegin(GL_TRIANGLES)
    GL_Color3f(r g b)
    world_vertex(x0 y0 z0)
    world_vertex(x1 y1 z1)
    world_vertex(x2 y2 z2)
    glEnd()
    return 0
}

let quad3 = (x0:int y0:int z0:int x1:int y1:int z1:int x2:int y2:int z2:int x3:int y3:int z3:int r:int g:int b:int):>void => {
    glBegin(GL_QUADS)
    GL_Color3f(r g b)
    world_vertex(x0 y0 z0)
    world_vertex(x1 y1 z1)
    world_vertex(x2 y2 z2)
    world_vertex(x3 y3 z3)
    glEnd()
    return 0
}

let bar2 = (x:int y:int w:int h:int r:int g:int b:int):>void => {
    quad3(x y 0 (x + w) y 0 (x + w) (y + h) 0 x (y + h) 0 r g b)
    return 0
}

let digit_glyph = (value:int):>int => {
    if value =? 0 {
        return glyph_0
    }
    if value =? 1 {
        return glyph_1
    }
    if value =? 2 {
        return glyph_2
    }
    if value =? 3 {
        return glyph_3
    }
    if value =? 4 {
        return glyph_4
    }
    if value =? 5 {
        return glyph_5
    }
    if value =? 6 {
        return glyph_6
    }
    if value =? 7 {
        return glyph_7
    }
    if value =? 8 {
        return glyph_8
    }
    return glyph_9
}

let draw_glyph = (glyph:int x:int y:int scale:int r:int g:int b:int):>void => {
    let row:int = 0
    loop row <? 7 {
        let bits:int = __load__(glyph + (row * 8))
        let col:int = 0
        loop col <? 5 {
            if ((bits >> (4 - col)) and 1) not=? 0 {
                bar2(x + (col * scale) y + (row * scale) scale (scale - 1) r g b)
            }
            col += 1
        }
        row += 1
    }
    return 0
}

let draw_digit = (value:int x:int y:int scale:int r:int g:int b:int):>void => {
    draw_glyph(digit_glyph(value) x y scale r g b)
    return 0
}

let draw_number = (value:int digits:int x:int y:int scale:int r:int g:int b:int):>void => {
    let remaining:int = value
    let place:int = digits - 1
    loop place >=? 0 {
        let div:int = 1
        let j:int = 0
        loop j <? place {
            div *= 10
            j += 1
        }
        let digit:int = (remaining // div) % 10
        draw_digit(digit x + ((digits - 1 - place) * scale * 6) y scale r g b)
        place -= 1
    }
    return 0
}

let draw_word_muzero = (x:int y:int scale:int r:int g:int b:int):>void => {
    draw_glyph(glyph_mu x y scale r g b)
    draw_glyph(glyph_Z x + (scale * 6) y scale r g b)
    draw_glyph(glyph_E x + (scale * 12) y scale r g b)
    draw_glyph(glyph_R x + (scale * 18) y scale r g b)
    draw_glyph(glyph_O x + (scale * 24) y scale r g b)
    return 0
}

