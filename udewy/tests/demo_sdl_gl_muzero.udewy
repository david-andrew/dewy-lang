let player_scrape:int = 0

let cpu_progress_fp:int = 0
let cpu_speed_fp:int = 0
let cpu_lane:int = 0
let cpu_lane_vel:int = 0
let cpu_lap:int = 0

let audio_stream:int = 0
let audio_buf:int = 0
