import p"../third_party/sdl/sdl.udewy"

const STATE_TITLE:int = 0
const STATE_RACE:int = 1
const STATE_FINISH:int = 2

const TRACK_SAMPLES:int = 320
const TRACK_TOTAL_FP:int = 81920
const TRACK_HALF_WIDTH:int = 160
const TRACK_WALL_HEIGHT:int = 34
const TRACK_MAP_RANGE:int = 1600
const TRACK_BYTES:int = 2560
const START_PROGRESS_FP:int = 46080

const FP_SHIFT:int = 8
const FP_ONE:int = 256
const FP_MASK:int = 255

const TOTAL_LAPS:int = 3
const CPU_COUNT:int = 4
const RACER_COUNT:int = 5
const CPU_BYTES:int = 32

const HOVER_HEIGHT:int = 18
const CAMERA_BACK_SAMPLES:int = 18
const CAMERA_LOOK_SAMPLES:int = 22
const AUDIO_SAMPLES:int = 2048
const AUDIO_BYTES:int = 4096

const F32_ZERO:int = 0x00000000
const F32_ONE:int = 0x3f800000
const F32_HALF:int = 0x3f000000
const F32_QUARTER:int = 0x3e800000
const F32_POINT_FIVE:int = 0x3f000000
const F32_THREE_QUARTER:int = 0x3f400000
const F32_POINT_TWO:int = 0x3e4ccccd
const F32_POINT_THREE:int = 0x3e99999a
const F32_POINT_SIX:int = 0x3f19999a
const F32_POINT_EIGHT:int = 0x3f4ccccd
const F32_POINT_NINE:int = 0x3f666666

const F64_NEG_FOUR:int = __i64_to_f64_bits__(-4)
const F64_NEG_TWO:int = __i64_to_f64_bits__(-2)
const F64_NEG_ONE:int = __i64_to_f64_bits__(-1)
const F64_ZERO:int = __i64_to_f64_bits__(0)
const F64_ONE:int = __i64_to_f64_bits__(1)
const F64_TWO:int = __i64_to_f64_bits__(2)
const F64_FOUR:int = __i64_to_f64_bits__(4)
const F64_FIVE:int = __i64_to_f64_bits__(5)
const F64_FORTY:int = __i64_to_f64_bits__(40)
const F64_TWO_THOUSAND:int = __i64_to_f64_bits__(2000)

let glyph_mu:int = [0 0 17 21 21 21 25]
let glyph_Z:int = [31 1 2 4 8 16 31]
let glyph_E:int = [31 16 30 16 16 16 31]
let glyph_R:int = [30 17 17 30 20 18 17]
let glyph_O:int = [14 17 17 17 17 17 14]
let glyph_S:int = [15 16 14 1 1 17 14]
let glyph_P:int = [30 17 17 30 16 16 16]
let glyph_A:int = [14 17 17 31 17 17 17]
let glyph_C:int = [14 17 16 16 16 17 14]
let glyph_D:int = [30 17 17 17 17 17 30]
let glyph_F:int = [31 16 30 16 16 16 16]
let glyph_I:int = [14 4 4 4 4 4 14]
let glyph_N:int = [17 25 21 19 17 17 17]
let glyph_H:int = [17 17 17 31 17 17 17]
let glyph_G:int = [14 17 16 23 17 17 14]
let glyph_K:int = [17 18 20 24 20 18 17]
let glyph_L:int = [16 16 16 16 16 16 31]
let glyph_M:int = [17 27 21 21 17 17 17]
let glyph_T:int = [31 4 4 4 4 4 4]

let glyph_0:int = [14 17 19 21 25 17 14]
let glyph_1:int = [4 12 4 4 4 4 14]
let glyph_2:int = [14 17 1 2 4 8 31]
let glyph_3:int = [30 1 1 14 1 1 30]
let glyph_4:int = [2 6 10 18 31 2 2]
let glyph_5:int = [31 16 30 1 1 17 14]
let glyph_6:int = [14 16 30 17 17 17 14]
let glyph_7:int = [31 1 2 4 8 8 8]
let glyph_8:int = [14 17 17 14 17 17 14]
let glyph_9:int = [14 17 17 15 1 2 28]

