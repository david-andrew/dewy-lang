import p"../../third_party/clay/clay.udewy"

const TXT_BRAND:int = "DEWY UI\0"
const TXT_HOME:int = "HOME\0"
const TXT_DOCS:int = "DOCS\0"
const TXT_DEMO:int = "DEMO\0"
const TXT_START:int = "START\0"
const TXT_DASH:int = "DASHBOARD\0"
const TXT_LAYOUT:int = "LAYOUT\0"
const TXT_RENDER:int = "RENDER\0"
const TXT_THEMES:int = "THEMES\0"
const TXT_SHIP:int = "SHIP\0"
const TXT_HERO:int = "CLAY RESPONSIVE UI\0"
const TXT_SUB:int = "NATIVE AND WASM\0"
const TXT_CARD1:int = "LAYOUT\0"
const TXT_CARD2:int = "STYLE\0"
const TXT_CARD3:int = "STATE\0"
const TXT_PANEL:int = "PROJECT SETTINGS\0"
const TXT_FIELD:int = "COMPONENT NAME\0"
const TXT_SAVE:int = "SAVE\0"
const TXT_STATS:int = "STATS\0"
const TXT_FAST:int = "FAST\0"
const TXT_SMALL:int = "SMALL\0"
const TXT_PORT:int = "PORTABLE\0"
const TXT_FOOT:int = "CLAY DEMO\0"
const TXT_HELP:int = "RESIZE WINDOW\0"

let glyph_row = (ch:int row:int):>int => {
    if ch =? 32 { return 0 }
    if ch =? 65 { if row =? 0 { return 14 } if row =? 1 { return 17 } if row =? 2 { return 17 } if row =? 3 { return 31 } if row =? 4 { return 17 } if row =? 5 { return 17 } return 17 }
    if ch =? 66 { if row =? 0 { return 30 } if row =? 1 { return 17 } if row =? 2 { return 17 } if row =? 3 { return 30 } if row =? 4 { return 17 } if row =? 5 { return 17 } return 30 }
    if ch =? 67 { if row =? 0 { return 14 } if row =? 1 { return 17 } if row =? 2 { return 16 } if row =? 3 { return 16 } if row =? 4 { return 16 } if row =? 5 { return 17 } return 14 }
    if ch =? 68 { if row =? 0 { return 30 } if row =? 1 { return 17 } if row =? 2 { return 17 } if row =? 3 { return 17 } if row =? 4 { return 17 } if row =? 5 { return 17 } return 30 }
    if ch =? 69 { if row =? 0 { return 31 } if row =? 1 { return 16 } if row =? 2 { return 16 } if row =? 3 { return 30 } if row =? 4 { return 16 } if row =? 5 { return 16 } return 31 }
    if ch =? 70 { if row =? 0 { return 31 } if row =? 1 { return 16 } if row =? 2 { return 16 } if row =? 3 { return 30 } if row =? 4 { return 16 } if row =? 5 { return 16 } return 16 }
    if ch =? 71 { if row =? 0 { return 14 } if row =? 1 { return 17 } if row =? 2 { return 16 } if row =? 3 { return 23 } if row =? 4 { return 17 } if row =? 5 { return 17 } return 14 }
    if ch =? 72 { if row =? 0 { return 17 } if row =? 1 { return 17 } if row =? 2 { return 17 } if row =? 3 { return 31 } if row =? 4 { return 17 } if row =? 5 { return 17 } return 17 }
    if ch =? 73 { if row =? 0 { return 14 } if row =? 1 { return 4 } if row =? 2 { return 4 } if row =? 3 { return 4 } if row =? 4 { return 4 } if row =? 5 { return 4 } return 14 }
    if ch =? 74 { if row =? 0 { return 7 } if row =? 1 { return 2 } if row =? 2 { return 2 } if row =? 3 { return 2 } if row =? 4 { return 2 } if row =? 5 { return 18 } return 12 }
    if ch =? 75 { if row =? 0 { return 17 } if row =? 1 { return 18 } if row =? 2 { return 20 } if row =? 3 { return 24 } if row =? 4 { return 20 } if row =? 5 { return 18 } return 17 }
    if ch =? 76 { if row =? 0 { return 16 } if row =? 1 { return 16 } if row =? 2 { return 16 } if row =? 3 { return 16 } if row =? 4 { return 16 } if row =? 5 { return 16 } return 31 }
    if ch =? 77 { if row =? 0 { return 17 } if row =? 1 { return 27 } if row =? 2 { return 21 } if row =? 3 { return 21 } if row =? 4 { return 17 } if row =? 5 { return 17 } return 17 }
    if ch =? 78 { if row =? 0 { return 17 } if row =? 1 { return 25 } if row =? 2 { return 21 } if row =? 3 { return 19 } if row =? 4 { return 17 } if row =? 5 { return 17 } return 17 }
    if ch =? 79 { if row =? 0 { return 14 } if row =? 1 { return 17 } if row =? 2 { return 17 } if row =? 3 { return 17 } if row =? 4 { return 17 } if row =? 5 { return 17 } return 14 }
    if ch =? 80 { if row =? 0 { return 30 } if row =? 1 { return 17 } if row =? 2 { return 17 } if row =? 3 { return 30 } if row =? 4 { return 16 } if row =? 5 { return 16 } return 16 }
    if ch =? 81 { if row =? 0 { return 14 } if row =? 1 { return 17 } if row =? 2 { return 17 } if row =? 3 { return 17 } if row =? 4 { return 21 } if row =? 5 { return 18 } return 13 }
    if ch =? 82 { if row =? 0 { return 30 } if row =? 1 { return 17 } if row =? 2 { return 17 } if row =? 3 { return 30 } if row =? 4 { return 20 } if row =? 5 { return 18 } return 17 }
    if ch =? 83 { if row =? 0 { return 15 } if row =? 1 { return 16 } if row =? 2 { return 16 } if row =? 3 { return 14 } if row =? 4 { return 1 } if row =? 5 { return 1 } return 30 }
    if ch =? 84 { if row =? 0 { return 31 } if row =? 1 { return 4 } if row =? 2 { return 4 } if row =? 3 { return 4 } if row =? 4 { return 4 } if row =? 5 { return 4 } return 4 }
    if ch =? 85 { if row =? 0 { return 17 } if row =? 1 { return 17 } if row =? 2 { return 17 } if row =? 3 { return 17 } if row =? 4 { return 17 } if row =? 5 { return 17 } return 14 }
    if ch =? 86 { if row =? 0 { return 17 } if row =? 1 { return 17 } if row =? 2 { return 17 } if row =? 3 { return 17 } if row =? 4 { return 17 } if row =? 5 { return 10 } return 4 }
    if ch =? 87 { if row =? 0 { return 17 } if row =? 1 { return 17 } if row =? 2 { return 17 } if row =? 3 { return 21 } if row =? 4 { return 21 } if row =? 5 { return 21 } return 10 }
    if ch =? 88 { if row =? 0 { return 17 } if row =? 1 { return 17 } if row =? 2 { return 10 } if row =? 3 { return 4 } if row =? 4 { return 10 } if row =? 5 { return 17 } return 17 }
    if ch =? 89 { if row =? 0 { return 17 } if row =? 1 { return 17 } if row =? 2 { return 10 } if row =? 3 { return 4 } if row =? 4 { return 4 } if row =? 5 { return 4 } return 4 }
    if ch =? 90 { if row =? 0 { return 31 } if row =? 1 { return 1 } if row =? 2 { return 2 } if row =? 3 { return 4 } if row =? 4 { return 8 } if row =? 5 { return 16 } return 31 }
    return 31
}

let demo_mouse_down:int = 0
let demo_pressed:int = 0
let demo_prev_mouse_x:int = 0
let demo_prev_mouse_y:int = 0
let demo_motion:int = 0
let demo_accent:int = 0
let demo_layout_width:int = 0
let demo_layout_height:int = 0
let demo_hot_start:int = 0
let demo_hot_save:int = 0
let demo_hot_card1:int = 0
let demo_hot_card2:int = 0
let demo_hot_card3:int = 0
let demo_hot_side:int = 0
let demo_hot_dash:int = 0
let demo_hot_nav:int = 0
let demo_hot_ship:int = 0
let demo_hot_fast:int = 0
let demo_hot_small:int = 0
let demo_hot_port:int = 0
let demo_accent_r:int = 230
let demo_accent_g:int = 118
let demo_accent_b:int = 72
let demo_start_r:int = 75
let demo_start_g:int = 88
let demo_start_b:int = 140

let demo_abs = (value:int):>int => {
    if value <? 0 {
        return 0 - value
    }
    return value
}

let clay_demo_set_input = (x:int y:int down:int):>void => {
    Clay_SetPointerState(x y down)
    demo_motion = demo_abs(x - demo_prev_mouse_x) + demo_abs(y - demo_prev_mouse_y)
    demo_pressed = 0
    if down not=? 0 {
        if demo_mouse_down =? 0 {
            demo_pressed = 1
        }
    }
    demo_mouse_down = down
    demo_prev_mouse_x = x
    demo_prev_mouse_y = y
    return 0
}

let clay_demo_update_hot_state = ():>void => {
    demo_hot_start = Clay_PointerOver(8) or Clay_PointerOver(21)
    demo_hot_save = Clay_PointerOver(40)
    demo_hot_card1 = Clay_PointerOver(23) or Clay_PointerOver(46)
    demo_hot_card2 = Clay_PointerOver(27) or Clay_PointerOver(47)
    demo_hot_card3 = Clay_PointerOver(31) or Clay_PointerOver(48)
    demo_hot_side = Clay_PointerOver(11) or Clay_PointerOver(12) or Clay_PointerOver(13) or Clay_PointerOver(14) or Clay_PointerOver(16)
    demo_hot_dash = Clay_PointerOver(11)
    demo_hot_nav = Clay_PointerOver(12) or Clay_PointerOver(13) or Clay_PointerOver(14)
    demo_hot_ship = Clay_PointerOver(16)
    demo_hot_fast = Clay_PointerOver(46)
    demo_hot_small = Clay_PointerOver(47)
    demo_hot_port = Clay_PointerOver(48)
    return 0
}

let clay_demo_update_palette = ():>void => {
    if demo_pressed not=? 0 {
        if demo_hot_start or demo_hot_save or demo_hot_card1 or demo_hot_card2 or demo_hot_card3 or demo_hot_side {
            demo_accent += 1
            if demo_accent >? 2 {
                demo_accent = 0
            }
        }
    }

    demo_accent_r = 230
    demo_accent_g = 118
    demo_accent_b = 72
    if demo_accent =? 1 {
        demo_accent_r = 83
        demo_accent_g = 190
        demo_accent_b = 142
    }
    if demo_accent =? 2 {
        demo_accent_r = 105
        demo_accent_g = 135
        demo_accent_b = 219
    }

    demo_start_r = 75
    demo_start_g = 88
    demo_start_b = 140
    if demo_hot_start {
        demo_start_r = 105
        demo_start_g = 135
        demo_start_b = 219
    }
    if demo_hot_start and (demo_mouse_down not=? 0) {
        demo_start_r = 83
        demo_start_g = 190
        demo_start_b = 142
    }
    return 0
}

let start_demo_root = ():>void => {
    Clay_OpenBoxEx(1 demo_layout_width demo_layout_height CLAY_SIZE_FIXED CLAY_SIZE_FIXED CLAY_TOP_TO_BOTTOM 18 14 18 22 32 255)
    return 0
}

let end_demo_root = ():>void => {
    Clay_Close()
    return 0
}

let render_header_link = (id:int text:int len:int width:int):>void => {
    Clay_OpenBox(id width 36 CLAY_LEFT_TO_RIGHT 7 0 255 232 194 255)
    Clay_Text(text len 12 42 50 68 255)
    Clay_Close()
    return 0
}

let render_start_button = (id:int height:int font_size:int):>void => {
    Clay_OpenBox(id 112 height CLAY_LEFT_TO_RIGHT 7 0 demo_start_r demo_start_g demo_start_b 255)
    Clay_Text(TXT_START 5 font_size 239 246 255 255)
    Clay_Close()
    return 0
}

let render_header = ():>void => {
    Clay_OpenBoxEx(2 0 64 CLAY_SIZE_GROW CLAY_SIZE_FIXED CLAY_LEFT_TO_RIGHT 14 10 demo_accent_r demo_accent_g demo_accent_b 255)
    Clay_OpenBox(3 62 36 CLAY_LEFT_TO_RIGHT 7 0 249 206 101 255)
    Clay_Text(TXT_BRAND 7 12 42 50 68 255)
    Clay_Close()
    render_header_link(4 TXT_HOME 4 92)
    render_header_link(5 TXT_DOCS 4 96)
    render_header_link(6 TXT_DEMO 4 78)
    Clay_OpenBoxEx(7 0 36 CLAY_SIZE_GROW CLAY_SIZE_FIXED CLAY_LEFT_TO_RIGHT 0 0 demo_accent_r demo_accent_g demo_accent_b 255)
    Clay_Close()
    render_start_button(8 36 12)
    Clay_Close()
    return 0
}

let render_nav_item = (id:int text:int len:int hot:int r:int g:int b:int text_r:int text_g:int text_b:int):>void => {
    if hot {
        r += 17
        g += 29
        b += 51
    }
    Clay_OpenBoxEx(id 0 40 CLAY_SIZE_GROW CLAY_SIZE_FIXED CLAY_LEFT_TO_RIGHT 7 0 r g b 255)
    Clay_Text(text len 10 text_r text_g text_b 255)
    Clay_Close()
    return 0
}

let render_sidebar = ():>void => {
    Clay_OpenBoxEx(10 116 0 CLAY_SIZE_FIXED CLAY_SIZE_GROW CLAY_TOP_TO_BOTTOM 10 8 35 43 62 255)
    render_nav_item(11 TXT_DASH 9 demo_hot_dash 92 132 219 239 246 255)
    render_nav_item(12 TXT_LAYOUT 6 demo_hot_nav 51 63 91 176 196 225)
    render_nav_item(13 TXT_RENDER 6 demo_hot_nav 51 63 91 176 196 225)
    render_nav_item(14 TXT_THEMES 6 demo_hot_nav 51 63 91 176 196 225)
    Clay_OpenBoxEx(15 0 0 CLAY_SIZE_GROW CLAY_SIZE_GROW CLAY_LEFT_TO_RIGHT 0 0 35 43 62 255)
    Clay_Close()
    render_nav_item(16 TXT_SHIP 4 demo_hot_ship 224 196 91 42 50 68)
    Clay_Close()
    return 0
}

let render_hero = ():>void => {
    Clay_OpenBoxEx(18 0 0 CLAY_SIZE_GROW CLAY_SIZE_FIT CLAY_TOP_TO_BOTTOM 9 6 68 92 142 255)
    Clay_OpenBoxEx(19 0 28 CLAY_SIZE_GROW CLAY_SIZE_FIXED CLAY_LEFT_TO_RIGHT 4 0 239 246 255 255)
    Clay_Text(TXT_HERO 18 16 42 50 68 255)
    Clay_Close()
    Clay_OpenBoxEx(20 0 22 CLAY_SIZE_GROW CLAY_SIZE_FIXED CLAY_LEFT_TO_RIGHT 5 0 176 196 225 255)
    Clay_Text(TXT_SUB 15 11 42 50 68 255)
