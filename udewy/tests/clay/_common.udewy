}

let render_metric_tile = (id:int text:int len:int hot:int r:int g:int b:int text_r:int text_g:int text_b:int):>void => {
    if hot {
        r += 13
        g += 22
        b += 23
    }
    Clay_OpenBoxEx(id 0 66 CLAY_SIZE_GROW CLAY_SIZE_FIXED CLAY_LEFT_TO_RIGHT 7 0 r g b 255)
    Clay_Text(text len 11 text_r text_g text_b 255)
    Clay_Close()
    return 0
}

let render_aside = ():>void => {
    Clay_OpenBoxEx(45 132 0 CLAY_SIZE_FIXED CLAY_SIZE_GROW CLAY_TOP_TO_BOTTOM 12 10 35 43 62 255)
    render_metric_tile(46 TXT_FAST 4 demo_hot_fast 105 135 219 239 246 255)
    render_metric_tile(47 TXT_SMALL 5 demo_hot_small 83 190 142 239 246 255)
    render_metric_tile(48 TXT_PORT 8 demo_hot_port 224 196 91 42 50 68)
    Clay_OpenBoxEx(49 0 0 CLAY_SIZE_GROW CLAY_SIZE_GROW CLAY_LEFT_TO_RIGHT 0 0 35 43 62 255)
    Clay_Close()
    Clay_OpenBoxEx(50 0 54 CLAY_SIZE_GROW CLAY_SIZE_FIXED CLAY_LEFT_TO_RIGHT 0 0 demo_accent_r demo_accent_g demo_accent_b 255)
    Clay_Close()
    Clay_Close()
    return 0
}

let render_body = ():>void => {
    Clay_OpenBoxEx(9 0 0 CLAY_SIZE_GROW CLAY_SIZE_GROW CLAY_LEFT_TO_RIGHT 0 14 18 22 32 255)
    render_sidebar()
    render_main_content()
    render_aside()
    Clay_Close()
    return 0
}

let render_footer = ():>void => {
    Clay_OpenBoxEx(51 0 34 CLAY_SIZE_GROW CLAY_SIZE_FIXED CLAY_LEFT_TO_RIGHT 10 8 42 50 68 255)
    Clay_OpenBox(52 110 18 CLAY_LEFT_TO_RIGHT 4 0 144 166 198 255)
    Clay_Text(TXT_FOOT 9 9 42 50 68 255)
    Clay_Close()
    Clay_OpenBoxEx(53 0 18 CLAY_SIZE_GROW CLAY_SIZE_FIXED CLAY_LEFT_TO_RIGHT 0 0 42 50 68 255)
    Clay_Close()
    Clay_OpenBox(54 110 18 CLAY_LEFT_TO_RIGHT 4 0 144 166 198 255)
    Clay_Text(TXT_HELP 13 9 42 50 68 255)
    Clay_Close()
    Clay_Close()
    return 0
}

let clay_demo_layout = (width:int height:int):>int => {
    demo_layout_width = width
    demo_layout_height = height
    ud_clay_set_layout_dimensions(width height)
    clay_demo_update_hot_state()
    clay_demo_update_palette()

    Clay_BeginLayout()
    start_demo_root()
        render_header()
        render_body()
        render_footer()
    end_demo_root()
    return Clay_EndLayout(16)
}
