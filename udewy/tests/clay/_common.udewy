let render_main_content = ():>void => {
    Clay_OpenBoxEx(17 0 0 CLAY_SIZE_GROW CLAY_SIZE_GROW CLAY_TOP_TO_BOTTOM 0 14 18 22 32 255)
    render_hero()
    render_card_grid()
    render_main_panel()
    Clay_Close()
