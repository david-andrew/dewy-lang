let render_main_panel = ():>void => {
    Clay_OpenBoxEx(35 0 0 CLAY_SIZE_GROW CLAY_SIZE_GROW CLAY_LEFT_TO_RIGHT 0 14 18 22 32 255)
    render_settings_panel()
    render_stats_panel()
    Clay_Close()
    return 0
