let render_feature_card = (id:int title_box_id:int line_id:int fill_id:int title:int len:int hot:int fill_r:int fill_g:int fill_b:int):>void => {
    let card_r:int = 69
    let card_g:int = 91
    let card_b:int = 124
    if hot {
        card_r = 82
        card_g = 111
        card_b = 153
    }
    Clay_OpenBoxEx(id 0 0 CLAY_SIZE_GROW CLAY_SIZE_FIT CLAY_TOP_TO_BOTTOM 12 8 card_r card_g card_b 255)
    Clay_OpenBoxEx(title_box_id 0 20 CLAY_SIZE_GROW CLAY_SIZE_FIXED CLAY_LEFT_TO_RIGHT 5 0 239 246 255 255)
    Clay_Text(title len 10 42 50 68 255)
    Clay_Close()
    Clay_OpenBoxEx(line_id 0 12 CLAY_SIZE_GROW CLAY_SIZE_FIXED CLAY_LEFT_TO_RIGHT 0 0 144 166 198 255)
    Clay_Close()
    Clay_OpenBoxEx(fill_id 0 40 CLAY_SIZE_GROW CLAY_SIZE_FIXED CLAY_LEFT_TO_RIGHT 0 0 fill_r fill_g fill_b 255)
    Clay_Close()
    Clay_Close()
    return 0
}

let render_card_grid = ():>void => {
    Clay_OpenBoxEx(22 0 0 CLAY_SIZE_GROW CLAY_SIZE_FIT CLAY_LEFT_TO_RIGHT 0 14 18 22 32 255)
    render_feature_card(23 24 25 26 TXT_CARD1 6 demo_hot_card1 83 190 142)
    render_feature_card(27 28 29 30 TXT_CARD2 5 demo_hot_card2 224 196 91)
    render_feature_card(31 32 33 34 TXT_CARD3 5 demo_hot_card3 201 106 145)
    Clay_Close()
    return 0
}

let render_save_button = ():>void => {
    let save_r:int = 83
    let save_g:int = 190
    let save_b:int = 142
    if demo_hot_save {
        save_r = 105
        save_g = 212
        save_b = 164
    }
    if demo_hot_save and (demo_mouse_down not=? 0) {
        save_r = demo_accent_r
        save_g = demo_accent_g
        save_b = demo_accent_b
    }
    Clay_OpenBox(40 130 32 CLAY_LEFT_TO_RIGHT 7 0 save_r save_g save_b 255)
    Clay_Text(TXT_SAVE 4 11 239 246 255 255)
    Clay_Close()
    return 0
}

