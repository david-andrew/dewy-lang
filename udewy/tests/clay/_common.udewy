}

let render_stats_panel = ():>void => {
    Clay_OpenBoxEx(41 132 0 CLAY_SIZE_FIXED CLAY_SIZE_GROW CLAY_TOP_TO_BOTTOM 12 8 35 43 62 255)
    Clay_OpenBoxEx(42 0 32 CLAY_SIZE_GROW CLAY_SIZE_FIXED CLAY_LEFT_TO_RIGHT 7 0 105 135 219 255)
