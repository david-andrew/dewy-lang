$supported_targets = ["wasm32"]

import p"./_common.udewy"

let canvas_width:int = 720
let canvas_height:int = 480
let canvas_buffer:int = 0
let initialized:int = 0

let draw_rect = (x:int y:int width:int height:int r:int g:int b:int a:int):>void => {
    if x <? 0 {
        width += x
        x = 0
    }
    if y <? 0 {
        height += y
        y = 0
    }
    if x + width >? canvas_width {
        width = canvas_width - x
    }
    if y + height >? canvas_height {
        height = canvas_height - y
    }
    if width <=? 0 {
        return 0
    }
    if height <=? 0 {
        return 0
    }

    let end_y:int = y + height
    let row:int = y
    loop row <? end_y {
        let end_x:int = x + width
        let col:int = x
        loop col <? end_x {
            let addr:int = canvas_buffer + (((row * canvas_width) + col) * 4)
            __store_u8__(r addr)
            __store_u8__(g addr + 1)
            __store_u8__(b addr + 2)
            __store_u8__(a addr + 3)
            col += 1
        }
        row += 1
    }
    return 0
}

let draw_text_block = (x:int y:int size:int r:int g:int b:int a:int):>void => {
    draw_rect(x y size size r g b a)
    return 0
}

let render_clay_text_to_canvas = (cmd_idx:int):>void => {
    let font_size:int = ud_clay_render_text_size(cmd_idx)
    let scale:int = font_size // 8
    if scale <? 1 {
        scale = 1
    }
    let x0:int = ud_clay_render_x(cmd_idx)
    let y0:int = ud_clay_render_y(cmd_idx)
    let r:int = ud_clay_render_text_r(cmd_idx)
    let g:int = ud_clay_render_text_g(cmd_idx)
    let b:int = ud_clay_render_text_b(cmd_idx)
    let a:int = ud_clay_render_text_a(cmd_idx)

    let char_idx:int = 0
    let char_count:int = ud_clay_render_text_len(cmd_idx)
    loop char_idx <? char_count {
        let ch:int = ud_clay_render_text_char(cmd_idx char_idx)
        let row:int = 0
        loop row <? 7 {
            let bits:int = glyph_row(ch row)
            let col:int = 0
            loop col <? 5 {
                let mask:int = 1 << (4 - col)
                if (bits and mask) not=? 0 {
                    draw_text_block(x0 + (char_idx * 6 * scale) + (col * scale) y0 + (row * scale) scale r g b a)
                }
                col += 1
            }
            row += 1
        }
        char_idx += 1
    }
    return 0
}

let render_clay_to_canvas = ():>void => {
    let count:int = ud_clay_render_count()
    let i:int = 0
    loop i <? count {
        if ud_clay_render_type(i) =? CLAY_RENDER_COMMAND_TYPE_RECTANGLE {
            draw_rect(
                ud_clay_render_x(i)
                ud_clay_render_y(i)
                ud_clay_render_width(i)
                ud_clay_render_height(i)
                ud_clay_render_rect_r(i)
                ud_clay_render_rect_g(i)
                ud_clay_render_rect_b(i)
                ud_clay_render_rect_a(i)
            )
        }
        if ud_clay_render_type(i) =? CLAY_RENDER_COMMAND_TYPE_TEXT {
            render_clay_text_to_canvas(i)
        }
        i += 1
    }
    return 0
}

let main = ():>int => {
    if initialized =? 0 {
        canvas_width = __window_width__()
        canvas_height = __window_height__()
        canvas_buffer = __canvas_init__(canvas_width canvas_height)
        __canvas_set_aspect_lock__(0)
        if Clay_Init(canvas_width canvas_height) =? 0 {
            return 1
        }
        initialized = 1
    }

    let window_width:int = __window_width__()
    let window_height:int = __window_height__()
    if (window_width not=? canvas_width) or (window_height not=? canvas_height) {
        canvas_width = window_width
        canvas_height = window_height
        canvas_buffer = __canvas_init__(canvas_width canvas_height)
    }

    clay_demo_set_input(__pointer_x__() __pointer_y__() __pointer_down__())
    clay_demo_layout(canvas_width canvas_height)
    render_clay_to_canvas()
    __canvas_present__()
    return 0
}
