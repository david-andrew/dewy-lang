# ============================================================================
# μZero2: SDL3 + OpenGL 2.1 entry point (x86_64 / c targets).
# ============================================================================

$supported_targets = ["x86_64" "c"]

import p"./platform_sdl.udewy"
import p"./game.udewy"

let main = ():>int => {
    arena_init()
    let rc:int = backend_init(1280 720 "μZero2\0")
    if rc not=? 0 {
        return rc
    }
    game_init()

    loop running {
        frame_step(16)
    }

    backend_shutdown()
    return 0
}
