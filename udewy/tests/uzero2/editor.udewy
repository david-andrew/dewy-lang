# ============================================================================
# μZero2 in-game track editor.
#
# Works directly on the node/segment graph with incremental rebake. Fully
# usable with keyboard alone, mouse alone, or (best) both:
#
#   mouse      LMB click selects, LMB drag moves the node on the horizontal
#              plane (hold LSHIFT: move vertically, hold LCTRL: snap to grid)
#              RMB drag orbits, MMB (or LSHIFT+RMB) drag pans, wheel zooms,
#              LALT+LMB also orbits (browser fallback)
#   camera     W/A/S/D fly, Q/E down/up, arrows look, LSHIFT fast
#   selection  TAB next node (LSHIFT+TAB prev), P pick node nearest the
#              crosshair ray
#   move node  I/K fwd/back, J/L left/right, U/O down/up (camera relative)
#   tangent    T/G pitch, Y/H yaw       roll  R/F
#   widths     Z/X narrower/wider       xsect C/V    lift B/N
#   surface    M cycle kind
#   segment    1/2 toggle left/right rail, 3/4 twist -/+ (first out-segment)
#   topology   ENTER append node+segment, DELETE delete node,
#              5 mark node, 6 connect mark->selected, 7 disconnect
#   files      F2 edit the track file name, F5 save, F9 load
#   test drive SPACE enter, TAB leave    ESC back to menu
# ============================================================================

import p"./prelude.udewy"
import p"./state.udewy"
import p"./track_model.udewy"
import p"./track_bake.udewy"
import p"./track_format.udewy"
import p"./physics.udewy"
import p"./camera.udewy"
import p"./render_world.udewy"
import p"./render_hud.udewy"
import p"./input.udewy"

# ---------- Editor state -------------------------------------------------------

let ed_sel:NodeId = 0
let ed_mark:NodeId = -1
let ed_testdrive:bool = false
let ed_cam_x:Q16 = 0
let ed_cam_y:Q16 = 3276800                # 50 m up
let ed_cam_z:Q16 = 6553600                # 100 m back
let ed_yaw:AngleFine = 0                  # 0 = looking -z
let ed_pitch:AngleFine = -6400
let ed_focus_dist:Q16 = 9830400           # 150 m orbit / zoom pivot distance
let ed_dirty_progress:bool = false
const ED_STATUS_CAP:int = 48
const ED_STATUS:Ptr = __static_alloca__(48)
let ed_status_frames:int = 0

let ed_set_status = (s:Cstr):>void => {
    let i:int = 0
    loop (__load_u8__(s + i) not=? 0) and (i <? ED_STATUS_CAP - 1) {
        __store_u8__(__load_u8__(s + i) ED_STATUS + i)
        i += 1
    }
    __store_u8__(0 ED_STATUS + i)
    ed_status_frames = 150
    return void
}

# ---------- Camera basis ---------------------------------------------------------

const ED_FWD:Vec3 = __static_alloca__(24)
const ED_RIGHT:Vec3 = __static_alloca__(24)
const ED_UP:Vec3 = __static_alloca__(24)

let ed_cam_basis = ():>void => {
    let cy_:Q16 = cos_fine(ed_yaw)
    let sy_:Q16 = sin_fine(ed_yaw)
    let cp_:Q16 = cos_fine(ed_pitch)
    let sp_:Q16 = sin_fine(ed_pitch)
    v3_set(ED_FWD fp_mul(sy_ cp_) sp_ (-fp_mul(cy_ cp_)))
    v3_set(ED_RIGHT cy_ 0 sy_)
    v3_cross(ED_UP ED_RIGHT ED_FWD)
    return void
}

let ed_apply_camera = ():>void => {
    ed_cam_basis()
    cam_x = ed_cam_x
    cam_y = ed_cam_y
    cam_z = ed_cam_z
    cam_fx = v3_x(ED_FWD)
    cam_fy = v3_y(ED_FWD)
    cam_fz = v3_z(ED_FWD)
    cam_ux = v3_x(ED_UP)
    cam_uy = v3_y(ED_UP)
    cam_uz = v3_z(ED_UP)
    cur_fov_top_q16 = 131072
    return void
}

# ---------- Rebake helpers ---------------------------------------------------------

# Re-bake all segments incident to a node (after a parameter change).
let ed_rebake_node = (n:NodeId):>void => {
    let s:int = 0
    loop s <? seg_count() {
        let sg:Ptr = seg_p(s)
        if (__load__(sg + SG_N0) =? n) or (__load__(sg + SG_N1) =? n) {
            bake_one_segment(s)
        }
        s += 1
    }
    ed_dirty_progress = true
    return void
}

# Full rebake after topology changes (adjacency / route / progress).
let ed_rebake_all = ():>void => {
    track_bake()
    ed_dirty_progress = false
    return void
}

# Rebuild the main route by walking out-segments from the start segment.
let ed_route_auto = ():>void => {
    vec_set_len(g_route 0)
    if seg_count() =? 0 { return void }
    track_build_adjacency()
    if g_start_seg >=? seg_count() { g_start_seg = 0 }
    let s:SegId = g_start_seg
    let guard:int = 0
    loop guard <? seg_count() * 2 {
        vec_push(g_route s)
        let nxt:SegId = node_out_seg(__load__(seg_p(s) + SG_N1) 0)
        if nxt <? 0 { return void }
        if nxt =? g_start_seg { return void }
        s = nxt
        guard += 1
    }
    return void
}

# ---------- Topology operations ------------------------------------------------------

let ed_append_node = ():>void => {
    let nd:Ptr = node_p(ed_sel)
    let px:Q16 = __load__(nd + ND_PX) + fp_mul(__load__(nd + ND_TX) ED_NEW_SEG_LEN)
    let py:Q16 = __load__(nd + ND_PY) + fp_mul(__load__(nd + ND_TY) ED_NEW_SEG_LEN)
    let pz:Q16 = __load__(nd + ND_PZ) + fp_mul(__load__(nd + ND_TZ) ED_NEW_SEG_LEN)
    let id:NodeId = node_new(px py pz
                             __load__(nd + ND_TX) __load__(nd + ND_TY) __load__(nd + ND_TZ) 0
                             __load__(nd + ND_UX) __load__(nd + ND_UY) __load__(nd + ND_UZ)
                             __load__(nd + ND_WL) __load__(nd + ND_WR)
                             __load__(nd + ND_XSECT) __load__(nd + ND_LIFT)
                             __load__(nd + ND_SURF))
    seg_new(ed_sel id)
    ed_sel = id
    ed_rebake_all()
    ed_set_status("APPENDED\0")
    return void
}

let ed_connect = ():>void => {
    if (ed_mark <? 0) or (ed_mark =? ed_sel) {
        ed_set_status("MARK A NODE FIRST (5)\0")
        return void
    }
    if seg_find(ed_mark ed_sel) >=? 0 {
        ed_set_status("ALREADY CONNECTED\0")
        return void
    }
    seg_new(ed_mark ed_sel)
    ed_rebake_all()
    ed_set_status("CONNECTED\0")
    return void
}

let ed_disconnect = ():>void => {
    if ed_mark <? 0 {
        ed_set_status("MARK A NODE FIRST (5)\0")
        return void
    }
    let s:SegId = seg_find(ed_mark ed_sel)
    if s <? 0 {
        s = seg_find(ed_sel ed_mark)
    }
    if s <? 0 {
        ed_set_status("NOT CONNECTED\0")
        return void
    }
    seg_remove(s)
    ed_route_auto()
    ed_rebake_all()
    ed_set_status("DISCONNECTED\0")
    return void
}

let ed_delete_node = ():>void => {
    if node_count() <=? 2 {
        ed_set_status("TRACK TOO SMALL\0")
        return void
    }
    # remove incident segments (indices shift on swap-remove, so rescan)
    let s:int = 0
    loop s <? seg_count() {
        let sg:Ptr = seg_p(s)
        if (__load__(sg + SG_N0) =? ed_sel) or (__load__(sg + SG_N1) =? ed_sel) {
            seg_remove(s)
        } else {
            s += 1
        }
    }
    # swap-remove the node; re-point segments at the moved node id
    let last:NodeId = node_count() - 1
    if ed_sel <? last {
        vec_set(g_nodes ed_sel vec_get(g_nodes last))
        s = 0
        loop s <? seg_count() {
            let sg:Ptr = seg_p(s)
            if __load__(sg + SG_N0) =? last { __store__(ed_sel sg + SG_N0) }
            if __load__(sg + SG_N1) =? last { __store__(ed_sel sg + SG_N1) }
            s += 1
        }
    }
    vec_set_len(g_nodes last)
    if ed_mark >=? node_count() { ed_mark = -1 }
    if ed_sel >=? node_count() { ed_sel = 0 }
    if g_start_seg >=? seg_count() { g_start_seg = 0 }
    ed_route_auto()
    ed_rebake_all()
    ed_set_status("DELETED\0")
    return void
}

# ---------- Node pick (crosshair ray) ---------------------------------------------------

let ed_pick_node = ():>void => {
    ed_cam_basis()
    let best:NodeId = -1
    let best_score:Q16 = 58982              # require cos > 0.9 to the ray
    let i:int = 0
    loop i <? node_count() {
        let nd:Ptr = node_p(i)
        let dx:Q16 = __load__(nd + ND_PX) - ed_cam_x
        let dy:Q16 = __load__(nd + ND_PY) - ed_cam_y
        let dz:Q16 = __load__(nd + ND_PZ) - ed_cam_z
        let dm:Q16 = fp_sqrt((dx * dx) + (dy * dy) + (dz * dz))
        if dm >? 65536 {
            let d:Q16 = fp_mul(fp_div(dx dm) v3_x(ED_FWD))
                      + fp_mul(fp_div(dy dm) v3_y(ED_FWD))
                      + fp_mul(fp_div(dz dm) v3_z(ED_FWD))
            if d >? best_score {
                best_score = d
                best = i
            }
        }
        i += 1
    }
    if best >=? 0 {
        ed_sel = best
        ed_set_status("PICKED\0")
    }
    return void
}

# ---------- Mouse: projection, picking, dragging, camera ------------------------------

const ED_RAY:Vec3 = __static_alloca__(24)        # unnormalized view ray
const ED_HIT:Vec3 = __static_alloca__(24)
const ED_PLANE_P:Vec3 = __static_alloca__(24)
const ED_PLANE_N:Vec3 = __static_alloca__(24)
const ED_GRAB_OFF:Vec3 = __static_alloca__(24)   # node pos - plane hit at grab
let ed_drag_active:bool = false
let ed_drag_vertical:bool = false

# View ray through the mouse cursor (editor fov: tan(v/2) = 1, near plane 2 m).
let ed_mouse_ray = ():>void => {
    ed_cam_basis()
    let ndc_x:Q16 = ((mouse_x * 2 - scr_w) << 16) // scr_w
    let ndc_y:Q16 = ((scr_h - mouse_y * 2) << 16) // scr_h
    let aspect:Q16 = (scr_w << 16) // scr_h
    v3_copy(ED_RAY ED_FWD)
    v3_addscaled(ED_RAY ED_RAY ED_RIGHT fp_mul(ndc_x aspect))
    v3_addscaled(ED_RAY ED_RAY ED_UP ndc_y)
    return void
}

# Project a world point to window pixels; returns false when behind the camera.
let ed_proj_x:int = 0
let ed_proj_y:int = 0

let ed_project = (px:Q16 py:Q16 pz:Q16):>bool => {
    let dx:Q16 = px - ed_cam_x
    let dy:Q16 = py - ed_cam_y
    let dz:Q16 = pz - ed_cam_z
    let zc:Q16 = fp_mul(dx v3_x(ED_FWD)) + fp_mul(dy v3_y(ED_FWD)) + fp_mul(dz v3_z(ED_FWD))
    if zc <? 131072 { return false }
    let xc:Q16 = fp_mul(dx v3_x(ED_RIGHT)) + fp_mul(dy v3_y(ED_RIGHT)) + fp_mul(dz v3_z(ED_RIGHT))
    let yc:Q16 = fp_mul(dx v3_x(ED_UP)) + fp_mul(dy v3_y(ED_UP)) + fp_mul(dz v3_z(ED_UP))
    let aspect:Q16 = (scr_w << 16) // scr_h
    let rx_:Q16 = fp_div(fp_div(xc zc) aspect)
    let ry_:Q16 = fp_div(yc zc)
    ed_proj_x = scr_w // 2 + (rx_ * scr_w) // (2 * FP_ONE)
    ed_proj_y = scr_h // 2 - (ry_ * scr_h) // (2 * FP_ONE)
    return true
}

# Nearest node within ED_PICK_RADIUS_PX of the cursor (screen space), or -1.
let ed_pick_screen = ():>NodeId => {
    ed_cam_basis()
    let best:NodeId = -1
    let best_d2:int = ED_PICK_RADIUS_PX * ED_PICK_RADIUS_PX
    let i:int = 0
    loop i <? node_count() {
        let nd:Ptr = node_p(i)
        if ed_project(__load__(nd + ND_PX) __load__(nd + ND_PY) __load__(nd + ND_PZ)) {
            let ddx:int = ed_proj_x - mouse_x
            let ddy:int = ed_proj_y - mouse_y
            let d2:int = (ddx * ddx) + (ddy * ddy)
            if d2 <=? best_d2 {
                best_d2 = d2
                best = i
            }
        }
        i += 1
    }
    return best
}

# Intersect the mouse ray with the plane (ED_PLANE_P, ED_PLANE_N) into ED_HIT.
let ed_ray_plane = ():>bool => {
    let denom:Q16 = v3_dot(ED_RAY ED_PLANE_N)
    if (denom <? 3277) and (denom >? -3277) { return false }
    let rel_x:Q16 = v3_x(ED_PLANE_P) - ed_cam_x
    let rel_y:Q16 = v3_y(ED_PLANE_P) - ed_cam_y
    let rel_z:Q16 = v3_z(ED_PLANE_P) - ed_cam_z
    let num:Q16 = fp_mul(rel_x v3_x(ED_PLANE_N)) + fp_mul(rel_y v3_y(ED_PLANE_N)) + fp_mul(rel_z v3_z(ED_PLANE_N))
    let t:Q16 = fp_div(num denom)
    if t <? 0 { return false }
    v3_set(ED_HIT
           ed_cam_x + fp_mul(v3_x(ED_RAY) t)
           ed_cam_y + fp_mul(v3_y(ED_RAY) t)
           ed_cam_z + fp_mul(v3_z(ED_RAY) t))
    return true
}

# Set the drag plane through the selected node for the current mode:
# horizontal (move in xz) or vertical (move in y, facing the camera).
let ed_drag_set_plane = ():>void => {
    let nd:Ptr = node_p(ed_sel)
    v3_copy(ED_PLANE_P nd + ND_PX)
    if ed_drag_vertical {
        let hx:Q16 = v3_x(ED_FWD)
        let hz:Q16 = v3_z(ED_FWD)
        let hm:Q16 = fp_sqrt((hx * hx) + (hz * hz))
        if hm >? 1024 {
            v3_set(ED_PLANE_N fp_div(hx hm) 0 fp_div(hz hm))
        } else {
            v3_set(ED_PLANE_N 0 0 (-FP_ONE))
        }
    } else {
        v3_set(ED_PLANE_N 0 FP_ONE 0)
    }
    return void
}

# (Re)grab: plane hit -> offset so the node doesn't jump under the cursor.
let ed_drag_grab = ():>bool => {
    ed_drag_set_plane()
    if ed_ray_plane() =? false { return false }
    let nd:Ptr = node_p(ed_sel)
    v3_set(ED_GRAB_OFF
           __load__(nd + ND_PX) - v3_x(ED_HIT)
           __load__(nd + ND_PY) - v3_y(ED_HIT)
           __load__(nd + ND_PZ) - v3_z(ED_HIT))
    return true
}

let ed_snap_q16 = (v:Q16 step:Q16):>Q16 => {
    let h:Q16 = step // 2
    if v >=? 0 { return ((v + h) // step) * step }
    return -(((-v + h) // step) * step)
}

let ed_drag_update = ():>void => {
    ed_mouse_ray()
    # live axis toggle: re-grab when LSHIFT changes the plane mid-drag
    let want_vertical:bool = key_down(KEY_LSHIFT)
    if want_vertical not=? ed_drag_vertical {
        ed_drag_vertical = want_vertical
        if ed_drag_grab() =? false { return void }
    }
    ed_drag_set_plane()
    if ed_ray_plane() =? false { return void }
    let nd:Ptr = node_p(ed_sel)
    let nx:Q16 = v3_x(ED_HIT) + v3_x(ED_GRAB_OFF)
    let ny:Q16 = v3_y(ED_HIT) + v3_y(ED_GRAB_OFF)
    let nz:Q16 = v3_z(ED_HIT) + v3_z(ED_GRAB_OFF)
    if ed_drag_vertical {
        if key_down(KEY_LCTRL) { ny = ed_snap_q16(ny ED_GRID_STEP) }
        __store__(ny nd + ND_PY)
    } else {
        if key_down(KEY_LCTRL) {
            nx = ed_snap_q16(nx ED_GRID_STEP)
            nz = ed_snap_q16(nz ED_GRID_STEP)
        }
        __store__(nx nd + ND_PX)
        __store__(nz nd + ND_PZ)
    }
    ed_rebake_node(ed_sel)
    return void
}

# Orbit the camera around the focus point (cam + fwd * focus_dist).
let ed_mouse_orbit = ():>void => {
    ed_cam_basis()
    let pvx:Q16 = ed_cam_x + fp_mul(v3_x(ED_FWD) ed_focus_dist)
    let pvy:Q16 = ed_cam_y + fp_mul(v3_y(ED_FWD) ed_focus_dist)
    let pvz:Q16 = ed_cam_z + fp_mul(v3_z(ED_FWD) ed_focus_dist)
    ed_yaw = (ed_yaw + mouse_dx() * ED_MOUSE_ORBIT_FINE) % ANG_FINE_TURN
    if ed_yaw <? 0 { ed_yaw += ANG_FINE_TURN }
    ed_pitch = clamp_i(ed_pitch - mouse_dy() * ED_MOUSE_ORBIT_FINE (-16000) 16000)
    ed_cam_basis()
    ed_cam_x = pvx - fp_mul(v3_x(ED_FWD) ed_focus_dist)
    ed_cam_y = pvy - fp_mul(v3_y(ED_FWD) ed_focus_dist)
    ed_cam_z = pvz - fp_mul(v3_z(ED_FWD) ed_focus_dist)
    return void
}

# Pan: slide the camera in the view plane, scaled so the point at the focus
# distance tracks the cursor.
let ed_mouse_pan = ():>void => {
    ed_cam_basis()
    let wpp:Q16 = (ed_focus_dist * 2) // max_i(scr_h 1)    # world per pixel
    let dx_w:Q16 = mouse_dx() * wpp
    let dy_w:Q16 = mouse_dy() * wpp
    ed_cam_x -= fp_mul(v3_x(ED_RIGHT) dx_w)
    ed_cam_y -= fp_mul(v3_y(ED_RIGHT) dx_w)
    ed_cam_z -= fp_mul(v3_z(ED_RIGHT) dx_w)
    ed_cam_x += fp_mul(v3_x(ED_UP) dy_w)
    ed_cam_y += fp_mul(v3_y(ED_UP) dy_w)
    ed_cam_z += fp_mul(v3_z(ED_UP) dy_w)
    return void
}

# Wheel dolly toward / away from the focus point.
let ed_mouse_zoom = (steps:int):>void => {
    ed_cam_basis()
    let s:int = steps
    loop s >? 0 {
        let delta:Q16 = ed_focus_dist // 5
        if ed_focus_dist - delta <? 655360 { delta = ed_focus_dist - 655360 }
        if delta >? 0 {
            ed_cam_x += fp_mul(v3_x(ED_FWD) delta)
            ed_cam_y += fp_mul(v3_y(ED_FWD) delta)
            ed_cam_z += fp_mul(v3_z(ED_FWD) delta)
            ed_focus_dist -= delta
        }
        s -= 1
    }
    loop s <? 0 {
        let delta:Q16 = ed_focus_dist // 4
        if ed_focus_dist + delta >? 327680000 { delta = 0 }
        ed_cam_x -= fp_mul(v3_x(ED_FWD) delta)
        ed_cam_y -= fp_mul(v3_y(ED_FWD) delta)
        ed_cam_z -= fp_mul(v3_z(ED_FWD) delta)
        ed_focus_dist += delta
        s += 1
    }
    return void
}

let ed_handle_mouse = ():>void => {
    if mouse_wheel not=? 0 {
        ed_mouse_zoom(mouse_wheel)
    }

    let orbit:bool = false
    let pan:bool = false
    if mouse_down(MOUSE_R) {
        if key_down(KEY_LSHIFT) { pan = true } else { orbit = true }
    }
    if mouse_down(MOUSE_M) { pan = true }
    if mouse_down(MOUSE_L) and key_down(KEY_LALT) { orbit = true }

    if orbit {
        ed_mouse_orbit()
        ed_drag_active = false
        return void
    }
    if pan {
        ed_mouse_pan()
        ed_drag_active = false
        return void
    }

    if mouse_pressed(MOUSE_L) {
        let hit:NodeId = ed_pick_screen()
        if hit >=? 0 {
            ed_sel = hit
            ed_mouse_ray()
            ed_drag_vertical = key_down(KEY_LSHIFT)
            if ed_drag_grab() {
                ed_drag_active = true
            }
        }
    }
    if ed_drag_active {
        if mouse_down(MOUSE_L) {
            ed_drag_update()
        } else {
            ed_drag_active = false
        }
    }
    return void
}

# ---------- Track file name / save / load ------------------------------------------------

const ED_NAME_CAP:int = 20
const ED_NAME_BUF:Ptr = __static_alloca__(24)
const ED_NAME_BAK:Ptr = __static_alloca__(24)
let ed_name_len:int = 0
let ed_name_bak_len:int = 0
let ed_naming:bool = false
const ED_PATH_BUF:Ptr = __static_alloca__(40)
# Character produced by each letter key id (KEY_W=0 .. KEY_P=25).
const ED_KEY_CHARS:Cstr = "wasdqerftgyhuoijklzxcvbnmp\0"
const ED_DIGIT_CHARS:Cstr = "1234567890\0"

let ed_name_set_default = ():>void => {
    let def:Cstr = "mytrack\0"
    let i:int = 0
    loop __load_u8__(def + i) not=? 0 {
        __store_u8__(__load_u8__(def + i) ED_NAME_BUF + i)
        i += 1
    }
    ed_name_len = i
    return void
}

# Current save/load path: "<name>.uztrack".
let ed_path = ():>Cstr => {
    let i:int = 0
    loop i <? ed_name_len {
        __store_u8__(__load_u8__(ED_NAME_BUF + i) ED_PATH_BUF + i)
        i += 1
    }
    let suffix:Cstr = ".uztrack\0"
    let j:int = 0
    loop __load_u8__(suffix + j) not=? 0 {
        __store_u8__(__load_u8__(suffix + j) ED_PATH_BUF + i + j)
        j += 1
    }
    __store_u8__(0 ED_PATH_BUF + i + j)
    return ED_PATH_BUF
}

let ed_name_push = (ch:int):>void => {
    if ed_name_len <? ED_NAME_CAP - 1 {
        __store_u8__(ch ED_NAME_BUF + ed_name_len)
        ed_name_len += 1
    }
    return void
}

# Text entry for the file name. Letters / digits append, SPACE adds '_',
# BACKSPACE deletes, ENTER commits, ESC cancels.
let ed_handle_naming = ():>void => {
    let k:int = 0
    loop k <? 26 {
        if key_pressed(k) {
            ed_name_push(__load_u8__(ED_KEY_CHARS + k))
        }
        k += 1
    }
    let d:int = 0
    loop d <? 10 {
        if key_pressed(KEY_1 + d) {
            ed_name_push(__load_u8__(ED_DIGIT_CHARS + d))
        }
        d += 1
    }
    if key_pressed(KEY_SPACE) { ed_name_push(95) }   # '_'
    if key_pressed(KEY_BACKSPACE) and (ed_name_len >? 0) {
        ed_name_len -= 1
    }
    if key_pressed(KEY_ENTER) {
        if ed_name_len =? 0 { ed_name_set_default() }
        ed_naming = false
        ed_set_status("FILE NAME SET\0")
    }
    if key_pressed(KEY_ESC) {
        let i:int = 0
        loop i <? ed_name_bak_len {
            __store_u8__(__load_u8__(ED_NAME_BAK + i) ED_NAME_BUF + i)
            i += 1
        }
        ed_name_len = ed_name_bak_len
        ed_naming = false
    }
    __store_u8__(0 ED_NAME_BUF + ed_name_len)
    return void
}

let ed_naming_begin = ():>void => {
    let i:int = 0
    loop i <? ed_name_len {
        __store_u8__(__load_u8__(ED_NAME_BUF + i) ED_NAME_BAK + i)
        i += 1
    }
    ed_name_bak_len = ed_name_len
    ed_naming = true
    return void
}

const ED_LOAD_CAP:int = 65536
const ED_LOAD_BUF:Ptr = __static_alloca__(65536)

let ed_save = ():>void => {
    let bb:int = track_serialize()
    let fd:int = host_open(ed_path() O_WRONLY + O_CREAT + O_TRUNC 438)
    if fd >=? 0 {
        host_write(fd bb_data(bb) bb_len(bb))
        host_close(fd)
        ed_set_status("SAVED\0")
    } else {
        # no filesystem (wasm): emit through stdout / console log
        host_write(STDOUT bb_data(bb) bb_len(bb))
        ed_set_status("DUMPED TO CONSOLE\0")
    }
    return void
}

let ed_load = ():>void => {
    let fd:int = host_open(ed_path() O_RDONLY 0)
    if fd <? 0 {
        ed_set_status("FILE NOT FOUND\0")
        return void
    }
    let n:int = host_read(fd ED_LOAD_BUF ED_LOAD_CAP - 1)
    host_close(fd)
    if n <=? 0 {
        ed_set_status("EMPTY FILE\0")
        return void
    }
    __store_u8__(0 ED_LOAD_BUF + n)
    if track_parse(ED_LOAD_BUF) {
        ed_sel = 0
        ed_mark = -1
        ed_rebake_all()
        ed_set_status("LOADED\0")
    } else {
        ed_set_status("PARSE ERROR\0")
    }
    return void
}

# ---------- Test drive ------------------------------------------------------------------------

let ed_place_test_car = ():>void => {
    let adj:VecHandle = __load__(node_p(ed_sel) + ND_ADJ)
    let sid:SegId = g_start_seg
    let si:FrameId = 0
    if (adj not=? 0) and (vec_len(adj) >? 0) {
        sid = vec_get(adj 0)
        if __load__(seg_p(sid) + SG_N1) =? ed_sel {
            si = seg_nsamp(seg_p(sid)) - 1
        }
    }
    let saved_start_seg:SegId = g_start_seg
    let saved_start_t:Q16 = g_start_t
    g_start_seg = sid
    let n:int = seg_nsamp(seg_p(sid))
    g_start_t = (si << 16) // max_i(n - 1 1)
    init_cars(1)
    g_start_seg = saved_start_seg
    g_start_t = saved_start_t
    car_load(0)
    camera_snap_behind_craft()
    return void
}

# ---------- Per-frame update --------------------------------------------------------------------

let ed_move_speed = ():>Q16 => {
    if key_down(KEY_LSHIFT) { return ED_MOVE_FAST }
    return ED_MOVE_STEP
}

let ed_handle_node_keys = ():>void => {
    let nd:Ptr = node_p(ed_sel)
    let changed:bool = false
    let step:Q16 = ed_move_speed()
    ed_cam_basis()

    if key_down(KEY_I) {
        __store__(__load__(nd + ND_PX) + fp_mul(v3_x(ED_FWD) step) nd + ND_PX)
        __store__(__load__(nd + ND_PY) + fp_mul(v3_y(ED_FWD) step) nd + ND_PY)
        __store__(__load__(nd + ND_PZ) + fp_mul(v3_z(ED_FWD) step) nd + ND_PZ)
        changed = true
    }
    if key_down(KEY_K) {
        __store__(__load__(nd + ND_PX) - fp_mul(v3_x(ED_FWD) step) nd + ND_PX)
        __store__(__load__(nd + ND_PY) - fp_mul(v3_y(ED_FWD) step) nd + ND_PY)
        __store__(__load__(nd + ND_PZ) - fp_mul(v3_z(ED_FWD) step) nd + ND_PZ)
        changed = true
    }
    if key_down(KEY_J) {
        __store__(__load__(nd + ND_PX) - fp_mul(v3_x(ED_RIGHT) step) nd + ND_PX)
        __store__(__load__(nd + ND_PZ) - fp_mul(v3_z(ED_RIGHT) step) nd + ND_PZ)
        changed = true
    }
    if key_down(KEY_L) {
        __store__(__load__(nd + ND_PX) + fp_mul(v3_x(ED_RIGHT) step) nd + ND_PX)
        __store__(__load__(nd + ND_PZ) + fp_mul(v3_z(ED_RIGHT) step) nd + ND_PZ)
        changed = true
    }
    if key_down(KEY_U) {
        __store__(__load__(nd + ND_PY) - step nd + ND_PY)
        changed = true
    }
    if key_down(KEY_O) {
        __store__(__load__(nd + ND_PY) + step nd + ND_PY)
        changed = true
    }

    # tangent pitch/yaw (preserve roll by re-applying it around the new tangent)
    if key_down(KEY_T) or key_down(KEY_G) or key_down(KEY_Y) or key_down(KEY_H) {
        let roll:Angle = node_get_roll(ed_sel)
        if key_down(KEY_T) {
            v3_rotate_about(nd + ND_TX ED_RIGHT ED_ANGLE_STEP * ANG_FINE_PER_RAW)
        }
        if key_down(KEY_G) {
            v3_rotate_about(nd + ND_TX ED_RIGHT (-ED_ANGLE_STEP) * ANG_FINE_PER_RAW)
        }
        if key_down(KEY_Y) {
            v3_rotate_about(nd + ND_TX ED_UP ED_ANGLE_STEP * ANG_FINE_PER_RAW)
        }
        if key_down(KEY_H) {
            v3_rotate_about(nd + ND_TX ED_UP (-ED_ANGLE_STEP) * ANG_FINE_PER_RAW)
        }
        v3_norm(nd + ND_TX)
        node_set_roll(ed_sel roll)
        changed = true
    }
    if key_down(KEY_R) {
        node_set_roll(ed_sel node_get_roll(ed_sel) + ED_ANGLE_STEP)
        changed = true
    }
    if key_down(KEY_F) {
        node_set_roll(ed_sel node_get_roll(ed_sel) - ED_ANGLE_STEP)
        changed = true
    }

    if key_down(KEY_Z) {
        __store__(max_i(__load__(nd + ND_WL) - ED_WIDTH_STEP 131072) nd + ND_WL)
        __store__(max_i(__load__(nd + ND_WR) - ED_WIDTH_STEP 131072) nd + ND_WR)
        changed = true
    }
    if key_down(KEY_X) {
        __store__(__load__(nd + ND_WL) + ED_WIDTH_STEP nd + ND_WL)
        __store__(__load__(nd + ND_WR) + ED_WIDTH_STEP nd + ND_WR)
        changed = true
    }
    if key_down(KEY_C) {
        __store__(clamp_i(__load__(nd + ND_XSECT) - ED_XSECT_STEP (-1024) 1024) nd + ND_XSECT)
        changed = true
    }
    if key_down(KEY_V) {
        __store__(clamp_i(__load__(nd + ND_XSECT) + ED_XSECT_STEP (-1024) 1024) nd + ND_XSECT)
        changed = true
    }
    if key_down(KEY_B) {
        __store__(clamp_i(__load__(nd + ND_LIFT) - 1638 0 FP_ONE) nd + ND_LIFT)
        changed = true
    }
    if key_down(KEY_N) {
        __store__(clamp_i(__load__(nd + ND_LIFT) + 1638 0 FP_ONE) nd + ND_LIFT)
        changed = true
    }
    if key_pressed(KEY_M) {
        __store__((__load__(nd + ND_SURF) + 1) % SURF_KIND_COUNT nd + ND_SURF)
        changed = true
    }

    # segment params: first out-segment of the selected node
    let osg:SegId = node_out_seg(ed_sel 0)
    if osg >=? 0 {
        let sg:Ptr = seg_p(osg)
        if key_pressed(KEY_1) {
            __store__(__load__(sg + SG_RAILS) xor RAIL_LEFT sg + SG_RAILS)
            changed = true
        }
        if key_pressed(KEY_2) {
            __store__(__load__(sg + SG_RAILS) xor RAIL_RIGHT sg + SG_RAILS)
            changed = true
        }
        if key_pressed(KEY_3) {
            __store__(__load__(sg + SG_TWIST) - 256 sg + SG_TWIST)
            changed = true
        }
        if key_pressed(KEY_4) {
            __store__(__load__(sg + SG_TWIST) + 256 sg + SG_TWIST)
            changed = true
        }
    }

    if changed {
        ed_rebake_node(ed_sel)
    }
    return void
}

let ed_handle_camera_keys = ():>void => {
    ed_cam_basis()
    let spd:Q16 = ED_CAM_SPEED
    if key_down(KEY_LSHIFT) { spd = ED_CAM_FAST }
    if key_down(KEY_W) {
        ed_cam_x += fp_mul(v3_x(ED_FWD) spd)
        ed_cam_y += fp_mul(v3_y(ED_FWD) spd)
        ed_cam_z += fp_mul(v3_z(ED_FWD) spd)
    }
    if key_down(KEY_S) {
        ed_cam_x -= fp_mul(v3_x(ED_FWD) spd)
        ed_cam_y -= fp_mul(v3_y(ED_FWD) spd)
        ed_cam_z -= fp_mul(v3_z(ED_FWD) spd)
    }
    if key_down(KEY_A) {
        ed_cam_x -= fp_mul(v3_x(ED_RIGHT) spd)
        ed_cam_z -= fp_mul(v3_z(ED_RIGHT) spd)
    }
    if key_down(KEY_D) {
        ed_cam_x += fp_mul(v3_x(ED_RIGHT) spd)
        ed_cam_z += fp_mul(v3_z(ED_RIGHT) spd)
    }
    if key_down(KEY_Q) { ed_cam_y -= spd }
    if key_down(KEY_E) { ed_cam_y += spd }
    if key_down(KEY_LEFT) { ed_yaw -= ED_CAM_TURN * ANG_FINE_PER_RAW }
    if key_down(KEY_RIGHT) { ed_yaw += ED_CAM_TURN * ANG_FINE_PER_RAW }
    if key_down(KEY_UP) { ed_pitch = clamp_i(ed_pitch + ED_CAM_TURN * ANG_FINE_PER_RAW (-16000) 16000) }
    if key_down(KEY_DOWN) { ed_pitch = clamp_i(ed_pitch - ED_CAM_TURN * ANG_FINE_PER_RAW (-16000) 16000) }
    ed_yaw = ed_yaw % ANG_FINE_TURN
    if ed_yaw <? 0 { ed_yaw += ANG_FINE_TURN }
    return void
}

# Returns true while the editor stays active; false = exit to menu.
let editor_update = ():>bool => {
    if ed_testdrive {
        if key_pressed(KEY_TAB) or key_pressed(KEY_ESC) {
            ed_testdrive = false
            return true
        }
        gather_player_input()
        current_car_is_player = 1
        car_load(0)
        physics_step()
        trail_push()
        car_store(0)
        update_chase()
        spark_step()
        return true
    }

    if ed_naming {
        ed_handle_naming()
        return true
    }

    if key_pressed(KEY_ESC) {
        return false
    }
    if key_pressed(KEY_SPACE) {
        if ed_dirty_progress {
            ed_rebake_all()
        }
        ed_place_test_car()
        trail_count = 0
        trail_head = 0
        ed_testdrive = true
        return true
    }

    ed_handle_mouse()
    ed_handle_camera_keys()

    if key_pressed(KEY_TAB) {
        if key_down(KEY_LSHIFT) {
            ed_sel = (ed_sel + node_count() - 1) % node_count()
        } else {
            ed_sel = (ed_sel + 1) % node_count()
        }
    }
    if key_pressed(KEY_P) { ed_pick_node() }
    if key_pressed(KEY_5) {
        ed_mark = ed_sel
        ed_set_status("MARKED\0")
    }
    if key_pressed(KEY_6) { ed_connect() }
    if key_pressed(KEY_7) { ed_disconnect() }
    if key_pressed(KEY_ENTER) { ed_append_node() }
    if key_pressed(KEY_DELETE) or key_pressed(KEY_BACKSPACE) { ed_delete_node() }
    if key_pressed(KEY_F2) { ed_naming_begin() }
    if key_pressed(KEY_F5) { ed_save() }
    if key_pressed(KEY_F9) { ed_load() }

    ed_handle_node_keys()

    # progress / bounds refresh once per second while dirty
    if ed_dirty_progress and ((frame_count % 60) =? 0) {
        bake_progress()
        bake_track_bounds()
        ed_dirty_progress = false
    }
    return true
}

# ---------- Rendering -------------------------------------------------------------------------

# Axis gizmo + tangent arrow on the selected node, dots on the others.
let ed_draw_gizmos = ():>void => {
    gpu_set_texture(0)
    gpu_enable_depth_test(0)
    gpu_lines_begin(FP_ONE * 2)
    let i:int = 0
    loop i <? node_count() {
        let nd:Ptr = node_p(i)
        let px:Q16 = __load__(nd + ND_PX)
        let py:Q16 = __load__(nd + ND_PY)
        let pz:Q16 = __load__(nd + ND_PZ)
        if i =? ed_sel {
            let g:Q16 = 983040           # 15 m gizmo arms
            gpu_set_color4(FP_ONE 13107 13107 FP_ONE)
            gpu_vertex3(px - g py pz)
            gpu_vertex3(px + g py pz)
            gpu_set_color4(13107 FP_ONE 13107 FP_ONE)
            gpu_vertex3(px py - g pz)
            gpu_vertex3(px py + g pz)
            gpu_set_color4(13107 39321 FP_ONE FP_ONE)
            gpu_vertex3(px py pz - g)
            gpu_vertex3(px py pz + g)
            gpu_set_color4(FP_ONE FP_ONE 13107 FP_ONE)
            gpu_vertex3(px py pz)
            gpu_vertex3(px + fp_mul(__load__(nd + ND_TX) 1966080)
                        py + fp_mul(__load__(nd + ND_TY) 1966080)
                        pz + fp_mul(__load__(nd + ND_TZ) 1966080))
        } else {
            if i =? ed_mark {
                gpu_set_color4(FP_ONE 32768 FP_ONE FP_ONE)
            } else {
                gpu_set_color4(45875 45875 45875 FP_ONE)
            }
            let g:Q16 = 327680           # 5 m dots
            gpu_vertex3(px - g py pz)
            gpu_vertex3(px + g py pz)
            gpu_vertex3(px py - g pz)
            gpu_vertex3(px py + g pz)
        }
        i += 1
    }
    gpu_end()
    gpu_enable_depth_test(1)
    return void
}

const ED_TITLE:Cstr = "EDITOR\0"
const ED_LBL_NODE:Cstr = "NODE \0"
const ED_LBL_POS:Cstr = "POS \0"
const ED_LBL_ROLL:Cstr = "ROLL \0"
const ED_LBL_W:Cstr = "W \0"
const ED_LBL_XS:Cstr = "XSECT \0"
const ED_LBL_LIFT:Cstr = "LIFT \0"
const ED_LBL_SURF:Cstr = "SURF \0"
const ED_LBL_SEGS:Cstr = "SEGS \0"
const ED_LBL_FILE:Cstr = "FILE \0"
const ED_LBL_SP:Cstr = " \0"
const ED_NAME_PROMPT:Cstr = "NAME: \0"
const ED_NAME_HINT:Cstr = "TYPE NAME  ENTER OK  ESC CANCEL\0"
const ED_CURSOR_GLYPH:Cstr = "_\0"
const ED_HINT1:Cstr = "LMB DRAG  SHIFT VERT  CTRL SNAP  RMB ORBIT\0"
const ED_HINT2:Cstr = "MMB PAN  WHEEL ZOOM  TAB/P SELECT  IJKLUO MOVE\0"
const ED_HINT3:Cstr = "TYGH TAN  RF ROLL  ZX W  CV XSECT  BN LIFT  M SURF\0"
const ED_HINT4:Cstr = "ENTER ADD  DEL DEL  5 MARK  6/7 CON/DIS  1-4 RAIL/TWIST\0"
const ED_HINT5:Cstr = "F2 NAME  F5 SAVE  F9 LOAD  SPACE DRIVE  ESC MENU\0"
const ED_DRIVE_HINT:Cstr = "TAB BACK TO EDITOR\0"

let ed_q16_m = (v:Q16):>int => {
    return __signed_shr__(v FP_SHIFT)
}

let ed_draw_hud = (sw:int sh:int):>void => {
    gpu_overlay_begin(sw sh)
    if ed_testdrive {
        gpu_set_color4(FP_ONE FP_ONE FP_ONE 52428)
        text_draw(HUD_MARGIN_PX HUD_MARGIN_PX ED_DRIVE_HINT 2)
        gpu_overlay_end()
        return void
    }

    # crosshair
    gpu_set_texture(0)
    gpu_set_color4(FP_ONE FP_ONE FP_ONE 39321)
    gpu_quads_begin()
    hud_quad(sw // 2 - 8 sh // 2 - 1 sw // 2 + 8 sh // 2 + 1)
    hud_quad(sw // 2 - 1 sh // 2 - 8 sw // 2 + 1 sh // 2 + 8)
    gpu_end()

    draw_panel(8 8 380 210)
    gpu_set_color4(FP_ONE 58982 13107 FP_ONE)
    let x:int = text_draw(20 18 ED_TITLE 2)
    gpu_set_color4(FP_ONE FP_ONE FP_ONE FP_ONE)

    let nd:Ptr = node_p(ed_sel)
    let y:int = 44
    x = text_draw(20 y ED_LBL_NODE 2)
    x = text_draw(x y fmt_int(ed_sel) 2)
    x = text_draw(x y ED_LBL_SP 2)
    x = text_draw(x y ED_LBL_SEGS 2)
    text_draw(x y fmt_int(seg_count()) 2)
    y += 22
    x = text_draw(20 y ED_LBL_POS 2)
    x = text_draw(x y fmt_int(ed_q16_m(__load__(nd + ND_PX))) 2)
    x = text_draw(x y ED_LBL_SP 2)
    x = text_draw(x y fmt_int(ed_q16_m(__load__(nd + ND_PY))) 2)
    x = text_draw(x y ED_LBL_SP 2)
    text_draw(x y fmt_int(ed_q16_m(__load__(nd + ND_PZ))) 2)
    y += 22
    x = text_draw(20 y ED_LBL_ROLL 2)
    x = text_draw(x y fmt_int((node_get_roll(ed_sel) * 360) // 1024) 2)
    x = text_draw(x y ED_LBL_SP 2)
    x = text_draw(x y ED_LBL_W 2)
    x = text_draw(x y fmt_int(ed_q16_m(__load__(nd + ND_WL))) 2)
    x = text_draw(x y ED_LBL_SP 2)
    text_draw(x y fmt_int(ed_q16_m(__load__(nd + ND_WR))) 2)
    y += 22
    x = text_draw(20 y ED_LBL_XS 2)
    x = text_draw(x y fmt_int((__load__(nd + ND_XSECT) * 360) // 1024) 2)
    x = text_draw(x y ED_LBL_SP 2)
    x = text_draw(x y ED_LBL_LIFT 2)
    text_draw(x y fmt_int((__load__(nd + ND_LIFT) * 100) // FP_ONE) 2)
    y += 22
    x = text_draw(20 y ED_LBL_SURF 2)
    text_draw(x y surf_kind_name(__load__(nd + ND_SURF)) 2)
    y += 22
    gpu_set_color4(45875 65535 45875 FP_ONE)
    x = text_draw(20 y ED_LBL_FILE 2)
    text_draw(x y ed_path() 2)

    gpu_set_color4(45875 52428 65535 45875)
    text_draw(20 sh - 128 ED_HINT1 2)
    text_draw(20 sh - 104 ED_HINT2 2)
    text_draw(20 sh - 80 ED_HINT3 2)
    text_draw(20 sh - 56 ED_HINT4 2)
    text_draw(20 sh - 32 ED_HINT5 2)

    if ed_naming {
        let pw:int = 460
        let px0:int = (sw - pw) // 2
        let py0:int = sh // 2 - 60
        draw_panel(px0 py0 px0 + pw py0 + 120)
        gpu_set_color4(FP_ONE FP_ONE 26214 FP_ONE)
        x = text_draw(px0 + 24 py0 + 24 ED_NAME_PROMPT 3)
        x = text_draw(x py0 + 24 ED_NAME_BUF 3)
        if (frame_count % 60) <? 36 {
            text_draw(x py0 + 24 ED_CURSOR_GLYPH 3)
        }
        gpu_set_color4(FP_ONE FP_ONE FP_ONE 45875)
        text_draw(px0 + 24 py0 + 80 ED_NAME_HINT 2)
    }

    if ed_status_frames >? 0 {
        ed_status_frames -= 1
        gpu_set_color4(FP_ONE FP_ONE 26214 FP_ONE)
        text_draw_centered(sw // 2 sh // 2 + 30 ED_STATUS 2)
    }
    gpu_overlay_end()
    return void
}

let editor_render = (sw:int sh:int):>void => {
    if ed_testdrive =? false {
        ed_apply_camera()
    }
    render_world_common(sw sh)
    if ed_testdrive {
        draw_all_cars()
        draw_trail()
        draw_sparks()
    } else {
        ed_draw_gizmos()
    }
    ed_draw_hud(sw sh)
    return void
}

# Called when entering the editor state.
let editor_enter = ():>void => {
    ed_sel = 0
    ed_mark = -1
    ed_testdrive = false
    ed_naming = false
    ed_drag_active = false
    if ed_name_len =? 0 {
        ed_name_set_default()
    }
    # park the camera near the start of the track
    let sg:Ptr = seg_p(g_start_seg)
    let fp:Ptr = fr_p(sg 0)
    ed_cam_x = __load__(fp + FR_PX)
    ed_cam_y = __load__(fp + FR_PY) + 3932160
    ed_cam_z = __load__(fp + FR_PZ) + 7864320
    ed_yaw = 0
    ed_pitch = -7680
    ed_focus_dist = 9830400
    return void
}
