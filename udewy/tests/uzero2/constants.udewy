# ---------- Track representation --------------------------------------------

# Surface kind tags. Affect physics (boost / recharge) and the draw texture.
const SURF_NORMAL:SurfKind = 0
const SURF_BOOST:SurfKind = 1
const SURF_RECHARGE:SurfKind = 2
const SURF_GRID:SurfKind = 3
const SURF_LOOP:SurfKind = 4             # purple tint (visual only)
const SURF_CORK:SurfKind = 5             # pink tint (visual only)
const SURF_RAMP:SurfKind = 6             # amber tint (visual only)
const SURF_KIND_COUNT:int = 7

const RAIL_LEFT:int = 1
const RAIL_RIGHT:int = 2
const RAIL_HEIGHT:Q16 = 196608           # 3 m

# Lateral bailout: a probe this far beyond the track edge counts as fully off
# the surface (no clamp / snap; the craft flies free).
const OFF_TRACK_LAT:Q16 = 655360         # 10 m past the rail counts as off

# Node record layout (arena allocated).
const ND_PX:int = 0
const ND_PY:int = 8
const ND_PZ:int = 16
const ND_TX:int = 24                     # unit tangent
const ND_TY:int = 32
const ND_TZ:int = 40
const ND_TLEN:int = 48                   # Hermite tangent magnitude (0 = auto)
const ND_UX:int = 56                     # unit up (perpendicular to tangent)
const ND_UY:int = 64
const ND_UZ:int = 72
const ND_WL:int = 80                     # left half-width (Q16 m, surface arc length)
const ND_WR:int = 88                     # right half-width
const ND_XSECT:int = 96                  # cross-section angle, raw units (+-1024 = closed)
const ND_LIFT:int = 104                  # Q16 0..1: arc center pulled onto the centerline
const ND_SURF:int = 112
const ND_ADJ:int = 120                   # vec of incident segment ids (built at bake)
const ND_SIZE:int = 128

# Segment record layout.
const SG_N0:int = 0
const SG_N1:int = 8
const SG_FLIP0:int = 16                  # +1 / -1: sign of node tangent at this end
const SG_FLIP1:int = 24
const SG_TWIST:int = 32                  # extra roll across the segment (raw; 1024 = full corkscrew)
const SG_SURF:int = 40                   # -1 = use node kinds
const SG_RAILS:int = 48                  # RAIL_LEFT | RAIL_RIGHT bits
const SG_NSAMP:int = 56                  # baked frame count
const SG_FRAMES:int = 64                 # ptr to frame array
const SG_FRAME_CAP:int = 72              # allocated frame slots
const SG_MESH:int = 80                   # ptr to baked vertex grid
const SG_MESH_CAP:int = 88               # allocated mesh bytes
const SG_MESH_ROWS:int = 96
const SG_MESH_COLS:int = 104
const SG_LEN:int = 112                   # arc length (Q16 m)
const SG_PROG0:int = 120                 # progress at segment start
const SG_PROG1:int = 128                 # progress at segment end
const SG_MINX:int = 136                  # AABB (already expanded by track width)
const SG_MINY:int = 144
const SG_MINZ:int = 152
const SG_MAXX:int = 160
const SG_MAXY:int = 168
const SG_MAXZ:int = 176
const SG_ROUTE_IDX:int = 184             # index on the main route, -1 if off-route
const SG_BAKE_STAMP:int = 192            # unique id of the latest bake (render cache key)
const SG_SIZE:int = 200

# Baked frame layout (one sample along a segment).
const FR_PX:int = 0
const FR_PY:int = 8
const FR_PZ:int = 16
const FR_FX:int = 24                     # unit forward (centerline tangent)
const FR_FY:int = 32
const FR_FZ:int = 40
const FR_UX:int = 48                     # unit up at the lateral center
const FR_UY:int = 56
const FR_UZ:int = 64
const FR_WL:int = 72
const FR_WR:int = 80
const FR_XSECT:int = 88                  # raw angle units
const FR_LIFT:int = 96                   # Q16
const FR_KIND:int = 104
const FR_CUMARC:int = 112                # arc length from segment start (Q16 m)
const FR_PROG:int = 120                  # global lap progress at this frame (Q16)
const FR_STRIDE:int = 128

const MAX_FRAMES_PER_SEG:int = 224
const SAMPLE_SPACING:Q16 = 393216        # 6 m between baked frames
const XSECT_FLAT_EPS:int = 4             # |xsect| below this (raw) = flat ribbon
const XSECT_CLOSED_MIN:int = 1010        # |xsect| above this = closed pipe (no edges)

# Mesh vertex: x, y, z, u, v, shade (Q16 each).
const MV_STRIDE:int = 48
const MESH_MAX_COLS:int = 16

# Track query tuning.
const QUERY_WINDOW:int = 8
const QUERY_END_MARGIN:int = 2
const BROADPHASE_MARGIN:Q16 = 3276800    # 50 m AABB expansion for re-acquire

# Progress per route segment (Q16). Lap length = route_len * PROG_PER_SEG.
const PROG_PER_SEG:Q16 = 65536

