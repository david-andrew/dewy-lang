node n33 pos 2050 -100 -1100 tan 0.5803 0.3675 0.7254 roll 10 width 72 72 xsect 0 surf normal
# Main line takes the wide outside sweeper; a narrow pipe cuts inside.
node n34 pos 2250 180 -600 tan 0.1414 0.3017 0.9429 roll 24 width 78 78 xsect 0 surf normal
node n35 pos 2200 220 -100 tan -0.3009 0.0401 0.9528 roll 28 width 88 88 xsect 0 surf normal
node n36 pos 1950 220 350 tan -0.6544 -0.0403 0.7551 roll 20 width 88 88 xsect 0 surf normal
node n37 pos 1550 180 650 tan -0.8701 -0.0967 0.4834 roll 12 width 82 82 xsect 0 surf recharge
node n38 pos 1050 120 850 tan -0.9448 -0.09 0.3149 roll -8 width 78 78 xsect 0 surf normal
