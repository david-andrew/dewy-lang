let builtin_track_text = (idx:int):>Cstr => {
    if idx =? 1 { return TRACK_PIPE_DREAM }
    if idx =? 2 { return TRACK_PLAYGROUND }
    if idx =? 3 { return TRACK_SERPENT_KNOT }
    if idx =? 4 { return TRACK_AETHER_DIVIDE }
    return TRACK_VELOCITY_RING
}

const TRACK_NAME_0:Cstr = "VELOCITY RING\0"
const TRACK_NAME_1:Cstr = "PIPE DREAM\0"
const TRACK_NAME_2:Cstr = "PLAYGROUND\0"
const TRACK_NAME_3:Cstr = "SERPENT KNOT\0"
const TRACK_NAME_4:Cstr = "AETHER DIVIDE\0"

let builtin_track_name = (idx:int):>Cstr => {
    if idx =? 1 { return TRACK_NAME_1 }
    if idx =? 2 { return TRACK_NAME_2 }
    if idx =? 3 { return TRACK_NAME_3 }
    if idx =? 4 { return TRACK_NAME_4 }
    return TRACK_NAME_0
}

let builtin_race_track_index = (cursor:int):>int => {
    if cursor >=? 2 { return cursor + 1 }
    return cursor
}

let builtin_race_track_cursor = (idx:int):>int => {
    if idx =? 1 { return 1 }
    if idx =? 3 { return 2 }
    if idx =? 4 { return 3 }
    return 0
}
