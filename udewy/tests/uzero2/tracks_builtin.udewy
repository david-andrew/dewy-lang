seg s17 from n17 to n18
seg s18 from n18 to n19
seg s19 from n19 to n20
seg s20 from n20 to n21
seg s21 from n21 to n22
seg s22 from n22 to n23
seg s23 from n23 to n24
seg s24 from n24 to n25
seg s25 from n25 to n26
seg s26 from n26 to t0
seg s27 from t0 to t1
seg s28 from t1 to t2
seg s29 from t2 to t3
seg s30 from t3 to a0
seg s31 from a0 to t4
seg s32 from t4 to t5
seg s33 from t5 to t6
seg s34 from t6 to t7
seg s35 from t7 to n27
seg s36 from n27 to n28
seg s37 from n28 to n29
seg s38 from n29 to n30
seg s39 from n30 to n31 twist 1
seg s40 from n31 to n32
seg s41 from n32 to n33
seg s42 from n33 to n34
seg s43 from n34 to n35
seg s44 from n35 to n36 twist 1
seg s45 from n36 to n37
