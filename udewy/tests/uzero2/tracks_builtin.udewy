node n13 pos 1010 340 -10 tan 0 1 0 up 0 0 -1 width 58 58 xsect 0 surf loop
node n14 pos 1070 500 150 tan 0 0 1 up 0 -1 0 width 58 58 xsect 0 surf loop
node n15 pos 1130 340 310 tan 0 -1 0 up 0 0 1 width 58 58 xsect 0 surf loop
node n16 pos 1190 180 150 tan 0 0 -1 up 0 1 0 width 58 58 xsect 0 surf loop
node n17 pos 1210 140 -300 tan 0.184 -0.092 -0.9786 width 64 64 xsect 0 surf normal
# The road everts onto a broad tube and climbs around the outside of the arena.
node n18 pos 1350 100 -700 tan 0.4869 -0.025 -0.8731 roll 8 width 105 105 xsect -180 lift 1 surf normal
node n19 pos 1600 120 -1000 tan 0.8785 0.1882 -0.4392 width 145 145 xsect -360 lift 1 surf normal
node n20 pos 2050 250 -1050 tan 0.8926 0.399 0.21 width 145 145 xsect -360 lift 1 surf normal
