const TRACK_AETHER_DIVIDE:Cstr = "
uztrack 1
name AETHER DIVIDE
laps 3
space
# Launch through a long grid straight into climbing, heavily banked esses.
node n0 pos 0 120 0 tan 0 0 -1 width 58 58 xsect 0 surf grid
node n1 pos 0 120 -700 tan -0.2424 0.0291 -0.9697 roll -6 width 64 64 xsect 0 surf normal
node n2 pos -250 150 -1000 tan -0.8339 0.131 -0.5361 roll -18 width 68 68 xsect 0 surf normal
node n3 pos -700 230 -1150 tan -0.9724 0.2269 0.054 roll -28 width 76 76 xsect 0 surf normal
node n4 pos -1150 360 -950 tan -0.7028 0.2919 0.6487 roll -22 width 72 72 xsect 0 surf normal
node n5 pos -1350 500 -550 tan -0.1125 0.27 0.9563 roll 18 width 66 66 xsect 0 surf normal
node n6 pos -1250 600 -100 tan 0.4643 0.1238 0.877 roll 24 width 74 74 xsect 0 surf recharge
# Crest funnel: half-pipe closes around a full barrel roll, then opens again.
node n7 pos -900 620 300 tan 0.776 -0.0194 0.6305 roll 12 width 100 100 xsect 180 surf normal
node n8 pos -450 580 550 tan 0.9357 -0.131 0.3275 width 125 125 xsect 360 surf normal
node n9 pos 100 480 650 tan 0.9696 -0.2401 0.0462 width 125 125 xsect 360 surf cork
