seg s47 from n38 to n39
seg s48 from n39 to n40
seg s49 from n40 to n41
seg s50 from n41 to n42
seg s51 from n42 to n43
seg s52 from n43 to n44
seg s53 from n44 to n45
seg s54 from n45 to n0
start s0 0.5
route s0 s1 s2 s3 s4 s5 s6 s7 s8 s9 s10 s11 s12 s13 s14 s15 s16 s17 s18 s19 s20 s21 s22 s23 s24 s25 s26 s27 s28 s29 s30 s31 s32 s33 s34 s35 s36 s37 s38 s39 s40 s41 s42 s43 s44 s45 s46 s47 s48 s49 s50 s51 s52 s53 s54
\0"

let builtin_track_text = (idx:int):>Cstr => {
    if idx =? 1 { return TRACK_PIPE_DREAM }
    if idx =? 2 { return TRACK_PLAYGROUND }
    if idx =? 3 { return TRACK_SERPENT_KNOT }
    return TRACK_VELOCITY_RING
}

const TRACK_NAME_0:Cstr = "VELOCITY RING\0"
const TRACK_NAME_1:Cstr = "PIPE DREAM\0"
const TRACK_NAME_2:Cstr = "PLAYGROUND\0"
const TRACK_NAME_3:Cstr = "SERPENT KNOT\0"

let builtin_track_name = (idx:int):>Cstr => {
    if idx =? 1 { return TRACK_NAME_1 }
    if idx =? 2 { return TRACK_NAME_2 }
    if idx =? 3 { return TRACK_NAME_3 }
    return TRACK_NAME_0
}
