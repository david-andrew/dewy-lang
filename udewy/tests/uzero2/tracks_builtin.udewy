node n22 pos 2600 760 -350 tan 0 0.4281 0.9037 width 160 160 xsect -360 lift 1 surf loop
node n23 pos 2450 950 150 tan -0.5222 0.2754 0.8071 width 160 160 xsect -360 lift 1 surf normal
node n24 pos 2050 1050 500 tan -0.8731 0.0485 0.4851 width 145 145 xsect -360 lift 1 surf recharge
node n25 pos 1550 1000 650 tan -0.9734 -0.2049 0.1025 width 145 145 xsect -360 lift 1 surf normal
node n26 pos 1100 850 600 tan -0.8768 -0.3507 -0.3288 width 145 145 xsect -360 lift 1 surf normal
node n27 pos 750 680 350 tan -0.5492 -0.4027 -0.7323 width 105 105 xsect -180 lift 1 surf normal
node n28 pos 650 520 0 tan -0.0609 -0.402 -0.9136 width 72 72 xsect 0 surf recharge
# A second pipe tightens around the steep corkscrew plunge.
node n29 pos 700 350 -400 tan 0.2017 -0.4739 -0.8571 width 105 105 xsect 180 surf normal
node n30 pos 850 50 -850 tan 0.4621 -0.4898 -0.7393 width 125 125 xsect 360 surf cork
node n31 pos 1200 -180 -1200 tan 0.8197 -0.2562 -0.5123 width 125 125 xsect 360 surf normal
