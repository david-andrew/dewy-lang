# ============================================================================
# uZero shared math: backend-agnostic primitives.
#   - Float bit constants
#   - Q16 fixed-point arithmetic (FP_ONE = 65536, 1 unit = 1 m)
#   - 1024-units-per-turn sin/cos
#   - Q16 -> f32 / f64 bit-pattern conversion
#   - vec3 helpers
#   - xorshift128+ RNG
# Identical to uzero_core.udewy minus the SDL/GL boundary helpers.
# ============================================================================

# ---------- Float bit constants ----------------------------------------------

const F32_ZERO:int = 0
const F32_ONE:int = 0x3f800000
const F32_NEG_ONE:int = 0xbf800000
const F32_HALF:int = 0x3f000000

const F64_ZERO:int = 0
const F64_NEAR:int = __i64_to_f64_bits__(2)
const F64_FAR:int = __i64_to_f64_bits__(4000)

# ---------- Fixed-point ------------------------------------------------------

const FP_SHIFT:int = 16
const FP_ONE:int = 65536
const FP_HALF:int = 32768
const FP_QUARTER:int = 16384

const ANG_TURN:int = 1024
const ANG_HALF_TURN:int = 512
const ANG_QTR:int = 256
const ANG_OCTANT:int = 128
const ANG_MASK:int = 1023

# ---------- Math primitives --------------------------------------------------

let abs_i = (v:int):>int => {
    if v <? 0 {
        return 0 - v
    }
    return v
}

let clamp_i = (v:int lo:int hi:int):>int => {
    if v <? lo {
        return lo
    }
    if v >? hi {
        return hi
    }
    return v
}

let fp_mul = (a:int b:int):>int => {
    return __signed_shr__(a * b 16)
}

let fp_div = (a:int b:int):>int => {
    if b =? 0 {
        return 0
    }
    return (a << 16) // b
}

let fp_sqrt = (n:int):>int => {
    if n <=? 0 {
        return 0
    }
    let bit:int = 1
    let value:int = n
    loop value >=? 4 {
        value = value >> 2
        bit = bit << 1
    }
    let x:int = bit << 1
    let i:int = 0
    loop i <? 12 {
        if x =? 0 {
            return 0
        }
        let y:int = (x + (n // x)) >> 1
        if y >=? x {
            return x
        }
        x = y
        i += 1
    }
    return x
}

# Bhaskara I sin (1024-units-per-turn, returns Q16).
let sin_fp = (angle:int):>int => {
    let a:int = angle % ANG_TURN
    if a <? 0 {
        a += ANG_TURN
    }
    let sign:int = 1
    if a >=? ANG_HALF_TURN {
        a -= ANG_HALF_TURN
        sign = 0 - 1
    }
    let u:int = a * (ANG_HALF_TURN - a)
    let num:int = (16 * u) * FP_ONE
    let denom:int = (5 * 262144) - (4 * u)
    return sign * (num // denom)
}

let cos_fp = (angle:int):>int => {
    return sin_fp(angle + ANG_QTR)
}

# ---------- xorshift128+ PRNG ------------------------------------------------

let xs_state0:int = 0x9E3779B97F4A7C15
let xs_state1:int = 0xBF58476D1CE4E5B9

let xs_seed = (seed:int):>void => {
    let z:int = seed + 0x9E3779B97F4A7C15
    z = (z xor (z >> 30)) * 0xBF58476D1CE4E5B9
    z = (z xor (z >> 27)) * 0x94D049BB133111EB
    xs_state0 = z xor (z >> 31)
    if xs_state0 =? 0 {
        xs_state0 = 1
    }
    z = xs_state0 + 0x9E3779B97F4A7C15
    z = (z xor (z >> 30)) * 0xBF58476D1CE4E5B9
    z = (z xor (z >> 27)) * 0x94D049BB133111EB
    xs_state1 = z xor (z >> 31)
    if xs_state1 =? 0 {
        xs_state1 = 1
    }
    return 0
}

let xs_next = ():>int => {
    let x:int = xs_state0
    let y:int = xs_state1
    xs_state0 = y
    x = x xor (x << 23)
    xs_state1 = x xor y xor (x >> 17) xor (y >> 26)
    return xs_state1 + y
}

let xs_range = (n:int):>int => {
    let r:int = xs_next() >> 1
    return r % n
}

# ---------- vec3 helpers (Q16 components) ------------------------------------

let vec3_mag = (x:int y:int z:int):>int => {
    return fp_sqrt((x * x) + (y * y) + (z * z))
}

let vec3_dot = (ax:int ay:int az:int bx:int by:int bz:int):>int => {
    return fp_mul(ax bx) + fp_mul(ay by) + fp_mul(az bz)
}

# ---------- Q16 -> float bit-pattern -----------------------------------------

let q16_to_f32 = (val:int):>int => {
    if val =? 0 {
        return 0
    }
    let raw:int = __i64_to_f32_bits__(val)
    return raw - (16 << 23)
}

let q16_to_f64 = (val:int):>int => {
    if val =? 0 {
        return 0
    }
    let raw:int = __i64_to_f64_bits__(val)
    return raw - (16 << 52)
}

let f32_from_int = (value:int):>int => {
    return __i64_to_f32_bits__(value)
}

let f64_from_int = (value:int):>int => {
    return __i64_to_f64_bits__(value)
}
