# ---------- Track -----------------------------------------------------------

# Surface kind tags. Used both for surface lookup (recharge / boost effects)
# and to pick the texture binding at draw time. Kinds 4..6 only affect the
# visual texture binding; their physics behavior is identical to SURF_NORMAL.
const SURF_NORMAL:int = 0
const SURF_BOOST:int = 1
const SURF_RECHARGE:int = 2
const SURF_GRID:int = 3                  # start/finish grid stripe
const SURF_LOOP:int = 4                  # vertical loop tint (purple)
const SURF_CORK:int = 5                  # corkscrew tint (pink)
const SURF_RAMP:int = 6                  # ramps / hills tint (amber)
const SURF_WALL_HEIGHT:int = 196608      # 3 m -- visible side wall along track edges

# Lateral bailout: any probe more than this far off the side of the track
# (beyond surf_half_w) is treated as "fully off the surface" -- physics
# skips the wall push-back, damage, and downward snap so the craft can
# fly free in space rather than being yanked sideways onto the ribbon.
const OFF_TRACK_LAT:int = 1966080        # 30 m

const NUM_WAYPOINTS:int = 512            # ring buffer of track waypoints
const WP_STRIDE:int = 96                 # 12 q16 fields per waypoint
const WP_BUF_BYTES:int = 49152

const CHECKER_TILE:int = 327680          # 5 m target tile edge
const GROUND_HALF_EXTENT:int = 327680000 # +/- 5000 m
const GROUND_TEX_UV_DIVISOR:int = 10
const GROUND_TEX_BYTES:int = 16
const GROUND_Y:int = -32768000           # -500 m: well below any track geometry,
                                         # acts as a distant horizon plane only

# Horizon color: a darker, desaturated tint of the sky so the meeting line
# is visible without competing with the actual track surface.
const COL_HORIZON_R:int = 1638           # ~0.025
const COL_HORIZON_G:int = 2621           # ~0.040
const COL_HORIZON_B:int = 5243           # ~0.080

# Visual ribbon: per-segment lateral subdivisions stay coarse since the
# checker repeats via texture UV. Two quads (one per lateral side of the
# centerline) per (waypoint, next-waypoint) pair = ~720 quads for the
# track surface alone.
const TRACK_LAT_SEGS:int = 2

