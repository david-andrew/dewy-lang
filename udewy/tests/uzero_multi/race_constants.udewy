# ---------- Audio -----------------------------------------------------------

const AUDIO_SAMPLE_RATE:int = 44100
const AUDIO_FRAME_SAMPLES:int = 800      # ~18 ms (matches game frame)
const AUDIO_FRAME_BYTES:int = 1600       # AUDIO_FRAME_SAMPLES * 2 (S16LE mono)
const AUDIO_QUEUE_HIGH_BYTES:int = 6400  # ~4 frames -> skip a fill
const MUSIC_LOOP_SAMPLES:int = 88200     # 2 seconds @ 44100
const MUSIC_LOOP_BYTES:int = 176400

# SFX voice slots. Each holds (active_flag, sample_pos, len, kind, vol_q).
const SFX_SLOTS:int = 8
const SFX_SLOT_STRIDE:int = 40
const SFX_BUF_BYTES:int = 320

const SFX_KIND_BOOST:int = 0
const SFX_KIND_WALL:int = 1
const SFX_KIND_RECHARGE:int = 2
const SFX_KIND_LAP:int = 3
const SFX_KIND_EXPLODE:int = 4
const SFX_KIND_COUNT:int = 5

# Per-SFX precomputed S16 buffer length (frames). 8820 = 0.2s, 17640 = 0.4s.
const SFX_LEN_BOOST:int = 13230          # 0.3 s
const SFX_LEN_WALL:int = 6615            # 0.15 s
const SFX_LEN_RECHARGE:int = 17640       # 0.4 s
const SFX_LEN_LAP:int = 22050            # 0.5 s
const SFX_LEN_EXPLODE:int = 35280        # 0.8 s

# Big enough static buffer to hold the longest SFX for each of 5 kinds.
const SFX_MAX_LEN:int = 35280
const SFX_TABLE_BYTES:int = 352800       # 5 * SFX_MAX_LEN * 2
