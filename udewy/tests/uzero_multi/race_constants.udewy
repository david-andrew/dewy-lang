# ---------- Energy / damage rules -------------------------------------------

const WALL_HIT_INITIAL:int = 1311        # ~0.02 of bar on the frame contact begins
const WALL_DRAIN:int = 327               # ~0.005 of bar per frame while still scraping
const RECHARGE_RATE:int = 656            # ~0.01 per frame on recharge strip
const PAD_BOOST_OVERCAP:int = 200000     # bonus overcap when crossing a boost pad
const PAD_IMPULSE:int = 32768            # forward impulse per frame on pad

# Wall-hit detection: lateral distance past the half_width (Q16 m) before
# the slab clamp fires. The clamp pushes the car back to the lateral edge
# and zeros its outward velocity component (analogous to stage_15
# wall_collide). Below the threshold, scraping the wall costs nothing.
const WALL_SCRAPE_THRESHOLD:int = 0      # any penetration counts

