let glyph_row = (ch:int row:int):>int => {
    let c:int = ch
    if (c >=? 97) and (c <=? 122) {
        c -= 32
    }

    if (c <? GLYPH_FIRST) or (c >? GLYPH_LAST) {
        return 0
    }

    let glyph_index:int = ((c - GLYPH_FIRST) * GLYPH_ROW_COUNT) + row
    return __load__(glyph_rows + glyph_index * 8)
}
