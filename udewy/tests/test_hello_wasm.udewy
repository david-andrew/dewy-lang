# WebAssembly browser test
# Uses browser host functions provided by the JS runtime

# Buffer for int_to_str: 8 bytes length prefix + 21 bytes for digits (max i64 + sign)
# We use a string literal as a buffer - the actual content will be overwritten
let int_buf:int = "                     "

# Convert integer to string, returns pointer to string data
let int_to_str = (n:int):>int => {
    let buf:int = int_buf
    let is_neg:int = 0
    let val:int = n
    
    # Handle negative
    if n <? 0 {
        is_neg = 1
        val = 0 - n
    }
    
    # Handle zero case
    if val =? 0 {
        __store_u8__(48 buf)  # '0' = 48
        __store__(1 buf - 8)
        return buf
    }
    
    # Write digits from end of buffer, working backwards
    let pos:int = 20
    loop val >? 0 {
        let digit:int = val % 10
        __store_u8__(digit + 48 buf + pos)  # '0' = 48
        pos = pos - 1
        val = val // 10
    }
    
    # Add minus sign if negative
    if is_neg {
        __store_u8__(45 buf + pos)  # '-' = 45
        pos = pos - 1
    }
    
    # Calculate length and starting position
    let start:int = pos + 1
    let len:int = 21 - start
    
    # Copy result to beginning of buffer and set length
    let i:int = 0
    loop i <? len {
        let c:int = __load_u8__(buf + start + i)
        __store_u8__(c buf + i)
        i = i + 1
    }
    __store__(len buf - 8)
    
    return buf
}

# Helper to print string to DOM
let print = (s:int):>int => {
    let len:int = __load__(s - 8)
    __dom_append__(s len)
    return 0
}

# Helper to print string to console
let log = (s:int):>int => {
    let len:int = __load__(s - 8)
    __host_log__(s len)
    return 0
}

let main = ():>int => {
    print("=== WASM Backend Test ===\n\n")
    
    # Test host_time
    print("Timestamp (ms): ")
    let t:int = __host_time__()
    print(int_to_str(t))
    print("\n")
    
    # Test host_random  
    print("Random number: ")
    let r:int = __host_random__()
    print(int_to_str(r))
    print("\n")
    
    # Simple math test
    print("\n7 * 6 = ")
    let result:int = 7 * 6
    print(int_to_str(result))
    print("\n")
    
    # Test negative number
    print("-123 = ")
    print(int_to_str(0 - 123))
    print("\n")
    
    # Console logging
    log("Console: timestamp = ")
    log(int_to_str(t))
    
    return result
}
