# Test stack-allocated arrays with runtime values
let square = (x:int):>int => {
    return x * x
}

let main = ():>int => {
    let a:int = 2
    let b:int = 3
    let c:int = 5
    
    # Array with runtime values - should be built on stack
    let arr:array<int> = [a b c square(4)]
    
    # Sum all elements: 2 + 3 + 5 + 16 = 26
    let sum:int = 0
    let len:int = __load64__(arr + 0 - 8)
    let i:int = 0
    loop i <? len {
        let elem:int = __load64__(arr + (i * 8))
        sum = sum + elem
        i = i + 1
    }
    
    return sum
}
