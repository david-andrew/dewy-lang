# Backend abstraction for the bootstrap compiler
# Routes code generation calls to the selected backend

import p"prelude.udewy"
import p"output.udewy"
import p"symbols.udewy"
import p"backend_x86_64.udewy"
import p"backend_riscv.udewy"
import p"backend_arm.udewy"

# ============================================================================
# Backend selection
# ============================================================================

const BACKEND_X86_64:int = 0
const BACKEND_RISCV:int = 1
const BACKEND_ARM:int = 2

let current_backend:int = 0

let backend_set = (backend:int):>void => {
    current_backend = backend
    return void
}

# ============================================================================
# Dispatched backend operations
# ============================================================================

let backend_emit_prologue = (frame_size:int):>void => {
    if current_backend =? BACKEND_X86_64 {
        emit_prologue(frame_size)
    } else if current_backend =? BACKEND_RISCV {
        riscv_emit_prologue(frame_size)
    } else if current_backend =? BACKEND_ARM {
        arm_emit_prologue(frame_size)
    }
    return void
}

let backend_emit_epilogue = (frame_size:int):>void => {
    if current_backend =? BACKEND_X86_64 {
