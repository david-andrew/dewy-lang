let backend_emit_load_fn_ref = (label_id:int):>void => {
    if current_backend =? BACKEND_X86_64 {
        text_str("    leaq .Lfn")
        text_int(label_id)
        text_line("(%rip), %rax")
    } else if current_backend =? BACKEND_RISCV {
        text_str("    la a0, .Lfn")
        text_int(label_id)
        text_char(CH_LF)
    } else if current_backend =? BACKEND_ARM {
        text_str("    adrp x0, .Lfn")
        text_int(label_id)
        text_char(CH_LF)
        text_str("    add x0, x0, :lo12:.Lfn")
        text_int(label_id)
        text_char(CH_LF)
    }
    return void
}

let backend_emit_indexed_store = ():>void => {
    # Expects address on stack, value in result register
    # Stores value to address
    if current_backend =? BACKEND_X86_64 {
        emit_pop("%rcx")
        text_line("    movq %rax, (%rcx)")
    } else if current_backend =? BACKEND_RISCV {
        riscv_emit_pop("t0")
        text_line("    sd a0, 0(t0)")
    } else if current_backend =? BACKEND_ARM {
        arm_emit_pop("x1")
        text_line("    str x0, [x1]")
    }
    return void
}

let backend_emit_index_calc = ():>void => {
    # Calculate index * 8, expects index in result register
    if current_backend =? BACKEND_X86_64 {
        text_line("    shlq $3, %rax")
    } else if current_backend =? BACKEND_RISCV {
        text_line("    slli a0, a0, 3")
    } else if current_backend =? BACKEND_ARM {
        text_line("    lsl x0, x0, #3")
    }
    return void
}

let backend_emit_add_to_saved = ():>void => {
    # Add result register to top of stack, result in result register
    if current_backend =? BACKEND_X86_64 {
        emit_pop("%rcx")
        text_line("    addq %rcx, %rax")
    } else if current_backend =? BACKEND_RISCV {
        riscv_emit_pop("t0")
        text_line("    add a0, a0, t0")
    } else if current_backend =? BACKEND_ARM {
        arm_emit_pop("x1")
        text_line("    add x0, x0, x1")
    }
    return void
}
