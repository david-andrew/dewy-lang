# kind: 0=gt, 1=lt, 2=gte, 3=lte
let arm_unsigned_cmp = (kind:int):>void => {
    arm_emit_indented("mov x9, x0")
    arm_pop_saved_into("x0")
    arm_emit_indented("cmp x0, x9")
    let bb:int = bb_new(24)
    bb_push_str(bb "    csetm x0, ")
    if kind =? 0      { bb_push_str(bb "hi") }
    else if kind =? 1 { bb_push_str(bb "lo") }
    else if kind =? 2 { bb_push_str(bb "hs") }
    else              { bb_push_str(bb "ls") }
    vec_push(arm_current_fn_code bb_finalize_as_string(bb))
    return void
}

let arm_alloca = ():>void => {
    arm_emit_indented("add x0, x0, #15")
    arm_emit_indented("and x0, x0, #-16")
    arm_emit_indented("sub x9, sp, x0")
    arm_emit_indented("mov sp, x9")
    arm_emit_indented("mov x0, x9")
    return void
}

let arm_call_direct = (label_id:int num_args:int):>void => {
    let stack_bytes:int = arm_prepare_call_args(num_args 0)
    let label:int = intmap_get(arm_fn_labels label_id)
    let bb:int = bb_new(32 + str_len(label))
    bb_push_str(bb "    bl ")
    bb_push_str(bb label)
    vec_push(arm_current_fn_code bb_finalize_as_string(bb))
    if stack_bytes >? 0 {
        let bb2:int = bb_new(32)
        bb_push_str(bb2 "    add sp, sp, #")
        bb_push_int(bb2 stack_bytes)
        vec_push(arm_current_fn_code bb_finalize_as_string(bb2))
    }
    return void
}

let arm_call_indirect = (num_args:int):>void => {
    let stack_bytes:int = arm_prepare_call_args(num_args "x9")
    arm_emit_indented("blr x9")
    if stack_bytes >? 0 {
        let bb:int = bb_new(32)
        bb_push_str(bb "    add sp, sp, #")
        bb_push_int(bb stack_bytes)
        vec_push(arm_current_fn_code bb_finalize_as_string(bb))
    }
    return void
}

let arm_max_call_args = ():>int => { return 0 - 1 }

let arm_syscall = (num_args:int):>void => {
    if num_args =? 1 {
        arm_emit_indented("mov x8, x0")
        arm_emit_indented("svc #0")
    } else if num_args =? 2 {
        arm_emit_indented("mov x9, x0")
        arm_pop_saved_into("x8")
        arm_emit_indented("mov x0, x9")
        arm_emit_indented("svc #0")
    } else if num_args =? 3 {
        arm_emit_indented("mov x1, x0")
        arm_pop_saved_into("x0")
        arm_pop_saved_into("x8")
        arm_emit_indented("svc #0")
    } else if num_args =? 4 {
        arm_emit_indented("mov x2, x0")
        arm_pop_saved_into("x1")
        arm_pop_saved_into("x0")
        arm_pop_saved_into("x8")
        arm_emit_indented("svc #0")
    } else if num_args =? 5 {
        arm_emit_indented("mov x3, x0")
        arm_pop_saved_into("x2")
        arm_pop_saved_into("x1")
        arm_pop_saved_into("x0")
        arm_pop_saved_into("x8")
        arm_emit_indented("svc #0")
    } else if num_args =? 6 {
        arm_emit_indented("mov x4, x0")
        arm_pop_saved_into("x3")
        arm_pop_saved_into("x2")
        arm_pop_saved_into("x1")
        arm_pop_saved_into("x0")
        arm_pop_saved_into("x8")
        arm_emit_indented("svc #0")
    } else if num_args =? 7 {
        arm_emit_indented("mov x5, x0")
        arm_pop_saved_into("x4")
        arm_pop_saved_into("x3")
        arm_pop_saved_into("x2")
        arm_pop_saved_into("x1")
        arm_pop_saved_into("x0")
        arm_pop_saved_into("x8")
        arm_emit_indented("svc #0")
    }
    return void
}

let arm_mixed_extern_arg_slots = (name:int):>int => {
    if not str_prefix(name "__call_extern_mixed_") { return 0 - 1 }
    let n:int = str_len(name)
    if n <? 23 { return 0 - 1 }
    if __load_u8__(name + n - 2) not=? 95 { return 0 - 1 }
    if __load_u8__(name + n - 1) not=? 95 { return 0 - 1 }
    let mid_len:int = n - 22
    if mid_len <? 1 { return 0 - 1 }
    let v:int = 0
    let i:int = 0
    loop i <? mid_len {
        let c:int = __load_u8__(name + 20 + i)
        if (c <? 48) or (c >? 57) { return 0 - 1 }
        v = v * 10 + (c - 48)
        i = i + 1
    }
    if (v <? 1) or (v >? 8) { return 0 - 1 }
    return v
}

# Build a "<prefix><n>" string, e.g. "s0", "d3".
let arm_fp_reg_name = (prefix:int idx:int):>int => {
    let bb:int = bb_new(8)
    bb_push_str(bb prefix)
    bb_push_int(bb idx)
    return bb_finalize_as_string(bb)
}

let arm_call_extern_fp_mixed = (tags:int):>void => {
    let n:int = vec_len(tags)
    let gp_slots:int = vec_new(n)
    let fp_slots:int = vec_new(n)
    let gp_count:int = 0
    let fp_count:int = 0
    let i:int = 0
    loop i <? n {
        let k:int = vec_get(tags i)
        if k =? 0 {
            vec_push(gp_slots gp_count)
            vec_push(fp_slots 0 - 1)
            gp_count = gp_count + 1
        } else {
            vec_push(gp_slots 0 - 1)
            vec_push(fp_slots fp_count)
            fp_count = fp_count + 1
        }
        i = i + 1
    }
    let ai:int = n - 1
    loop ai >=? 0 {
        let k:int = vec_get(tags ai)
        if k =? 0 {
            let dst:int = arm_arg_reg(vec_get(gp_slots ai))
            if not str_eq(dst "x0") {
                let bb:int = bb_new(16)
                bb_push_str(bb "    mov ")
                bb_push_str(bb dst)
                bb_push_str(bb ", x0")
                vec_push(arm_current_fn_code bb_finalize_as_string(bb))
            }
        } else if k =? 1 {
            let bb:int = bb_new(16)
            bb_push_str(bb "    fmov ")
            bb_push_str(bb arm_fp_reg_name("s" vec_get(fp_slots ai)))
            bb_push_str(bb ", w0")
            vec_push(arm_current_fn_code bb_finalize_as_string(bb))
        } else {
            let bb:int = bb_new(16)
            bb_push_str(bb "    fmov ")
            bb_push_str(bb arm_fp_reg_name("d" vec_get(fp_slots ai)))
            bb_push_str(bb ", x0")
            vec_push(arm_current_fn_code bb_finalize_as_string(bb))
        }
        if ai >? 0 { arm_pop_saved_into("x0") }
        ai = ai - 1
    }
    arm_pop_saved_into("x9")
    arm_emit_indented("blr x9")
    return void
}

let arm_mixed_extern_type_tags = (name:int static_args_map:int):>int => {
    let m:int = arm_mixed_extern_arg_slots(name)
    let tags:int = vec_new(m)
    let i:int = 0
    loop i <? m {
        let idx:int = 1 + i * 2
        vec_push(tags intmap_get(static_args_map idx))
        i = i + 1
    }
    return tags
}

# --- Control flow ---

let arm_begin_if = ():>void => {
    let el:int = arm_new_label("else")
    let en:int = arm_new_label("if_end")
    vec_push(arm_if_else_labels el)
    vec_push(arm_if_end_labels en)
    vec_push(arm_if_else_emitted FALSE_VAL)
    let bb:int = bb_new(32)
    bb_push_str(bb "    cbz x0, ")
    bb_push_str(bb el)
    vec_push(arm_current_fn_code bb_finalize_as_string(bb))
    return void
}

let arm_begin_else = ():>void => {
    let top:int = vec_len(arm_if_else_labels) - 1
    let el:int = vec_get(arm_if_else_labels top)
    let en:int = vec_get(arm_if_end_labels top)
    vec_set(arm_if_else_emitted top TRUE_VAL)
    let bb:int = bb_new(16)
    bb_push_str(bb "    b ")
    bb_push_str(bb en)
    vec_push(arm_current_fn_code bb_finalize_as_string(bb))
    arm_emit_label_str(el)
    return void
}

let arm_end_if = ():>void => {
    let top:int = vec_len(arm_if_else_labels) - 1
    let el:int = vec_get(arm_if_else_labels top)
    let en:int = vec_get(arm_if_end_labels top)
    let emit:int = vec_get(arm_if_else_emitted top)
    vec_pop(arm_if_else_labels)
    vec_pop(arm_if_end_labels)
    vec_pop(arm_if_else_emitted)
    if emit =? FALSE_VAL { arm_emit_label_str(el) }
    arm_emit_label_str(en)
    return void
}

let arm_begin_loop = ():>void => {
    let s:int = arm_new_label("loop_start")
    let e:int = arm_new_label("loop_end")
    vec_push(arm_loop_start_labels s)
    vec_push(arm_loop_end_labels e)
    arm_emit_label_str(s)
    return void
}

let arm_begin_loop_body = ():>void => {
    let top:int = vec_len(arm_loop_end_labels) - 1
    let bb:int = bb_new(32)
    bb_push_str(bb "    cbz x0, ")
    bb_push_str(bb vec_get(arm_loop_end_labels top))
    vec_push(arm_current_fn_code bb_finalize_as_string(bb))
    return void
}

let arm_end_loop = ():>void => {
    let top:int = vec_len(arm_loop_start_labels) - 1
    let s:int = vec_get(arm_loop_start_labels top)
    let e:int = vec_get(arm_loop_end_labels top)
    vec_pop(arm_loop_start_labels)
    vec_pop(arm_loop_end_labels)
    let bb:int = bb_new(16)
    bb_push_str(bb "    b ")
    bb_push_str(bb s)
    vec_push(arm_current_fn_code bb_finalize_as_string(bb))
    arm_emit_label_str(e)
    return void
}

let arm_emit_break = ():>void => {
    let top:int = vec_len(arm_loop_end_labels) - 1
    let bb:int = bb_new(16)
    bb_push_str(bb "    b ")
    bb_push_str(bb vec_get(arm_loop_end_labels top))
    vec_push(arm_current_fn_code bb_finalize_as_string(bb))
    return void
}

let arm_emit_continue = ():>void => {
    let top:int = vec_len(arm_loop_start_labels) - 1
    let bb:int = bb_new(16)
    bb_push_str(bb "    b ")
    bb_push_str(bb vec_get(arm_loop_start_labels top))
    vec_push(arm_current_fn_code bb_finalize_as_string(bb))
    return void
}

let arm_cond_and_split = ():>int => {
    let lbl:int = arm_new_label("cond_and_false")
    let bb:int = bb_new(32)
    bb_push_str(bb "    cbz x0, ")
    bb_push_str(bb lbl)
    vec_push(arm_current_fn_code bb_finalize_as_string(bb))
    return lbl
}

let arm_cond_and_join = (false_label:int):>void => {
    let done:int = arm_new_label("cond_and_done")
    let bb:int = bb_new(16)
    bb_push_str(bb "    b ")
    bb_push_str(bb done)
    vec_push(arm_current_fn_code bb_finalize_as_string(bb))
    arm_emit_label_str(false_label)
    arm_emit_indented("mov x0, #0")
    arm_emit_label_str(done)
    return void
}

let arm_cond_or_split = ():>int => {
    let done:int = arm_new_label("cond_or_done")
    let bb:int = bb_new(32)
    bb_push_str(bb "    cbnz x0, ")
    bb_push_str(bb done)
    vec_push(arm_current_fn_code bb_finalize_as_string(bb))
    return done
}

let arm_cond_or_join = (done_label:int):>void => {
    arm_emit_label_str(done_label)
    return void
}

let arm_emit_return = ():>void => {
    let bb:int = bb_new(16)
    bb_push_str(bb "    b ")
    bb_push_str(bb arm_current_fn_epilogue)
    vec_push(arm_current_fn_code bb_finalize_as_string(bb))
    return void
}

# --- Intrinsics ---

let g_arm_intrinsics:int = 0

let arm_init_intrinsics = ():>void => {
    if g_arm_intrinsics not=? 0 { return void }
    core_intrinsics_init()
    let m:int = map_new()
    let cap:int = map_cap(g_core_intrinsics)
    let slots:int = map_slots(g_core_intrinsics)
    let i:int = 0
    loop i <? cap {
        let slot:int = slots + (i * 32)
        if __load__(slot) =? 1 {
            map_put(m __load__(slot + 8) __load__(slot + 16) __load__(slot + 24))
        }
        i = i + 1
    }
    linux_syscall_intrinsics_into(m)
    map_put_str(m "__i64_to_f32_bits__" 1)
    map_put_str(m "__i64_to_f64_bits__" 1)
    map_put_str(m "__f32_bits_to_i64__" 1)
    map_put_str(m "__f64_bits_to_i64__" 1)
    g_arm_intrinsics = m
    return void
}

let arm_is_intrinsic = (name:int):>int => {
    arm_init_intrinsics()
    if map_has_str(g_arm_intrinsics name) { return TRUE_VAL }
    if arm_mixed_extern_arg_slots(name) >=? 0 { return TRUE_VAL }
    return FALSE_VAL
}

let arm_intrinsic_arity = (name:int):>int => {
    arm_init_intrinsics()
    let m:int = arm_mixed_extern_arg_slots(name)
    if m >=? 0 { return 1 + m * 2 }
    if map_has_str(g_arm_intrinsics name) { return map_get_str(g_arm_intrinsics name) }
    return 0 - 1
}

let arm_intrinsic_static_arg_indices = (name:int):>int => {
    let m:int = arm_mixed_extern_arg_slots(name)
    if m <? 0 { return 0 }
    let mask:int = 0
    let i:int = 0
    loop i <? m {
        mask = mask or (1 << (1 + i * 2))
        i = i + 1
    }
    return mask
}

let arm_emit_intrinsic = (name:int num_args:int static_args_map:int):>void => {
    if str_eq(name "__load_u8__")        { arm_load_mem(8 0) }
    else if str_eq(name "__load_u16__")  { arm_load_mem(16 0) }
    else if str_eq(name "__load_u32__")  { arm_load_mem(32 0) }
    else if str_eq(name "__load_u64__")  { arm_load_mem(64 0) }
    else if str_eq(name "__load__")      { arm_load_mem(64 0) }
    else if str_eq(name "__store_u8__")  { arm_store_mem(8) }
    else if str_eq(name "__store_u16__") { arm_store_mem(16) }
    else if str_eq(name "__store_u32__") { arm_store_mem(32) }
    else if str_eq(name "__store_u64__") { arm_store_mem(64) }
    else if str_eq(name "__store__")     { arm_store_mem(64) }
    else if str_eq(name "__load_i8__")   { arm_load_mem(8 1) }
    else if str_eq(name "__load_i16__")  { arm_load_mem(16 1) }
    else if str_eq(name "__load_i32__")  { arm_load_mem(32 1) }
    else if str_eq(name "__load_i64__")  { arm_load_mem(64 1) }
    else if str_eq(name "__store_i8__")  { arm_store_mem(8) }
    else if str_eq(name "__store_i16__") { arm_store_mem(16) }
    else if str_eq(name "__store_i32__") { arm_store_mem(32) }
    else if str_eq(name "__store_i64__") { arm_store_mem(64) }
    else if str_eq(name "__signed_shr__")    { arm_signed_shr() }
    else if str_eq(name "__unsigned_idiv__") { arm_unsigned_idiv() }
    else if str_eq(name "__unsigned_mod__")  { arm_unsigned_mod() }
    else if str_eq(name "__unsigned_lt__")   { arm_unsigned_cmp(1) }
    else if str_eq(name "__unsigned_gt__")   { arm_unsigned_cmp(0) }
    else if str_eq(name "__unsigned_lte__")  { arm_unsigned_cmp(3) }
    else if str_eq(name "__unsigned_gte__")  { arm_unsigned_cmp(2) }
    else if str_eq(name "__alloca__")        { arm_alloca() }
    else if str_eq(name "__i64_to_f32_bits__") {
        arm_emit_indented("scvtf s0, x0")
        arm_emit_indented("fmov w0, s0")
    } else if str_eq(name "__i64_to_f64_bits__") {
        arm_emit_indented("scvtf d0, x0")
        arm_emit_indented("fmov x0, d0")
    } else if str_eq(name "__f32_bits_to_i64__") {
        arm_emit_indented("fmov s0, w0")
        arm_emit_indented("fcvtzs x0, s0")
    } else if str_eq(name "__f64_bits_to_i64__") {
        arm_emit_indented("fmov d0, x0")
        arm_emit_indented("fcvtzs x0, d0")
    } else if str_prefix(name "__syscall") {
        arm_syscall(num_args)
    } else {
        arm_call_extern_fp_mixed(arm_mixed_extern_type_tags(name static_args_map))
    }
    return void
}

let arm_get_builtin_constants = ():>int => {
    return linux_builtin_constants(1)
}

# --- compile_and_link / run ---

let arm_compile_and_link = (code:int input_name:int cache_dir:int options:int):>int => {
    fs_mkdir_p(cache_dir)
    let asm_bb:int = bb_new(str_len(cache_dir) + str_len(input_name) + 4)
    bb_push_str(asm_bb cache_dir)
    bb_push_byte(asm_bb 47)
    bb_push_str(asm_bb input_name)
    bb_push_str(asm_bb ".s")
    let asm_path:int = bb_finalize_as_string(asm_bb)

    let obj_bb:int = bb_new(str_len(cache_dir) + str_len(input_name) + 4)
    bb_push_str(obj_bb cache_dir)
    bb_push_byte(obj_bb 47)
    bb_push_str(obj_bb input_name)
    bb_push_str(obj_bb ".o")
    let obj_path:int = bb_finalize_as_string(obj_bb)

    let exe_bb:int = bb_new(str_len(cache_dir) + str_len(input_name) + 2)
    bb_push_str(exe_bb cache_dir)
    bb_push_byte(exe_bb 47)
    bb_push_str(exe_bb input_name)
    let exe_path:int = bb_finalize_as_string(exe_bb)

    fs_write_file(path_to_cstr(asm_path) code str_len(code))

    let av1:int = vec_new(8)
    vec_push(av1 arm_str("aarch64-linux-gnu-as"))
    vec_push(av1 asm_path)
    vec_push(av1 arm_str("-o"))
    vec_push(av1 obj_path)
    proc_run_or_die(av1 "aarch64 assembler failed")

    let av2:int = vec_new(16)
    vec_push(av2 arm_str("aarch64-linux-gnu-ld"))
    vec_push(av2 arm_str("--gc-sections"))
    vec_push(av2 arm_str("-e"))
    vec_push(av2 arm_str("_start"))
    vec_push(av2 obj_path)
    let arts_arm:int = be_opt_link_artifacts(options)
    if arts_arm not=? 0 {
        let ai:int = 0
        loop ai <? vec_len(arts_arm) {
            vec_push(av2 vec_get(arts_arm ai))
            ai = ai + 1
        }
    }
    vec_push(av2 arm_str("-o"))
    vec_push(av2 exe_path)
    proc_run_or_die(av2 "aarch64 linker failed")
    return exe_path
}

let arm_run = (output_path:int args:int options:int):>int => {
    let argv:int = vec_new(vec_len(args) + 2)
    vec_push(argv arm_str("qemu-aarch64"))
    vec_push(argv output_path)
    let i:int = 0
    loop i <? vec_len(args) {
        vec_push(argv vec_get(args i))
        i = i + 1
    }
    return proc_run(argv)
}

let arm_get_compile_message = (output_path:int options:int):>int => {
    let bb:int = bb_new(64)
    bb_push_str(bb "Compiled: ")
    bb_push_str(bb output_path)
    return bb_finalize_as_string(bb)
}

let arm_install_backend = ():>void => {
    arm_alloc_state()
    be_begin_module = arm_begin_module
    be_finish_module = arm_finish_module
    be_set_module_init = arm_set_module_init
    be_set_imported_sources = be_default_set_imported_sources
    be_intern_string = arm_intern_string
    be_intern_array = arm_intern_array
    be_define_global = arm_define_global
    be_declare_extern_global = arm_declare_extern_global
    be_intern_static = arm_intern_static
    be_push_string_ref = arm_push_string_ref
    be_push_array_ref = arm_push_array_ref
    be_push_global_ref = arm_push_global_ref
    be_push_static_ref = arm_push_static_ref
    be_load_global = arm_load_global
    be_store_global = arm_store_global
    be_function_ref = arm_function_ref
    be_string_ref = arm_string_ref
    be_array_ref = arm_array_ref
    be_static_ref = arm_static_ref
    be_declare_function = arm_declare_function
    be_bind_extern_function = arm_bind_extern_function
    be_declare_extern_function = arm_declare_extern_function
    be_should_warn_unused_extern = be_default_should_warn_unused_extern
    be_begin_function = arm_begin_function
    be_end_function = arm_end_function
    be_set_reachable_functions = arm_set_reachable_functions
    be_load_param = arm_load_param
    be_alloc_local = arm_alloc_local
    be_load_local = arm_load_local
    be_store_local = arm_store_local
    be_push_const_i64 = arm_push_const_i64
    be_push_void = arm_push_void
    be_push_fn_ref = arm_push_fn_ref
    be_pop_value = arm_pop_value
    be_save_value = arm_save_value
    be_restore_value = arm_restore_value
    be_unary_op = arm_unary_op
    be_binary_op = arm_binary_op
    be_pipe_call = arm_pipe_call
    be_begin_if = arm_begin_if
    be_begin_else = arm_begin_else
    be_end_if = arm_end_if
    be_begin_loop = arm_begin_loop
    be_begin_loop_body = arm_begin_loop_body
    be_end_loop = arm_end_loop
    be_emit_break = arm_emit_break
    be_emit_continue = arm_emit_continue
    be_cond_and_split = arm_cond_and_split
    be_cond_and_join = arm_cond_and_join
    be_cond_or_split = arm_cond_or_split
    be_cond_or_join = arm_cond_or_join
    be_emit_return = arm_emit_return
    be_call_direct = arm_call_direct
    be_call_indirect = arm_call_indirect
    be_max_call_args = arm_max_call_args
    be_is_intrinsic = arm_is_intrinsic
    be_intrinsic_arity = arm_intrinsic_arity
    be_intrinsic_static_arg_indices = arm_intrinsic_static_arg_indices
    be_emit_intrinsic = arm_emit_intrinsic
    be_get_builtin_constants = arm_get_builtin_constants
    be_compile_and_link = arm_compile_and_link
    be_run = arm_run
    be_get_compile_message = arm_get_compile_message
    return void
}
