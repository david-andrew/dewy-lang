let arm_emit_cmp_csetm = (cond:int):>void => {
    arm_emit_indented("cmp x0, x9")
    let bb:int = bb_new(24)
    bb_push_str(bb "    csetm x0, ")
    bb_push_str(bb cond)
    vec_push(arm_current_fn_code bb_finalize_as_string(bb))
    return void
}

let arm_binary_op = (op_kind:int):>void => {
    arm_emit_indented("mov x9, x0")
    arm_pop_saved_into("x0")
    if op_kind =? TK_PLUS         { arm_emit_indented("add x0, x0, x9") }
    else if op_kind =? TK_MINUS   { arm_emit_indented("sub x0, x0, x9") }
    else if op_kind =? TK_MUL     { arm_emit_indented("mul x0, x0, x9") }
    else if op_kind =? TK_IDIV    { arm_emit_signed_sdiv() }
    else if op_kind =? TK_MOD     { arm_emit_signed_mod() }
    else if op_kind =? TK_LEFT_SHIFT  { arm_emit_indented("lsl x0, x0, x9") }
    else if op_kind =? TK_RIGHT_SHIFT { arm_emit_indented("lsr x0, x0, x9") }
    else if op_kind =? TK_AND     { arm_emit_indented("and x0, x0, x9") }
    else if op_kind =? TK_OR      { arm_emit_indented("orr x0, x0, x9") }
    else if op_kind =? TK_XOR     { arm_emit_indented("eor x0, x0, x9") }
    else if op_kind =? TK_EQ      { arm_emit_cmp_csetm("eq") }
    else if op_kind =? TK_NOT_EQ  { arm_emit_cmp_csetm("ne") }
    else if op_kind =? TK_GT      { arm_emit_cmp_csetm("gt") }
    else if op_kind =? TK_LT      { arm_emit_cmp_csetm("lt") }
    else if op_kind =? TK_GT_EQ   { arm_emit_cmp_csetm("ge") }
    else if op_kind =? TK_LT_EQ   { arm_emit_cmp_csetm("le") }
    return void
}

let arm_pipe_call = ():>void => {
    arm_emit_indented("mov x9, x0")
    arm_pop_saved_into("x0")
    arm_emit_indented("blr x9")
    return void
}

let arm_load_mem = (width:int signed:int):>void => {
    if width =? 64      { arm_emit_indented("ldr x0, [x0]") }
    else if width =? 32 {
        if signed { arm_emit_indented("ldrsw x0, [x0]") } else { arm_emit_indented("ldr w0, [x0]") }
    } else if width =? 16 {
        if signed { arm_emit_indented("ldrsh x0, [x0]") } else { arm_emit_indented("ldrh w0, [x0]") }
    } else if width =? 8 {
        if signed { arm_emit_indented("ldrsb x0, [x0]") } else { arm_emit_indented("ldrb w0, [x0]") }
    }
    return void
}

let arm_store_mem = (width:int):>void => {
    arm_pop_saved_into("x9")
    if width =? 64      { arm_emit_indented("str x9, [x0]") }
    else if width =? 32 { arm_emit_indented("str w9, [x0]") }
    else if width =? 16 { arm_emit_indented("strh w9, [x0]") }
    else if width =? 8  { arm_emit_indented("strb w9, [x0]") }
    arm_emit_indented("mov x0, #0")
    return void
}

