# ARM (AArch64) backend for the udewy bootstrap. Mirrors udewy/backend/arm.py.

import p"./common.udewy"
import p"./linux.udewy"
import p"../t1.udewy"

const ARM_SAVE_AREA_BYTES:int = 96
const ARM_MAX_STACK_ADJUST_IMM:int = 4080

let arm_function_ids:int = 0
let arm_function_codes:int = 0
let arm_current_fn_code:int = 0
let arm_reachable:int = 0
let arm_have_reachable:int = 0
let arm_data:int = 0
let arm_next_label:int = 0
let arm_extern_symbols:int = 0
let arm_module_init_name:int = 0

let arm_current_fn_epilogue:int = 0
let arm_stack_offset:int = 0
let arm_param_slots:int = 0
let arm_saved_depth:int = 0
let arm_spilled_depth:int = 0
let arm_min_slot_offset:int = 0
let arm_frame_setup_index:int = 0

let arm_if_else_labels:int = 0
let arm_if_end_labels:int = 0
let arm_if_else_emitted:int = 0
let arm_loop_start_labels:int = 0
let arm_loop_end_labels:int = 0

let arm_fn_labels:int = 0
let arm_global_labels:int = 0
let arm_string_labels:int = 0
let arm_array_labels:int = 0
let arm_static_labels:int = 0

let arm_alloc_state = ():>void => {
    arm_function_ids = vec_new(16)
    arm_function_codes = vec_new(16)
    arm_data = vec_new(32)
    arm_extern_symbols = set_new()
    arm_param_slots = vec_new(8)
    arm_if_else_labels = vec_new(4)
    arm_if_end_labels = vec_new(4)
    arm_if_else_emitted = vec_new(4)
    arm_loop_start_labels = vec_new(4)
    arm_loop_end_labels = vec_new(4)
    arm_fn_labels = intmap_new()
    arm_global_labels = intmap_new()
    arm_string_labels = intmap_new()
    arm_array_labels = intmap_new()
    arm_static_labels = intmap_new()
    return void
}

let arm_str = (s:int):>int => {
    let bb:int = bb_new(str_len(s))
    bb_push_str(bb s)
    return bb_finalize_as_string(bb)
}

let arm_emit_indented = (s:int):>void => {
    let bb:int = bb_new(8 + str_len(s))
    bb_push_str(bb "    ")
    bb_push_str(bb s)
    vec_push(arm_current_fn_code bb_finalize_as_string(bb))
    return void
}

let arm_emit_label_str = (label:int):>void => {
    let bb:int = bb_new(str_len(label) + 1)
    bb_push_str(bb label)
    bb_push_byte(bb 58)
    vec_push(arm_current_fn_code bb_finalize_as_string(bb))
    return void
}

let arm_emit_data_label = (label:int):>void => {
    let bb:int = bb_new(str_len(label) + 1)
    bb_push_str(bb label)
    bb_push_byte(bb 58)
    vec_push(arm_data bb_finalize_as_string(bb))
    return void
}

let arm_new_label = (prefix:int):>int => {
    let bb:int = bb_new(8 + str_len(prefix))
    bb_push_byte(bb 46)
    bb_push_str(bb prefix)
    bb_push_int(bb arm_next_label)
    arm_next_label = arm_next_label + 1
    return bb_finalize_as_string(bb)
}

let arm_arg_reg = (i:int):>int => {
    if i =? 0 { return "x0" }
    if i =? 1 { return "x1" }
    if i =? 2 { return "x2" }
    if i =? 3 { return "x3" }
    if i =? 4 { return "x4" }
    if i =? 5 { return "x5" }
    if i =? 6 { return "x6" }
    if i =? 7 { return "x7" }
    return 0
}

let arm_value_cache_reg = (i:int):>int => {
    if i =? 0 { return "x20" }
    if i =? 1 { return "x21" }
    if i =? 2 { return "x22" }
    if i =? 3 { return "x23" }
    return 0
}

let arm_fp_arg_v = (i:int):>int => {
    if i =? 0 { return 0 }   # index, used to build "s0"/"d0" etc.
    return i
}

let arm_note_slot = (slot:int):>void => {
    if slot <? arm_min_slot_offset { arm_min_slot_offset = slot }
    return void
}

let arm_local_area_bytes = ():>int => {
    let required:int = 0
    if 0 - arm_min_slot_offset >? 0 { required = 0 - arm_min_slot_offset }
    return (required + 15) and (0 - 16)
}

let arm_int_to_str = (n:int):>int => {
    let bb:int = bb_new(16)
    bb_push_int(bb n)
    return bb_finalize_as_string(bb)
}

# "    sub sp, sp, #<chunks>" repeated.
let arm_emit_sp_adjust = (op:int amount:int):>void => {
    let remaining:int = amount
    loop remaining >? 0 {
        let chunk:int = remaining
        if chunk >? ARM_MAX_STACK_ADJUST_IMM { chunk = ARM_MAX_STACK_ADJUST_IMM }
        chunk = chunk and (0 - 16)
        if chunk =? 0 { chunk = remaining }
        let bb:int = bb_new(40)
        bb_push_str(bb "    ")
        bb_push_str(bb op)
        bb_push_str(bb " sp, sp, #")
        bb_push_int(bb chunk)
        vec_push(arm_current_fn_code bb_finalize_as_string(bb))
        remaining = remaining - chunk
    }
    return void
}

# "mov x29, sp" then "add x29, x29, #<chunks>" repeated to add `local_bytes`.
let arm_emit_fp_setup = (local_bytes:int):>void => {
    arm_emit_indented("mov x29, sp")
    let remaining:int = local_bytes
    loop remaining >? 0 {
        let chunk:int = remaining
        if chunk >? 4095 { chunk = 4095 }
        let bb:int = bb_new(40)
        bb_push_str(bb "    add x29, x29, #")
        bb_push_int(bb chunk)
        vec_push(arm_current_fn_code bb_finalize_as_string(bb))
        remaining = remaining - chunk
    }
    return void
}

# Returns 1 if `slot` fits in a [x29, #imm] addressing mode, else 0.
let arm_slot_in_range = (slot:int):>int => {
    if (slot >=? 0 - 256) and (slot <=? 255) { return 1 }
    if (slot >=? 0) and ((slot and 7) =? 0) and (slot <=? 32760) { return 1 }
    return 0
}

let arm_materialize_frame_addr = (reg:int slot:int):>void => {
    if slot =? 0 {
        let bb:int = bb_new(32)
        bb_push_str(bb "    mov ")
        bb_push_str(bb reg)
        bb_push_str(bb ", x29")
        vec_push(arm_current_fn_code bb_finalize_as_string(bb))
        return void
    }
    if slot >? 0 {
        let bb0:int = bb_new(32)
        bb_push_str(bb0 "    mov ")
        bb_push_str(bb0 reg)
        bb_push_str(bb0 ", x29")
        vec_push(arm_current_fn_code bb_finalize_as_string(bb0))
        let remaining:int = slot
        loop remaining >? 0 {
            let chunk:int = remaining
            if chunk >? 4095 { chunk = 4095 }
            let bb:int = bb_new(40)
            bb_push_str(bb "    add ")
            bb_push_str(bb reg)
            bb_push_str(bb ", ")
            bb_push_str(bb reg)
            bb_push_str(bb ", #")
            bb_push_int(bb chunk)
            vec_push(arm_current_fn_code bb_finalize_as_string(bb))
            remaining = remaining - chunk
        }
        return void
    }
    let bb1:int = bb_new(32)
    bb_push_str(bb1 "    mov ")
    bb_push_str(bb1 reg)
    bb_push_str(bb1 ", x29")
    vec_push(arm_current_fn_code bb_finalize_as_string(bb1))
    let remaining2:int = 0 - slot
    loop remaining2 >? 0 {
        let chunk:int = remaining2
        if chunk >? 4095 { chunk = 4095 }
        let bb2:int = bb_new(40)
        bb_push_str(bb2 "    sub ")
        bb_push_str(bb2 reg)
        bb_push_str(bb2 ", ")
        bb_push_str(bb2 reg)
        bb_push_str(bb2 ", #")
        bb_push_int(bb2 chunk)
        vec_push(arm_current_fn_code bb_finalize_as_string(bb2))
        remaining2 = remaining2 - chunk
    }
    return void
}

let arm_load_frame_slot = (dst:int slot:int):>void => {
    if arm_slot_in_range(slot) {
        let bb:int = bb_new(40)
        bb_push_str(bb "    ldr ")
        bb_push_str(bb dst)
        bb_push_str(bb ", [x29, #")
        bb_push_int(bb slot)
        bb_push_byte(bb 93)
        vec_push(arm_current_fn_code bb_finalize_as_string(bb))
        return void
    }
    arm_materialize_frame_addr("x9" slot)
    let bb2:int = bb_new(32)
    bb_push_str(bb2 "    ldr ")
    bb_push_str(bb2 dst)
    bb_push_str(bb2 ", [x9]")
    vec_push(arm_current_fn_code bb_finalize_as_string(bb2))
    return void
}

let arm_store_frame_slot = (src:int slot:int):>void => {
    if arm_slot_in_range(slot) {
        let bb:int = bb_new(40)
        bb_push_str(bb "    str ")
        bb_push_str(bb src)
        bb_push_str(bb ", [x29, #")
        bb_push_int(bb slot)
        bb_push_byte(bb 93)
        vec_push(arm_current_fn_code bb_finalize_as_string(bb))
        return void
    }
    arm_materialize_frame_addr("x9" slot)
    let bb2:int = bb_new(32)
    bb_push_str(bb2 "    str ")
    bb_push_str(bb2 src)
    bb_push_str(bb2 ", [x9]")
    vec_push(arm_current_fn_code bb_finalize_as_string(bb2))
    return void
}

let arm_save_reg = (reg:int):>void => {
    if arm_spilled_depth >? 0 {
        arm_emit_indented("sub sp, sp, #16")
        let bb:int = bb_new(24)
        bb_push_str(bb "    str ")
        bb_push_str(bb reg)
        bb_push_str(bb ", [sp]")
        vec_push(arm_current_fn_code bb_finalize_as_string(bb))
        arm_spilled_depth = arm_spilled_depth + 1
    } else if arm_saved_depth <? 4 {
        let bb:int = bb_new(24)
        bb_push_str(bb "    mov ")
        bb_push_str(bb arm_value_cache_reg(arm_saved_depth))
        bb_push_str(bb ", ")
        bb_push_str(bb reg)
        vec_push(arm_current_fn_code bb_finalize_as_string(bb))
    } else {
        let i:int = 0
        loop i <? arm_saved_depth {
            arm_emit_indented("sub sp, sp, #16")
            let bb1:int = bb_new(24)
            bb_push_str(bb1 "    str ")
            bb_push_str(bb1 arm_value_cache_reg(i))
            bb_push_str(bb1 ", [sp]")
            vec_push(arm_current_fn_code bb_finalize_as_string(bb1))
            i = i + 1
        }
        arm_emit_indented("sub sp, sp, #16")
        let bb2:int = bb_new(24)
        bb_push_str(bb2 "    str ")
        bb_push_str(bb2 reg)
        bb_push_str(bb2 ", [sp]")
        vec_push(arm_current_fn_code bb_finalize_as_string(bb2))
        arm_spilled_depth = arm_saved_depth + 1
    }
    arm_saved_depth = arm_saved_depth + 1
    return void
}

let arm_pop_saved_into = (reg:int):>void => {
    arm_saved_depth = arm_saved_depth - 1
    if arm_spilled_depth >? 0 {
        let bb:int = bb_new(32)
        bb_push_str(bb "    ldr ")
        bb_push_str(bb reg)
        bb_push_str(bb ", [sp], #16")
        vec_push(arm_current_fn_code bb_finalize_as_string(bb))
        arm_spilled_depth = arm_spilled_depth - 1
    } else if arm_saved_depth <? 4 {
        let cache_reg:int = arm_value_cache_reg(arm_saved_depth)
        if not str_eq(cache_reg reg) {
            let bb:int = bb_new(24)
            bb_push_str(bb "    mov ")
            bb_push_str(bb reg)
            bb_push_str(bb ", ")
            bb_push_str(bb cache_reg)
            vec_push(arm_current_fn_code bb_finalize_as_string(bb))
        }
    }
    return void
}

let arm_prepare_call_args = (num_args:int fn_reg:int):>int => {
    let reg_count:int = num_args
    if reg_count >? 8 { reg_count = 8 }
    let stack_count:int = num_args - reg_count
    let stack_bytes:int = ((stack_count * 8) + 15) and (0 - 16)
    let consumed:int = num_args
    if fn_reg not=? 0 { consumed = consumed + 1 }

    if arm_spilled_depth >? 0 {
        arm_emit_indented("mov x10, sp")
        if stack_bytes >? 0 {
            let bb:int = bb_new(32)
            bb_push_str(bb "    sub sp, sp, #")
            bb_push_int(bb stack_bytes)
            vec_push(arm_current_fn_code bb_finalize_as_string(bb))
            let o:int = 0
            loop o <? stack_count {
                let src_off:int = (stack_count - 1 - o) * 16
                let bb1:int = bb_new(40)
                bb_push_str(bb1 "    ldr x9, [x10, #")
                bb_push_int(bb1 src_off)
                bb_push_byte(bb1 93)
                vec_push(arm_current_fn_code bb_finalize_as_string(bb1))
                let bb2:int = bb_new(40)
                bb_push_str(bb2 "    str x9, [sp, #")
                bb_push_int(bb2 o * 8)
                bb_push_byte(bb2 93)
                vec_push(arm_current_fn_code bb_finalize_as_string(bb2))
                o = o + 1
            }
        }
        let ri:int = reg_count - 1
        loop ri >=? 0 {
            let src_off:int = (stack_count + (reg_count - 1 - ri)) * 16
            let bb3:int = bb_new(40)
            bb_push_str(bb3 "    ldr ")
            bb_push_str(bb3 arm_arg_reg(ri))
            bb_push_str(bb3 ", [x10, #")
            bb_push_int(bb3 src_off)
            bb_push_byte(bb3 93)
            vec_push(arm_current_fn_code bb_finalize_as_string(bb3))
            ri = ri - 1
        }
        if fn_reg not=? 0 {
            let bb4:int = bb_new(40)
            bb_push_str(bb4 "    ldr ")
            bb_push_str(bb4 fn_reg)
            bb_push_str(bb4 ", [x10, #")
            bb_push_int(bb4 num_args * 16)
            bb_push_byte(bb4 93)
            vec_push(arm_current_fn_code bb_finalize_as_string(bb4))
        }
        arm_saved_depth = arm_saved_depth - consumed
        arm_spilled_depth = arm_spilled_depth - consumed
        return stack_bytes + consumed * 16
    }

    if stack_bytes >? 0 {
        let bb:int = bb_new(32)
        bb_push_str(bb "    sub sp, sp, #")
        bb_push_int(bb stack_bytes)
        vec_push(arm_current_fn_code bb_finalize_as_string(bb))
        let o:int = stack_count - 1
        loop o >=? 0 {
            arm_pop_saved_into("x9")
            let bb2:int = bb_new(40)
            bb_push_str(bb2 "    str x9, [sp, #")
            bb_push_int(bb2 o * 8)
            bb_push_byte(bb2 93)
            vec_push(arm_current_fn_code bb_finalize_as_string(bb2))
            o = o - 1
        }
    }
    let ri2:int = reg_count - 1
    loop ri2 >=? 0 {
        arm_pop_saved_into(arm_arg_reg(ri2))
        ri2 = ri2 - 1
    }
    if fn_reg not=? 0 {
        arm_pop_saved_into(fn_reg)
    }
    return stack_bytes
}

# --- Module lifecycle ---

let arm_begin_module = ():>void => { return void }
let arm_set_module_init = (name:int):>void => { arm_module_init_name = name  return void }
let arm_set_reachable_functions = (s:int):>void => {
    arm_reachable = s
    arm_have_reachable = TRUE_VAL
    return void
}

let arm_finish_module = ():>int => {
    let out:int = bb_new(4096)
    bb_push_str(out ".text\n")
    bb_push_str(out ".globl _start\n")
    let cap:int = map_cap(arm_extern_symbols)
    let slots:int = map_slots(arm_extern_symbols)
    let names:int = vec_new(16)
    let i:int = 0
    loop i <? cap {
        let slot:int = slots + (i * 32)
        if __load__(slot) =? 1 {
            let key:int = __load__(slot + 8)
            let keylen:int = __load__(slot + 16)
            let bb:int = bb_new(keylen + 1)
            bb_push_bytes(bb key keylen)
            vec_push(names bb_finalize_as_string(bb))
        }
        i = i + 1
    }
    let m:int = vec_len(names)
    let a:int = 1
    loop a <? m {
        let cur:int = vec_get(names a)
        let b:int = a - 1
        loop b >=? 0 {
            let prev:int = vec_get(names b)
            if str_lex_cmp(prev cur) <=? 0 { break }
            vec_set(names b + 1 prev)
            b = b - 1
        }
        vec_set(names b + 1 cur)
        a = a + 1
    }
    let k:int = 0
    loop k <? m {
        bb_push_str(out ".extern ")
        bb_push_str(out vec_get(names k))
        bb_push_byte(out 10)
        k = k + 1
    }
    bb_push_byte(out 10)
    bb_push_str(out "_start:\n")
    bb_push_str(out "    mov x29, xzr\n")
    bb_push_str(out "    ldr x0, [sp]\n")
    bb_push_str(out "    add x1, sp, #8\n")
    bb_push_str(out "    mov x9, sp\n")
    bb_push_str(out "    bic x9, x9, #15\n")
    bb_push_str(out "    mov sp, x9\n")
    if arm_module_init_name not=? 0 {
        bb_push_str(out "    bl ")
        bb_push_str(out arm_module_init_name)
        bb_push_byte(out 10)
    }
    bb_push_str(out "    bl __main__\n")
    bb_push_str(out "    mov x8, #94\n")
    bb_push_str(out "    svc #0\n\n")
    let nf:int = vec_len(arm_function_ids)
    let fi:int = 0
    loop fi <? nf {
        let lid:int = vec_get(arm_function_ids fi)
        if (arm_have_reachable =? FALSE_VAL) or intset_has(arm_reachable lid) {
            let lines:int = vec_get(arm_function_codes fi)
            let ll:int = vec_len(lines)
            let li:int = 0
            loop li <? ll {
                bb_push_str(out vec_get(lines li))
                bb_push_byte(out 10)
                li = li + 1
            }
        }
        fi = fi + 1
    }
    bb_push_str(out "\n.data\n")
    bb_push_str(out ".hidden __dso_handle\n")
    bb_push_str(out ".weak __dso_handle\n")
    bb_push_str(out "__dso_handle:\n")
    bb_push_str(out "    .xword 0\n")
    let nd:int = vec_len(arm_data)
    let di:int = 0
    loop di <? nd {
        bb_push_str(out vec_get(arm_data di))
        bb_push_byte(out 10)
        di = di + 1
    }
    bb_push_str(out "\n.section .note.GNU-stack,\"\",@progbits\n\n")
    return bb_finalize_as_string(out)
}

# --- Data section ---

let arm_intern_string = (data:int len:int):>int => {
    let label_id:int = arm_next_label
    let label:int = arm_new_label("str")
    intmap_put(arm_string_labels label_id label)
    let bb:int = bb_new(64 + str_len(label))
    bb_push_str(bb ".section .data.")
    bb_push_str(bb label)
    bb_push_str(bb ",\"aw\",@progbits")
    vec_push(arm_data bb_finalize_as_string(bb))
    arm_emit_data_label(label)
    let bb2:int = bb_new(32)
    bb_push_str(bb2 "    .xword ")
    bb_push_int(bb2 len)
    vec_push(arm_data bb_finalize_as_string(bb2))
    if len >? 0 {
        let bb3:int = bb_new(8 + len * 4)
        bb_push_str(bb3 "    .byte ")
        let i:int = 0
        loop i <? len {
            if i >? 0 { bb_push_str(bb3 ", ") }
            bb_push_int(bb3 __load_u8__(data + i))
            i = i + 1
        }
        vec_push(arm_data bb_finalize_as_string(bb3))
    }
    return label_id
}

let arm_intern_array = (elems_vec:int kinds_vec:int):>int => {
    let label_id:int = arm_next_label
    let label:int = arm_new_label("arr")
    intmap_put(arm_array_labels label_id label)
    let n:int = vec_len(elems_vec)
    let bb:int = bb_new(64 + str_len(label))
    bb_push_str(bb ".section .data.")
    bb_push_str(bb label)
    bb_push_str(bb ",\"aw\",@progbits")
    vec_push(arm_data bb_finalize_as_string(bb))
    arm_emit_data_label(label)
    let bb2:int = bb_new(32)
    bb_push_str(bb2 "    .xword ")
    bb_push_int(bb2 n)
    vec_push(arm_data bb_finalize_as_string(bb2))
    let i:int = 0
    loop i <? n {
        let kind:int = vec_get(kinds_vec i)
        let val:int = vec_get(elems_vec i)
        let line:int = bb_new(32)
        bb_push_str(line "    .xword ")
        if kind =? 1 { bb_push_int(line val) } else { bb_push_str(line val) }
        vec_push(arm_data bb_finalize_as_string(line))
        i = i + 1
    }
    return label_id
}

let arm_define_global = (name:int kind:int value:int):>int => {
    let label_id:int = arm_next_label
    let label:int = 0
    if name =? 0 {
        label = arm_new_label("global")
    } else {
        label = arm_str(name)
        arm_next_label = arm_next_label + 1
    }
    intmap_put(arm_global_labels label_id label)
    let bb:int = bb_new(64 + str_len(label))
    bb_push_str(bb ".section .data.")
    bb_push_str(bb label)
    bb_push_str(bb ",\"aw\",@progbits")
    vec_push(arm_data bb_finalize_as_string(bb))
    arm_emit_data_label(label)
    let line:int = bb_new(32)
    bb_push_str(line "    .xword ")
    if kind =? 1 { bb_push_int(line value) } else { bb_push_str(line value) }
    vec_push(arm_data bb_finalize_as_string(line))
    return label_id
}

let arm_declare_extern_global = (name:int):>int => {
    let label_id:int = arm_next_label
    arm_next_label = arm_next_label + 1
    let label:int = arm_str(name)
    intmap_put(arm_global_labels label_id label)
    set_add_str(arm_extern_symbols label)
    return label_id
}

let arm_intern_static = (size:int):>int => {
    let label_id:int = arm_next_label
    let label:int = arm_new_label("static")
    intmap_put(arm_static_labels label_id label)
    let bb:int = bb_new(64 + str_len(label))
    bb_push_str(bb ".section .bss.")
    bb_push_str(bb label)
    bb_push_str(bb ",\"aw\",@nobits")
    vec_push(arm_data bb_finalize_as_string(bb))
    arm_emit_data_label(label)
    if size >? 0 {
        let line:int = bb_new(32)
        bb_push_str(line "    .zero ")
        bb_push_int(line size)
        vec_push(arm_data bb_finalize_as_string(line))
    }
    return label_id
}

let arm_emit_adrp_add = (dst:int label:int):>void => {
    let bb1:int = bb_new(40)
    bb_push_str(bb1 "    adrp ")
    bb_push_str(bb1 dst)
    bb_push_str(bb1 ", ")
    bb_push_str(bb1 label)
    vec_push(arm_current_fn_code bb_finalize_as_string(bb1))
    let bb2:int = bb_new(40)
    bb_push_str(bb2 "    add ")
    bb_push_str(bb2 dst)
    bb_push_str(bb2 ", ")
    bb_push_str(bb2 dst)
    bb_push_str(bb2 ", :lo12:")
    bb_push_str(bb2 label)
    vec_push(arm_current_fn_code bb_finalize_as_string(bb2))
    return void
}

let arm_push_string_ref = (label_id:int):>void => {
    arm_emit_adrp_add("x0" intmap_get(arm_string_labels label_id))
    arm_emit_indented("add x0, x0, #8")
    return void
}

let arm_push_array_ref = (label_id:int):>void => {
