}

let arm_store_global = (label_id:int):>void => {
    arm_emit_adrp_add("x9" intmap_get(arm_global_labels label_id))
    arm_emit_indented("str x0, [x9]")
    return void
}

let arm_function_ref = (label_id:int):>int => { return intmap_get(arm_fn_labels label_id) }

let arm_string_ref = (label_id:int):>int => {
    let label:int = intmap_get(arm_string_labels label_id)
    let bb:int = bb_new(str_len(label) + 4)
    bb_push_str(bb label)
    bb_push_str(bb "+8")
    return bb_finalize_as_string(bb)
}

let arm_array_ref = (label_id:int):>int => {
    let label:int = intmap_get(arm_array_labels label_id)
    let bb:int = bb_new(str_len(label) + 4)
    bb_push_str(bb label)
    bb_push_str(bb "+8")
    return bb_finalize_as_string(bb)
}

let arm_static_ref = (label_id:int):>int => { return intmap_get(arm_static_labels label_id) }

# --- Functions ---

let arm_declare_function = (name:int num_params:int):>int => {
    let label_id:int = arm_next_label
    let label:int = 0
    if name =? 0 {
        label = arm_new_label("fn")
    } else {
        label = arm_str(name)
        arm_next_label = arm_next_label + 1
    }
    intmap_put(arm_fn_labels label_id label)
    return label_id
}

let arm_bind_extern_function = (label_id:int name:int):>void => {
    let label:int = arm_str(name)
    intmap_put(arm_fn_labels label_id label)
    set_add_str(arm_extern_symbols label)
    return void
}

let arm_declare_extern_function = (name:int num_params:int):>int => {
    let label_id:int = arm_declare_function(name num_params)
    set_add_str(arm_extern_symbols intmap_get(arm_fn_labels label_id))
    return label_id
}

let arm_begin_function = (label_id:int name:int param_count:int is_main:int):>void => {
    let label:int = intmap_get(arm_fn_labels label_id)
    arm_saved_depth = 0
    arm_spilled_depth = 0
    arm_min_slot_offset = 0
    let code:int = vec_new(64)
    vec_push(arm_function_ids label_id)
    vec_push(arm_function_codes code)
    arm_current_fn_code = code

    let bb:int = bb_new(64 + str_len(label))
    bb_push_str(bb ".section .text.")
    bb_push_str(bb label)
    bb_push_str(bb ",\"ax\",@progbits")
    vec_push(arm_current_fn_code bb_finalize_as_string(bb))
    if is_main { arm_emit_label_str("__main__") }
    arm_emit_label_str(label)

    arm_emit_indented("stp x29, x30, [sp, #-96]!")
    arm_emit_indented("stp x27, x28, [sp, #80]")
    arm_emit_indented("stp x25, x26, [sp, #64]")
    arm_emit_indented("stp x23, x24, [sp, #48]")
    arm_emit_indented("stp x21, x22, [sp, #32]")
    arm_emit_indented("stp x19, x20, [sp, #16]")

    arm_frame_setup_index = vec_len(arm_current_fn_code)
    arm_emit_indented("# local frame setup")

    vec_set_len(arm_param_slots 0)
    arm_stack_offset = 0 - 16
    let i:int = 0
    loop i <? param_count {
        let slot:int = arm_stack_offset
        vec_push(arm_param_slots slot)
        arm_note_slot(slot)
        if i <? 8 {
            arm_store_frame_slot(arm_arg_reg(i) slot)
        } else {
            let caller_off:int = 96 + (i - 8) * 8
            arm_load_frame_slot("x9" caller_off)
            arm_store_frame_slot("x9" slot)
        }
        arm_stack_offset = arm_stack_offset - 8
        i = i + 1
    }
    let ebb:int = bb_new(str_len(label) + 16)
    bb_push_str(ebb label)
    bb_push_str(ebb "_epilogue")
    arm_current_fn_epilogue = bb_finalize_as_string(ebb)
    return void
}

let arm_end_function = ():>void => {
    let local_bytes:int = arm_local_area_bytes()
    let saved:int = arm_current_fn_code
    let prologue:int = vec_new(8)
    arm_current_fn_code = prologue
    arm_emit_sp_adjust("sub" local_bytes)
    arm_emit_fp_setup(local_bytes)
    arm_current_fn_code = saved

    let insert_at:int = arm_frame_setup_index
    let plen:int = vec_len(prologue)
    let new_code:int = vec_new(vec_len(saved) + plen)
    let i:int = 0
    loop i <? insert_at {
        vec_push(new_code vec_get(saved i))
        i = i + 1
    }
    let j:int = 0
    loop j <? plen {
        vec_push(new_code vec_get(prologue j))
        j = j + 1
    }
    let k:int = insert_at + 1
    loop k <? vec_len(saved) {
        vec_push(new_code vec_get(saved k))
        k = k + 1
    }
    let last:int = vec_len(arm_function_codes) - 1
    vec_set(arm_function_codes last new_code)
    arm_current_fn_code = new_code

    arm_emit_label_str(arm_current_fn_epilogue)
    arm_emit_indented("mov sp, x29")
    arm_emit_indented("ldp x19, x20, [sp, #16]")
    arm_emit_indented("ldp x21, x22, [sp, #32]")
    arm_emit_indented("ldp x23, x24, [sp, #48]")
    arm_emit_indented("ldp x25, x26, [sp, #64]")
    arm_emit_indented("ldp x27, x28, [sp, #80]")
    arm_emit_indented("ldp x29, x30, [sp], #96")
    arm_emit_indented("ret")
    arm_current_fn_code = 0
    return void
}

let arm_load_param = (index:int):>void => {
    arm_load_frame_slot("x0" vec_get(arm_param_slots index))
    return void
}

let arm_alloc_local = ():>int => {
    let slot:int = arm_stack_offset
    arm_stack_offset = arm_stack_offset - 8
    arm_note_slot(slot)
    return slot
}

let arm_load_local = (slot:int):>void => { arm_load_frame_slot("x0" slot)  return void }
let arm_store_local = (slot:int):>void => { arm_store_frame_slot("x0" slot)  return void }

let arm_push_const_i64 = (value:int):>void => {
    if (value >=? 0) and (value <=? 65535) {
        let bb:int = bb_new(24)
        bb_push_str(bb "    mov x0, #")
        bb_push_int(bb value)
        vec_push(arm_current_fn_code bb_finalize_as_string(bb))
    } else if (value >=? 0 - 65536) and (value <? 0) {
        let bb:int = bb_new(24)
        bb_push_str(bb "    mov x0, #")
        bb_push_int(bb value)
        vec_push(arm_current_fn_code bb_finalize_as_string(bb))
    } else {
        let bb:int = bb_new(24)
        bb_push_str(bb "    ldr x0, =")
        bb_push_int(bb value)
        vec_push(arm_current_fn_code bb_finalize_as_string(bb))
    }
    return void
}

let arm_push_void = ():>void => { arm_emit_indented("mov x0, #0")  return void }
let arm_push_fn_ref = (label_id:int):>void => {
    arm_emit_adrp_add("x0" intmap_get(arm_fn_labels label_id))
    return void
}
let arm_pop_value = ():>void => { return void }
let arm_save_value = ():>void => { arm_save_reg("x0")  return void }
let arm_restore_value = ():>void => { arm_pop_saved_into("x0")  return void }

let arm_unary_op = (op_kind:int):>void => {
    if op_kind =? TK_MINUS { arm_emit_indented("neg x0, x0") }
    else if op_kind =? TK_NOT { arm_emit_indented("mvn x0, x0") }
    return void
}

let arm_emit_signed_sdiv = ():>void => {
    let div_zero:int = arm_new_label("div_zero")
    let done:int = arm_new_label("div_done")
    let do_sdiv:int = arm_new_label("div_sdiv")
    arm_emit_indented("cmp x9, #0")
    let bb:int = bb_new(32)
    bb_push_str(bb "    beq ")
    bb_push_str(bb div_zero)
    vec_push(arm_current_fn_code bb_finalize_as_string(bb))
    arm_emit_indented("ldr x10, =0x8000000000000000")
    arm_emit_indented("cmp x0, x10")
    let bb2:int = bb_new(32)
    bb_push_str(bb2 "    bne ")
    bb_push_str(bb2 do_sdiv)
    vec_push(arm_current_fn_code bb_finalize_as_string(bb2))
    arm_emit_indented("mov x10, #-1")
    arm_emit_indented("cmp x9, x10")
    let bb3:int = bb_new(32)
    bb_push_str(bb3 "    bne ")
    bb_push_str(bb3 do_sdiv)
    vec_push(arm_current_fn_code bb_finalize_as_string(bb3))
    let bb4:int = bb_new(16)
    bb_push_str(bb4 "    b ")
    bb_push_str(bb4 done)
    vec_push(arm_current_fn_code bb_finalize_as_string(bb4))
    arm_emit_label_str(do_sdiv)
    arm_emit_indented("sdiv x0, x0, x9")
    let bb5:int = bb_new(16)
    bb_push_str(bb5 "    b ")
    bb_push_str(bb5 done)
    vec_push(arm_current_fn_code bb_finalize_as_string(bb5))
    arm_emit_label_str(div_zero)
    arm_emit_indented("mov x0, #-1")
    arm_emit_label_str(done)
    return void
}

let arm_emit_signed_mod = ():>void => {
    let mod_zero:int = arm_new_label("mod_zero")
    let done:int = arm_new_label("mod_done")
    let do_sdiv:int = arm_new_label("mod_sdiv")
    arm_emit_indented("cmp x9, #0")
