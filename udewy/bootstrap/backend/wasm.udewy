    w_alloc_state()
    be_begin_module = w_begin_module
    be_finish_module = w_finish_module
    be_set_module_init = w_set_module_init
    be_set_imported_sources = be_default_set_imported_sources
    be_intern_string = w_intern_string
    be_intern_array = w_intern_array
    be_define_global = w_define_global
    be_declare_extern_global = w_declare_extern_global
    be_intern_static = w_intern_static
    be_push_string_ref = w_push_string_ref
    be_push_array_ref = w_push_array_ref
    be_push_global_ref = w_push_global_ref
    be_push_static_ref = w_push_static_ref
    be_load_global = w_load_global
    be_store_global = w_store_global
    be_function_ref = w_function_ref
    be_string_ref = w_string_ref
    be_array_ref = w_array_ref
    be_static_ref = w_static_ref
    be_declare_function = w_declare_function
    be_bind_extern_function = w_bind_extern_function
    be_declare_extern_function = w_declare_extern_function
    be_should_warn_unused_extern = be_default_should_warn_unused_extern
    be_begin_function = w_begin_function
    be_end_function = w_end_function
    be_set_reachable_functions = w_set_reachable_functions
    be_load_param = w_load_param
    be_alloc_local = w_alloc_local
    be_load_local = w_load_local
    be_store_local = w_store_local
    be_push_const_i64 = w_push_const_i64
    be_push_void = w_push_void
    be_push_fn_ref = w_push_fn_ref
    be_pop_value = w_pop_value
    be_save_value = w_save_value
    be_restore_value = w_restore_value
    be_unary_op = w_unary_op
    be_binary_op = w_binary_op
    be_pipe_call = w_pipe_call
    be_begin_if = w_begin_if
    be_begin_else = w_begin_else
    be_end_if = w_end_if
    be_begin_loop = w_begin_loop
    be_begin_loop_body = w_begin_loop_body
    be_end_loop = w_end_loop
    be_emit_break = w_emit_break
    be_emit_continue = w_emit_continue
    be_cond_and_split = w_cond_and_split
    be_cond_and_join = w_cond_and_join
    be_cond_or_split = w_cond_or_split
    be_cond_or_join = w_cond_or_join
    be_emit_return = w_emit_return
    be_call_direct = w_call_direct
    be_call_indirect = w_call_indirect
    be_max_call_args = w_max_call_args
    be_is_intrinsic = w_is_intrinsic
    be_intrinsic_arity = w_intrinsic_arity
    be_intrinsic_static_arg_indices = w_intrinsic_static_arg_indices
    be_emit_intrinsic = w_emit_intrinsic
    be_get_builtin_constants = w_get_builtin_constants
    be_compile_and_link = w_compile_and_link
    be_run = w_run
    be_get_compile_message = w_get_compile_message
    return void
}
