let sdl_icon_endian_mode:int = 0

let SDL_EventType = (event:int):>int => {
    return __load_u32__(event)
}

let SDL_ScancodeDown = (keyboard:int scancode:int):>int => {
    return __load_u8__(keyboard + scancode)
}

let SDL_SetAudioSpec = (spec:int format:int channels:int freq:int):>void => {
    __store_u16__(format spec)
    __store_u16__(0 spec + 2)
    __store_u32__(channels spec + 4)
    __store_u32__(freq spec + 8)
    return 0
}

let SDL_IconEndianMode = ():>int => {
    if sdl_icon_endian_mode not=? 0 {
        return sdl_icon_endian_mode
    }

    let probe:int = __alloca__(8)
    __store_u64__(0x01020304_05060708 probe)
    if __load_u8__(probe) =? 1 {
        sdl_icon_endian_mode = 1
    } else {
        sdl_icon_endian_mode = 2
    }
    return sdl_icon_endian_mode
}

let SDL_RGBA32PixelFormat = ():>int => {
    if SDL_IconEndianMode() =? 1 {
        return SDL_PIXELFORMAT_RGBA8888
    }
    return SDL_PIXELFORMAT_ABGR8888
}

let SDL_WriteRGBA32Pixel = (buf:int offset:int pixel:int):>void => {
    __store_u8__(((pixel >> 24) and 255) (buf + offset))
    __store_u8__(((pixel >> 16) and 255) (buf + offset + 1))
    __store_u8__(((pixel >> 8) and 255) (buf + offset + 2))
    __store_u8__((pixel and 255) (buf + offset + 3))
    return 0
}

let SDL_SetWindowIconFromUdewyData = (window:int icon_data:int):>int => {
    if __load_u64__(icon_data) not=? SDL_UDEWY_ICON_MAGIC {
        return 0
    }
    if __load_u64__(icon_data + 8) not=? SDL_UDEWY_ICON_FORMAT_VERSION {
        return 0
    }

    let width:int = __load_u64__(icon_data + 16)
    let height:int = __load_u64__(icon_data + 24)
    let packed_word_count:int = __load_u64__(icon_data + 32)
    let pixel_count:int = width * height
    let pixel_buf:int = __alloca__(pixel_count * 4)
    let word_idx:int = 0
    let pixel_idx:int = 0
    loop word_idx <? packed_word_count {
        let word:int = __load_u64__(icon_data + 40 + (word_idx * 8))
        let pixel0:int = (word >> 32) and 0xFFFF_FFFF
        SDL_WriteRGBA32Pixel(pixel_buf (pixel_idx * 4) pixel0)
        pixel_idx += 1
        if pixel_idx <? pixel_count {
            let pixel1:int = word and 0xFFFF_FFFF
            SDL_WriteRGBA32Pixel(pixel_buf (pixel_idx * 4) pixel1)
            pixel_idx += 1
        }
        word_idx += 1
    }

    let surface:int = SDL_CreateSurfaceFrom(width height SDL_RGBA32PixelFormat() pixel_buf width * 4)
    if surface =? 0 {
        return 0
    }

    let ok:int = SDL_SetWindowIcon(window surface)
    SDL_DestroySurface(surface)
    return ok
}

let SDL_SetDefaultWindowIcon = (window:int):>int => {
    return SDL_SetWindowIconFromUdewyData(window SDL_DEFAULT_WINDOW_ICON_DATA)
}

let GL_F32_FromInt = (value:int):>int => {
    return __i64_to_f32_bits__(value)
}

let GL_F64_FromInt = (value:int):>int => {
    return __i64_to_f64_bits__(value)
}

let GL_ClearColor = (r:int g:int b:int a:int):>void => {
    __call_extern_xmm_mixed_4__(glClearColor 1 r 1 g 1 b 1 a)
    return 0
}

let GL_Ortho = (left:int right:int bottom:int top:int near_val:int far_val:int):>void => {
    __call_extern_xmm_mixed_6__(glOrtho 2 left 2 right 2 bottom 2 top 2 near_val 2 far_val)
    return 0
}

let GL_Frustum = (left:int right:int bottom:int top:int near_val:int far_val:int):>void => {
    __call_extern_xmm_mixed_6__(glFrustum 2 left 2 right 2 bottom 2 top 2 near_val 2 far_val)
    return 0
}

let GL_Translatef = (x:int y:int z:int):>void => {
    __call_extern_xmm_mixed_3__(glTranslatef 1 x 1 y 1 z)
    return 0
}

let GL_Rotatef = (angle:int x:int y:int z:int):>void => {
    __call_extern_xmm_mixed_4__(glRotatef 1 angle 1 x 1 y 1 z)
    return 0
}

let GL_Scalef = (x:int y:int z:int):>void => {
    __call_extern_xmm_mixed_3__(glScalef 1 x 1 y 1 z)
    return 0
}

let GL_Color3f = (r:int g:int b:int):>void => {
    __call_extern_xmm_mixed_3__(glColor3f 1 r 1 g 1 b)
    return 0
}

let GL_Vertex3f = (x:int y:int z:int):>void => {
    __call_extern_xmm_mixed_3__(glVertex3f 1 x 1 y 1 z)
    return 0
}
