const SDL_INIT_VIDEO:int = 0x00000020
const SDL_EVENT_QUIT:int = 0x00000100
const SDL_WINDOW_OPENGL:int = 0x00000002
const SDL_WINDOW_RESIZABLE:int = 0x00000020
const SDL_EVENT_SIZE:int = 128
const SDL_AUDIO_DEVICE_DEFAULT_PLAYBACK:int = 0xFFFF_FFFF
const SDL_AUDIO_S16LE:int = 0x8010
const SDL_AUDIO_SPEC_SIZE:int = 12
const SDL_SCANCODE_A:int = 4
const SDL_SCANCODE_D:int = 7
const SDL_SCANCODE_S:int = 22
const SDL_SCANCODE_W:int = 26
const SDL_SCANCODE_RETURN:int = 40
const SDL_SCANCODE_ESCAPE:int = 41
const SDL_SCANCODE_SPACE:int = 44
const SDL_SCANCODE_LEFT:int = 80
const SDL_SCANCODE_RIGHT:int = 79
