{
  "name": "udewy",
  "displayName": "udewy",
  "description": "Syntax highlighting for the udewy programming language",
  "version": "0.1.4",
  "publisher": "RedFoxLabs",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "icon": "images/udewy_logo_128x128.png",
  "contributes": {
    "languages": [
      {
        "id": "udewy",
        "aliases": [
          "udewy"
        ],
        "extensions": [
          ".udewy"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "udewy",
        "scopeName": "source.udewy",
        "path": "./syntaxes/udewy.tmLanguage.json"
      }
    ]
  },
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/david-andrew/dewy-lang"
  }
}
