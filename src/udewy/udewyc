#!/bin/bash

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUNTIME="$SCRIPT_DIR/runtime.s"
COMPILER="python"
COMPILER_PATH=""

usage() {
    echo "Usage: udewyc [OPTIONS] <file.udewy>"
    echo ""
    echo "Options:"
    echo "  -c, --compiler PATH   Use custom compiler executable instead of Python"
    echo "  -o, --output NAME     Output executable name (default: input name without extension)"
    echo "  -h, --help            Show this help"
    exit 1
}

OUTPUT=""

while [[ $# -gt 0 ]]; do
    case $1 in
        -c|--compiler)
            COMPILER="custom"
            COMPILER_PATH="$2"
            shift 2
            ;;
        -o|--output)
            OUTPUT="$2"
            shift 2
            ;;
        -h|--help)
            usage
            ;;
        -*)
            echo "Unknown option: $1"
            usage
            ;;
        *)
            INPUT="$1"
            shift
            ;;
    esac
done

if [[ -z "$INPUT" ]]; then
    echo "Error: No input file specified"
    usage
fi

if [[ ! -f "$INPUT" ]]; then
    echo "Error: File not found: $INPUT"
    exit 1
fi

if [[ -z "$OUTPUT" ]]; then
    OUTPUT="${INPUT%.udewy}"
fi

TMPDIR=$(mktemp -d)
trap "rm -rf $TMPDIR" EXIT

ASM="$TMPDIR/out.s"
OBJ="$TMPDIR/out.o"
RUNTIME_OBJ="$TMPDIR/runtime.o"

if [[ "$COMPILER" == "python" ]]; then
    python -m src.udewy.p0 "$INPUT" > "$ASM"
else
    "$COMPILER_PATH" "$INPUT" > "$ASM"
fi

as "$RUNTIME" -o "$RUNTIME_OBJ"
as "$ASM" -o "$OBJ"
ld "$OBJ" "$RUNTIME_OBJ" -o "$OUTPUT"

echo "Compiled: $OUTPUT"
